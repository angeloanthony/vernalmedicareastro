---
// src/components/FAQ.astro  (Runbook Part 2 — the welded FAQ+schema component)
//
// The visible FAQ and its FAQPage JSON-LD are generated from the SAME array,
// so they can NEVER disagree. You cannot ship a FAQ without its schema —
// the two are welded together in one file.
//
// Usage:
//   <FAQ heading="Medicare in Vernal — Frequently Asked Questions"
//        faqs={[{ q: '...', a: '...' }, ...]} />
//
// `a` may contain inline HTML; it is rendered with set:html in the visible
// list and stripped to text for the schema.

interface FaqItem {
  q: string;
  a: string; // may contain inline HTML
}
interface Props {
  faqs: FaqItem[];
  heading?: string;
  id?: string;
}
const { faqs, heading, id = 'faq' } = Astro.props;

// Strip tags for the schema's plain-text answer
const stripTags = (html: string) =>
  html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: stripTags(f.q),
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripTags(f.a),
    },
  })),
};
---

<section id={id} aria-label="Frequently Asked Questions">
  {heading && <h2>{heading}</h2>}
  {
    faqs.map((f) => (
      <details>
        <summary set:html={f.q} />
        <p set:html={f.a} />
      </details>
    ))
  }
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
