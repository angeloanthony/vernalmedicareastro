---
// src/components/Breadcrumbs.astro  (Runbook Part 3 — breadcrumbs + schema together)
//
// One component renders the visual trail AND the BreadcrumbList JSON-LD, so
// they can never drift apart.
//
// Usage:
//   <Breadcrumbs trail={[
//     { name: 'Home', url: 'https://vernalmedicare.com/' },
//     { name: 'Medicare in Vernal, UT', url: 'https://vernalmedicare.com/medicare-vernal-ut.html' },
//   ]} />

interface Crumb {
  name: string;
  url: string;
}
interface Props {
  trail: Crumb[];
}
const { trail } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: trail.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};
---

<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol>
    {
      trail.map((c, i) => (
        <li>
          {i < trail.length - 1 ? <a href={c.url}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
