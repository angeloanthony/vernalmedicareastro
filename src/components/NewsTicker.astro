---
// src/components/NewsTicker.astro — homepage "Medicare Updates" ticker.
//
// Data-driven: reads NEWS_ARTICLES from data/news.ts, so headlines stay in sync
// with the News Center. Add/retire an article there and this bar updates — never
// hardcode links here. The fixed "Medicare Updates" label (clickable → the News
// Center) stays put while the headlines scroll horizontally; the row pauses on
// hover/focus and freezes for visitors who prefer reduced motion. Every headline
// is a real crawlable internal link into /medicare-news/{slug}.html.
//
// Ordering: featured articles pin to the front, then newest-first. Articles
// published within the last 14 days get an automatic NEW badge.
import { NEWS_ARTICLES } from '../data/news';
import type { NewsCategory } from '../types/News';

// Short, professional category badges (no emoji) to match the site's tone.
const CATEGORY_BADGE: Record<NewsCategory, string> = {
  costs: 'COSTS',
  'part-d': 'PART D',
  coverage: 'COVERAGE',
  assistance: 'SAVINGS',
  alerts: 'ALERT',
};

const NEW_WINDOW_DAYS = 14;
const now = Date.now();
const isNew = (iso: string) => {
  const ageDays = (now - new Date(iso).getTime()) / 86_400_000;
  return ageDays >= 0 && ageDays <= NEW_WINDOW_DAYS;
};

// Newest first; drop archived. Then pin featured items to the front (stable).
const live = NEWS_ARTICLES.filter((a) => a.lifecycle !== 'archived').sort((a, b) =>
  b.published.localeCompare(a.published),
);
const items = [...live.filter((a) => a.featured), ...live.filter((a) => !a.featured)]
  .slice(0, 8)
  .map((a) => ({
    href: `/medicare-news/${a.slug}.html`,
    label: a.title,
    badge: CATEGORY_BADGE[a.category],
    isNew: isNew(a.published),
  }));

// Pace the scroll to the amount of content — slow enough to read comfortably
// (~8s per headline, min 32s).
const durationS = Math.max(32, items.length * 8);
---

{items.length > 0 && (
  <section class="vm-ticker" aria-label="Medicare updates">
    <div class="vm-ticker__inner">
      <a class="vm-ticker__label" href="/medicare-news.html">
        <span aria-hidden="true">📢</span> Medicare Updates
      </a>

      <div class="vm-ticker__viewport">
        <div class="vm-ticker__track" style={`--vm-ticker-duration:${durationS}s`}>
          {/* Real links. */}
          {items.map((it) => (
            <a class="vm-ticker__item" href={it.href}>
              <span class="vm-ticker__badge">{it.badge}</span>
              {it.isNew && <span class="vm-ticker__new">NEW</span>}
              <span class="vm-ticker__text">{it.label}</span>
              <span class="vm-ticker__arrow" aria-hidden="true">→</span>
            </a>
          ))}
          {/* Duplicate set for a seamless loop; hidden from a11y + crawlers. */}
          {items.map((it) => (
            <a class="vm-ticker__item" href={it.href} aria-hidden="true" tabindex="-1">
              <span class="vm-ticker__badge">{it.badge}</span>
              {it.isNew && <span class="vm-ticker__new">NEW</span>}
              <span class="vm-ticker__text">{it.label}</span>
              <span class="vm-ticker__arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <a class="vm-ticker__all" href="/medicare-news.html">All updates</a>
    </div>
  </section>
)}

<style>
  .vm-ticker {
    background: #0b2c45;
    color: #fff;
    border-bottom: 3px solid var(--color-accent, #9e0853);
  }
  .vm-ticker__inner {
    display: flex;
    align-items: stretch;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Fixed left label — clickable, goes to the News Center. */
  .vm-ticker__label {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: var(--color-accent, #9e0853);
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
    text-decoration: none;
  }

  /* Scrolling viewport. */
  .vm-ticker__viewport {
    flex: 1 1 auto;
    overflow: hidden;
    position: relative;
    /* Fade the edges so headlines slide in/out cleanly. */
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 2.5rem, #000 calc(100% - 2.5rem), transparent);
    mask-image: linear-gradient(90deg, transparent, #000 2.5rem, #000 calc(100% - 2.5rem), transparent);
  }
  .vm-ticker__track {
    display: flex;
    width: max-content;
    animation: vm-ticker-scroll var(--vm-ticker-duration, 40s) linear infinite;
  }
  /* Pause when the visitor is reading. */
  .vm-ticker__viewport:hover .vm-ticker__track,
  .vm-ticker__track:focus-within {
    animation-play-state: paused;
  }

  .vm-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 1.4rem;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.92rem;
  }

  /* Category badge — small, quiet, professional. */
  .vm-ticker__badge {
    flex: 0 0 auto;
    padding: 0.12rem 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.08);
  }

  /* Automatic NEW badge for recent articles — brighter, draws the eye. */
  .vm-ticker__new {
    flex: 0 0 auto;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #0b2c45;
    background: #ffd27a;
  }

  .vm-ticker__text { border-bottom: 1px solid transparent; }
  .vm-ticker__item:hover .vm-ticker__text,
  .vm-ticker__item:focus-visible .vm-ticker__text { border-bottom-color: #fff; }
  .vm-ticker__arrow { color: #ffd27a; font-weight: 700; }

  /* Right "all updates" link — hidden on small screens to save room. */
  .vm-ticker__all {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    padding: 0.6rem 1rem;
    color: #ffd27a;
    font-weight: 700;
    font-size: 0.85rem;
    white-space: nowrap;
    text-decoration: none;
  }
  .vm-ticker__all:hover { text-decoration: underline; }

  @keyframes vm-ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 640px) {
    .vm-ticker__all { display: none; }
    .vm-ticker__label { font-size: 0.8rem; padding: 0.6rem 0.75rem; }
  }

  /* No motion: freeze the track and let visitors scroll it manually. */
  @media (prefers-reduced-motion: reduce) {
    .vm-ticker__track { animation: none; }
    .vm-ticker__viewport { overflow-x: auto; }
  }
</style>
