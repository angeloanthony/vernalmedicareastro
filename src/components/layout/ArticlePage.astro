---
// ArticlePage.astro — informational/guide pages. The thinnest specialization:
// set the primary schema to Article; StandardPageLayout does everything else.
// The unique body prose is passed as the default slot.
import StandardPageLayout from './StandardPageLayout.astro';
import type { PageContext } from '../../types/Page';

interface Props {
  context: PageContext;
  /** Render a custom hero instead of the default H1 header block. */
  bareHeader?: boolean;
  /** Render custom FAQ/sources/related/CTA instead of the default footer. */
  bareFooter?: boolean;
}
const { context, bareHeader = false, bareFooter = false } = Astro.props;
---

<StandardPageLayout context={context} primarySchema="Article" bareHeader={bareHeader} bareFooter={bareFooter}>
  <slot />
</StandardPageLayout>
