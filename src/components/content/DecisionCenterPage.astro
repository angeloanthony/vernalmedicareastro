---
// src/components/content/DecisionCenterPage.astro — the Decision Center
// template (M4 batch 2; playbook §4.5). Page copy from content JSON;
// DECISION_PATHS card copy is a SHARED DATA MODULE (Phase B translation
// boundary) and renders in English on /es/ until that module gets its own
// translation source. Card hrefs still localize (auto-upgrade to /es/).
import ArticlePage from '../layout/ArticlePage.astro';
import { DECISION_PATHS } from '../../data/decisionPaths';
import { BUSINESS } from '../../data/business';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta } from '../../i18n/locales';
import type { PageContext } from '../../types/Page';

const SLUG = 'medicare-decision-center';
const vars = { phone: BUSINESS.phone, tty: BUSINESS.tty };
const t9 = (s: string) => interp(s, vars);

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; self: string };
  hero: {
    subtitle: string;
    lede: string;
    badges: string[];
    ctaWhen: string;
    ctaText: string;
    signpostAria: string;
  };
  body: {
    introHtml: string;
    h2Map: string;
    mapHtml: string;
    h2Person: string;
    personHtml: string;
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

// Per-path colour + icon, keyed by the shared data-module id (so the shared
// DECISION_PATHS module stays presentation-free / translation-clean). Colours
// echo the signpost hero; the icon is a glyph shown in the card's circle.
const PATH_STYLE: Record<string, { icon: string; color: string; tint: string }> = {
  'turning-65':     { icon: '65', color: '#0d9488', tint: '#d8f2ee' },
  'still-working':  { icon: '💼', color: '#2563eb', tint: '#e6effe' },
  'already-have':   { icon: '🛡️', color: '#16a34a', tint: '#e6f6ec' },
  'drug-help':      { icon: '💊', color: '#7c3aed', tint: '#f1e9fd' },
  'financial-help': { icon: '👛', color: '#ea580c', tint: '#fdece0' },
  'compare-plans':  { icon: '⚖️', color: '#0d9488', tint: '#d8f2ee' },
  'estimate-costs': { icon: '🧮', color: '#2563eb', tint: '#e6effe' },
};
const FALLBACK_STYLE = { icon: '➜', color: '#0b2c45', tint: '#eef3f8' };

const context: PageContext = {
  page: {
    title: c.page.title,
    heading: c.page.heading,
    description: c.page.description,
    taxonomy: { silo: 'medicare-101', tags: ['medicare-101', 'hub', 'decision-center', 'start-here', 'overview'], pillar: true },
    summary: c.page.summary,
    faqs: c.page.faqs.map((q) => ({ question: t9(q.question), answer: t9(q.answer) })),
    sources: c.page.sources,
    nextSteps: c.page.nextSteps.map((s) => ({ when: s.when, action: t9(s.action) })),
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'website',
    ogTitle: c.meta.ogTitle,
    ogDescription: c.meta.ogDescription,
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};
---

<ArticlePage context={context} bareHeader>
  <!-- Two-column hero: message + reassurance on the left, a signpost of the
       seven starting points on the right. The signs are real links. -->
  <section class="dc-hero">
    <div class="dc-hero__copy">
      <h1 class="dc-hero__title">{c.page.heading}</h1>
      <p class="dc-hero__subtitle">{c.hero.subtitle}</p>
      <p class="dc-hero__lede">{c.hero.lede}</p>

      <ul class="dc-hero__features">
        {c.hero.badges.map((label) => (
          <li><span class="dc-hero__check" aria-hidden="true">✓</span>{label}</li>
        ))}
      </ul>

      <a class="dc-phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="dc-phone__icon" aria-hidden="true">📞</span>
        <span class="dc-phone__body">
          <span class="dc-phone__when">{c.hero.ctaWhen}</span>
          <span class="dc-phone__line" set:html={t9(c.hero.ctaText).replace(
            BUSINESS.phone,
            `<strong>${BUSINESS.phone}</strong>`
          )} />
        </span>
      </a>
    </div>

    <div class="dc-hero__art">
      <img
        class="dc-hero__img"
        src="/pictures/decision-signpost.webp"
        alt="Signpost pointing to the seven Medicare starting points: new to Medicare, turning 65, already enrolled, prescription help, lower costs, compare plans, and estimate costs."
        width="495"
        height="565"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <div class="dc-divider"><span>Choose the path that fits you</span></div>

  <div class="dc-grid">
    {DECISION_PATHS.map((p) => {
      const s = PATH_STYLE[p.id] ?? FALLBACK_STYLE;
      return (
        <section class="dc-card" id={p.id} style={`--accent:${s.color};--tint:${s.tint}`}>
          <div class="dc-card__icon" aria-hidden="true">{s.icon}</div>
          <h2 class="dc-card__title"><a href={localizeHref(p.primary.href, lang)}>{p.situation}</a></h2>
          <p class="dc-card__blurb">{p.blurb}</p>
          <a class="dc-card__cta" href={localizeHref(p.primary.href, lang)}>{p.primary.label} →</a>
          <ul class="dc-card__links">
            {p.links.map((l) => <li><a href={localizeHref(l.href, lang)}>{l.label}</a></li>)}
          </ul>
        </section>
      );
    })}
  </div>

  <!-- Closing CTA: talk to a person -->
  <div class="dc-cta">
    <div class="dc-cta__text">
      <h2>{b.h2Person}</h2>
      <p set:html={t9(b.personHtml)} />
    </div>
    <a class="dc-cta__phone" href={`tel:${BUSINESS.phoneTel}`}>
      <span aria-hidden="true">📞</span> {BUSINESS.phone}
    </a>
  </div>

  <p class="dc-map"><strong>{b.h2Map}</strong> <span set:html={t9(b.mapHtml)} /></p>
</ArticlePage>

<style>
  /* ---- Two-column hero --------------------------------------------------- */
  .dc-hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.5rem 0 2.5rem;
    /* whole-hero float */
    animation: dc-hero-float 6s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes dc-hero-float {
    from { transform: translateY(0); }
    to   { transform: translateY(-8px); }
  }
  .dc-hero__title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    color: #0b2c45;
    margin: 0 0 0.5rem;
  }
  .dc-hero__subtitle {
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    font-weight: 700;
    font-style: italic;
    color: #1f4e8c;
    border-bottom: 3px solid #d6455f;
    display: inline-block;
    padding-bottom: 0.15rem;
    margin: 0 0 1rem;
  }
  .dc-hero__lede { font-size: 1.05rem; color: #475569; line-height: 1.55; margin: 0 0 1.5rem; max-width: 34ch; }
  .dc-hero__features { list-style: none; padding: 0; margin: 0 0 1.75rem; display: grid; gap: 0.7rem; }
  .dc-hero__features li {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    background: #fff;
    border: 1px solid #e4ecf5;
    border-radius: 999px;
    padding: 0.45rem 1rem 0.45rem 0.5rem;
    font-weight: 600;
    color: #0b2c45;
    font-size: 0.92rem;
    box-shadow: 0 10px 22px rgba(11, 44, 69, 0.12);
    /* floating effect */
    animation: dc-badge-float 3.2s ease-in-out infinite alternate;
    will-change: transform;
  }
  .dc-hero__features li:nth-child(2) { animation-delay: 0.5s; }
  .dc-hero__features li:nth-child(3) { animation-delay: 1s; }
  @keyframes dc-badge-float {
    from { transform: translateY(0); box-shadow: 0 10px 22px rgba(11, 44, 69, 0.12); }
    to   { transform: translateY(-7px); box-shadow: 0 18px 30px rgba(11, 44, 69, 0.16); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dc-hero,
    .dc-hero__img,
    .dc-hero__features li { animation: none; }
  }
  .dc-hero__check {
    flex: none; width: 22px; height: 22px; border-radius: 50%;
    background: #1f4e8c; color: #fff; display: grid; place-items: center;
    font-size: 0.75rem; font-weight: 800;
  }
  .dc-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #fff;
    color: #0b2c45;
    text-decoration: none;
    padding: 0.85rem 1.4rem;
    border-radius: 14px;
    border: 1px solid #dbe6f2;
    box-shadow: 0 12px 26px rgba(11, 44, 69, 0.12);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .dc-phone:hover { transform: translateY(-2px); box-shadow: 0 16px 32px rgba(11, 44, 69, 0.18); }
  .dc-phone__icon {
    flex: none; width: 40px; height: 40px; border-radius: 50%;
    background: #1f4e8c; color: #fff; display: grid; place-items: center; font-size: 1.1rem;
  }
  .dc-phone__body { display: flex; flex-direction: column; line-height: 1.3; }
  .dc-phone__when { font-weight: 700; font-size: 0.95rem; }
  .dc-phone__line { font-size: 0.9rem; color: #475569; }
  .dc-phone__line :global(strong) { color: #d6455f; font-size: 1.05rem; }

  /* ---- Signpost art ------------------------------------------------------ */
  .dc-hero__art { display: flex; justify-content: center; }
  .dc-hero__img {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: 0 16px 40px rgba(11, 44, 69, 0.18);
    /* signpost float (offset from the hero so they drift independently) */
    animation: dc-img-float 4.5s ease-in-out 0.6s infinite alternate;
    will-change: transform;
  }
  @keyframes dc-img-float {
    from { transform: translateY(0); box-shadow: 0 16px 40px rgba(11, 44, 69, 0.18); }
    to   { transform: translateY(-12px); box-shadow: 0 28px 52px rgba(11, 44, 69, 0.22); }
  }

  @media (max-width: 820px) {
    .dc-hero { grid-template-columns: 1fr; padding: 2rem 1.5rem; text-align: center; }
    .dc-hero__lede { max-width: none; }
    .dc-hero__subtitle { border-bottom-color: #d6455f; }
    .dc-hero__features { justify-items: center; }
    .dc-hero__features li { text-align: left; }
    .dc-hero__img { max-width: 380px; }
  }

  /* ---- Section divider --------------------------------------------------- */
  .dc-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }
  .dc-divider::before,
  .dc-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #dbe4ee;
  }
  .dc-divider span {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0b2c45;
    font-size: 1rem;
    white-space: nowrap;
  }

  /* ---- Cards ------------------------------------------------------------- */
  .dc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 0 0 3rem;
  }
  .dc-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e8edf3;
    border-top: 4px solid var(--accent);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    background: #fff;
    box-shadow: 0 10px 30px rgba(11, 44, 69, 0.06);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .dc-card:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(11, 44, 69, 0.12); }
  .dc-card__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 34px;
    font-weight: 800;
    color: var(--accent);
    background: var(--tint);
    margin: 0 auto 1rem;
  }
  .dc-card__title { text-align: center; margin: 0 0 0.5rem; font-size: 1.25rem; }
  .dc-card__title a { text-decoration: none; color: var(--accent); }
  .dc-card__title a:hover { text-decoration: underline; }
  .dc-card__blurb { text-align: center; color: #5b6b7d; font-size: 0.95rem; line-height: 1.5; margin: 0 0 1.25rem; }
  .dc-card__cta {
    display: block;
    text-align: center;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    padding: 0.8rem 1rem;
    border-radius: 10px;
    margin: 0 0 1.1rem;
    box-shadow: 0 6px 16px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .dc-card__cta:hover { filter: brightness(1.07); }
  .dc-card__links { list-style: none; padding: 0; margin: auto 0 0; }
  .dc-card__links li { padding: 0.5rem 0; border-top: 1px solid #eef2f6; }
  .dc-card__links li:first-child { border-top: none; }
  .dc-card__links a {
    text-decoration: none;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.92rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .dc-card__links a::before { content: "›"; font-weight: 800; }
  .dc-card__links a:hover { text-decoration: underline; }

  /* ---- Closing CTA ------------------------------------------------------- */
  .dc-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: #eef6ff;
    border: 1px solid #d5e6f7;
    border-radius: 20px;
    padding: 2rem 2.25rem;
    margin: 0 0 1.5rem;
  }
  .dc-cta__text { flex: 1 1 340px; }
  .dc-cta__text h2 { margin: 0 0 0.5rem; color: #0b2c45; }
  .dc-cta__text p { margin: 0; color: #475569; line-height: 1.6; }
  .dc-cta__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #0b2c45;
    color: #fff;
    text-decoration: none;
    padding: 0.95rem 1.75rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 1.25rem;
    white-space: nowrap;
    box-shadow: 0 10px 24px rgba(11, 44, 69, 0.22);
  }
  .dc-cta__phone:hover { filter: brightness(1.08); }

  .dc-map { font-size: 0.95rem; color: #64748b; text-align: center; }
  .dc-map strong { color: #0b2c45; }

  @media (max-width: 640px) {
    .dc-cta { flex-direction: column; align-items: stretch; text-align: center; }
    .dc-cta__phone { justify-content: center; }
  }
</style>
