---
// src/components/content/DecisionCenterPage.astro — the Decision Center
// template (M4 batch 2; playbook §4.5). Page copy from content JSON;
// DECISION_PATHS card copy is a SHARED DATA MODULE (Phase B translation
// boundary) and renders in English on /es/ until that module gets its own
// translation source. Card hrefs still localize (auto-upgrade to /es/).
import ArticlePage from '../layout/ArticlePage.astro';
import { DECISION_PATHS } from '../../data/decisionPaths';
import { BUSINESS } from '../../data/business';
import { authorById } from '../../data/authors';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta, localizeLabel, t } from '../../i18n/locales';
import { relatedFor } from '../../lib/related';
import { PAGE_INDEX } from '../../data/pageIndex';
import type { PageContext } from '../../types/Page';

const SLUG = 'medicare-decision-center';
const vars = { phone: BUSINESS.phone, tty: BUSINESS.tty };
const t9 = (s: string) => interp(s, vars);

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; self: string };
  personCta: {
    letsTalk: string;
    quoteLabel: string;
    secureTitle: string;
    secureSub: string;
    features: string[];
  };
  hero: {
    subtitle: string;
    lede: string;
    badges: string[];
    ctaWhen: string;
    ctaText: string;
    signpostAria: string;
  };
  body: {
    introHtml: string;
    h2Map: string;
    mapHtml: string;
    h2Person: string;
    personHtml: string;
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

// Agent (for the "start with a person" CTA photo + caption).
const agent = authorById('rocco');
const quoteHref = localizeHref('/medicare-quote-vernal.html', lang);

// Related resources for the footer card (same scoring the layout would use).
const relatedPages = relatedFor(
  { silo: 'medicare-101', tags: ['medicare-101', 'hub', 'decision-center', 'start-here', 'overview'], pillar: true },
  PAGE_INDEX,
  pagePath,
).slice(0, 4);

// Split "…— Free" so the trailing word can be accented (works for EN "Free"
// and ES "gratis"; both keep the em-dash).
const [personTitleMain, personTitleAccent] = b.h2Person.split('—');

// Inline SVGs for the four trust features, aligned to personCta.features order.
const FEATURE_ICONS = [
  // Local & Personal — person
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg>',
  // No Cost, No Pressure — shield check
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
  // Plain English Answers — chat
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg>',
  // Here to Help You Decide — handshake
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 13l3 3 5-5 4 4"/><path d="M2 9l4-4 4 3 4-3 4 4"/></svg>',
];

// Per-path colour + icon, keyed by the shared data-module id (so the shared
// DECISION_PATHS module stays presentation-free / translation-clean). Colours
// echo the signpost hero; the icon is a glyph shown in the card's circle.
const PATH_STYLE: Record<string, { icon: string; color: string; tint: string }> = {
  'turning-65':     { icon: '65', color: '#0d9488', tint: '#d8f2ee' },
  'still-working':  { icon: '💼', color: '#2563eb', tint: '#e6effe' },
  'already-have':   { icon: '🛡️', color: '#16a34a', tint: '#e6f6ec' },
  'drug-help':      { icon: '💊', color: '#7c3aed', tint: '#f1e9fd' },
  'financial-help': { icon: '👛', color: '#ea580c', tint: '#fdece0' },
  'compare-plans':  { icon: '⚖️', color: '#0d9488', tint: '#d8f2ee' },
  'estimate-costs': { icon: '🧮', color: '#2563eb', tint: '#e6effe' },
};
const FALLBACK_STYLE = { icon: '➜', color: '#0b2c45', tint: '#eef3f8' };

const context: PageContext = {
  page: {
    title: c.page.title,
    heading: c.page.heading,
    description: c.page.description,
    taxonomy: { silo: 'medicare-101', tags: ['medicare-101', 'hub', 'decision-center', 'start-here', 'overview'], pillar: true },
    summary: c.page.summary,
    faqs: c.page.faqs.map((q) => ({ question: t9(q.question), answer: t9(q.answer) })),
    sources: c.page.sources,
    nextSteps: c.page.nextSteps.map((s) => ({ when: s.when, action: t9(s.action) })),
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'website',
    ogTitle: c.meta.ogTitle,
    ogDescription: c.meta.ogDescription,
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};
---

<ArticlePage context={context} bareHeader bareFooter>
  <!-- Two-column hero: message + reassurance on the left, a signpost of the
       seven starting points on the right. The signs are real links. -->
  <section class="dc-hero">
    <div class="dc-hero__copy">
      <h1 class="dc-hero__title">{c.page.heading}</h1>
      <p class="dc-hero__subtitle">{c.hero.subtitle}</p>
      <p class="dc-hero__lede">{c.hero.lede}</p>

      <ul class="dc-hero__features">
        {c.hero.badges.map((label) => (
          <li><span class="dc-hero__check" aria-hidden="true">✓</span>{label}</li>
        ))}
      </ul>

      <a class="dc-phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="dc-phone__icon" aria-hidden="true">📞</span>
        <span class="dc-phone__body">
          <span class="dc-phone__when">{c.hero.ctaWhen}</span>
          <span class="dc-phone__line" set:html={t9(c.hero.ctaText).replace(
            BUSINESS.phone,
            `<strong>${BUSINESS.phone}</strong>`
          )} />
        </span>
      </a>
    </div>

    <div class="dc-hero__art">
      <img
        class="dc-hero__img"
        src="/pictures/decision-signpost.webp"
        alt="Signpost pointing to the seven Medicare starting points: new to Medicare, turning 65, already enrolled, prescription help, lower costs, compare plans, and estimate costs."
        width="495"
        height="565"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <div class="dc-divider"><span>Choose the path that fits you</span></div>

  <div class="dc-grid">
    {DECISION_PATHS.map((p) => {
      const s = PATH_STYLE[p.id] ?? FALLBACK_STYLE;
      return (
        <section class="dc-card" id={p.id} style={`--accent:${s.color};--tint:${s.tint}`}>
          <div class="dc-card__icon" aria-hidden="true">{s.icon}</div>
          <h2 class="dc-card__title"><a href={localizeHref(p.primary.href, lang)}>{p.situation}</a></h2>
          <p class="dc-card__blurb">{p.blurb}</p>
          <a class="dc-card__cta" href={localizeHref(p.primary.href, lang)}>{p.primary.label} →</a>
          <ul class="dc-card__links">
            {p.links.map((l) => <li><a href={localizeHref(l.href, lang)}>{l.label}</a></li>)}
          </ul>
        </section>
      );
    })}
  </div>

  <!-- "Whole map" banner -->
  <aside class="dc-mapbanner">
    <span class="dc-mapbanner__icon dc-mapbanner__icon--map" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 4L3 6v14l6-2 6 2 6-2V4l-6 2-6-2z"/><path d="M9 4v14M15 6v14"/></svg>
    </span>
    <p class="dc-mapbanner__text"><strong>{b.h2Map}</strong> <span set:html={t9(b.mapHtml)} /></p>
    <span class="dc-mapbanner__icon dc-mapbanner__icon--compass" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5 5-2z"/></svg>
    </span>
  </aside>

  <!-- Resources: FAQ · Sources · Related -->
  <div class="dc-resources">
    <section class="dc-rcard dc-rcard--faq">
      <header class="dc-rcard__head">
        <span class="dc-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.9.4-1.5 1-1.5 2"/><circle cx="11.5" cy="16.5" r="0.6" fill="currentColor" stroke="none"/></svg>
        </span>
        <h2>{t('faq.heading', lang)}</h2>
      </header>
      <div class="dc-rcard__body">
        {c.page.faqs.map((f) => (
          <details class="dc-faq">
            <summary set:html={t9(f.question)} />
            <p set:html={t9(f.answer)} />
          </details>
        ))}
      </div>
      <a class="dc-rcard__more dc-rcard__more--faq" href={localizeHref('/faq.html', lang)}>{t('faq.viewAll', lang)} →</a>
    </section>

    <section class="dc-rcard dc-rcard--sources">
      <header class="dc-rcard__head">
        <span class="dc-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/><path d="M10 12h5M10 15h5"/></svg>
        </span>
        <h2>{t('sources.heading', lang)}</h2>
      </header>
      <ul class="dc-rlist">
        {c.page.sources.map((s) => (
          <li>
            <span class="dc-rlist__tick" aria-hidden="true">✓</span>
            <span><a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a><span class="dc-rlist__pub">{s.publisher}</span></span>
          </li>
        ))}
      </ul>
    </section>

    <section class="dc-rcard dc-rcard--related">
      <header class="dc-rcard__head">
        <span class="dc-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a3 3 0 0 0 3 3h3a3 3 0 0 0 0-6h-1"/><path d="M15 12a3 3 0 0 0-3-3H9a3 3 0 0 0 0 6h1"/></svg>
        </span>
        <h2>{t('related.resourcesTitle', lang)}</h2>
      </header>
      <ul class="dc-rlist dc-rlist--links">
        {relatedPages.map((r) => (
          <li>
            <span class="dc-rlist__doc" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v4h4"/></svg>
            </span>
            <a href={localizeHref(r.href, lang)}>{r.label}</a>
          </li>
        ))}
      </ul>
      <a class="dc-rcard__more dc-rcard__more--related" href={localizeHref('/medicare-help-center.html', lang)}>{t('related.explore', lang)} →</a>
    </section>
  </div>

  <!-- Closing CTA: talk to a person -->
  <section class="dc-cta">
    <!-- Left: agent -->
    <figure class="dc-cta__agent">
      <span class="dc-cta__dots" aria-hidden="true"></span>
      <span class="dc-cta__photo-wrap">
        <img
          class="dc-cta__photo"
          src="/pictures/rocco.webp"
          alt={`${agent?.name ?? 'Rocco DeLuca'}, licensed Medicare agent in Vernal, Utah`}
          width="132"
          height="132"
          loading="lazy"
          decoding="async"
        />
      </span>
      <figcaption>
        <strong>{agent?.name ?? 'Rocco DeLuca'}</strong>
        <span>{agent ? localizeLabel(agent.jobTitle, lang) : 'Licensed Medicare Insurance Agent'}</span>
        <span class="dc-cta__rule" aria-hidden="true"></span>
      </figcaption>
    </figure>

    <!-- Middle: message + trust features -->
    <div class="dc-cta__main">
      <h2 class="dc-cta__title">{personTitleMain}{personTitleAccent && <><span class="dc-cta__dash">—</span><em class="dc-cta__free">{personTitleAccent.trim()}</em></>}</h2>
      <p class="dc-cta__lead" set:html={t9(b.personHtml)} />
      <ul class="dc-cta__features">
        {c.personCta.features.map((f, i) => (
          <li>
            <span class="dc-cta__ficon" aria-hidden="true" set:html={FEATURE_ICONS[i] ?? ''} />
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Right: actions -->
    <div class="dc-cta__actions">
      <span class="dc-cta__letstalk">{c.personCta.letsTalk}</span>
      <a class="dc-cta__phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="dc-cta__phone-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg>
        </span>
        <span class="dc-cta__phone-body">
          <span class="dc-cta__phone-num">{BUSINESS.phone}</span>
          <span class="dc-cta__phone-tty">TTY: {BUSINESS.tty}</span>
        </span>
      </a>
      <a class="dc-cta__quote" href={quoteHref}>
        <span class="dc-cta__quote-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v3H9z"/><path d="M8 5H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><path d="M9 12l1.5 1.5L14 10"/></svg>
        </span>
        {c.personCta.quoteLabel} <span aria-hidden="true">›</span>
      </a>
      <div class="dc-cta__secure">
        <span class="dc-cta__secure-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>
        </span>
        <span class="dc-cta__secure-text">
          <strong>{c.personCta.secureTitle}</strong>
          <span>{c.personCta.secureSub}</span>
        </span>
        <span class="dc-cta__lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
        </span>
      </div>
    </div>
  </section>
</ArticlePage>

<style>
  /* ---- Two-column hero --------------------------------------------------- */
  .dc-hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.5rem 0 2.5rem;
    /* whole-hero float */
    animation: dc-hero-float 6s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes dc-hero-float {
    from { transform: translateY(0); }
    to   { transform: translateY(-8px); }
  }
  .dc-hero__title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    color: #0b2c45;
    margin: 0 0 0.5rem;
  }
  .dc-hero__subtitle {
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    font-weight: 700;
    font-style: italic;
    color: #1f4e8c;
    border-bottom: 3px solid #d6455f;
    display: inline-block;
    padding-bottom: 0.15rem;
    margin: 0 0 1rem;
  }
  .dc-hero__lede { font-size: 1.05rem; color: #475569; line-height: 1.55; margin: 0 0 1.5rem; max-width: 34ch; }
  .dc-hero__features { list-style: none; padding: 0; margin: 0 0 1.75rem; display: grid; gap: 0.7rem; }
  .dc-hero__features li {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    background: #fff;
    border: 1px solid #e4ecf5;
    border-radius: 999px;
    padding: 0.45rem 1rem 0.45rem 0.5rem;
    font-weight: 600;
    color: #0b2c45;
    font-size: 0.92rem;
    box-shadow: 0 10px 22px rgba(11, 44, 69, 0.12);
    /* floating effect */
    animation: dc-badge-float 3.2s ease-in-out infinite alternate;
    will-change: transform;
  }
  .dc-hero__features li:nth-child(2) { animation-delay: 0.5s; }
  .dc-hero__features li:nth-child(3) { animation-delay: 1s; }
  @keyframes dc-badge-float {
    from { transform: translateY(0); box-shadow: 0 10px 22px rgba(11, 44, 69, 0.12); }
    to   { transform: translateY(-7px); box-shadow: 0 18px 30px rgba(11, 44, 69, 0.16); }
  }
  @media (prefers-reduced-motion: reduce) {
    .dc-hero,
    .dc-hero__img,
    .dc-hero__features li { animation: none; }
  }
  .dc-hero__check {
    flex: none; width: 22px; height: 22px; border-radius: 50%;
    background: #1f4e8c; color: #fff; display: grid; place-items: center;
    font-size: 0.75rem; font-weight: 800;
  }
  .dc-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #fff;
    color: #0b2c45;
    text-decoration: none;
    padding: 0.85rem 1.4rem;
    border-radius: 14px;
    border: 1px solid #dbe6f2;
    box-shadow: 0 12px 26px rgba(11, 44, 69, 0.12);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .dc-phone:hover { transform: translateY(-2px); box-shadow: 0 16px 32px rgba(11, 44, 69, 0.18); }
  .dc-phone__icon {
    flex: none; width: 40px; height: 40px; border-radius: 50%;
    background: #1f4e8c; color: #fff; display: grid; place-items: center; font-size: 1.1rem;
  }
  .dc-phone__body { display: flex; flex-direction: column; line-height: 1.3; }
  .dc-phone__when { font-weight: 700; font-size: 0.95rem; }
  .dc-phone__line { font-size: 0.9rem; color: #475569; }
  .dc-phone__line :global(strong) { color: #d6455f; font-size: 1.05rem; }

  /* ---- Signpost art ------------------------------------------------------ */
  .dc-hero__art { display: flex; justify-content: center; }
  .dc-hero__img {
    width: 100%;
    max-width: 420px;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: 0 16px 40px rgba(11, 44, 69, 0.18);
    /* signpost float (offset from the hero so they drift independently) */
    animation: dc-img-float 4.5s ease-in-out 0.6s infinite alternate;
    will-change: transform;
  }
  @keyframes dc-img-float {
    from { transform: translateY(0); box-shadow: 0 16px 40px rgba(11, 44, 69, 0.18); }
    to   { transform: translateY(-12px); box-shadow: 0 28px 52px rgba(11, 44, 69, 0.22); }
  }

  @media (max-width: 820px) {
    .dc-hero { grid-template-columns: 1fr; padding: 2rem 1.5rem; text-align: center; }
    .dc-hero__lede { max-width: none; }
    .dc-hero__subtitle { border-bottom-color: #d6455f; }
    .dc-hero__features { justify-items: center; }
    .dc-hero__features li { text-align: left; }
    .dc-hero__img { max-width: 380px; }
  }

  /* ---- Section divider --------------------------------------------------- */
  .dc-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 0 1.75rem;
  }
  .dc-divider::before,
  .dc-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #dbe4ee;
  }
  .dc-divider span {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #0b2c45;
    font-size: 1rem;
    white-space: nowrap;
  }

  /* ---- Cards ------------------------------------------------------------- */
  .dc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 0 0 3rem;
  }
  .dc-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e8edf3;
    border-top: 4px solid var(--accent);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    background: #fff;
    box-shadow: 0 10px 30px rgba(11, 44, 69, 0.06);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .dc-card:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(11, 44, 69, 0.12); }
  .dc-card__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 34px;
    font-weight: 800;
    color: var(--accent);
    background: var(--tint);
    margin: 0 auto 1rem;
  }
