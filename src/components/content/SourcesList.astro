---
// SourcesList.astro — authoritative citations (Evidence). Visible list; the
// machine-readable citations are emitted by assembleSchema.
// i18n (M3): default heading + aria via t(); an explicit heading prop wins.
import { getLangFromUrl, t } from '../../i18n/locales';
import type { Evidence } from '../../types/Page';

interface Props {
  sources: Evidence[];
  heading?: string;
}
const { sources, heading } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const headingText = heading ?? t('sources.heading', lang);
---

{sources.length > 0 && (
  <section class="sources" aria-label={t('sources.aria', lang)}>
    <h2>{headingText}</h2>
    <ul>
      {sources.map((s) => (
        <li>
          <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a> — {s.publisher}
          {s.date && <Fragment> ({s.date})</Fragment>}
        </li>
      ))}
    </ul>
  </section>
)}
