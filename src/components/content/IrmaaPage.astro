---
// src/components/content/IrmaaPage.astro — IRMAA authority hub template
// (M4 batch 3; playbook §4.5). Dynamic-data pattern: {year}, {lookbackYear},
// and both IRMAA thresholds interpolate from annualMedicareData.
//
// Design (M46): the old stacked-prose page was a text wall. Rebuilt as a custom
// landing layout (bareHeader + bareFooter) matching the costs & coverage hubs —
// a hero with an image callout, a four-item "what IRMAA is" feature strip, a
// three-card explainer row (how it works / two-year lookback / appeal), a
// "where to go next" router with a call box, an FAQ/Sources/Related trio, a
// person CTA banner, and a trust bar. All display copy (chrome included) still
// comes from the localized JSON so both languages stay in sync — the .astro
// only owns icons, accents, and layout.
import ArticlePage from '../layout/ArticlePage.astro';
import { figuresFor } from '../../data/annualMedicareData';
import { usd } from '../../lib/formatters';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta, t } from '../../i18n/locales';
import { BUSINESS } from '../../data/business';
import { authorById } from '../../data/authors';
import type { PageContext } from '../../types/Page';

const SLUG = 'medicare-irmaa';
const f = figuresFor();
const vars = {
  year: f.year,
  lookbackYear: f.year - 2,
  irmaaSingle: usd(f.irmaa.single[0]),
  irmaaMarried: usd(f.irmaa.married[0]),
};
const t9 = (s: string) => interp(s, vars);

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; parent: string; self: string };
  body: {
    introHtml: string;
    h2How: string;
    howHtml: string;
    surchargeIntro: string;
    partItemsHtml: string[];
    seeHtml: string;
    h2Lookback: string;
    lookbackHtml: string;
    h2Appeal: string;
    appealHtml: string;
    h2Next: string;
    nextItemsHtml: string[];
    outroHtml: string;
  };
  ui: {
    byline: string;
    updated: string;
    accuracyLink: string;
    heroCalloutTitle: string;
    heroCalloutBody: string;
    features: { title: string; sub: string }[];
    seeBracketsCta: string;
    lookbackLead: string;
    lookbackNoteTitle: string;
    lookbackNote: string;
    appealCta: string;
    nextSub: string;
    callTitle: string;
    callSub: string;
    relatedHeading: string;
    related: { label: string; href: string }[];
    ctaTitle: string;
    ctaButtonQuote: string;
    trust: { title: string; sub: string }[];
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const ui = c.ui;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

const agent = authorById('rocco');
const agentName = agent?.name ?? 'Rocco DeLuca';
const phoneLink = `<a href="tel:${BUSINESS.phoneTel}">${BUSINESS.phone}</a>`;
// interp() leaves unknown {tokens} untouched, so we can layer chrome tokens on
// top of the figure tokens t9() already resolved.
const fill = (s: string) =>
  t9(s)
    .replaceAll('{phoneLink}', phoneLink)
    .replaceAll('{tty}', BUSINESS.tty)
    .replaceAll('{phone}', BUSINESS.phone)
    .replaceAll('{name}', agentName);

const context: PageContext = {
  page: {
    title: t9(c.page.title),
    heading: c.page.heading,
    description: t9(c.page.description),
    taxonomy: { silo: 'costs-irmaa', tags: ['irmaa', 'costs', 'part-b', 'part-d', 'magi'], pillar: true },
    summary: t9(c.page.summary),
    faqs: c.page.faqs.map((q) => ({ question: t9(q.question), answer: t9(q.answer) })),
    sources: c.page.sources,
    nextSteps: c.page.nextSteps,
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'article',
    ogTitle: c.meta.ogTitle,
    ogDescription: t9(c.meta.ogDescription),
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.parent, href: localizeHref('/medicare-cost-uintah-county.html', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};

const FAQS = context.page.faqs ?? [];
const editorialHref = localizeHref('/editorial-policy.html', lang);

// Accent the "IRMAA" keyword in the heading (works for en and es headings).
const heroTitleHtml = t9(c.page.heading).replace('IRMAA', '<span>IRMAA</span>');

// ── Icon library ─────────────────────────────────────────────────────────
const ICON_SHIELD_PLUS = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M12 9v5M9.5 11.5h5"/></svg>';
const ICON_PEOPLE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/><path d="M15.2 20c0-1.7-.5-3.2-1.4-4.3"/></svg>';
const ICON_CAL_BACK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="16" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/><path d="M13.5 13.5l-2 2 2 2M11.5 15.5H15"/></svg>';
const ICON_PHONE_FILL = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg>';
const ICON_GEAR = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.1"/><path d="M19.4 13a1.7 1.7 0 0 0 .3 1.9l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 0 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.9.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.9 1.7 1.7 0 0 0-1.5-1H3a2 2 0 0 1 0-4h.1a1.7 1.7 0 0 0 1.5-1.1 1.7 1.7 0 0 0-.3-1.9l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.9.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 0 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.9-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.9V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 0 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/></svg>';
const ICON_CAL_CLOCK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M12 12v3l2 1.2"/></svg>';
const ICON_HEART = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20s-6.5-4.4-6.5-9.4A3.9 3.9 0 0 1 12 7.2a3.9 3.9 0 0 1 6.5 3.4C18.5 15.6 12 20 12 20z"/></svg>';
const ICON_PILL = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 20.5a5 5 0 0 1-7-7l7-7a5 5 0 0 1 7 7l-7 7z"/><path d="M8 6l10 10"/></svg>';
const ICON_SHIELD = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/></svg>';
const ICON_CHECK_CIRCLE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.4 12.4l2.4 2.4 4.8-5.2"/></svg>';
const ICON_PIN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>';
const ICON_ARROW = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
const ICON_TABLE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M4 9.5h16M9 9.5V20"/></svg>';
const ICON_CALC = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M8 7h8"/><path d="M8 11h.01M12 11h.01M16 11h.01M8 15h.01M12 15h.01M16 15v3"/></svg>';
const ICON_EVENT = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M17 7l2.1-2.1M4.9 19.1 7 17"/></svg>';
const ICON_DOC = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>';

// ── Data: feature strip, part rows, next-step router, related, trust ──────
const FEATURE_STYLE = [
  { accent: '#2563eb', tint: '#e5edfe', icon: ICON_SHIELD_PLUS },
  { accent: '#16a34a', tint: '#e4f5ea', icon: ICON_PEOPLE },
  { accent: '#7c3aed', tint: '#f0e9fd', icon: ICON_CAL_BACK },
  { accent: '#ea580c', tint: '#fdeadd', icon: ICON_PHONE_FILL },
];
const features = ui.features.map((ft, i) => ({ ...ft, ...FEATURE_STYLE[i % FEATURE_STYLE.length] }));

const PART_ICONS = [ICON_SHIELD, ICON_PILL];

const NEXT_STYLE = [
  { accent: '#2563eb', tint: '#e5edfe', icon: ICON_TABLE },
  { accent: '#0d9488', tint: '#d7f0ec', icon: ICON_CALC },
  { accent: '#ea580c', tint: '#fdeadd', icon: ICON_EVENT },
  { accent: '#7c3aed', tint: '#f0e9fd', icon: ICON_DOC },
];
// Each next item is "<a href>Label</a> — description." — split into title + desc.
const nextItems = b.nextItemsHtml.map((raw, i) => {
  const html = t9(raw);
  const m = html.match(/^<a href="([^"]+)">([\s\S]*?)<\/a>\s*[—–-]\s*([\s\S]*)$/);
  return {
    href: m ? m[1] : '#',
    label: m ? m[2] : html,
    desc: m ? m[3].replace(/\s*\.\s*$/, '') : '',
    ...NEXT_STYLE[i % NEXT_STYLE.length],
  };
});

const related = ui.related.map((r) => ({ label: t9(r.label), href: r.href }));

const TRUST_STYLE = [
  { color: '#16a34a', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { color: '#7c3aed', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { color: '#ea580c', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8 13l3 3 5-5 4 4"/><path d="M2 9l4-4 4 3 4-3 4 4"/></svg>' },
  { color: '#2563eb', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];
const trust = ui.trust.map((tr, i) => ({ ...tr, ...TRUST_STYLE[i % TRUST_STYLE.length] }));
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="irm-hero">
    <div class="irm-hero__copy">
      <h1 class="irm-hero__title" set:html={heroTitleHtml} />
      <p class="irm-hero__byline">
        {fill(ui.byline)} · {t9(ui.updated)} · <a href={editorialHref}>{ui.accuracyLink}</a>
      </p>
      <p class="irm-hero__lede" set:html={t9(c.page.summary)} />
    </div>

    <div class="irm-hero__art">
      <img
        class="irm-hero__img"
        src="/pictures/help-you-deserve.webp"
        alt="A man reviews an IRMAA notice about his Medicare premiums at home."
        width="1536"
        height="1024"
        loading="eager"
        decoding="async"
      />
      <div class="irm-hero__callout">
        <span class="irm-hero__callout-icon" aria-hidden="true" set:html={ICON_SHIELD_PLUS} />
        <p><strong>{ui.heroCalloutTitle}</strong>{ui.heroCalloutBody}</p>
      </div>
    </div>
  </section>

  {/* ─── Feature strip ────────────────────────────────────────────────── */}
  <section class="irm-features" aria-hidden="false">
    {features.map((ft) => (
      <div class="irm-feature" style={`--accent:${ft.accent};--tint:${ft.tint}`}>
        <span class="irm-feature__icon" aria-hidden="true" set:html={ft.icon} />
        <span class="irm-feature__text"><strong>{ft.title}</strong><em>{ft.sub}</em></span>
      </div>
    ))}
  </section>

  {/* ─── Three-card explainer ─────────────────────────────────────────── */}
  <section class="irm-cards">
    {/* How IRMAA works */}
    <article class="irm-card" style="--accent:#2563eb;--tint:#e5edfe">
      <div class="irm-card__head">
        <span class="irm-card__icon" aria-hidden="true" set:html={ICON_GEAR} />
        <h2 class="irm-card__title">{b.h2How}</h2>
      </div>
      <p class="irm-card__body" set:html={t9(b.howHtml)} />
      <p class="irm-card__mini">{b.surchargeIntro}</p>
      <ul class="irm-parts">
        {b.partItemsHtml.map((item, i) => (
          <li>
            <span class="irm-parts__icon" aria-hidden="true" set:html={PART_ICONS[i % PART_ICONS.length]} />
            <span set:html={t9(item)} />
          </li>
        ))}
      </ul>
      <p class="irm-card__foot" set:html={t9(b.seeHtml)} />
    </article>

    {/* Two-year lookback */}
    <article class="irm-card" style="--accent:#16a34a;--tint:#e4f5ea">
      <div class="irm-card__head">
        <span class="irm-card__icon" aria-hidden="true" set:html={ICON_CAL_CLOCK} />
        <h2 class="irm-card__title">{b.h2Lookback}</h2>
      </div>
      <p class="irm-card__body">{t9(ui.lookbackLead)}</p>
      <div class="irm-note">
        <span class="irm-note__icon" aria-hidden="true" set:html={ICON_CHECK_CIRCLE} />
        <p><strong>{ui.lookbackNoteTitle}:</strong> {ui.lookbackNote}</p>
      </div>
    </article>

    {/* Appeal */}
    <article class="irm-card" style="--accent:#7c3aed;--tint:#f0e9fd">
      <div class="irm-card__head">
        <span class="irm-card__icon" aria-hidden="true" set:html={ICON_HEART} />
        <h2 class="irm-card__title">{b.h2Appeal}</h2>
      </div>
      <p class="irm-card__body" set:html={t9(b.appealHtml)} />
      <a class="irm-card__cta" href="medicare-irmaa-appeal-ssa-44.html">
        {ui.appealCta}
        <span aria-hidden="true" set:html={ICON_ARROW} />
      </a>
    </article>
  </section>

  {/* ─── Where to go next router ──────────────────────────────────────── */}
  <section class="irm-next" aria-labelledby="irm-next-h">
    <div class="irm-next__intro">
      <span class="irm-next__intro-icon" aria-hidden="true" set:html={ICON_PIN} />
      <h2 id="irm-next-h" class="irm-next__title">{b.h2Next}</h2>
      <p class="irm-next__sub">{t9(ui.nextSub)}</p>
    </div>
    <div class="irm-next__grid">
      {nextItems.map((n) => (
        <a class="irm-next__item" href={n.href} style={`--accent:${n.accent};--tint:${n.tint}`}>
          <span class="irm-next__item-icon" aria-hidden="true" set:html={n.icon} />
          <span class="irm-next__item-text"><strong>{n.label}</strong><em>{n.desc}</em></span>
        </a>
      ))}
    </div>
    <div class="irm-next__call">
      <span class="irm-next__call-icon" aria-hidden="true" set:html={ICON_PHONE_FILL} />
      <strong>{t9(ui.callTitle)}</strong>
      <span class="irm-next__call-sub">{t9(ui.callSub)}</span>
      <a class="irm-next__call-num" href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phone}</a>
      <span class="irm-next__call-tty">(TTY: {BUSINESS.tty})</span>
    </div>
  </section>

  {/* ─── FAQ · Sources · Related trio ─────────────────────────────────── */}
  <div class="irm-trio">
    <section class="irm-panel">
      <h2 class="irm-panel__h">{t('faq.heading', lang)}</h2>
      {FAQS.map((q) => (
        <details class="irm-faq">
          <summary>{q.question}</summary>
          <p set:html={q.answer} />
        </details>
      ))}
    </section>

    <section class="irm-panel">
      <h2 class="irm-panel__h">{t('sources.heading', lang)}</h2>
      <ul class="irm-sources">
        {c.page.sources.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
            <em>{s.publisher}</em>
          </li>
        ))}
      </ul>
    </section>

    <section class="irm-panel">
      <h2 class="irm-panel__h">{ui.relatedHeading}</h2>
      <ul class="irm-related">
        {related.map((r) => (
          <li><a href={r.href}>{r.label}</a></li>
        ))}
      </ul>
    </section>
  </div>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="irm-cta">
    <img class="irm-cta__photo" src="/pictures/rocco.webp" alt={`${agentName}, licensed Medicare agent in Vernal, Utah`} width="88" height="88" loading="lazy" decoding="async" />
    <div class="irm-cta__msg">
      <h2 class="irm-cta__title">{t9(ui.ctaTitle)}</h2>
      <p set:html={t9(b.outroHtml)} />
    </div>
    <div class="irm-cta__actions">
      <a class="irm-cta__phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="irm-cta__phone-icon" aria-hidden="true" set:html={ICON_PHONE_FILL} />
        <span>{BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="irm-cta__quote" href="medicare-quote-vernal.html">
        <span class="irm-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        {t9(ui.ctaButtonQuote)}
      </a>
    </div>
  </section>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="irm-trust">
    {trust.map((tr) => (
      <div class="irm-trust__item">
        <span class="irm-trust__icon" style={`--c:${tr.color}`} aria-hidden="true" set:html={tr.icon} />
        <span class="irm-trust__text"><strong>{t9(tr.title)}</strong><em>{t9(tr.sub)}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the costs & coverage hubs: navy #0b2c45, blue #2563eb, with
     per-item accents (blue/green/purple/orange). */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .irm-hero {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.25rem 0 2rem;
  }
  .irm-hero__title {
    font-size: clamp(2.1rem, 4.6vw, 3.2rem);
    line-height: 1.06;
    font-weight: 800;
    color: #0b2c45;
    margin: 0 0 0.6rem;
  }
  .irm-hero__title :global(span) { color: #2563eb; }
  .irm-hero__byline { margin: 0 0 1rem; color: #64748b; font-size: 0.85rem; line-height: 1.5; }
