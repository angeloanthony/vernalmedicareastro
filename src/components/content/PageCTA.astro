---
// PageCTA.astro — conversion block. Defaults (phone + quote) come from
// business.ts so the CTA can never drift from the live NAP.
// i18n (M3): default strings via t() with {agent}/{phone} interpolation; an
// explicit per-page cta config wins (page content arrives already localized).
import { BUSINESS } from '../../data/business';
import { getLangFromUrl, t } from '../../i18n/locales';
import { localizeHref } from '../../i18n/content';
import type { CTAConfig } from '../../types/Page';

interface Props {
  cta?: CTAConfig;
}
const { cta } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const heading = cta?.heading ?? t('cta.heading', lang);
const text = cta?.text ?? t('cta.text', lang, { agent: BUSINESS.legalAgent });
const primary = cta?.primary ?? {
  label: t('cta.call', lang, { phone: BUSINESS.phone }),
  href: `tel:${BUSINESS.phoneTel}`,
};
const secondary = cta?.secondary ?? { label: t('cta.quote', lang), href: BUSINESS.quoteUrl };
---

<section class="page-cta">
  <h2>{heading}</h2>
  <p>{text}</p>
  <p class="page-cta-actions">
    <a class="button" href={localizeHref(primary.href, lang)}>{primary.label}</a>
    {secondary && (
      <a class="button" href={localizeHref(secondary.href, lang)} target="_blank" rel="noopener noreferrer">{secondary.label}</a>
    )}
  </p>
</section>
