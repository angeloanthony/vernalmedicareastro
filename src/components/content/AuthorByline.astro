---
// AuthorByline.astro — E-E-A-T byline. Takes author IDs and resolves them to
// records (no stale copies). Rendered by StandardPageLayout under the H1.
import { authorById } from '../../data/authors';
import type { AuthorId } from '../../types/Page';

interface Props {
  authorId?: AuthorId;
  reviewedById?: AuthorId;
  updated?: string;
  localAvailability?: string;
}
const { authorId, reviewedById, updated, localAvailability } = Astro.props;

const author = authorId ? authorById(authorId) : undefined;
const reviewerRaw = reviewedById ? authorById(reviewedById) : undefined;
const reviewer = reviewerRaw && reviewerRaw.id !== author?.id ? reviewerRaw : undefined;
const show = Boolean(author || reviewer || updated || localAvailability);

// Display an ISO date as "Month YYYY"; pass other strings through unchanged.
const parsed = updated ? new Date(updated) : null;
const updatedDisplay =
  parsed && !Number.isNaN(parsed.getTime())
    ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' }).format(parsed)
    : updated;
---

{show && (
  <p class="byline">
    {author && (
      <Fragment>By <a href={author.url ?? '#'}>{author.name}</a>, {author.jobTitle}</Fragment>
    )}
    {reviewer && <Fragment> · Reviewed by {reviewer.name}</Fragment>}
    {updated && <Fragment> · Updated {updatedDisplay}</Fragment>}
    {localAvailability && <Fragment> · {localAvailability}</Fragment>}
    {author && <Fragment> · <a href="/editorial-policy.html">How we keep this accurate</a></Fragment>}
  </p>
)}
