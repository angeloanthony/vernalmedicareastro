---
// src/components/content/MedicareCostsPage.astro — Costs pillar hub template
// (M4 batch 2; playbook §4.5). DYNAMIC-DATA PATTERN at full scale: every
// figure ({year}, premiums, deductibles, caps, IRMAA thresholds) comes from
// annualMedicareData via placeholders — an annual figures update flows into
// BOTH languages from the one data edit, and translations never go stale on
// a dollar amount.
//
// Design (M45): the old stacked-prose page was a text wall. Rebuilt as a
// custom landing layout (bareHeader + bareFooter) matching the coverage hub —
// a hero, a color-coded "building blocks" card grid, a Cost Estimator feature
// strip, a higher-income/lower-income split (IRMAA vs assistance), caps cards,
// a local strip, a person CTA banner, an FAQ/jump/agent trio, and a trust bar.
// All display copy (chrome included) still comes from the localized JSON so
// both languages stay in sync — the .astro only owns icons, accents, layout.
import ArticlePage from '../layout/ArticlePage.astro';
import { figuresFor } from '../../data/annualMedicareData';
import { usd } from '../../lib/formatters';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta, t } from '../../i18n/locales';
import { BUSINESS } from '../../data/business';
import { authorById } from '../../data/authors';
import type { PageContext } from '../../types/Page';

const SLUG = 'medicare-costs';
const f = figuresFor();
const vars = {
  year: f.year,
  partADeductible: usd(f.partA.deductible),
  partBPremium: usd(f.partB.premium, { cents: true }),
  partBDeductible: usd(f.partB.deductible),
  partDBase: usd(f.partD.basePremium, { cents: true }),
  partDCap: usd(f.partD.annualCap),
  insulinCap: usd(f.partD.insulinCap),
  irmaaSingle: usd(f.irmaa.single[0]),
  irmaaMarried: usd(f.irmaa.married[0]),
};
const t9 = (s: string) => interp(s, vars);

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; self: string };
  body: {
    introHtml: string;
    h2Blocks: string;
    blockItemsHtml: string[];
    h2Estimate: string;
    estimateHtml: string;
    h2Irmaa: string;
    irmaaHtml: string;
    h2Assistance: string;
    assistanceHtml: string;
    h2Caps: string;
    capItemsHtml: string[];
    h2Local: string;
    localHtml: string;
    outroHtml: string;
  };
  ui: {
    heroLede: string;
    heroPoints: { title: string; sub: string }[];
    heroCallout: string;
    blocksSub: string;
    blockTitles: string[];
    estimateCta: string;
    incomeHeading: string;
    irmaaTag: string;
    assistanceTag: string;
    capsSub: string;
    localCta: string;
    ctaTitle: string;
    ctaButtonQuote: string;
    centersHeading: string;
    agentHeading: string;
    agentBlurb: string;
    agentCta: string;
    trust: { title: string; sub: string }[];
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const ui = c.ui;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

const agent = authorById('rocco');
const agentName = agent?.name ?? 'Rocco DeLuca';
const phoneLink = `<a href="tel:${BUSINESS.phoneTel}">${BUSINESS.phone}</a>`;
// interp() leaves unknown {tokens} untouched, so we can layer chrome tokens on
// top of the figure tokens t9() already resolved.
const fill = (s: string) =>
  t9(s)
    .replaceAll('{phoneLink}', phoneLink)
    .replaceAll('{tty}', BUSINESS.tty)
    .replaceAll('{phone}', BUSINESS.phone)
    .replaceAll('{name}', agentName);

const context: PageContext = {
  page: {
    title: t9(c.page.title),
    heading: t9(c.page.heading),
    description: t9(c.page.description),
    taxonomy: { silo: 'costs-irmaa', tags: ['costs', 'part-a', 'part-b', 'part-d', 'irmaa', 'overview'], pillar: true },
    summary: t9(c.page.summary),
    faqs: c.page.faqs.map((q) => ({ question: t9(q.question), answer: t9(q.answer) })),
    sources: c.page.sources,
    nextSteps: c.page.nextSteps,
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'article',
    ogTitle: t9(c.meta.ogTitle),
    ogDescription: t9(c.meta.ogDescription),
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};

const FAQS = context.page.faqs ?? [];

// Wrap the trailing year in the heading so it can be accented (e.g. "…in 2026?").
const heroTitleHtml = t9(c.page.heading).replace(/(\d{4}\??)\s*$/, '<span>$1</span>');

// Pull the leading "<strong>Title</strong> — body" out of a content blob so it
// can render as a card title + body. The pattern is identical across both
// languages, so this works for en and es without per-locale branching.
const splitLead = (html: string): { title: string; body: string } => {
  const m = html.match(/^\s*<strong>([\s\S]*?)<\/strong>\s*[—–-]?\s*([\s\S]*)$/);
  return m ? { title: m[1], body: m[2] } : { title: '', body: html };
};

// Per-block accent + tint + icon for the "building blocks" grid. Order matches
// blockItemsHtml: Part A, Part B, Part D, Medigap/Advantage.
const BLOCK_STYLE = [
  { accent: '#2563eb', tint: '#e5edfe', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V6a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v15"/><path d="M2.5 21h19"/><path d="M12 8v5M9.5 10.5h5"/><path d="M9 21v-3.5h6V21"/></svg>' },
  { accent: '#0d9488', tint: '#d7f0ec', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v6a5 5 0 0 0 10 0V3"/><path d="M3.5 3H6M13 3h2.5"/><path d="M10 18.5a4 4 0 0 0 8 0V16"/><circle cx="18" cy="13" r="2.3"/></svg>' },
  { accent: '#7c3aed', tint: '#f0e9fd', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 20.5a5 5 0 0 1-7-7l7-7a5 5 0 0 1 7 7l-7 7z"/><path d="M8 6l10 10"/></svg>' },
  { accent: '#ea580c', tint: '#fdeadd', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M12 9v5M9.5 11.5h5"/></svg>' },
];
const blocks = b.blockItemsHtml.map((raw, i) => ({
  ...splitLead(t9(raw)),
  label: ui.blockTitles[i] ?? '',
  ...BLOCK_STYLE[i % BLOCK_STYLE.length],
}));

// Caps & penalties cards (3): out-of-pocket max, late-enrollment penalty, HD Plan G.
const CAP_STYLE = [
  { accent: '#16a34a', tint: '#e4f5ea', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { accent: '#dc2626', tint: '#fdeaea', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5 21 19H3z"/><path d="M12 10v4M12 17h.01"/></svg>' },
  { accent: '#2563eb', tint: '#e5edfe', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 12.4 12.4 4.2a1.5 1.5 0 0 0-1-.4H5.3A1.3 1.3 0 0 0 4 5v6.1c0 .4.2.8.4 1l8.2 8.2a1.4 1.4 0 0 0 2 0l6-6a1.4 1.4 0 0 0 0-1.9z"/><circle cx="8.2" cy="8.2" r="1.3" fill="currentColor" stroke="none"/></svg>' },
];
const caps = b.capItemsHtml.map((raw, i) => ({ ...splitLead(t9(raw)), ...CAP_STYLE[i % CAP_STYLE.length] }));

// Hero value-prop icons.
const HERO_ICONS = [
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 5-9 5-9-5 9-5z"/><path d="M3.5 12 12 17l8.5-5"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="16" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/></svg>',
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M14.5 9.2a2.8 2.8 0 0 0-5.2 1.3c0 2.6 4.9 1.6 4.9 4.1a2.8 2.8 0 0 1-5.2 1.3"/><path d="M12 6.5v1.5M12 16v1.5"/></svg>',
];

// Icons for the estimate, income-split, and local strips.
const ICON_CALC = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M8 7h8"/><path d="M8 11h.01M12 11h.01M16 11h.01M8 15h.01M12 15h.01M16 15v3"/></svg>';
const ICON_UP = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M15 7h6v6"/></svg>';
const ICON_DOWN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l6 6 4-4 8 8"/><path d="M15 17h6v-6"/></svg>';
const ICON_PIN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>';
const ICON_ARROW = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';

// Jump-to-section list for the trio panel.
const JUMPS = [
  { label: t9(b.h2Blocks), href: '#cst-blocks', ...BLOCK_STYLE[0] },
  { label: t9(b.h2Estimate), href: '#cst-estimate', accent: '#0d9488', tint: '#d7f0ec', icon: ICON_CALC },
  { label: t9(ui.incomeHeading), href: '#cst-income', accent: '#ea580c', tint: '#fdeadd', icon: ICON_UP },
  { label: t9(b.h2Caps), href: '#cst-caps', ...CAP_STYLE[0] },
  { label: t9(b.h2Local), href: '#cst-local', accent: '#db2777', tint: '#fce7f1', icon: ICON_PIN },
];

// Trust bar.
const TRUST_STYLE = [
  { color: '#16a34a', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { color: '#7c3aed', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { color: '#ea580c', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8 13l3 3 5-5 4 4"/><path d="M2 9l4-4 4 3 4-3 4 4"/></svg>' },
  { color: '#2563eb', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];
const trust = ui.trust.map((t, i) => ({ ...t, ...TRUST_STYLE[i % TRUST_STYLE.length] }));
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="cst-hero">
    <div class="cst-hero__copy">
      <h1 class="cst-hero__title" set:html={heroTitleHtml} />
      <p class="cst-hero__lede">{t9(ui.heroLede)}</p>

      <ul class="cst-hero__points">
        {ui.heroPoints.map((p, i) => (
          <li>
            <span class="cst-hero__pt-icon" aria-hidden="true" set:html={HERO_ICONS[i % HERO_ICONS.length]} />
            <span><strong>{t9(p.title)}</strong><em>{t9(p.sub)}</em></span>
          </li>
        ))}
      </ul>
    </div>

    <div class="cst-hero__art">
      <img
        class="cst-hero__img"
        src="/pictures/help-you-deserve.webp"
        alt="A person reviews what Medicare costs on a tablet at home."
        width="1536"
        height="1024"
        loading="eager"
        decoding="async"
      />
      <div class="cst-hero__callout">
        <span class="cst-hero__callout-icon" aria-hidden="true" set:html={ICON_CALC} />
        <p set:html={fill(ui.heroCallout)} />
      </div>
    </div>
  </section>

  {/* ─── Building blocks card grid ────────────────────────────────────── */}
  <section class="cst-section" id="cst-blocks" aria-labelledby="cst-blocks-h">
    <h2 id="cst-blocks-h" class="cst-h2 cst-h2--center">{t9(b.h2Blocks)}</h2>
    <p class="cst-sub cst-sub--center">{t9(ui.blocksSub)}</p>
    <div class="cst-blocks__grid">
      {blocks.map((blk) => (
        <article class="cst-card" style={`--accent:${blk.accent};--tint:${blk.tint}`}>
          <div class="cst-card__head">
            <span class="cst-card__icon" aria-hidden="true" set:html={blk.icon} />
            <span class="cst-card__eyebrow">{blk.label}</span>
          </div>
          <h3 class="cst-card__title" set:html={blk.title} />
          <p class="cst-card__body" set:html={blk.body} />
        </article>
      ))}
    </div>
  </section>

  {/* ─── Cost Estimator feature strip ─────────────────────────────────── */}
  <section class="cst-estimate" id="cst-estimate">
    <span class="cst-estimate__icon" aria-hidden="true" set:html={ICON_CALC} />
    <div class="cst-estimate__msg">
      <h2 class="cst-estimate__title">{t9(b.h2Estimate)}</h2>
      <p set:html={t9(b.estimateHtml)} />
    </div>
    <a class="cst-estimate__cta" href="medicare-cost-estimator.html">
      {t9(ui.estimateCta)}
      <span aria-hidden="true" set:html={ICON_ARROW} />
    </a>
  </section>

  {/* ─── Higher income vs lower income ────────────────────────────────── */}
  <section class="cst-income" id="cst-income" aria-labelledby="cst-income-h">
    <h2 id="cst-income-h" class="cst-h2 cst-h2--center">{t9(ui.incomeHeading)}</h2>
    <div class="cst-income__grid">
      <article class="cst-income__panel cst-income__panel--up">
        <div class="cst-income__head">
          <span class="cst-income__icon" aria-hidden="true" set:html={ICON_UP} />
          <span class="cst-income__tag">{t9(ui.irmaaTag)}</span>
        </div>
        <h3 class="cst-income__title">{t9(b.h2Irmaa)}</h3>
        <p class="cst-income__body" set:html={t9(b.irmaaHtml)} />
      </article>
      <article class="cst-income__panel cst-income__panel--down">
        <div class="cst-income__head">
          <span class="cst-income__icon" aria-hidden="true" set:html={ICON_DOWN} />
          <span class="cst-income__tag">{t9(ui.assistanceTag)}</span>
        </div>
        <h3 class="cst-income__title">{t9(b.h2Assistance)}</h3>
        <p class="cst-income__body" set:html={t9(b.assistanceHtml)} />
      </article>
    </div>
  </section>

  {/* ─── Caps & penalties cards ───────────────────────────────────────── */}
  <section class="cst-section" id="cst-caps" aria-labelledby="cst-caps-h">
    <h2 id="cst-caps-h" class="cst-h2 cst-h2--center">{t9(b.h2Caps)}</h2>
    <p class="cst-sub cst-sub--center">{t9(ui.capsSub)}</p>
    <div class="cst-caps__grid">
      {caps.map((cap) => (
        <article class="cst-card cst-card--cap" style={`--accent:${cap.accent};--tint:${cap.tint}`}>
          <span class="cst-card__icon" aria-hidden="true" set:html={cap.icon} />
          <h3 class="cst-card__title" set:html={cap.title} />
          <p class="cst-card__body" set:html={cap.body} />
        </article>
      ))}
    </div>
  </section>

  {/* ─── Local costs strip ────────────────────────────────────────────── */}
  <section class="cst-local" id="cst-local">
    <span class="cst-local__icon" aria-hidden="true" set:html={ICON_PIN} />
    <div class="cst-local__msg">
      <h2 class="cst-local__title">{t9(b.h2Local)}</h2>
      <p set:html={t9(b.localHtml)} />
    </div>
    <a class="cst-local__cta" href="medicare-cost-uintah-county.html">
      {t9(ui.localCta)}
      <span aria-hidden="true" set:html={ICON_ARROW} />
    </a>
  </section>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="cst-cta">
    <img class="cst-cta__photo" src="/pictures/rocco.webp" alt={`${agentName}, licensed Medicare agent in Vernal, Utah`} width="88" height="88" loading="lazy" decoding="async" />
    <div class="cst-cta__msg">
      <h2 class="cst-cta__title" set:html={t9(ui.ctaTitle)} />
      <p set:html={t9(b.outroHtml)} />
    </div>
    <div class="cst-cta__actions">
      <a class="cst-cta__phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="cst-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>{BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="cst-cta__quote" href="medicare-quote-vernal.html">
        <span class="cst-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        {t9(ui.ctaButtonQuote)}
      </a>
    </div>
  </section>

  {/* ─── FAQ · Jump-to · Agent trio ───────────────────────────────────── */}
  <div class="cst-trio">
    <section class="cst-panel">
      <h2 class="cst-panel__h">{t('faq.heading', lang)}</h2>
      {FAQS.map((q) => (
        <details class="cst-faq">
          <summary>{q.question}</summary>
          <p set:html={q.answer} />
        </details>
      ))}
      <p class="cst-panel__src"><strong>{t('sources.heading', lang)}:</strong> <a href={c.page.sources[0]?.url} target="_blank" rel="noopener noreferrer">{c.page.sources[0]?.title} — {c.page.sources[0]?.publisher}</a></p>
    </section>

    <section class="cst-panel">
      <h2 class="cst-panel__h">{t9(ui.centersHeading)}</h2>
      <ul class="cst-centers">
        {JUMPS.map((j) => (
          <li style={`--accent:${j.accent};--tint:${j.tint}`}>
            <span class="cst-centers__icon" aria-hidden="true" set:html={j.icon} />
            <a href={j.href}>{j.label}</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="cst-panel cst-panel--agent">
      <img class="cst-agent__photo" src="/pictures/rocco.webp" alt={`${agentName}, licensed Medicare agent`} width="96" height="96" loading="lazy" decoding="async" />
      <h2 class="cst-panel__h">{t9(ui.agentHeading)}</h2>
      <p class="cst-agent__blurb">{fill(ui.agentBlurb)}</p>
      <a class="cst-agent__cta" href={`tel:${BUSINESS.phoneTel}`}>{fill(ui.agentCta)}</a>
      <span class="cst-agent__sig">— {agentName}</span>
    </section>
  </div>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="cst-trust">
    {trust.map((t) => (
      <div class="cst-trust__item">
        <span class="cst-trust__icon" style={`--c:${t.color}`} aria-hidden="true" set:html={t.icon} />
        <span class="cst-trust__text"><strong>{t9(t.title)}</strong><em>{t9(t.sub)}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the coverage hub: navy #0b2c45, blue #2563eb, with
     per-block accents (blue/teal/purple/orange) and semantic accents for the
     income split (amber up / green down) and caps. */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
