---
// src/components/content/BestPartDPlansPage.astro — Part D pillar-adjacent
// template (M4; playbook §4.5). Rendered by BOTH /best-part-d-plans-vernal.html
// and its /es/ sibling; copy from src/i18n/content/{locale}/best-part-d-plans-vernal.json.
import ArticlePage from '../layout/ArticlePage.astro';
import { getPageContent, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta } from '../../i18n/locales';
import type { PageContext } from '../../types/Page';

const SLUG = 'best-part-d-plans-vernal';

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
  };
  breadcrumb: { home: string; self: string };
  body: Record<string, string | string[]> & { relatedItemsHtml: string[] };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

const context: PageContext = {
  page: {
    title: c.page.title,
    heading: c.page.heading,
    description: c.page.description,
    taxonomy: {
      silo: 'part-d',
      tags: ['part-d', 'best-plans', 'drugs', 'vernal', 'uintah-county', 'local'],
    },
    summary: c.page.summary,
    faqs: c.page.faqs,
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'article',
    gaIds: ['G-NW6ENB89NF', 'G-FTDW9B2G6Q'],
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-07-01',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};
---

<ArticlePage context={context}>
  <div style="background:#f0f9ff; border-left:5px solid #0b6ea3; border-radius:8px; padding:1.25rem; margin:1.5rem 0;" set:html={b.needHtml} />

  <p set:html={b.introHtml} />

  <h2>{b.h2How}</h2>
  <p set:html={b.howHtml} />

  <h2>{b.h2Key}</h2>
  <p set:html={b.keyHtml} />

  <h2>{b.h2Costs}</h2>
  <p set:html={b.costsHtml} />

  <h2>{b.h2Common}</h2>
  <p set:html={b.commonHtml} />

  <h2>{b.h2When}</h2>
  <p set:html={b.whenHtml} />

  <section style="background:#f8fbff; border:1px solid #d9e7f5; border-radius:10px; padding:1.5rem; margin:2rem 0;">
  <h2 style="margin-top:0; color:#0b2c45;">{b.relatedHeading}</h2>

  <ul style="line-height:2; padding-left:1.2rem;">
    {b.relatedItemsHtml.map((item) => <li set:html={item} />)}
  </ul>
</section>

  <p set:html={b.sourceHtml} />

  <p style="text-align:center;margin-top:2rem;">
    <a href="https://www.sunfirematrix.com/app/consumer/medicareadvocates/10569110/" class="enroll-btn" target="_blank" rel="noopener noreferrer" set:html={b.enrollLabel} />
  </p>
  <p style="text-align:center;margin-top:1rem;" set:html={b.callHtml} />
</ArticlePage>
