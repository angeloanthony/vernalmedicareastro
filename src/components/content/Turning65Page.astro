---
// src/components/content/Turning65Page.astro — THE Turning-65 template
// (playbook §4.5: one shared component per page). Rendered by BOTH the master
// route (/turning-65.html) and the localized dynamic route (/es/turning-65.html);
// the locale is derived from the URL and every human-facing string comes from
// src/i18n/content/{locale}/turning-65.json with master fallback.
//
// M45 redesign: the old single-column "wall of text" became a Decision-Center-
// style layout — a two-column hero (copy + At-a-Glance card), a 60-second box,
// a two-column card TIMELINE (was a plain <ol>), a resources trio (Everything /
// Local / FAQ), a Helpful-Links row, and a closing agent CTA. Presentation only:
// all copy still comes from the content JSON; the ordered STEPS remain the
// shared data module (TURNING_65_STEPS), decorated here with a per-id icon map.
import ArticlePage from '../layout/ArticlePage.astro';
import { TURNING_65_STEPS } from '../../data/turning65';
import { BUSINESS } from '../../data/business';
import { authorById } from '../../data/authors';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta, t } from '../../i18n/locales';
import type { PageContext } from '../../types/Page';

interface HelpfulLink { label: string; href: string; external?: boolean }
interface Turning65Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; self: string };
  hero: { lede: string; badges: string[]; glanceHeading: string; glance: string[] };
  helpfulLinks: { heading: string; items: HelpfulLink[] };
  personCta: { title: string; blurb: string; callLabel: string; quoteLabel: string };
  body: {
    introHtml: string;
    sixtySecondHtml: string;
    timelineHeading: string;
    nextLabel: string;
    everythingHeading: string;
    everythingItemsHtml: string[];
    localHeading: string;
    localHelpHtml: string;
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Turning65Content>('turning-65', lang);
const vars = { phone: BUSINESS.phone, tty: BUSINESS.tty, stepCount: TURNING_65_STEPS.length };
const t9 = (s: string) => interp(s, vars);

const pagePath = lang === 'en' ? '/turning-65.html' : `/${lang}/turning-65.html`;

// Agent (closing CTA photo + caption).
const agent = authorById('rocco');
const quoteHref = localizeHref('/medicare-quote-vernal.html', lang);

// Per-step colour + glyph, keyed by the shared data-module id so TURNING_65_STEPS
// stays presentation-free. Colours/icons echo the journey's arc: enrollment (blue),
// the fork in the road (slate), the two paths (Medigap red / Advantage green),
// drugs (pink), numbers (blue), milestones (pink), upkeep (blue).
const STEP_STYLE: Record<string, { icon: string; color: string; tint: string }> = {
  'window-opens':      { icon: '📅', color: '#2563eb', tint: '#e6effe' },
  'employer-coverage': { icon: '🛡️', color: '#2563eb', tint: '#e6effe' },
  'sign-up-a-b':       { icon: '🪪', color: '#2563eb', tint: '#e6effe' },
  'choose-path':       { icon: '🚦', color: '#64748b', tint: '#eef2f6' },
  'medigap':           { icon: '❤️', color: '#dc2626', tint: '#fdeaea' },
  'advantage':         { icon: '⚖️', color: '#16a34a', tint: '#e6f6ec' },
  'part-d':            { icon: '💊', color: '#db2777', tint: '#fce7f1' },
  'costs':             { icon: '🧮', color: '#2563eb', tint: '#e6effe' },
  'coverage-begins':   { icon: '🎁', color: '#db2777', tint: '#fce7f1' },
  'annual-review':     { icon: '📋', color: '#2563eb', tint: '#e6effe' },
};
const FALLBACK_STEP = { icon: '➜', color: '#0b2c45', tint: '#eef3f8' };

// Hero trust badges — filled-circle icon tiles (matches hero.badges order):
// calendar · shield-check · piggy-bank · person, echoing the reference mockup.
const BADGE_STYLE = [
  {
    color: '#16a34a',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="4.5" width="17" height="16" rx="2.5"/><path d="M3.5 9h17M8 3v3M16 3v3"/></svg>',
  },
  {
    color: '#2563eb',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 11.5l2 2 4-4"/></svg>',
  },
  {
    color: '#7c3aed',
    svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.5 9.2c-.2-.6-.5-1.1-.9-1.6l.6-2.1-1.9.5a6.6 6.6 0 0 0-2.2-.4h-2c-2.8 0-5.2 1.9-5.8 4.5l-1.4.5c-.3.1-.5.4-.5.7v2c0 .4.3.7.7.7h1.2c.4.7 1 1.4 1.7 1.9V19c0 .4.3.7.7.7H10c.4 0 .7-.3.7-.7v-.8h2.6v.8c0 .4.3.7.7.7h1.6c.4 0 .7-.3.7-.7v-1.9c1.2-1 1.9-2.4 1.9-4 0-.6-.1-1.2-.3-1.7l.6-.2a.7.7 0 0 0 .5-.7v-.8a.7.7 0 0 0-.5-.7zM14 10a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>',
  },
  {
    color: '#ea580c',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.6"/><path d="M5 20c0-3.6 3.1-6.4 7-6.4s7 2.8 7 6.4"/></svg>',
  },
];

// Helpful-links row — one glyph per position.
const LINK_ICONS = ['🌐', '📅', '📋', '📍', '🛡️'];

const context: PageContext = {
  page: {
    title: c.page.title,
    heading: c.page.heading,
    description: c.page.description,
    taxonomy: { silo: 'enrollment', tags: ['turning-65', 'enrollment', 'iep', 'journey', 'deadlines'], pillar: true },
    summary: interp(c.page.summary, vars),
    faqs: c.page.faqs,
    sources: c.page.sources,
    nextSteps: c.page.nextSteps.map((s) => ({ when: s.when, action: interp(s.action, vars) })),
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'article',
    ogTitle: c.meta.ogTitle,
    ogDescription: c.meta.ogDescription,
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates('turning-65'),
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};
---

<ArticlePage context={context} bareHeader bareFooter>
  <!-- Hero: message + badges + 60-second box on the left; the birthday cake
       (with animated candle flames) and an overlapping At-a-Glance card right. -->
  <section class="t65-hero">
    <div class="t65-hero__copy">
      <h1 class="t65-hero__title">{c.page.heading}</h1>
      <p class="t65-hero__lede">{t9(c.hero.lede)}</p>

      <ul class="t65-badges">
        {c.hero.badges.map((label, i) => {
          const s = BADGE_STYLE[i] ?? { color: '#0b2c45', svg: '' };
          return (
            <li>
              <span class="t65-badges__icon" style={`--accent:${s.color}`} aria-hidden="true" set:html={s.svg} />
              <span class="t65-badges__label">{label}</span>
            </li>
          );
        })}
      </ul>

      <div class="t65-sixty">
        <span class="t65-sixty__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg>
        </span>
        <div class="t65-sixty__text" set:html={t9(c.body.sixtySecondHtml)} />
      </div>
    </div>

    <div class="t65-hero__art">
      <div class="t65-cake">
        <img
          class="t65-cake__img"
          src="/pictures/turning65-cake.webp"
          alt="A white birthday cake with lit number 6 and 5 candles."
          width="409"
          height="320"
          loading="eager"
          decoding="async"
        />
        <span class="t65-flame t65-flame--l" aria-hidden="true"><i></i></span>
        <span class="t65-flame t65-flame--r" aria-hidden="true"><i></i></span>
      </div>

      <aside class="t65-glance" aria-label={c.hero.glanceHeading}>
        <div class="t65-glance__head">
          <h2>{c.hero.glanceHeading}</h2>
          <span class="t65-glance__compass" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5 5-2z"/></svg>
          </span>
        </div>
        <ul class="t65-glance__list">
          {c.hero.glance.map((g) => (
            <li><span class="t65-glance__tick" aria-hidden="true">✓</span>{t9(g)}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>

  <!-- Step-by-step card timeline (was a plain <ol> wall of text) -->
  <div class="t65-tl-head">
    <h2>{c.body.timelineHeading}</h2>
    <p set:html={t9(c.body.introHtml)} />
  </div>

  <!-- 7-month enrollment-window infographic (visual summary of the timeline) -->
  <figure class="t65-window">
    <img
      class="t65-window__img"
      src="/pictures/7monthwindow.webp"
      alt="Your 7-month Medicare enrollment window: the 3 months before your birthday month (explore options, compare plans, prepare to enroll), your birthday month, and the 3 months after (finalize enrollment, coverage begins, last month to enroll)."
      width="905"
      height="440"
      loading="lazy"
      decoding="async"
    />
  </figure>

  <ol class="t65-grid">
    {TURNING_65_STEPS.map((s, i) => {
      const st = STEP_STYLE[s.id] ?? FALLBACK_STEP;
      return (
        <li id={s.id} class="t65-card" style={`--accent:${st.color};--tint:${st.tint}`}>
          <div class="t65-card__top">
            <span class="t65-card__num" aria-hidden="true">{i + 1}</span>
            <span class="t65-card__icon" aria-hidden="true">{st.icon}</span>
          </div>
          <p class="t65-card__when">{s.when}</p>
          <h3 class="t65-card__title">{s.title}</h3>
          <p class="t65-card__task">{s.task}</p>
          {(s.relatedHref || s.calculatorHref) && (
            <p class="t65-card__links">
              {s.relatedHref && <a href={localizeHref(s.relatedHref, lang)}>{s.relatedLabel} →</a>}
              {s.calculatorHref && <Fragment> · <a href={localizeHref(s.calculatorHref, lang)}>{s.calculatorLabel}</a></Fragment>}
            </p>
          )}
        </li>
      );
    })}
  </ol>

  <!-- Resources trio: Everything · Local help · FAQ -->
  <div class="t65-resources">
    <section class="t65-rcard t65-rcard--everything">
      <header class="t65-rcard__head">
        <span class="t65-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        </span>
        <h2>{c.body.everythingHeading}</h2>
      </header>
      <ul class="t65-rlist">
        {c.body.everythingItemsHtml.map((item) => (
          <li><span class="t65-rlist__tick" aria-hidden="true">✓</span><span set:html={t9(item)} /></li>
        ))}
      </ul>
    </section>

    <section class="t65-rcard t65-rcard--local">
      <header class="t65-rcard__head">
        <span class="t65-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.5"/><path d="M15.5 14.2c2.6.3 4.5 2.5 4.5 5.3"/></svg>
        </span>
        <h2>{c.body.localHeading}</h2>
      </header>
      <p class="t65-rcard__lead" set:html={t9(c.body.localHelpHtml)} />
      <a class="t65-rcard__phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span aria-hidden="true">📞</span> {c.personCta.callLabel.replace('{phone}', BUSINESS.phone)}
        <small>TTY: {BUSINESS.tty}</small>
      </a>
    </section>

    <section class="t65-rcard t65-rcard--faq">
      <header class="t65-rcard__head">
        <span class="t65-rcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.9.4-1.5 1-1.5 2"/><circle cx="11.5" cy="16.5" r="0.6" fill="currentColor" stroke="none"/></svg>
        </span>
        <h2>{t('faq.heading', lang)}</h2>
      </header>
      <div class="t65-rcard__body">
        {c.page.faqs.map((f) => (
          <details class="t65-faq">
            <summary set:html={f.question} />
            <p set:html={f.answer} />
          </details>
        ))}
      </div>
      <a class="t65-rcard__more" href={localizeHref('/faq.html', lang)}>{t('faq.viewAll', lang)} →</a>
    </section>
  </div>

  <!-- Helpful links & tools -->
  <section class="t65-links">
    <h2>{c.helpfulLinks.heading}</h2>
    <ul>
      {c.helpfulLinks.items.map((l, i) => (
        <li>
          <a
            href={l.external ? l.href : localizeHref(l.href, lang)}
            {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class="t65-links__icon" aria-hidden="true">{LINK_ICONS[i] ?? '›'}</span>
            <span>{l.label}{l.external && <span class="t65-links__ext" aria-hidden="true"> ↗</span>}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Closing CTA: talk to a local agent -->
  <section class="t65-cta">
    <figure class="t65-cta__agent">
      <img
        src="/pictures/rocco.webp"
        alt={`${agent?.name ?? BUSINESS.legalAgent}, licensed Medicare agent in Vernal, Utah`}
        width="96"
        height="96"
        loading="lazy"
        decoding="async"
      />
    </figure>
    <div class="t65-cta__copy">
      <h2>{c.personCta.title}</h2>
      <p>{t9(c.personCta.blurb)}</p>
    </div>
    <div class="t65-cta__actions">
      <a class="t65-cta__call" href={`tel:${BUSINESS.phoneTel}`}>
        <span aria-hidden="true">📞</span> {c.personCta.callLabel.replace('{phone}', BUSINESS.phone)}
      </a>
      <a class="t65-cta__quote" href={quoteHref}>{c.personCta.quoteLabel}</a>
    </div>
  </section>
</ArticlePage>

<style>
  /* ---- Hero -------------------------------------------------------------- */
  .t65-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.5rem 0 2.5rem;
  }
  .t65-hero__copy { min-width: 0; }
  .t65-hero__title {
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.08;
    color: #0b2c45;
    margin: 0 0 0.75rem;
  }
  .t65-hero__lede { font-size: 1.05rem; color: #475569; line-height: 1.55; margin: 0 0 1.6rem; max-width: 46ch; }

  /* Badge tiles — icon-on-top, centred label */
  .t65-badges {
    list-style: none; padding: 0; margin: 0 0 1.6rem;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.85rem;
  }
  .t65-badges li {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.6rem;
    background: #fff;
    border: 1px solid #e8eef5;
    border-radius: 14px;
    padding: 1.1rem 0.5rem 0.9rem;
    box-shadow: 0 10px 22px rgba(11, 44, 69, 0.08);
  }
  .t65-badges__icon {
    flex: none; width: 52px; height: 52px; border-radius: 50%;
    display: grid; place-items: center; color: #fff; background: var(--accent);
    box-shadow: 0 6px 14px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .t65-badges__icon :global(svg) { width: 26px; height: 26px; }
  .t65-badges__label { font-weight: 700; color: #0b2c45; font-size: 0.82rem; line-height: 1.25; }

  /* 60-second box */
  .t65-sixty {
    display: flex; align-items: flex-start; gap: 1rem;
    background: #0b2c45; color: #fff;
    padding: 1.3rem 1.5rem;
    border-radius: 16px;
    line-height: 1.55;
    box-shadow: 0 16px 34px rgba(11, 44, 69, 0.18);
  }
  .t65-sixty__icon {
    flex: none; width: 44px; height: 44px; border-radius: 50%;
    display: grid; place-items: center; background: #fff; color: #0b2c45;
  }
  .t65-sixty__icon :global(svg) { width: 22px; height: 22px; }
  .t65-sixty__text { font-size: 0.95rem; }
  .t65-sixty__text :global(strong):first-child { display: block; font-size: 1.05rem; margin-bottom: 0.35rem; }
  .t65-sixty :global(a) { color: #9fd0ff; }

  /* ---- Cake + candle flames ---------------------------------------------- */
  .t65-hero__art { position: relative; }
  .t65-cake { position: relative; line-height: 0; }
  .t65-cake__img {
    width: 100%; height: auto; display: block;
    border-radius: 18px;
    box-shadow: 0 18px 44px rgba(11, 44, 69, 0.20);
  }
  /* Two animated flames, sitting over the printed candle wicks. */
  .t65-flame {
    position: absolute;
    width: 2.6%; aspect-ratio: 3 / 5;
    transform-origin: 50% 100%;
    z-index: 2;
    filter: drop-shadow(0 0 10px rgba(255, 160, 40, 0.85));
    animation: t65-sway 1.6s ease-in-out infinite alternate;
  }
  /* outer + inner flame bodies */
  .t65-flame::before,
  .t65-flame > i {
    content: ""; position: absolute; inset: 0;
    border-radius: 50% 50% 50% 50% / 38% 38% 100% 100%;
    transform-origin: 50% 100%;
  }
  .t65-flame::before {
    background: radial-gradient(ellipse at 50% 78%, #ffd24d 0%, #ff9d17 52%, #ff6a00 100%);
    animation: t65-flick 0.42s ease-in-out infinite alternate;
  }
  .t65-flame > i {
    inset: 22% 24% 8% 24%;
    background: radial-gradient(ellipse at 50% 80%, #fff7d6 0%, #ffe58a 55%, #ffb733 100%);
    animation: t65-flick 0.36s ease-in-out infinite alternate-reverse;
  }
  .t65-flame--l { left: 41.3%; top: 8.5%; }
  .t65-flame--r { left: 60.2%; top: 6.5%; }
  .t65-flame--r { animation-delay: 0.2s; }
  .t65-flame--r::before { animation-delay: 0.15s; }
  @keyframes t65-flick {
    0%   { transform: scaleY(1) scaleX(1); }
    100% { transform: scaleY(1.16) scaleX(0.9); }
  }
  @keyframes t65-sway {
    0%   { transform: rotate(-4deg); }
    100% { transform: rotate(4deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .t65-flame, .t65-flame::before, .t65-flame > i { animation: none; }
  }

  /* At-a-Glance card — overlaps the bottom of the cake */
  .t65-glance {
    position: relative; z-index: 3;
    margin: -2.5rem 0 0 auto;
    width: 92%;
    background: #fff;
    border: 1px solid #e4ecf5;
    border-radius: 18px;
    padding: 1.4rem 1.5rem;
    box-shadow: 0 18px 40px rgba(11, 44, 69, 0.16);
  }
  .t65-glance__head { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.9rem; border-bottom: 2px solid #eef3f9; padding-bottom: 0.6rem; }
  .t65-glance__head h2 { margin: 0; font-size: 1.15rem; color: #1f4e8c; }
  .t65-glance__compass { flex: none; color: #1f4e8c; }
  .t65-glance__compass svg { width: 38px; height: 38px; }
  .t65-glance__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .t65-glance__list li { display: flex; align-items: flex-start; gap: 0.6rem; color: #334155; font-size: 0.92rem; line-height: 1.4; }
  .t65-glance__tick {
    flex: none; width: 20px; height: 20px; border-radius: 50%;
    background: #16a34a; color: #fff; display: grid; place-items: center;
    font-size: 0.66rem; font-weight: 800; margin-top: 0.1rem;
  }

  @media (max-width: 860px) {
    .t65-hero { grid-template-columns: 1fr; padding: 1.75rem 1.4rem; gap: 1.75rem; }
    .t65-hero__lede { max-width: none; }
    .t65-cake__img { max-width: 460px; margin: 0 auto; }
    .t65-glance { width: 100%; margin-top: -2rem; }
  }
  @media (max-width: 480px) {
    .t65-badges { grid-template-columns: repeat(2, 1fr); }
  }

  /* ---- Timeline heading -------------------------------------------------- */
  .t65-tl-head { text-align: center; margin: 0 0 1.5rem; }
  .t65-tl-head h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
