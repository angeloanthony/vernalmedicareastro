---
// src/components/content/HomePage.astro — THE homepage template (homepage
// milestone; playbook §4.5). Rendered by "/" and "/es.html". Every
// human-facing string comes from src/i18n/content/{locale}/index.json; the
// hand-rolled JSON-LD keeps its exact structure with human-facing fields
// swapped per locale (NAP/geo/hours stay data). Carousel scripts are
// preserved verbatim except the two runtime aria templates, which get their
// strings injected via define:vars (playbook residual #1: lang into scripts).
// NOTE: contactPoint.availableLanguage stays ["en"] — the phone line is
// English; only the site is bilingual. NewsTicker (data/news.ts) is a shared
// data module — English on /es until Phase B.
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsTicker from '../NewsTicker.astro';
import { getPageContent, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta } from '../../i18n/locales';
import { BUSINESS } from '../../data/business';

interface Content {
  meta: {
    title: string;
    description: string;
    ogTitle: string;
    ogDescription: string;
    twitterTitle: string;
    twitterDescription: string;
  };
  schema: {
    businessDescription: string;
    catalogName: string;
    offers: { name: string; description: string }[];
    navNames: string[];
    faqs: { q: string; a: string }[];
    videoName: string;
    videoDescription: string;
    breadcrumbHome: string;
  };
  hero: { imgAlt: string; h1: string; tagline: string; enrollLabel: string; startLabel: string };
  welcome: { h2: string; h3: string; videoTitle: string; comicAlt: string };
  paths: { aria: string; h2: string; introHtml: string; items: { label: string; href: string }[] };
  reviews: {
    aria: string; reviewFrom: string; starsAria: string; verified: string;
    prevAria: string; nextAria: string; dotsAria: string; goToAria: string;
    items: { name: string; initial: string; text: string }[];
  };
  nap: {
    aria: string; h2: string; findHtml: string; contactHtml: string;
    callLabel: string; directionsLabel: string; faqLabel: string;
    points: string[]; mapAria: string; figcaptionHtml: string;
  };
  localInternalHtml: string;
  help: {
    h2: string; intro: string; h3: string;
    items: { icon: string; html: string }[];
    quoteLabel: string; carriersAlt: string;
  };
  smile: { aria: string; title: string; prevAria: string; nextAria: string; slides: { img: string; alt: string }[] };
  spirit: { aria: string; prevAria: string; nextAria: string; dotsAria: string; goToAria: string; quotes: { text: string; by: string }[] };
  faq: { aria: string; h2: string; items: { q: string; a: string }[] };
  compliance: { heading: string; p1Html: string; p2Html: string; p3Html: string; p4Html: string };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>('index', lang);
const canonical = lang === 'en' ? `${SITE_ORIGIN}/` : `${SITE_ORIGIN}/${lang}.html`;

