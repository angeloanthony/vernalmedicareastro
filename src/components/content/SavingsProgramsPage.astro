---
// src/components/content/SavingsProgramsPage.astro — Medicare Savings Programs
// template (M4 batch 3; playbook §4.5). The programs table pairs translated
// rows (program/name/pays in JSON) with income limits from annualMedicareData
// by key — copy translates, figures stay single-sourced.
import ArticlePage from '../layout/ArticlePage.astro';
import { figuresFor } from '../../data/annualMedicareData';
import { usd } from '../../lib/formatters';
import { getPageContent, interp, hreflangAlternates, localizeHref, SITE_ORIGIN } from '../../i18n/content';
import { getLangFromUrl, getLocaleMeta } from '../../i18n/locales';
import type { PageContext } from '../../types/Page';

const SLUG = 'medicare-savings-programs-utah';
const f = figuresFor();
const msp = f.medicareSavingsPrograms;
const LIMITS: Record<string, { individual: number; couple: number }> = {
  qmb: msp.qmb,
  slmb: msp.slmb,
  qi: msp.qi,
};
const vars = {
  year: f.year,
  partBPremium: usd(f.partB.premium, { cents: true }),
  qmbIndividual: usd(msp.qmb.individual),
  slmbIndividual: usd(msp.slmb.individual),
  qiIndividual: usd(msp.qi.individual),
  resIndividual: usd(msp.resources.individual),
  resCouple: usd(msp.resources.couple),
};
const t9 = (s: string) => interp(s, vars);

interface Content {
  page: {
    title: string;
    heading: string;
    description: string;
    summary: string;
    faqs: { question: string; answer: string }[];
    sources: { title: string; url: string; publisher: string }[];
    nextSteps: { when: string; action: string }[];
  };
  meta: { ogTitle: string; ogDescription: string };
  breadcrumb: { home: string; parent: string; self: string };
  body: {
    introHtml: string;
    h2Three: string;
    tableHeadProgram: string;
    tableHeadPays: string;
    tableHeadSingle: string;
    tableHeadMarried: string;
    programs: { key: string; program: string; name: string; pays: string }[];
    resourceNoteHtml: string;
    h2Worth: string;
    worthHtml: string;
    outroHtml: string;
  };
}

const lang = getLangFromUrl(Astro.url);
const c = getPageContent<Content>(SLUG, lang);
const b = c.body;
const pagePath = lang === 'en' ? `/${SLUG}.html` : `/${lang}/${SLUG}.html`;

const context: PageContext = {
  page: {
    title: t9(c.page.title),
    heading: c.page.heading,
    description: t9(c.page.description),
    taxonomy: { silo: 'dual-eligible', tags: ['msp', 'qmb', 'slmb', 'qi', 'medicaid', 'costs', 'part-b'] },
    summary: t9(c.page.summary),
    faqs: c.page.faqs.map((q) => ({ question: t9(q.question), answer: t9(q.answer) })),
    sources: c.page.sources,
    nextSteps: c.page.nextSteps,
  },
  meta: {
    canonical: `${SITE_ORIGIN}${pagePath}`,
    ogType: 'article',
    ogTitle: c.meta.ogTitle,
    ogDescription: t9(c.meta.ogDescription),
    lang,
    ogLocale: getLocaleMeta(lang).ogLocale,
    hreflang: hreflangAlternates(SLUG),
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  breadcrumb: [
    { name: c.breadcrumb.home, href: localizeHref('/', lang) },
    { name: c.breadcrumb.parent, href: localizeHref('/dual-eligible.html', lang) },
    { name: c.breadcrumb.self, href: pagePath },
  ],
};
---

<ArticlePage context={context}>
  <p set:html={t9(b.introHtml)} />

  <h2>{b.h2Three}</h2>
  <table style="width:100%; border-collapse:collapse; margin:1.5rem 0;">
    <thead>
      <tr style="background:#0b2c45; color:#fff;">
        <th style="padding:12px; text-align:left; border:1px solid #ddd;">{b.tableHeadProgram}</th>
        <th style="padding:12px; text-align:left; border:1px solid #ddd;">{b.tableHeadPays}</th>
        <th style="padding:12px; text-align:left; border:1px solid #ddd;">{b.tableHeadSingle}</th>
        <th style="padding:12px; text-align:left; border:1px solid #ddd;">{b.tableHeadMarried}</th>
      </tr>
    </thead>
    <tbody>
      {b.programs.map((r) => (
        <tr>
          <td style="padding:10px; border:1px solid #ddd;"><strong>{r.program}</strong><br /><span style="font-size:.85rem; color:#555;">{r.name}</span></td>
          <td style="padding:10px; border:1px solid #ddd;">{r.pays}</td>
          <td style="padding:10px; border:1px solid #ddd;">{usd(LIMITS[r.key].individual)}</td>
          <td style="padding:10px; border:1px solid #ddd;">{usd(LIMITS[r.key].couple)}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p style="color:#555; font-size:.95rem;" set:html={t9(b.resourceNoteHtml)} />

  <h2>{b.h2Worth}</h2>
  <p set:html={t9(b.worthHtml)} />

  <p set:html={t9(b.outroHtml)} />
</ArticlePage>
