---
// Disclaimer.astro — optional medical/general disclaimer + the TPMO disclaimer
// (from business.ts, required sitewide).
// i18n (M3): TPMO text via businessDisclaimers() (CMS-published Spanish, never
// machine-translated); default medical text via t(). A custom string prop
// passes through unchanged (page content arrives already localized).
import { getLangFromUrl, t } from '../../i18n/locales';

interface Props {
  medical?: boolean | string;
}
const { medical } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const medicalText =
  typeof medical === 'string'
    ? medical
    : medical
      ? t('disclaimer.medical', lang)
      : undefined;
---

{/* TPMO "Not connected…" statement lives in the shared Footer, so it is not
    repeated in the page body. Only the optional medical disclaimer renders. */}
{medicalText && (
  <footer class="page-disclaimer">
    <p>{medicalText}</p>
  </footer>
)}
