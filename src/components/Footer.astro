---
// src/components/Footer.astro
// Lifted verbatim from the existing site footer. Contact + disclaimer come
// from the single source of truth so they can never drift across pages.
import { BUSINESS } from '../data/business';
const year = new Date().getFullYear();
const { multiPlan, representative } = BUSINESS.marketingDisclaimer;
---

<footer class="footer">
  <div class="container">
    <p>© {year} {BUSINESS.name}. All rights reserved.</p>
    <p>
      Email: <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a> | Phone:
      <a href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phone}</a> (TTY: {BUSINESS.tty})
    </p>
    <p style="font-size:.9rem;opacity:.9">
      {BUSINESS.disclaimer}
    </p>
    <p style="font-size:.9rem;opacity:.9">
      {multiPlan}
    </p>
    <p style="font-size:.9rem;opacity:.9">
      {representative}
    </p>
    <p><a href="/privacy.html">Privacy</a> • <a href="/terms.html">Terms</a></p>
  </div>
  <p class="powered-by">
    Powered by cozelosdata
    <a
      href="https://cozelosdata.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="powered-link"
    >
      <picture>
        <source srcset="/pictures/cozelos.webp" type="image/webp" />
        <img
          src="/pictures/cozelos.webp"
          alt="Cozelos Data"
          class="powered-logo"
          width="120"
          height="24"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </a>
  </p>
  <nav aria-label="Medicare Resources">
    <p>
      <strong>Medicare Help:</strong>
      <a href="/medicare-decision-center.html">Start Here</a> |
      <a href="/medicare-help-center.html">Help Center</a> |
      <a href="/medicare-financial-assistance.html">Help Paying</a> |
      <a href="/medicare-help-vernal.html">Local Help</a> |
      <a href="/medicare-agent-vernal.html">About Rocco</a> |
      <a href="/part-d-help-vernal.html">Part D</a> |
      <a href="/medicare-enrollment-vernal.html">Enrollment</a>
    </p>
  </nav>
</footer>
