---
// src/components/Footer.astro
// Lifted verbatim from the existing site footer. Contact + disclaimer come
// from the single source of truth so they can never drift across pages.
// i18n (M3): chrome strings via t()/localizeLabel; compliance text via
// businessDisclaimers() (CMS-published Spanish, never machine-translated).
// English output is byte-identical to the pre-i18n footer.
import { BUSINESS, businessDisclaimers } from '../data/business';
import { getLangFromUrl, t, localizeLabel } from '../i18n/locales';
import { localizeHref } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const d = businessDisclaimers(lang);
const year = new Date().getFullYear();

// Footer resource links: labels localized, hrefs existence-aware (fall back
// to the English page until a translation exists — never a 404).
const RESOURCES = [
  { href: '/medicare-decision-center.html', label: 'Start Here' },
  { href: '/medicare-help-center.html', label: 'Help Center' },
  { href: '/medicare-financial-assistance.html', label: 'Help Paying' },
  { href: '/medicare-help-vernal.html', label: 'Local Help' },
  { href: '/medicare-agent-vernal.html', label: 'About Rocco' },
  { href: '/part-d-help-vernal.html', label: 'Part D' },
  { href: '/medicare-enrollment-vernal.html', label: 'Enrollment' },
];
---

<footer class="footer">
  <div class="container">
    <p>© {year} {BUSINESS.name}. {t('footer.rights', lang)}</p>
    <p>
      {/* explicit {' '} — Astro drops whitespace after an expression */}
      {t('footer.email', lang)}{' '}<a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a> | {t('footer.phone', lang)}{' '}
      <a href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phone}</a> (TTY: {BUSINESS.tty})
    </p>
    <p><a href={localizeHref('/privacy.html', lang)}>{t('footer.privacy', lang)}</a> • <a href={localizeHref('/terms.html', lang)}>{t('footer.terms', lang)}</a></p>
  </div>
  <p class="powered-by">
    Powered by cozelosdata
    <a
      href="https://cozelosdata.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="powered-link"
    >
      <picture>
        <source srcset="/pictures/cozelos.webp" type="image/webp" />
        <img
          src="/pictures/cozelos.webp"
          alt="Cozelos Data"
          class="powered-logo"
          width="120"
          height="24"
          loading="lazy"
          decoding="async"
        />
      </picture>
    </a>
  </p>
  <nav aria-label={t('footer.resourcesAria', lang)}>
    <p>
      <strong>{t('footer.helpLabel', lang)}</strong>{' '}
      {RESOURCES.map((r, i) => (
        <Fragment>
          {i > 0 && ' | '}
          <a href={localizeHref(r.href, lang)}>{localizeLabel(r.label, lang)}</a>
        </Fragment>
      ))}
    </p>
  </nav>

  {/* Required CMS multi-plan + TPMO disclaimer — boxed at the very bottom */}
  <div class="footer-disclaimer">
    <p>{d.disclaimer}</p>
    <p>{d.multiPlan}</p>
    <p>{d.representative}</p>
  </div>
</footer>

<style>
  .footer-disclaimer {
    max-width: 1100px;
    margin: 1.5rem auto 0;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
  }
  .footer-disclaimer p {
    font-size: 0.8rem;
    opacity: 0.85;
    line-height: 1.5;
    margin: 0 0 0.6rem;
  }
  .footer-disclaimer p:last-child { margin-bottom: 0; }
</style>
