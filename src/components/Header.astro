---
// src/components/Header.astro
// Lifted verbatim from the existing site's top-bar + main-header + nav.
// Phone/email come from the single source of truth (business.ts).
// Active-nav is computed server-side from the current path — no client JS needed
// for the highlight, though the mobile toggle script still ships (see BaseLayout).
import { BUSINESS } from '../data/business';
import { PRIMARY_NAV, type NavLink } from '../config/navigation';

// Current path for active-nav highlighting. With build format 'file',
// pathname is like "/faq.html" or "/" for home.
const path = Astro.url.pathname;
const normalize = (href: string) =>
  href === 'index.html' || href === '/' ? '/' : '/' + href.replace(/^\//, '');
const here = path === '/' || path === '/index.html' ? '/' : path;
const isActive = (href?: string) => !!href && here === normalize(href);
// A hub is the "current section" if it OR any of its children is the page.
const inSection = (link: NavLink) =>
  isActive(link.href) || (link.children?.some((c) => isActive(c.href)) ?? false);

// Nav is data-driven from src/config/navigation.ts (single source of truth).
const navLinks = PRIMARY_NAV;
---

<!-- Top Bar -->
<div class="top-bar">
  <div class="container">
    <span>📧 <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a></span>
    <span>📞 <a href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phone}</a> (TTY: {BUSINESS.tty})</span>
  </div>
</div>

<!-- Header / Nav -->
<header class="main-header">
  <div class="container header-top">
    <div class="logo-left">
      <a href="/">
        <img src="/pictures/rocco.webp" alt="Rocco DeLuca — Vernal Medicare" />
      </a>
    </div>

    <div class="site-name-center">
      <a href="/" class="site-name" aria-label="Medicare Simplified — Home">
        <picture>
          <source srcset="/pictures/medicare-simplified.webp" type="image/webp" />
          <img src="/pictures/medicare-simplified.webp" alt="Medicare Simplified" class="brand-logo" />
        </picture>
      </a>
    </div>

    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="main-nav"
    />
    <label for="nav-toggle" class="nav-toggle-label" id="nav-toggle-label">
      <span></span>
    </label>

    <nav class="main-nav" id="main-nav">
      <ul class="nav-menu">
        {
          navLinks.map((link) =>
            link.children ? (
              <li class="has-dropdown">
                <a
                  href={link.href}
                  class:list={['nav-hub', { featured: link.featured }]}
                  aria-haspopup="true"
                  {...(inSection(link) ? { 'aria-current': 'true' } : {})}
                >
                  {link.label}
                  <span class="caret" aria-hidden="true">▾</span>
                </a>
                <ul class="dropdown">
                  {link.children.map((child) =>
                    child.href ? (
                      <li>
                        <a
                          href={child.href}
                          {...(isActive(child.href) ? { 'aria-current': 'page' } : {})}
                        >
                          {child.label}
                        </a>
                      </li>
                    ) : (
                      <li class="dropdown-heading" role="presentation">
                        {child.label}
                      </li>
                    )
                  )}
                </ul>
              </li>
            ) : (
              <li>
                <a
                  href={link.href}
                  {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
                >
                  {link.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>
  </div>
</header>
