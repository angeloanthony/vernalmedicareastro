---
// CalculatorLayout.astro — top-level shell for any calculator/tool page.
// Wraps Vernal's BaseLayout (so SEO/header/footer/schema are inherited) and
// lays out the form region + results region + disclaimer + CTA. A calculator
// page becomes: <CalculatorLayout ...> inputs / actions / results slots.
// Generic Print + Share chrome is wired below; per-calculator compute is added
// by the calculator's own <script> using src/lib/calculators helpers.
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalculatorHeader from './CalculatorHeader.astro';
import CalculatorDisclaimer from './CalculatorDisclaimer.astro';
import CalculatorCTA from './CalculatorCTA.astro';

interface Props {
  // Forwarded to BaseLayout (SEO)
  title: string;
  description: string;
  canonical: string;
  schema?: object[];
  // Calculator chrome
  heading: string;
  intro?: string;
  updated?: string;
  disclaimer?: string;
}
const { title, description, canonical, schema = [], heading, intro, updated, disclaimer } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema}>
  <article class="calculator" data-calc>
    <CalculatorHeader heading={heading} intro={intro} updated={updated} />

    <div class="calc-grid">
      <form class="calc-form" data-calc-form novalidate>
        <slot name="inputs" />
        <div class="calc-actions">
          <slot name="actions" />
        </div>
      </form>

      <div class="calc-output">
        <slot name="results" />
      </div>
    </div>

    <div class="calc-body">
      <slot />
    </div>

    <CalculatorDisclaimer text={disclaimer} />
    <CalculatorCTA />
  </article>
</BaseLayout>

<script>
  // Generic calculator chrome (works for every calculator, no per-calc logic):
  document.querySelectorAll('[data-calc-print]').forEach((b) =>
    b.addEventListener('click', () => window.print()),
  );
  document.querySelectorAll('[data-calc-share]').forEach((b) =>
    b.addEventListener('click', async () => {
      const url = location.href;
      const btn = b as HTMLElement;
      if (navigator.share) {
        try { await navigator.share({ url }); } catch { /* dismissed */ }
      } else {
        try { await navigator.clipboard.writeText(url); btn.textContent = 'Link copied'; } catch { /* no-op */ }
      }
    }),
  );
</script>
