---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "InsuranceAgency",
    "name": "Vernal Medicare",
    "url": "https://vernalmedicare.com/",
    "logo": "https://vernalmedicare.com/pictures/rocco.webp",
    "description": "Licensed help with Medicare Advantage, Medigap, Part D, and under-65 health insurance in Vernal and the Uintah Basin.",
    "telephone": "+1-435-219-5120",
    "email": "rocco@vernalmedicare.com",
    "areaServed": "Uintah County, Utah",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vernal",
      "addressRegion": "UT",
      "postalCode": "84078",
      "addressCountry": "US"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "26"
    }
  }
];
---

<BaseLayout
  title="Reviews — Medicare & Health Insurance in Vernal, Utah | Vernal Medicare"
  description="Real feedback from local clients in Vernal and the Uintah Basin about our Medicare and health insurance help."
  canonical="https://vernalmedicare.com/reviews.html"
  ogTitle="Client Reviews | Vernal Medicare"
  twitterTitle="Client Reviews | Vernal Medicare"
  twitterDescription="Real feedback from local clients in Vernal and the Uintah Basin."
  schema={schema}
>
  <main id="content" class="container">
    <section>
      <h1>What Clients Say</h1>
      <p>We're grateful for the trust our clients place in us. Here are a few reviews from local Medicare beneficiaries and their families.</p>
      
      <!-- Prominent Google Rating -->
      <div class="rating-box" style="text-align: center; margin: 40px 0;">
        <div style="font-size: 4.2rem; line-height: 1; margin-bottom: 8px; color: #fbbc05;">★★★★★</div>
        <div style="font-size: 2rem; font-weight: bold; margin-bottom: 4px;">4.9 / 5</div>
        <div style="color: #555; font-size: 1.1rem;">Based on 26 Google Reviews</div>
        <a
          href="https://www.google.com/search?q=Vernal+Medicare+Vernal+UT"
          target="_blank"
          rel="noopener nofollow"
          class="button"
          style="margin-top: 20px;">
          Read All Reviews on Google
        </a>
      </div>
    </section>

    <section class="reviews">
      <h2>Featured Google Reviews</h2>

      <div class="review-grid">
        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"Rocco made the whole Medicare process simple and stress-free. He took the time to explain every option clearly and made sure I understood what I was choosing."</blockquote>
          <figcaption>— James Richards via Google</figcaption>
        </figure>

        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"Rocco has been very helpful in selecting our Medicare plans. He has a vast knowledge of the plans offered in our area. He has been so easy to work with."</blockquote>
          <figcaption>— Gerie Galley via Google</figcaption>
        </figure>

        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"We had a wonderful experience working with Rocco. From the very beginning, he took the time to truly understand both mine and my husband's needs."</blockquote>
          <figcaption>— Ilka Moosman via Google</figcaption>
        </figure>

        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"I am pleased to provide a strong recommendation for Rocco, an outstanding insurance agent who has been instrumental in securing the best insurance coverage for my wife and me."</blockquote>
          <figcaption>— Robert Moosman via Google</figcaption>
        </figure>

        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"Thank you for your hard work. You have done such an amazing job. You are patient and kind and easy to work with. Have a lot of Knowledge!!! You're the best!!!!"</blockquote>
          <figcaption>— Trudy Wilson via Google</figcaption>
        </figure>

        <figure class="review-card">
          <div style="color: #fbbc05; font-size: 1.4rem; margin-bottom: 12px;">★★★★★</div>
          <blockquote>"He is a very good agent and very knowledgeable and helpful. I would recommend him to anyone that needs insurance."</blockquote>
          <figcaption>— Cadie Harrison via Google</figcaption>
        </figure>
      </div>

      <p style="text-align: center; margin: 40px 0;">
        <a
          href="https://www.google.com/search?q=Vernal+Medicare+Vernal+UT"
          target="_blank"
          rel="noopener nofollow"
          class="button">
          See All 26 Google Reviews
        </a>
      </p>
    </section>

    <!-- CTA -->
    <section class="cta" style="background: #002b49; border-color: #9e0853; text-align: center;">
      <h2 style="color: #fff;">Need Help Understanding Your Medicare Options?</h2>
      <p style="color: #e2e8f0; font-size: 1.1rem; max-width: 600px; margin: 0 auto 20px;">
        Call Rocco at <strong style="color: #fff;">(435) 219-5120</strong> for a free Medicare review.
      </p>
      <button
        class="button"
        onclick="if(window.Tawk_API && window.Tawk_API.toggle){ window.Tawk_API.toggle(); } else { window.open('https://tawk.to/chat/6a1a1c2981b0b81c38f87f93/1jpqvs0bj','_blank'); }"
        style="cursor:pointer; border:none;">
        Schedule a Consultation
      </button>
    </section>
  </main>
</BaseLayout>