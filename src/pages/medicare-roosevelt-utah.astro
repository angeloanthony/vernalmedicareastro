---
// src/pages/medicare-roosevelt-utah.astro — MIGRATED to the Page Framework (M12),
// then REDESIGNED (visual pass) from a text-wall into a scannable landing page:
// custom desert/basin hero, "How We Help You" tiles, Local Focus split, plan-option
// cards, Enrollment Windows quick-guide cards, and a dark CTA band. All SEO prose,
// internal links, figures and schema are preserved — only the presentation changed.
// bareHeader lets us render the custom hero; the default FAQ/sources/related/CTA/
// disclaimer footer still renders from context. FLAGSHIP for the 'local' silo.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { figuresFor } from '../data/annualMedicareData';
import { BUSINESS } from '../data/business';
import { usd } from '../lib/formatters';
import { relatedFor } from '../lib/related';
import { PAGE_INDEX } from '../data/pageIndex';
import type { PageContext } from '../types/Page';

const f = figuresFor();

const context: PageContext = {
  page: {
    title: 'Medicare Plans in Roosevelt, Utah 2026 | Local Medicare Agent',
    heading: 'Medicare Plans in Roosevelt, Utah — 2026 Guide',
    description:
      'Compare Medicare Advantage, Medigap, and Part D plans in Roosevelt, Utah for 2026. Free local help from a licensed agent serving Duchesne County. Call 435-219-5120.',
    taxonomy: { silo: 'local', tags: ['local', 'roosevelt', 'duchesne-county', 'overview', 'original-medicare'] },
    summary:
      'Roosevelt and Duchesne County residents have real Medicare choices — Medicare Advantage, Medigap, and Part D — but the right one depends on your doctors, your pharmacy, and the Uintah Basin networks. We’re a local, independent agency just up US-40 in Vernal, and we compare all of it with you at no cost.',
    faqs: [
      {
        question: 'What Medicare plans are available in Roosevelt, Utah?',
        answer:
          'Roosevelt residents can choose from Medicare Advantage (HMO/PPO), Medicare Supplement (Medigap), and Part D prescription drug plans. Availability changes annually. Call 435-219-5120 for a free 2026 comparison.',
      },
      {
        question: 'Is there a Medicare agent near Roosevelt, Utah?',
        answer:
          'Yes. Rocco DeLuca with Vernal Medicare serves Roosevelt, Duchesne, and all of Duchesne County. Free plan comparisons and enrollment help. Call 435-219-5120.',
      },
      {
        question: 'Does Medicare Advantage work at Uintah Basin Healthcare?',
        answer:
          'Many Medicare Advantage plans include Uintah Basin Healthcare in Roosevelt. We verify provider and hospital coverage before you enroll.',
      },
    ],
    sources: [
      { title: 'Find & compare plans in your area', url: 'https://www.medicare.gov/plan-compare', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'If you’re in Roosevelt or anywhere in Duchesne County,', action: `call us free at ${BUSINESS.phone} for a 2026 plan comparison built around your doctors and pharmacy.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-roosevelt-utah.html',
    ogType: 'article',
    ogTitle: 'Medicare Plans in Roosevelt, Utah — 2026 Guide',
    ogDescription: 'Local, independent Medicare help for Roosevelt and Duchesne County.',
    gaIds: ['G-NW6ENB89NF', 'G-FTDW9B2G6Q'],
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-06-30',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Roosevelt, Utah', href: '/medicare-roosevelt-utah.html' },
  ],
};

const tel = `tel:${BUSINESS.phoneTel}`;
const partB = usd(f.partB.premium, { cents: true });
// Same related-links computation the layout uses, so our custom card stays in sync.
const related = relatedFor(context.page.taxonomy, PAGE_INDEX, '/medicare-roosevelt-utah.html').slice(0, 4);
---

<ArticlePage context={context} bareHeader bareFooter>
  <div class="rz">

    <!-- ================= HERO ================= -->
    <section class="rz-hero">
      <img src="pictures/rooselvelt-hero.webp" alt="" class="rz-hero__bg" width="1600" height="700" loading="eager" decoding="async" fetchpriority="high" />
      <span class="rz-hero__scrim" aria-hidden="true"></span>
      <div class="rz-hero__inner">
        <div class="rz-hero__copy">
          <span class="rz-eyebrow">Roosevelt, UT · The Uintah Basin</span>
          <h1>Medicare Plans in <span class="rz-hl">Roosevelt, Utah</span></h1>
          <p class="rz-hero__lead">
            Local, licensed help comparing Medicare Advantage (Part C), Medigap, and Part D —
            so you can choose with confidence. <strong>2026 Guide.</strong>
          </p>
          <div class="rz-hero__btns">
            <a href={tel} class="rz-btn rz-btn--primary">📞 Call {BUSINESS.phone} <span>(TTY {BUSINESS.tty})</span></a>
            <a href={`mailto:${BUSINESS.email}`} class="rz-btn rz-btn--ghost">✉️ Email Us</a>
          </div>
          <ul class="rz-hero__trust">
            <li>📍 Roosevelt &amp; the Uintah Basin</li>
            <li>✓ Local · Licensed · No Cost</li>
          </ul>
        </div>

        <aside class="rz-hero__card">
          <div class="rz-card-badge" aria-hidden="true">👤</div>
          <h2>Talk to a Local, Licensed Agent</h2>
          <p>Get clear answers and guidance tailored to your doctors, prescriptions, and budget.</p>
          <a href={tel} class="rz-btn rz-btn--primary rz-btn--block">Call {BUSINESS.phone} (TTY {BUSINESS.tty})</a>
          <a href={BUSINESS.quoteUrl} class="rz-btn rz-btn--outline rz-btn--block" target="_blank" rel="noopener noreferrer">Get a Free Quote</a>
        </aside>
      </div>
    </section>

    <!-- ================= HOW WE HELP ================= -->
    <section class="rz-help">
      <h2 class="rz-h2 rz-h2--center">How We Help You</h2>
      <div class="rz-help__grid">
        <div class="rz-help__item">
          <span class="rz-ic rz-ic--blue">🩺</span>
          <h3>Compare</h3>
          <p>Plans for your doctors, clinics, and pharmacies.</p>
        </div>
        <div class="rz-help__item">
          <span class="rz-ic rz-ic--green">℞</span>
          <h3>Medigap + Part D</h3>
          <p>Find the right plan for predictable costs.</p>
        </div>
        <div class="rz-help__item">
          <span class="rz-ic rz-ic--purple">📋</span>
          <h3>Drug Review</h3>
          <p>Check formularies and preferred pharmacies.</p>
        </div>
        <div class="rz-help__item">
          <span class="rz-ic rz-ic--orange">🐷</span>
          <h3>Savings Programs</h3>
          <p>Extra Help, Medicare Savings Programs &amp; more.</p>
        </div>
        <div class="rz-help__item">
          <span class="rz-ic rz-ic--teal">📅</span>
          <h3>Annual Checkups</h3>
          <p>We make sure your plan still fits when things change.</p>
        </div>
      </div>
    </section>

    <!-- ================= LOCAL FOCUS ================= -->
    <section class="rz-local">
      <figure class="rz-postcard">
        <img src="pictures/roosevelt-welcome.webp" alt="Welcome to Roosevelt, Utah — gateway to the Uintah Basin" class="rz-postcard__img" width="640" height="440" loading="lazy" decoding="async" />
        <figcaption>Gateway to the Uintah Basin</figcaption>
      </figure>
      <div class="rz-local__body">
        <h2 class="rz-h2">Local Focus: Roosevelt &amp; the Basin</h2>
        <p>
          We help neighbors across Roosevelt and nearby communities — coordinating around the clinics
          and pharmacies you already use, and staying easy to reach when you need us. Roosevelt sits
          roughly 30 miles west of Vernal along US-40, and a plan that works in Salt Lake City may not
          serve you well out here.
        </p>
        <div class="rz-figure">
          <span class="rz-figure__icon" aria-hidden="true">👥</span>
          <p>Most beneficiaries pay <strong>{partB} per month</strong> for Original Medicare Part B in {f.year}.</p>
        </div>
      </div>
    </section>

    <!-- ================= PLAN OPTIONS ================= -->
    <section class="rz-plans">
      <h2 class="rz-h2 rz-h2--center">Medicare Options Available in Roosevelt</h2>
      <p class="rz-sub">The right choice depends on your doctors, prescriptions, preferred pharmacy, and budget.</p>
      <div class="rz-plans__grid">
        <article class="rz-plan">
          <span class="rz-plan__tag rz-plan__tag--blue">Part C</span>
          <h3>Medicare Advantage</h3>
          <p>
            Bundled HMO/PPO coverage that often includes drug, dental, vision, hearing and fitness benefits
            at low or $0 premiums. Network access matters in rural areas — before enrolling we verify your
            doctors, the nearest urgent care, and <strong>Uintah Basin Healthcare</strong> accept the plan.
          </p>
        </article>
        <article class="rz-plan">
          <span class="rz-plan__tag rz-plan__tag--green">Medigap</span>
          <h3>Medicare Supplement</h3>
          <p>
            Policies like <a href="plan-g-vs-plan-n-vernal.html">Plan G and Plan N</a> pair with Original
            Medicare to cover copays, coinsurance and deductibles — with nationwide provider freedom and no
            networks. Valuable in Duchesne County when specialist access means travel to Salt Lake City.
          </p>
        </article>
        <article class="rz-plan">
          <span class="rz-plan__tag rz-plan__tag--purple">Part D</span>
          <h3>Prescription Drug Plans</h3>
          <p>
            A standalone Part D plan (paired with Medigap) or an Advantage plan with drug coverage keeps
            medications affordable. We compare formularies against your exact drug list and check costs at
            Roosevelt-area pharmacies including Smith's, Walmart and local independents.
          </p>
        </article>
      </div>
    </section>

    <!-- ================= COST ================= -->
    <section class="rz-cost">
      <h2 class="rz-h2">How Much Does Medicare Cost in Roosevelt?</h2>
      <p>
        Costs depend on the plan type you choose. Original Medicare Part B is
        <strong>{partB} per month in {f.year}</strong> for most beneficiaries. Medicare Advantage plans are
        available with $0 premiums beyond Part B. Medigap Plan G premiums in Utah typically run $120–$220 per
        month depending on age and tobacco use, and Part D plans range from roughly $7 to $80 per month. We run
        a full <a href="medicare-cost-estimator.html">cost comparison</a> based on your specific situation.
      </p>
    </section>

    <!-- ================= ENROLLMENT WINDOWS ================= -->
    <section class="rz-enroll">
      <h2 class="rz-h2 rz-h2--center">Enrollment Windows (Quick Guide)</h2>
      <div class="rz-enroll__grid">
        <div class="rz-win rz-win--blue">
          <span class="rz-win__icon" aria-hidden="true">🗓️</span>
          <h3>AEP</h3>
          <p>Oct 15 – Dec 7 <span>(changes start Jan 1)</span></p>
        </div>
        <div class="rz-win rz-win--green">
          <span class="rz-win__icon" aria-hidden="true">🔁</span>
          <h3>OEP (MA)</h3>
          <p>Jan 1 – Mar 31 <span>(one change if you're on an MA plan)</span></p>
        </div>
        <div class="rz-win rz-win--purple">
          <span class="rz-win__icon" aria-hidden="true">🎂</span>
          <h3>IEP / ICEP</h3>
          <p>Around your 65th birthday <span>or first eligibility</span></p>
        </div>
        <div class="rz-win rz-win--orange">
          <span class="rz-win__icon" aria-hidden="true">🛡️</span>
          <h3>SEPs</h3>
          <p>Moving, losing coverage, <span>Extra Help / Medicaid &amp; more</span></p>
        </div>
      </div>
      <p class="rz-note">
        Your <a href="medicare-enrollment-periods.html">Initial Enrollment Period</a> begins three months
        before you turn 65. Missing these windows can mean
        <a href="medicare-part-b-penalty-calculator.html">permanent premium penalties</a> — especially for
        Part B and Part D.
      </p>
    </section>

    <!-- ================= CTA BAND ================= -->
    <!-- ================= WHY LOCAL (icon + image bleed) ================= -->
    <section class="rz-why">
      <div class="rz-why__body">
        <span class="rz-badge rz-badge--blue" aria-hidden="true">👥</span>
        <div>
          <h2 class="rz-h2 rz-h2--rule">Why Roosevelt Residents Need Local Guidance</h2>
          <p>
            Healthcare access in the Basin mixes local clinics, Uintah Basin Healthcare, and occasional trips
            to larger facilities. Locally, it matters whether a plan covers telehealth for specialist visits,
            whether your pharmacy is in-network at preferred pricing, and whether emergency transport to
            regional hospitals is covered without surprise billing.
          </p>
        </div>
      </div>
      <img src="pictures/rooselvelt-hero.webp" alt="" class="rz-why__img" width="720" height="480" loading="lazy" decoding="async" />
    </section>

    <!-- ================= FREE HELP + AGENT CARD ================= -->
    <section class="rz-freehelp">
      <div class="rz-freehelp__main">
        <span class="rz-badge rz-badge--green" aria-hidden="true">🤝</span>
        <div>
          <h2 class="rz-h2 rz-h2--rule">Free Medicare Help for Roosevelt &amp; Duchesne County</h2>
          <p>
            Rocco DeLuca is a licensed Medicare agent serving Roosevelt, Duchesne, Myton, Tabiona, and the
            entire Duchesne County area.
          </p>

          <div class="rz-mini">
            <div class="rz-mini__item">
              <span class="rz-mini__ic" aria-hidden="true">$</span>
              <p>No cost for plan comparisons, enrollment help, or ongoing support.</p>
            </div>
            <div class="rz-mini__item">
              <span class="rz-mini__ic" aria-hidden="true">📞</span>
              <p>Prefer a phone call, video meeting, or in-person visit? We come to you.</p>
            </div>
            <div class="rz-mini__item">
              <span class="rz-mini__ic" aria-hidden="true">📅</span>
              <p>Help is available year-round ({BUSINESS.hours.humanReadable}).</p>
            </div>
          </div>

          <div class="rz-basics">
            <span class="rz-basics__ic" aria-hidden="true">📄</span>
            <p>
              For Medicare basics, see our guides on
              <a href="medicare-part-a-vs-part-b.html">Part A vs Part B</a>,
              <a href="medicare-supplement-vs-advantage.html">Medigap vs Medicare Advantage</a>, and
              <a href="when-to-enroll-medicare-utah.html">when to enroll in Utah</a>.
            </p>
          </div>

          <p class="rz-src">
            <em>Source: <a href="https://www.medicare.gov" target="_blank" rel="nofollow">Medicare.gov</a>.
            Plan availability, premiums, and benefits change annually. Verify current options during
            enrollment periods.</em>
          </p>
        </div>
      </div>

      <aside class="rz-agentcard">
        <div class="rz-agentcard__head">
          <span class="rz-agentcard__badge" aria-hidden="true">👤</span>
          <h2>Talk to a Local, Licensed Agent</h2>
        </div>
        <p>Rocco DeLuca can walk you through your options — free, no pressure.</p>
        <a href={tel} class="rz-btn rz-btn--primary rz-btn--block">📞 Call {BUSINESS.phone} <span>(TTY {BUSINESS.tty})</span></a>
        <a href={BUSINESS.quoteUrl} class="rz-btn rz-btn--light rz-btn--block" target="_blank" rel="noopener noreferrer">Get a Free Quote</a>
      </aside>
    </section>

    <!-- ================= FOOTER CARD ROW ================= -->
    <section class="rz-cards">
      <article class="rz-fcard">
        <div class="rz-fcard__head"><span class="rz-fcard__ic rz-fcard__ic--orange" aria-hidden="true">❓</span><h3>Frequently Asked Questions</h3></div>
        <ul class="rz-fcard__list">
          {context.page.faqs?.map((q) => <li>{q.question}</li>)}
        </ul>
        <a href="faq.html" class="rz-fcard__more">View all FAQs →</a>
      </article>

      <article class="rz-fcard">
        <div class="rz-fcard__head"><span class="rz-fcard__ic rz-fcard__ic--blue" aria-hidden="true">🌐</span><h3>Sources</h3></div>
        <ul class="rz-fcard__list rz-fcard__list--links">
          {context.page.sources?.map((s) => <li><a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a> — {s.publisher}</li>)}
        </ul>
      </article>

      <article class="rz-fcard">
        <div class="rz-fcard__head"><span class="rz-fcard__ic rz-fcard__ic--purple" aria-hidden="true">🔗</span><h3>Related</h3></div>
        <ul class="rz-fcard__list rz-fcard__list--links">
          {related.map((r) => <li><a href={r.href}>{r.label}</a></li>)}
        </ul>
      </article>

      <article class="rz-fcard rz-fcard--agent">
        <div class="rz-fcard__head"><span class="rz-fcard__ic rz-fcard__ic--green" aria-hidden="true">👤</span><h3>Local. Licensed. Here for You.</h3></div>
        <div class="rz-fcard__agent">
          <img src="pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent" width="72" height="72" loading="lazy" decoding="async" />
          <div>
            <strong>Rocco DeLuca</strong>
            <span>Licensed Medicare Agent</span>
            <span>Roosevelt, Duchesne &amp; the Uintah Basin</span>
            <em>Local help. Real answers.</em>
          </div>
        </div>
        <div class="rz-fcard__btns">
          <a href={tel} class="rz-btn rz-btn--primary">📞 Call {BUSINESS.phone}</a>
          <a href={BUSINESS.quoteUrl} class="rz-btn rz-btn--outline" target="_blank" rel="noopener noreferrer">Get a Free Quote</a>
        </div>
      </article>
    </section>

  </div>
</ArticlePage>

<style>
  /* ============ Roosevelt landing page (scoped) ============ */
  .rz {
    --navy: #0b2c45;
    --navy-2: #002b49;
    --orange: #e07817;
    --orange-2: #f4922e;
    --ink: #223140;
    --muted: #5a6b7b;
    --line: #e2e8f0;
    --sky-1: #cfe4f2;
    --sky-2: #eaf3fa;
    color: var(--ink);
    line-height: 1.55;
  }
  .rz * { box-sizing: border-box; }
  .rz section { margin: 3rem 0; }

  .rz .rz-h2 {
    font-size: clamp(1.5rem, 1rem + 1.4vw, 2rem);
    color: var(--navy);
    margin: 0 0 .5rem;
    line-height: 1.2;
  }
  .rz .rz-h2--center { text-align: center; }
  .rz .rz-h2--center::after {
    content: "";
    display: block;
    width: 64px; height: 4px;
    margin: .6rem auto 0;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--orange), var(--orange-2));
  }
  .rz .rz-sub { text-align: center; color: var(--muted); margin: 0 auto 1.8rem; max-width: 640px; }

  /* Links inside the design → brand navy, not the global magenta */
  .rz a:not(.rz-btn) { color: var(--navy); font-weight: 700; text-decoration: underline; text-underline-offset: 2px; }
  .rz a:not(.rz-btn):hover { color: var(--orange); }

  /* ---------- Buttons ---------- */
  .rz .rz-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
    padding: .8rem 1.2rem; border-radius: 12px; font-weight: 800; text-decoration: none;
    font-size: 1rem; line-height: 1.15; border: 2px solid transparent; transition: transform .12s ease, box-shadow .12s ease, background .2s ease;
  }
  .rz .rz-btn span { font-weight: 600; opacity: .9; font-size: .85em; }
  .rz .rz-btn:hover { transform: translateY(-1px); }
  .rz .rz-btn--block { display: flex; width: 100%; }
  .rz .rz-btn--primary { background: linear-gradient(180deg, var(--orange-2), var(--orange)); color: #fff; box-shadow: 0 8px 20px rgba(224,120,23,.30); }
  .rz .rz-btn--ghost { background: #fff; color: var(--navy); border-color: #fff; }
  .rz .rz-btn--outline { background: #fff; color: var(--navy); border-color: var(--line); box-shadow: 0 4px 12px rgba(11,44,69,.08); }
  .rz .rz-btn--light { background: #fff; color: var(--navy); }
  .rz .rz-btn--outline-light { background: transparent; color: #fff; border-color: rgba(255,255,255,.55); }

  /* ---------- HERO ---------- */
  .rz-hero {
    position: relative; overflow: hidden; border-radius: 20px;
    background: #0b2c45;
    box-shadow: 0 20px 50px rgba(11,44,69,.18);
    margin-top: 1rem !important;
  }
  .rz-hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .rz-hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(6,26,43,.62) 0%, rgba(6,26,43,.28) 45%, rgba(6,26,43,0) 72%),
      linear-gradient(180deg, rgba(6,26,43,0) 55%, rgba(6,26,43,.22) 100%);
  }

  .rz-hero__inner {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.35fr .85fr; gap: 1.5rem; align-items: start;
    padding: clamp(1.4rem, 3vw, 3rem);
  }
  .rz-eyebrow {
    display: inline-block; background: rgba(11,44,69,.9); color: #fff; font-weight: 700;
    font-size: .78rem; letter-spacing: .04em; text-transform: uppercase; padding: .3rem .7rem; border-radius: 999px;
  }
  .rz-hero__copy h1 {
    color: #fff; font-size: clamp(2rem, 1.2rem + 3vw, 3.2rem); line-height: 1.08;
    margin: .8rem 0 .6rem; max-width: 14ch; text-shadow: 0 2px 12px rgba(0,0,0,.45);
  }
  .rz .rz-hl { color: var(--orange-2); }
  .rz-hero__lead { color: #eaf1f7; font-size: 1.08rem; max-width: 40ch; margin: 0 0 1.1rem; text-shadow: 0 1px 8px rgba(0,0,0,.4); }
  .rz-hero__btns { display: flex; flex-wrap: wrap; gap: .7rem; }
  .rz-hero__trust { list-style: none; padding: 0; margin: 1.1rem 0 0; display: flex; flex-wrap: wrap; gap: .5rem 1.4rem; color: #fff; font-weight: 700; font-size: .95rem; text-shadow: 0 1px 8px rgba(0,0,0,.45); }

  .rz-hero__card {
    background: rgba(255,255,255,.96); border-radius: 16px; padding: 1.4rem;
    box-shadow: 0 16px 36px rgba(11,44,69,.22); backdrop-filter: blur(2px);
  }
  .rz-card-badge {
    width: 46px; height: 46px; border-radius: 50%; display: grid; place-items: center; font-size: 1.4rem;
    background: linear-gradient(180deg, var(--orange-2), var(--orange)); margin-bottom: .6rem;
  }
  .rz-hero__card h2 { color: var(--orange); font-size: 1.25rem; margin: 0 0 .4rem; }
  .rz-hero__card p { color: var(--muted); margin: 0 0 1rem; font-size: .98rem; }
  .rz-hero__card .rz-btn { margin-top: .6rem; }

  /* ---------- HOW WE HELP ---------- */
  .rz-help__grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; margin-top: 2rem; }
  .rz-help__item { text-align: center; padding: 1rem .6rem; border-radius: 14px; transition: background .2s ease, transform .15s ease; }
  .rz-help__item:hover { background: #f5f9fc; transform: translateY(-3px); }
  .rz-ic {
    width: 64px; height: 64px; border-radius: 50%; display: grid; place-items: center;
    font-size: 1.7rem; margin: 0 auto .7rem; border: 3px solid; background: #fff;
  }
  .rz-ic--blue   { color: var(--navy);   border-color: #cfe0ee; }
  .rz-ic--green  { color: #1f8a4c; border-color: #c9ecd6; font-weight: 800; }
  .rz-ic--purple { color: #7c3aed; border-color: #e4d7fb; }
  .rz-ic--orange { color: var(--orange); border-color: #f7ddbe; }
  .rz-ic--teal   { color: #0d9488; border-color: #bfeae6; }
  .rz-help__item h3 { color: var(--navy); font-size: 1.05rem; margin: 0 0 .3rem; }
