---
// src/pages/medicare-penalty-calculator.astro — Decision Tools (M9).
// Combined Part B + Part D late-enrollment penalty calculator (one months
// input + one creditable-coverage toggle drives both). The Part B-only
// calculator lives separately at medicare-part-b-penalty-calculator.astro.
import CalculatorPage from '../components/layout/CalculatorPage.astro';
import CalculatorSection from '../components/calculator/CalculatorSection.astro';
import CalculatorInput from '../components/calculator/CalculatorInput.astro';
import CalculatorResult from '../components/calculator/CalculatorResult.astro';
import CalculatorPrint from '../components/calculator/CalculatorPrint.astro';
import CalculatorShare from '../components/calculator/CalculatorShare.astro';
import AuthorByline from '../components/content/AuthorByline.astro';
import SummaryBlock from '../components/SummaryBlock.astro';
import NextSteps from '../components/content/NextSteps.astro';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';
import type { PageContext } from '../types/Page';
import type { CalculatorField } from '../types/Calculator';

const f = figuresFor();
const year = f.year;
const monthsField: CalculatorField = {
  id: 'months',
  label: 'Months you delayed Medicare',
  type: 'number',
  help: 'Full months you were eligible for Medicare but didn’t enroll.',
  min: 0,
};
const creditableField: CalculatorField = {
  id: 'creditable',
  label: 'Did you have creditable coverage during that time?',
  type: 'radio',
  help: 'Employer, union, or VA coverage as good as Medicare’s usually counts.',
  options: [
    { label: 'No', value: 'no' },
    { label: 'Yes', value: 'yes' },
  ],
};

const context: PageContext = {
  page: {
    title: `Medicare Late Enrollment Penalty Calculator ${f.year} | Part B & Part D | Vernal Medicare`,
    heading: 'Medicare Late Enrollment Penalty Calculator',
    description: `Free Medicare late enrollment penalty calculator. Estimate your lifetime Part B and Part D penalties for delaying Medicare without creditable coverage, using ${f.year} figures.`,
    taxonomy: { silo: 'enrollment', tags: ['penalties', 'part-b', 'part-d', 'gep', 'deadlines'] },
    summary: `See whether delaying Medicare could permanently raise your premiums. The Part B penalty adds 10% to your premium for each full 12 months you delayed; the Part D penalty adds 1% of the ${f.year} base premium (${usd(f.partD.basePremium, { cents: true })}) for each full month you went without creditable drug coverage. Both are usually permanent.`,
    faqs: [
      { question: 'What is the Part B late enrollment penalty?', answer: 'Your Part B premium goes up 10% for each full 12-month period you could have had Part B but didn’t sign up. In most cases you pay it for as long as you have Part B.' },
      { question: 'What is the Part D late enrollment penalty?', answer: `The Part D penalty is 1% of the national base beneficiary premium (${usd(f.partD.basePremium, { cents: true })} in ${f.year}) times the number of full months you went without Part D or other creditable drug coverage. It’s added to your premium for as long as you have Part D.` },
      { question: 'How do I avoid Medicare late enrollment penalties?', answer: 'Enroll when you’re first eligible, or keep creditable coverage (such as an employer plan or VA benefits) and enroll within your Special Enrollment Period when it ends.' },
      { question: 'Are the penalties permanent?', answer: 'In most cases, yes. The Part B and Part D late enrollment penalties are added to your monthly premiums for as long as you have that coverage.' },
      { question: 'What counts as creditable coverage?', answer: 'Coverage that’s at least as good as Medicare’s, such as an active employer group health plan, union, or VA coverage. It lets you delay Medicare without a penalty.' },
      { question: 'Do the penalty amounts change each year?', answer: 'Yes. Penalties are based on the standard Part B premium and the Part D national base premium, which are set annually, so the dollar amounts can change each year.' },
    ],
    sources: [{ title: 'Avoid late-enrollment penalties', url: 'https://www.medicare.gov/basics/costs/medicare-costs/avoid-penalties', publisher: 'Medicare.gov' }],
    nextSteps: [
      {
        when: 'Delayed because of a job or VA coverage?',
        action: 'that coverage may have been creditable — call us and we can help confirm whether you actually owe a penalty.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-penalty-calculator.html',
    ogType: 'website',
    ogTitle: 'Medicare Late Enrollment Penalty Calculator',
    ogDescription: 'Estimate your Medicare Part B and Part D late enrollment penalties based on how long you delayed coverage.',
  },
  author: 'rocco',
  datePublished: '2026-07-09',
  lastUpdated: '2026-07-09',
  medicalDisclaimer: 'Estimate only, based on published CMS figures. Your actual penalty is set by Social Security and CMS.',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Calculators', href: '/medicare-calculators.html' },
    { name: 'Penalty Calculator', href: '/medicare-penalty-calculator.html' },
  ],
};
---

<CalculatorPage context={context} bareHeader>
  <div class="pen-hero">
    <div class="pen-hero-text">
      <span class="pen-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 16H3z"/><path d="M12 10v4"/><circle cx="12" cy="17.2" r="0.6" fill="currentColor" stroke="none"/></svg>
        Updated for {year}
      </span>
      <h1 class="pen-h1">Medicare Late Enrollment<br /><span class="pen-h1-accent">Penalty Calculator</span></h1>
      <AuthorByline
        authorId={context.author}
        reviewedById={context.reviewedBy}
        updated={context.lastUpdated}
        localAvailability={context.localAvailability}
      />
      <SummaryBlock text={context.page.summary} />
      <NextSteps steps={context.page.nextSteps ?? []} />
      <p class="pen-hero-lede">Enter how long you went without coverage to estimate both your <a href="medicare-part-b-penalty-calculator.html">Part B</a> and Part D penalties at once — both usually last for as long as you have Medicare.</p>
    </div>

    <div class="pen-hero-art" aria-hidden="true">
      <div class="pen-hero-card">
        <div class="pen-hero-card-top">
          <span class="pen-hero-led"></span>
          <span class="pen-hero-dot"></span>
          <span class="pen-hero-dot"></span>
          <span class="pen-hero-solar"></span>
        </div>
        <div class="pen-hero-display">
          <span class="pen-hero-display-label">Penalty</span>
          <span class="pen-hero-display-digits">+10%</span>
        </div>
        <div class="pen-hero-keys">
          <span class="pen-hero-key is-op">C</span>
          <span class="pen-hero-key is-op">%</span>
          <span class="pen-hero-key is-op">÷</span>
          <span class="pen-hero-key is-op">×</span>
          <span class="pen-hero-key">7</span>
          <span class="pen-hero-key">8</span>
          <span class="pen-hero-key">9</span>
          <span class="pen-hero-key is-op">−</span>
          <span class="pen-hero-key">4</span>
          <span class="pen-hero-key">5</span>
          <span class="pen-hero-key">6</span>
          <span class="pen-hero-key is-op">+</span>
          <span class="pen-hero-key">1</span>
          <span class="pen-hero-key">2</span>
          <span class="pen-hero-key">3</span>
          <span class="pen-hero-key is-eq">=</span>
          <span class="pen-hero-key is-zero">0</span>
          <span class="pen-hero-key">.</span>
        </div>
      </div>
      <div class="pen-hero-float">
        <span class="pen-hero-float-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S4.5 15.2 4.5 9.7A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7.5 2.7C19.5 15.2 12 20.5 12 20.5z"/></svg>
        </span>
        <span>
          <strong>Usually permanent</strong>
          <p>Added to your premium for as long as you have Medicare.</p>
        </span>
      </div>
    </div>
  </div>

  <div class="pen-feature-grid">
    <div class="pen-feature-card">
      <span class="pen-feature-icon" style="--c:#dc3545;--t:#fbe2e4">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v6"/><circle cx="12" cy="16.3" r="0.6" fill="currentColor" stroke="none"/></svg>
      </span>
      <h3>Usually Permanent</h3>
      <p>Once the penalty applies, it's added to your premium for as long as you have that coverage.</p>
    </div>
    <div class="pen-feature-card">
      <span class="pen-feature-icon" style="--c:#2563eb;--t:#e5edfe">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>
      </span>
      <h3>Part B: 10% Per Year</h3>
      <p>Your Part B premium goes up 10% for each full 12 months you could have had it but didn't.</p>
    </div>
    <div class="pen-feature-card">
      <span class="pen-feature-icon" style="--c:#16a34a;--t:#e4f5ea">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2.6" y="8.4" width="18.8" height="7.2" rx="3.6" transform="rotate(-45 12 12)"/><path d="M8.7 8.7l6.6 6.6"/></svg>
      </span>
      <h3>Part D: 1% Per Month</h3>
      <p>Added for each full month you went without Part D or other creditable drug coverage.</p>
    </div>
    <div class="pen-feature-card">
      <span class="pen-feature-icon" style="--c:#ea580c;--t:#fdeadd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M6 6l1.2 12a2 2 0 0 0 2 1.8h5.6a2 2 0 0 0 2-1.8L18 6"/><path d="M9 10.5l2.3 2.5 3.7-4.5"/></svg>
      </span>
      <h3>Had Coverage? Maybe Not</h3>
      <p>Employer, union, or VA coverage often counts as <a href="medicare-creditable-coverage.html">creditable coverage</a> — no penalty owed.</p>
    </div>
  </div>

  <form class="calc-form" data-calc-form novalidate>
    <div class="calc-form-head">
      <div class="calc-form-icon" aria-hidden="true">🧮</div>
      <div class="calc-form-titles">
        <h2 class="calc-form-title">Estimate Your Penalty</h2>
        <p class="calc-form-sub">Adjust the inputs below — your estimate updates as you type.</p>
      </div>
      <span class="calc-form-timer" aria-hidden="true">⏱ About 20 seconds</span>
    </div>

    <CalculatorSection title="Your delay">
      <CalculatorInput field={monthsField} />
      <CalculatorInput field={creditableField} />
    </CalculatorSection>
    <div class="calc-actions">
      <button type="button" class="btn btn-primary" data-calc-calculate>See My Penalty Estimate</button>
      <CalculatorPrint />
      <CalculatorShare />
    </div>
  </form>

  <div class="calc-result-stage">
    <CalculatorResult heading="Your estimated penalty" />
  </div>

  <p>These penalties are added to your premiums for as long as you have Medicare, and are recalculated as the base premiums rise each year — so the lifetime cost is usually far higher than a single year's estimate. If you had employer or VA coverage when you delayed, you may owe <strong>no penalty at all</strong> — see the <a href="medicare-general-enrollment-period.html">General Enrollment Period</a> and <a href="missed-medicare-enrollment.html">missed-enrollment</a> guides, or call us to check.</p>

  <script>
    import { bindCalculator } from '../lib/calculators';
    import { computePartBPenalty, computePartDPenalty } from '../lib/calculators/penalty';
    import { figuresFor } from '../data/annualMedicareData';
    import { usd, percent } from '../lib/formatters';
    import type { CalculatorResult } from '../types/Calculator';

    const F = figuresFor();
    function compute(fields: Record<string, string>): CalculatorResult {
      const months = Math.max(0, parseInt(fields.months || '0', 10) || 0);
      const creditable = fields.creditable === 'yes';

      const b = computePartBPenalty(creditable ? 0 : months, F);
      const d = computePartDPenalty(creditable ? 0 : months, F);
      const totalMonthly = b.monthlyPenalty + d.monthlyPenalty;
      const tenYearTotal = totalMonthly * 12 * 10;

      let summary: string;
      if (creditable) {
        summary = 'You likely owe no penalty — creditable coverage during that time generally protects you. Just be sure to enroll within your Special Enrollment Period when it ends.';
      } else if (months === 0) {
        summary = 'No delay, no penalty. Enter the months you delayed above to see the estimate.';
      } else {
        summary = `A delay of ${months} month${months === 1 ? '' : 's'} adds a lifetime penalty of about ${usd(totalMonthly, { cents: true })}/month to your Medicare premiums.`;
      }

      return {
        summary,
        rows: [
          { label: 'Part B penalty', value: `${usd(b.monthlyPenalty, { cents: true })}/mo${b.monthlyPenalty > 0 ? ` (${percent(b.penaltyPct)})` : ''}` },
          { label: 'Part D penalty', value: `${usd(d.monthlyPenalty, { cents: true })}/mo` },
          { label: 'Total added per month', value: usd(totalMonthly, { cents: true }), emphasis: true },
          { label: 'Added over 10 years', value: usd(tenYearTotal) },
        ],
      };
    }

    const form = document.querySelector<HTMLElement>('[data-calc-form]');
    const results = document.querySelector<HTMLElement>('[data-calc-results]');
    if (form && results) bindCalculator(form, results, compute);

    // Results update live on every input; the primary button just guides the
    // eye down to the (already computed) estimate for a satisfying action.
    const resultCard = document.querySelector<HTMLElement>('.calc-result');
    document.querySelector('[data-calc-calculate]')?.addEventListener('click', () => {
      resultCard?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      resultCard?.animate(
        [{ boxShadow: '0 0 0 4px rgba(220,53,69,0.45)' }, { boxShadow: '0 16px 40px rgba(11,44,69,0.28)' }],
        { duration: 900, easing: 'ease-out' },
      );
    });

    // Interactive 3D: the estimate card tilts toward the cursor and a sheen
    // tracks it. Mouse only; honours reduced-motion.
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (resultCard && !reduceMotion) {
      const MAX_TILT = 8; // degrees
      resultCard.addEventListener('pointermove', (e: PointerEvent) => {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        const r = resultCard.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        resultCard.style.setProperty('--ry', `${((px - 0.5) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--rx', `${((0.5 - py) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--mx', `${(px * 100).toFixed(1)}%`);
        resultCard.style.setProperty('--my', `${(py * 100).toFixed(1)}%`);
        resultCard.classList.add('is-tilting');
      });
      resultCard.addEventListener('pointerleave', () => {
        resultCard.style.setProperty('--rx', '0deg');
        resultCard.style.setProperty('--ry', '0deg');
        resultCard.classList.remove('is-tilting');
      });
    }
  </script>
</CalculatorPage>

<style>
  /* ---- Hero ------------------------------------------------------------ */
  .pen-hero {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 2.4rem;
    align-items: center;
    margin: 0.4rem 0 2rem;
  }

  .pen-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    border-radius: 999px;
    background: #fbe2e4;
    color: #dc3545 !important;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .pen-badge svg { width: 17px; height: 17px; }

  .pen-h1 {
    margin: 0.75rem 0 0.6rem;
    font-size: 2.5rem;
    line-height: 1.12;
    color: #0b2c45;
  }
  .pen-h1-accent { color: #dc3545; }

  .pen-hero-text :global(.byline) {
    color: #55627a;
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }
  .pen-hero-text :global(.byline a) { color: #2563eb; }

  .pen-hero-text :global(.summary-block) {
    margin: 0 0 1rem;
    color: #333;
  }
  .pen-hero-text :global(.summary-block p) { margin: 0; }

  .pen-hero-text :global(.next-steps) { margin: 0 0 1.1rem; }
  .pen-hero-text :global(.next-step) {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    background: #fdecec;
    border-left: 4px solid #dc3545;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: #17324d;
    font-size: 0.95rem;
  }
  .pen-hero-text :global(.next-step)::before {
    content: "↓";
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #dc3545;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .pen-hero-text :global(.next-step-when) { color: #0b2c45; }
  .pen-hero-text :global(.next-step a) { color: #2563eb; }

  .pen-hero-lede { margin: 0; color: #333; }
  .pen-hero-lede :global(a) { color: #2563eb; }

  .pen-hero-art { position: relative; display: grid; place-items: center; min-height: 300px; }
  .pen-hero-art::before {
    content: "";
    position: absolute;
    width: 200px;
    height: 240px;
    background: #fff;
    border-radius: 16px;
    transform: rotate(-9deg) translate(-46px, 4px);
    box-shadow: 0 14px 34px rgba(11, 44, 69, 0.14);
    z-index: 0;
  }

  .pen-hero-card {
    position: relative;
    width: 100%;
    max-width: 260px;
    background: linear-gradient(160deg, #163e60, #0b2c45 55%, #081d33);
    border-radius: 22px;
    padding: 1.15rem 1.2rem 1.35rem;
    box-shadow: 0 24px 50px rgba(11, 44, 69, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .pen-hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 45%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .pen-hero-card { animation: pen-hero-float 6s ease-in-out infinite; }
  }
  @keyframes pen-hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .pen-hero-card-top { display: flex; align-items: center; gap: 0.32rem; margin-bottom: 0.8rem; }
  .pen-hero-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px 1px rgba(74, 222, 128, 0.7);
  }
  .pen-hero-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.25); }
  .pen-hero-solar {
    margin-left: auto;
    width: 28px;
    height: 10px;
    border-radius: 2px;
    background: repeating-linear-gradient(90deg, #2c5478 0 3px, #1c3a56 3px 6px);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .pen-hero-display {
    position: relative;
    background: linear-gradient(165deg, #f9d3d6, #f0a8ad);
    border-radius: 10px;
    padding: 0.6rem 0.85rem 0.5rem;
    box-shadow: inset 0 2px 6px rgba(40, 10, 12, 0.22);
  }
  .pen-hero-display-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #8c2f36;
    text-transform: uppercase;
  }
  .pen-hero-display-digits {
    display: block;
    text-align: right;
    font-family: 'Courier New', monospace;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #4a1015;
    font-size: 1.4rem;
    margin-top: 0.05rem;
  }

  .pen-hero-keys {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 32px;
    gap: 0.42rem;
    margin-top: 1rem;
  }
  .pen-hero-key {
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Courier New', monospace;
    font-weight: 700;
    font-size: 0.82rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .pen-hero-key.is-op { background: rgba(96, 165, 250, 0.22); color: #cfe0fb; }
  .pen-hero-key.is-eq {
    grid-row: span 2;
    background: linear-gradient(160deg, #f0656f, #dc3545);
    color: #fff;
    box-shadow: 0 6px 14px rgba(220, 53, 69, 0.35);
  }
  .pen-hero-key.is-zero { grid-column: span 2; }
  .pen-hero-art:hover .pen-hero-key { transform: translateY(-1px); }

  .pen-hero-float {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: -12px;
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    max-width: 230px;
    background: #fff;
    border-radius: 14px;
    padding: 0.9rem 1.05rem;
    box-shadow: 0 14px 32px rgba(11, 44, 69, 0.2);
  }
  .pen-hero-float-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #fbe2e4;
    color: #dc3545;
  }
  .pen-hero-float-icon svg { width: 19px; height: 19px; }
  .pen-hero-float strong { display: block; color: #0b2c45; font-size: 0.92rem; }
  .pen-hero-float p { margin: 0.15rem 0 0; color: #55627a; font-size: 0.8rem; }

  @media (max-width: 900px) {
    .pen-hero { grid-template-columns: 1fr; }
    .pen-hero-art { margin-top: 0.5rem; }
    .pen-h1 { font-size: 2.1rem; }
  }

  /* ---- Feature cards ----------------------------------------------------- */
  .pen-feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
    margin: 0 0 2rem;
  }
  .pen-feature-card {
    background: #fff;
    border: 1px solid #e8edf3;
    border-radius: 14px;
    padding: 1.2rem 1.15rem 1.3rem;
    box-shadow: 0 10px 26px rgba(11, 44, 69, 0.06);
  }
  .pen-feature-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    margin-bottom: 0.75rem;
    background: var(--t);
    color: var(--c);
  }
