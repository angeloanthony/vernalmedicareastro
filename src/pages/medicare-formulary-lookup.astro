        { name: 'Breo Ellipta', generic: 'fluticasone/vilanterol', brand: true, tier: 3, cost: '$45–$100', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'COPD and asthma maintenance.', coverage: 'Tier 3 brand on most plans.', alts: ['Trelegy Ellipta', 'Symbicort (generic)'] },
        { name: 'Symbicort', generic: 'budesonide/formoterol', brand: true, tier: 3, cost: '$20–$60', pa: false, ql: false, step: false, genericAvail: true, status: 'covered', treats: 'Asthma and COPD.', coverage: 'A generic (budesonide/formoterol) is now available and lower cost.', alts: ['budesonide/formoterol (generic)'] },
