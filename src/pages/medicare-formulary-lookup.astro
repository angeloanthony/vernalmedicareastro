        { name: 'Novolog', generic: 'insulin aspart', brand: true, tier: 3, cost: '$35 cap', pa: false, ql: false, step: false, genericAvail: true, status: 'covered', treats: 'Rapid-acting insulin for diabetes.', coverage: 'Covered insulin — $35/month cap. Generic aspart available.', alts: ['insulin aspart (generic)', 'Humalog'] },
        { name: 'Biktarvy', generic: 'bictegravir/emtricitabine/tenofovir', brand: true, tier: 5, cost: '25–33% coinsurance', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'HIV.', coverage: 'Tier 5 specialty; protected drug class, broadly covered.', alts: ['Talk to your specialist'] },
