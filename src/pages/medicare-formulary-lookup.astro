        { name: 'Insulin (generic lispro)', generic: 'insulin lispro', brand: false, tier: 2, cost: '$35 cap', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Rapid-acting insulin for diabetes.', coverage: 'Covered insulin — capped at $35/month under Medicare.', alts: ['Humalog', 'Novolog'] },
        { name: 'Synthroid', generic: 'levothyroxine', brand: true, tier: 2, cost: '$10–$40', pa: false, ql: false, step: false, genericAvail: true, status: 'covered', treats: 'Underactive thyroid (brand levothyroxine).', coverage: 'Covered, but the generic (levothyroxine) is far lower cost.', alts: ['levothyroxine (generic)'] },
        { name: 'Lyrica', generic: 'pregabalin', brand: true, tier: 3, cost: '$40–$100', pa: false, ql: false, step: true, genericAvail: true, status: 'restrict', treats: 'Nerve pain and fibromyalgia.', coverage: 'Brand often requires step therapy; generic pregabalin preferred.', alts: ['pregabalin (generic)', 'Gabapentin'] },
      ];

      var searchEl = document.getElementById('fl-search');
      var tierEl = document.getElementById('fl-tier');
      var gridEl = document.getElementById('fl-grid');
      var countEl = document.getElementById('fl-count');
      var datalist = document.getElementById('fl-drug-names');
      var filters = document.querySelector('.fl-filters');
      var modal = document.getElementById('fl-modal');
      var panel = document.getElementById('fl-modal-panel');
      if (!searchEl || !tierEl || !gridEl || !countEl || !datalist || !filters || !modal || !panel) return;

      datalist.innerHTML = DRUGS.map(function (d) { return '<option value="' + d.name + '"></option>'; }).join('');

      var STATUS = {
        covered: { cls: 'is-green', label: 'Covered' },
        restrict: { cls: 'is-amber', label: 'Restrictions apply' },
        notcov: { cls: 'is-red', label: 'Not typically covered' },
      };

      function matches(d, q, tier, showGen) {
        if (tier !== 'all' && String(d.tier) !== tier) return false;
        if (showGen === 'no' && !d.brand) return false;
        if (!q) return true;
        var hay = (d.name + ' ' + d.generic).toLowerCase();
        return hay.indexOf(q) !== -1;
      }

      function render() {
        var q = searchEl.value.trim().toLowerCase();
        var tier = tierEl.value;
        var showGen = document.querySelector('input[name="fl-showgen"]:checked').value;

        var list = DRUGS.filter(function (d) { return matches(d, q, tier, showGen); })
          .sort(function (a, b) { return a.name.localeCompare(b.name); });

        countEl.textContent = 'Showing ' + list.length + ' of ' + DRUGS.length + ' medications.';

        if (!list.length) {
          gridEl.innerHTML = '<div class="fl-empty"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"></circle><path d="M15.3 15.3L21 21"></path></svg></span>No medications match. <a href="' + smsHref + '">Text us the name &rarr;</a></div>';
          return;
        }

        gridEl.innerHTML = list.map(function (d) {
          var st = STATUS[d.status];
          var chips = '';
          if (d.pa) chips += '<span class="fl-pill is-amber">Prior auth</span>';
          if (d.step) chips += '<span class="fl-pill is-amber">Step therapy</span>';
          if (d.ql) chips += '<span class="fl-pill is-amber">Quantity limit</span>';
          if (d.genericAvail) chips += '<span class="fl-pill is-blue">Generic available</span>';
          return '<div class="fl-drug">' +
            '<div class="fl-drug-top"><div><h3>' + d.name + '</h3><div class="fl-drug-sub">' + (d.brand ? 'Brand' : 'Generic') + ' &middot; ' + d.generic + '</div></div>' +
            '<span class="fl-pill ' + st.cls + '">' + st.label + '</span></div>' +
            '<div class="fl-drug-meta"><span class="fl-pill is-tier">Tier ' + d.tier + '</span>' + chips + '</div>' +
            '<div class="fl-drug-cost">' + d.cost + ' <span>typical / month</span></div>' +
            '<button type="button" class="fl-view" data-i="' + DRUGS.indexOf(d) + '">View details <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg></button>' +
            '</div>';
        }).join('');
      }

      function openModal(d) {
        var st = STATUS[d.status];
        var questions = [];
        questions.push('Is there a lower-tier or generic alternative that works for me?');
        if (d.pa) questions.push('Will you help me submit a prior authorization?');
        if (d.step) questions.push('Do I need to try another medication first (step therapy)?');
        if (d.ql) questions.push('Are there quantity limits I should plan around?');
        questions.push('Which drugs on my specific Part D plan would be the lowest cost?');

        panel.innerHTML =
          '<button type="button" class="fl-modal-close" data-fl-close aria-label="Close">&times;</button>' +
          '<h2>' + d.name + '</h2><p class="fl-modal-sub">' + (d.brand ? 'Brand name' : 'Generic') + ' &middot; ' + d.generic + ' &middot; Tier ' + d.tier + ' &middot; <span class="fl-pill ' + st.cls + '">' + st.label + '</span></p>' +
          '<div class="fl-modal-sec"><h4>What it treats</h4><p>' + d.treats + '</p></div>' +
          '<div class="fl-modal-sec"><h4>Typical Medicare Part D coverage</h4><p>' + d.coverage + ' Typical cost: <strong>' + d.cost + '</strong> per month.</p></div>' +
          '<div class="fl-modal-sec"><h4>Alternative drugs</h4><ul>' + d.alts.map(function (a) { return '<li>' + a + '</li>'; }).join('') + '</ul></div>' +
          '<div class="fl-modal-sec"><h4>Questions to ask your doctor</h4><ul>' + questions.map(function (x) { return '<li>' + x + '</li>'; }).join('') + '</ul></div>' +
          '<div class="fl-modal-sec fl-modal-cta"><a class="fl-pill is-blue fl-modal-link" href="' + smsHref + encodeURIComponent(d.name) + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"></path></svg> Text us about ' + d.name + '</a></div>';
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function closeModal() { modal.classList.remove('is-open'); document.body.style.overflow = ''; }

      gridEl.addEventListener('click', function (e) {
        var btn = e.target.closest('.fl-view');
        if (btn) openModal(DRUGS[parseInt(btn.getAttribute('data-i'), 10)]);
      });
      modal.addEventListener('click', function (e) { if (e.target.closest('[data-fl-close]')) closeModal(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal(); });

      document.querySelectorAll('.fl-chip').forEach(function (c) {
        c.addEventListener('click', function () {
          searchEl.value = c.textContent === 'Insulin' ? 'insulin' : c.textContent;
          render();
          searchEl.focus();
        });
      });

      searchEl.addEventListener('input', render);
      tierEl.addEventListener('change', render);
      filters.addEventListener('change', render);
      render();
    })();
  </script>

  <h2>How Part D Formularies Work</h2>
  <div class="fl-edu">
    <div class="fl-edu-item"><h3>What is a formulary?</h3><p>The list of drugs your Medicare Part D or Medicare Advantage plan covers, organized into pricing tiers.</p></div>
    <div class="fl-edu-item"><h3>What are drug tiers?</h3><p>Tiers group covered drugs by cost — Tier 1–2 are low-cost generics, Tier 3 preferred brands, Tier 4 non-preferred, Tier 5 specialty drugs.</p></div>
    <div class="fl-edu-item"><h3>What is prior authorization?</h3><p>Your plan must approve the drug before covering it, usually to confirm it's medically necessary.</p></div>
    <div class="fl-edu-item"><h3>What is step therapy?</h3><p>You may need to try one or more lower-cost drugs first before the plan covers a more expensive option.</p></div>
    <div class="fl-edu-item"><h3>What are quantity limits?</h3><p>Plans may limit how much of a drug they cover over a period of time for safety or cost reasons.</p></div>
    <div class="fl-edu-item"><h3>What if my drug is not covered?</h3><p>You can request a formulary exception and appeal, switch to a covered alternative, or compare plans during enrollment. We can help.</p></div>
  </div>
</CalculatorPage>

<style>
