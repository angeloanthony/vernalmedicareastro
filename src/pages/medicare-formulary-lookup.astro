        { name: 'Tamsulosin', generic: 'tamsulosin', brand: false, tier: 1, cost: '$0–$10', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Enlarged prostate (generic Flomax).', coverage: 'Tier 1 generic.', alts: ['Finasteride', 'Alfuzosin'] },
        { name: 'Allopurinol', generic: 'allopurinol', brand: false, tier: 1, cost: '$0–$6', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Gout prevention.', coverage: 'Tier 1 generic.', alts: ['Febuxostat'] },
        { name: 'Prednisone', generic: 'prednisone', brand: false, tier: 1, cost: '$0–$5', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Inflammation, allergic and autoimmune conditions (steroid).', coverage: 'Tier 1 generic.', alts: ['Methylprednisolone'] },
        { name: 'Tramadol', generic: 'tramadol', brand: false, tier: 2, cost: '$2–$12', pa: false, ql: true, step: false, genericAvail: false, status: 'restrict', treats: 'Moderate pain.', coverage: 'Tier 2 generic; quantity limits often apply (controlled substance).', alts: ['Acetaminophen', 'Hydrocodone/acetaminophen'] },
