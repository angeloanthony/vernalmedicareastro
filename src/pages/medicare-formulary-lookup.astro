        { name: 'Farxiga', generic: 'dapagliflozin', brand: true, tier: 3, cost: '$45–$100', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Type 2 diabetes, heart failure, chronic kidney disease.', coverage: 'Usually a Tier 3 preferred brand.', alts: ['Jardiance', 'Metformin (generic)'] },
        { name: 'Januvia', generic: 'sitagliptin', brand: true, tier: 3, cost: '$45–$100', pa: false, ql: false, step: true, genericAvail: false, status: 'restrict', treats: 'Type 2 diabetes.', coverage: 'Often Tier 3; some plans require step therapy after metformin.', alts: ['Metformin (generic)', 'Jardiance'] },
