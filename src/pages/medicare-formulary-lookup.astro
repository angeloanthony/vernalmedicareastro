        { name: 'Wegovy', generic: 'semaglutide', brand: true, tier: 3, cost: 'Not covered', pa: false, ql: false, step: false, genericAvail: false, status: 'notcov', treats: 'Chronic weight management.', coverage: 'Medicare Part D generally does NOT cover drugs used only for weight loss.', alts: ['Talk to your doctor about covered options'] },
