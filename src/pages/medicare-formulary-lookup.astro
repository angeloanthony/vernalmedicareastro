---
// src/pages/medicare-formulary-lookup.astro — NET-NEW page. A searchable
// Part D formulary lookup: type or browse a medication, filter by tier, and
// see typical coverage status, restrictions (PA/step/quantity limit), cost,
// and generic alternatives. Built on CalculatorPage for the shared
// header/byline/summary/FAQ/related/CTA/disclaimer + HowTo schema; the
// search/filter/modal widget is bespoke and lives entirely in the slot with
// its own scoped styles/script, matching the drug-cost-calculator pattern.
import CalculatorPage from '../components/layout/CalculatorPage.astro';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const phoneTel = `tel:${BUSINESS.phoneTel}`;
const smsHref = `sms:${BUSINESS.phoneTel}?body=${encodeURIComponent('Hi, can you look up coverage for my medication? It is: ')}`;
const ctaSmsHref = `sms:${BUSINESS.phoneTel}?body=${encodeURIComponent('Hi, can you check which plan covers my medications? My medications are: ')}`;

const context: PageContext = {
  page: {
    title: 'Medicare Formulary Lookup | Is My Drug Covered? | Vernal Medicare',
    heading: 'Medicare Formulary Lookup',
    description:
      'Free Medicare Part D formulary lookup. Search medications to see typical coverage tier, costs, prior authorization, step therapy, and generic alternatives.',
    taxonomy: { silo: 'part-d', tags: ['part-d', 'formulary', 'tiers', 'drugs', 'tools', 'coverage'] },
    summary:
      'Search a medication to see its typical Medicare Part D formulary tier, restrictions like prior authorization or step therapy, an estimated monthly cost, and lower-cost generic alternatives. These are educational estimates — your exact coverage depends on your specific plan.',
    faqs: [
      {
        question: 'Does Medicare cover Ozempic?',
        answer:
          'Medicare Part D plans typically cover Ozempic when it is prescribed for type 2 diabetes, usually on a higher brand tier and often with prior authorization. It is generally not covered for weight loss alone.',
      },
      {
        question: 'What is a formulary?',
        answer:
          'A formulary is the list of drugs a Medicare Part D or Medicare Advantage plan covers, organized into pricing tiers.',
      },
      {
        question: 'What are drug tiers?',
        answer:
          'Tiers group covered drugs by cost. Lower tiers (1–2) are generics with low copays; higher tiers (3–5) are preferred brands, non-preferred brands, and specialty drugs with higher costs.',
      },
      {
        question: 'What is prior authorization?',
        answer:
          'Prior authorization means your plan must approve a drug before it will cover it, usually to confirm it is medically necessary.',
      },
      {
        question: 'What is step therapy?',
        answer:
          'Step therapy requires you to try one or more lower-cost drugs first before the plan covers a more expensive option.',
      },
      {
        question: 'Can I appeal a coverage denial?',
        answer:
          'Yes. If your plan denies coverage, you can request an exception and file an appeal. A licensed agent or your doctor can help with the paperwork.',
      },
    ],
    sources: [
      { title: 'Medicare.gov — drug coverage (Part D)', url: 'https://www.medicare.gov/drug-coverage-part-d', publisher: 'Medicare.gov' },
      { title: 'Medicare Plan Finder', url: 'https://www.medicare.gov/plan-compare/', publisher: 'Medicare.gov' },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-formulary-lookup.html',
    ogType: 'website',
    ogTitle: 'Medicare Formulary Lookup',
    ogDescription: 'Search medications to understand typical Medicare Part D formulary coverage, tiers, restrictions, and generic alternatives.',
  },
  author: 'rocco',
  datePublished: '2026-07-09',
  lastUpdated: '2026-07-09',
  medicalDisclaimer:
    'Educational estimates only — not a substitute for reviewing your specific Medicare Part D plan formulary. Tiers, costs, and restrictions vary by plan and year. Confirm with your plan, Medicare Plan Finder, or a licensed agent.',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Calculators', href: '/medicare-calculators.html' },
    { name: 'Formulary Lookup', href: '/medicare-formulary-lookup.html' },
  ],
};
---

<CalculatorPage context={context}>
  <p>Every Medicare Part D and Medicare Advantage plan has its own formulary — the list of drugs it covers and what tier each one sits on. Search a medication below for typical coverage, restrictions, and generic alternatives. For your exact copay, <a href="best-part-d-plans-vernal.html">compare Part D plans</a>.</p>

  <div class="fl">
    <div class="fl-search-row">
      <div class="fl-combo">
        <span class="fl-search-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"></circle><path d="M15.3 15.3L21 21"></path></svg></span>
        <label for="fl-search" class="fl-sr-only">Search medications</label>
        <input type="text" id="fl-search" class="fl-control" list="fl-drug-names" autocomplete="off" placeholder="Search a medication — e.g. Eliquis, Ozempic, metformin" />
        <datalist id="fl-drug-names"></datalist>
      </div>
      <div class="fl-filters">
        <div class="fl-field">
          <label class="fl-label" for="fl-tier"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l9 5-9 5-9-5 9-5z"></path><path d="M3 13l9 5 9-5"></path></svg></span> Tier</label>
          <select id="fl-tier" class="fl-control">
            <option value="all">All tiers</option>
            <option value="1">Tier 1</option><option value="2">Tier 2</option>
            <option value="3">Tier 3</option><option value="4">Tier 4</option><option value="5">Tier 5</option>
          </select>
        </div>
        <div class="fl-field">
          <label class="fl-label"><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="4.5"></circle><circle cx="16" cy="16" r="4.5"></circle></svg></span> Show generic alternatives?</label>
          <div class="fl-seg">
            <input type="radio" id="fl-gen-yes" name="fl-showgen" value="yes" checked /><label for="fl-gen-yes">Yes</label>
            <input type="radio" id="fl-gen-no" name="fl-showgen" value="no" /><label for="fl-gen-no">No</label>
          </div>
        </div>
      </div>
    </div>

    <div class="fl-examples">
      <span class="fl-examples-lbl">Try:</span>
      <button type="button" class="fl-chip">Eliquis</button>
      <button type="button" class="fl-chip">Ozempic</button>
      <button type="button" class="fl-chip">Jardiance</button>
      <button type="button" class="fl-chip">Xarelto</button>
      <button type="button" class="fl-chip">Farxiga</button>
      <button type="button" class="fl-chip">Metformin</button>
      <button type="button" class="fl-chip">Insulin</button>
    </div>

    <p class="fl-count" id="fl-count"></p>
    <div class="fl-grid" id="fl-grid" aria-live="polite"></div>
  </div>

  <div class="fl-cta">
    <h2>Questions about prescription coverage?</h2>
    <p>Send us your medication list — we’ll find the plan that covers them for the least. Free, no pressure.</p>
    <div class="fl-cta-row">
      <a class="fl-cta-primary" href={phoneTel}><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"></path></svg></span> Call {BUSINESS.phone}</a>
      <a class="fl-cta-ghost" href={ctaSmsHref}><span aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"></path></svg></span> Text Your Meds</a>
    </div>
  </div>

  <!-- Drug details modal -->
  <div class="fl-modal" id="fl-modal" role="dialog" aria-modal="true" aria-label="Drug details">
    <div class="fl-modal-bg" data-fl-close></div>
    <div class="fl-modal-panel" id="fl-modal-panel"></div>
  </div>

  <script define:vars={{ smsHref }}>
    (function () {
      'use strict';

      // Educational dataset — typical Part D formulary placement. Swap for a
      // live API (RxNorm / CMS / FDB) with the same shape and the UI is unchanged.
      var DRUGS = [
        { name: 'Eliquis', generic: 'apixaban', brand: true, tier: 3, cost: '$45–$100', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Prevents blood clots and stroke, often in atrial fibrillation.', coverage: 'Usually covered as a preferred brand (Tier 3). No generic is available yet.', alts: ['Xarelto', 'Warfarin (generic)'] },
        { name: 'Xarelto', generic: 'rivaroxaban', brand: true, tier: 3, cost: '$45–$100', pa: false, ql: false, step: false, genericAvail: false, status: 'covered', treats: 'Prevents and treats blood clots; reduces stroke risk in AFib.', coverage: 'Typically a Tier 3 preferred brand on most plans.', alts: ['Eliquis', 'Warfarin (generic)'] },
        { name: 'Ozempic', generic: 'semaglutide', brand: true, tier: 3, cost: '$50–$120', pa: true, ql: true, step: false, genericAvail: false, status: 'restrict', treats: 'Type 2 diabetes; lowers blood sugar and cardiovascular risk.', coverage: 'Covered for diabetes, usually with prior authorization and quantity limits. Not covered for weight loss alone.', alts: ['Trulicity', 'Jardiance', 'Metformin (generic)'] },
        { name: 'Mounjaro', generic: 'tirzepatide', brand: true, tier: 3, cost: '$50–$120', pa: true, ql: true, step: false, genericAvail: false, status: 'restrict', treats: 'Type 2 diabetes; lowers blood sugar.', coverage: 'Covered for diabetes with prior authorization on many plans.', alts: ['Ozempic', 'Trulicity'] },
