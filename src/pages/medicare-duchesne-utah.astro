---
// src/pages/medicare-duchesne-utah.astro — MIGRATED to the Page Framework (M12),
// then REDESIGNED (visual pass) from a text-wall into a scannable landing page to
// match the Roosevelt flagship: golden-hour Basin hero with trust band, "Medicare
// Coverage Options" plan cards, a "Why Work With a Local Agent" split with agent
// card, and a dark CTA band. All SEO prose, internal links, the Part B deductible
// figure, FAQs and schema are preserved — only the presentation changed. bareHeader
// renders the custom hero; the default FAQ/sources/related/CTA/disclaimer footer
// still renders from context.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { figuresFor } from '../data/annualMedicareData';
import { BUSINESS } from '../data/business';
import { usd } from '../lib/formatters';
import { relatedFor } from '../lib/related';
import { PAGE_INDEX } from '../data/pageIndex';
import type { PageContext } from '../types/Page';

const f = figuresFor();

const context: PageContext = {
  page: {
    title: 'Medicare Agent in Duchesne, Utah | Free Medicare Help 2026',
    heading: 'Medicare Agent Serving Duchesne, Utah — 2026',
    description:
      'Licensed Medicare agent serving Duchesne, Utah. Free help comparing Medicare Advantage, Medigap, and Part D plans in 2026. Call 435-219-5120.',
    taxonomy: { silo: 'local', tags: ['local', 'duchesne', 'duchesne-county', 'overview', 'original-medicare'] },
    summary:
      'Duchesne sits at the western edge of the Uintah Basin, about 60 miles from Vernal, where local Medicare help is scarce. We provide free, licensed guidance to Duchesne residents — Medicare Advantage, Medigap, and Part D — by phone, video, or in person, at no cost to you.',
    faqs: [
      {
        question: 'Is there a Medicare agent in Duchesne, Utah?',
        answer:
          'Vernal Medicare serves Duchesne and all of Duchesne County with free Medicare plan comparisons and enrollment help. Call Rocco DeLuca at 435-219-5120.',
      },
      {
        question: 'What Medicare plans work in Duchesne, Utah?',
        answer:
          'Duchesne residents can access Medicare Advantage (HMO/PPO), Medicare Supplement (Medigap Plan G and Plan N), and Part D drug plans. We compare all options for 2026 at no cost.',
      },
      {
        question: 'How much does Medicare help cost in Duchesne?',
        answer:
          'There is no cost to you. Vernal Medicare is compensated by insurance carriers. You receive free plan comparisons, enrollment support, and year-round assistance.',
      },
    ],
    sources: [
      { title: 'Find & compare plans in your area', url: 'https://www.medicare.gov/plan-compare', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'If you live in or near Duchesne,', action: `call us free at ${BUSINESS.phone} — we’ll review your coverage and compare 2026 plans at no cost.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-duchesne-utah.html',
    ogType: 'article',
    ogTitle: 'Medicare Agent Serving Duchesne, Utah — 2026',
    ogDescription: 'Free, licensed Medicare help for Duchesne and Duchesne County.',
    gaIds: ['G-NW6ENB89NF', 'G-FTDW9B2G6Q'],
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-06-30',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Duchesne, Utah', href: '/medicare-duchesne-utah.html' },
  ],
};

const tel = `tel:${BUSINESS.phoneTel}`;
const partBDeductible = usd(f.partB.deductible);
// Same related-links computation the layout uses, so our custom card stays in sync.
const related = relatedFor(context.page.taxonomy, PAGE_INDEX, '/medicare-duchesne-utah.html').slice(0, 4);
---

<ArticlePage context={context} bareHeader bareFooter>
  <div class="dz">

    <!-- ================= HERO ================= -->
    <section class="dz-hero">
      <img src="pictures/medicareduchesne.webp" alt="" class="dz-hero__bg" width="1600" height="700" loading="eager" decoding="async" fetchpriority="high" />
      <span class="dz-hero__scrim" aria-hidden="true"></span>
      <div class="dz-hero__inner">
        <div class="dz-hero__copy">
          <span class="dz-eyebrow">Duchesne, UT · The Uintah Basin</span>
          <h1>Medicare Agent Serving <span class="dz-hl">Duchesne, Utah</span> — <span class="dz-year">2026</span></h1>
          <p class="dz-hero__lead">
            Local, licensed help you can trust. We make Medicare simple so you can choose the
            right plan with confidence.
          </p>
          <div class="dz-hero__btns">
            <a href={tel} class="dz-btn dz-btn--primary">📞 Call {BUSINESS.phone} <span>(TTY {BUSINESS.tty})</span></a>
            <a href={`mailto:${BUSINESS.email}`} class="dz-btn dz-btn--ghost">✉️ Email Us</a>
          </div>
        </div>

        <ul class="dz-hero__trust">
          <li><span class="dz-trust__ic" aria-hidden="true">📍</span><strong>Local Agent</strong><span>Duchesne, UT</span></li>
          <li><span class="dz-trust__ic" aria-hidden="true">🛡️</span><strong>Trusted Guidance</strong><span>Year-Round Support</span></li>
          <li><span class="dz-trust__ic" aria-hidden="true">$</span><strong>No Cost</strong><span>To You</span></li>
        </ul>
      </div>
    </section>

    <!-- ================= COVERAGE OPTIONS ================= -->
    <section class="dz-plans">
      <h2 class="dz-h2 dz-h2--center">Medicare Coverage Options in Duchesne</h2>
      <p class="dz-sub">The right choice depends on your doctors, prescriptions, preferred pharmacy, and budget — we compare all of it with you.</p>
      <div class="dz-plans__grid">
        <article class="dz-plan dz-plan--blue">
          <span class="dz-plan__ic dz-plan__ic--blue" aria-hidden="true">🛡️</span>
          <h3>Medicare Advantage (Part C)</h3>
          <p>All-in-one plans that may include dental, vision, hearing, and more.</p>
          <a href="best-medicare-advantage-vernal.html" class="dz-plan__link dz-plan__link--blue">Explore Advantage Plans →</a>
        </article>
        <article class="dz-plan dz-plan--green">
          <span class="dz-plan__ic dz-plan__ic--green" aria-hidden="true">💊</span>
          <h3>Medigap</h3>
          <p>Help pay your out-of-pocket costs with predictable coverage options.</p>
          <a href="plan-g-vs-plan-n-vernal.html" class="dz-plan__link dz-plan__link--green">View Medigap Plans →</a>
        </article>
        <article class="dz-plan dz-plan--purple">
          <span class="dz-plan__ic dz-plan__ic--purple" aria-hidden="true">℞</span>
          <h3>Part D Prescription Drug Plans</h3>
          <p>Compare drug coverage and find the lowest cost for your medications.</p>
          <a href="best-part-d-plans-vernal.html" class="dz-plan__link dz-plan__link--purple">Compare Drug Plans →</a>
        </article>
        <article class="dz-plan dz-plan--orange">
          <span class="dz-plan__ic dz-plan__ic--orange" aria-hidden="true">👥</span>
          <h3>Medigap for Rural Residents</h3>
          <p>Special care for rural Duchesne residents who travel for care.</p>
          <a href="medicare-supplement-vs-advantage.html" class="dz-plan__link dz-plan__link--orange">Learn More →</a>
        </article>
      </div>
    </section>

    <!-- ================= WHY LOCAL + AGENT CARD ================= -->
    <section class="dz-why">
      <div class="dz-why__body">
        <h2 class="dz-h2 dz-h2--rule">Why Work With a Local Agent?</h2>
        <p>
          Rocco DeLuca understands the unique healthcare needs of Duchesne residents. He compares
          plans from top providers, explains your options clearly, and supports you year-round —
          not just during enrollment. National call centers and online tools can’t account for the
          realities of healthcare in rural Utah.
        </p>

        <div class="dz-mini">
          <div class="dz-mini__item">
            <span class="dz-mini__ic dz-mini__ic--blue" aria-hidden="true">👥</span>
            <div><strong>Local expertise</strong><span>In Duchesne &amp; the Uintah Basin</span></div>
          </div>
          <div class="dz-mini__item">
            <span class="dz-mini__ic dz-mini__ic--green" aria-hidden="true">🤝</span>
            <div><strong>Top-rated plans</strong><span>From providers you can trust</span></div>
          </div>
          <div class="dz-mini__item">
            <span class="dz-mini__ic dz-mini__ic--purple" aria-hidden="true">📅</span>
            <div><strong>Year-round support</strong><span>By phone, video, or in person</span></div>
          </div>
          <div class="dz-mini__item">
            <span class="dz-mini__ic dz-mini__ic--orange" aria-hidden="true">$</span>
            <div><strong>Always free</strong><span>No cost for our services — ever</span></div>
          </div>
        </div>
      </div>

      <aside class="dz-agentcard">
        <div class="dz-agentcard__head">
          <img src="pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent" width="60" height="60" loading="lazy" decoding="async" />
          <h2>Talk to a Local, Licensed Agent</h2>
        </div>
        <p>Get answers, compare plans, and enroll with confidence.</p>
        <a href={tel} class="dz-btn dz-btn--primary dz-btn--block">📞 Call {BUSINESS.phone} <span>(TTY {BUSINESS.tty})</span></a>
        <a href={BUSINESS.quoteUrl} class="dz-btn dz-btn--light dz-btn--block" target="_blank" rel="noopener noreferrer">📋 Get a Free Quote</a>
      </aside>
    </section>

    <!-- ================= LOCAL FOCUS (scannable) ================= -->
    <section class="dz-focus">
      <h2 class="dz-h2 dz-h2--center">Medicare in Duchesne County</h2>
      <p class="dz-sub">
        Duchesne sits at the western edge of the Uintah Basin, about 60 miles from Vernal. Out here,
        the right plan is the one that actually covers your doctors, your pharmacy, and the hospitals
        you’d travel to.
      </p>

      <div class="dz-focus__grid">
        <div class="dz-infocard">
          <span class="dz-infocard__ic dz-infocard__ic--blue" aria-hidden="true">✓</span>
          <h3>What we check before you enroll</h3>
          <ul class="dz-check">
            <li>Your local clinics are in-network</li>
            <li>The providers you trust accept the plan</li>
            <li>Regional hospitals are covered — no surprise bills</li>
          </ul>
        </div>

        <div class="dz-infocard">
          <span class="dz-infocard__ic dz-infocard__ic--green" aria-hidden="true">🩺</span>
          <h3>Medigap for rural residents</h3>
          <p>
            <a href="plan-g-vs-plan-n-vernal.html">Plan G</a> pairs with Original Medicare and lets
            you see any Medicare-accepting provider nationwide — ideal when specialist care means a
            trip to Provo or Salt Lake City. It covers everything except the annual Part B deductible
            (<strong>{partBDeductible} in {f.year}</strong>); Plan N trades small office-visit copays
            for a lower premium.
          </p>
        </div>

        <div class="dz-infocard">
          <span class="dz-infocard__ic dz-infocard__ic--purple" aria-hidden="true">℞</span>
          <h3>Part D drug coverage</h3>
          <p>
            We compare your exact medications against every available plan and check pricing at
            Duchesne-area pharmacies to find the lowest total cost for the year — not just the lowest
            premium.
          </p>
        </div>
      </div>

      <div class="dz-area">
        <span class="dz-area__label">📍 We serve the whole Basin</span>
        <ul class="dz-chips">
          <li>Duchesne</li>
          <li><a href="medicare-roosevelt-utah.html" class="dz-chip__link">Roosevelt</a></li>
          <li>Myton</li>
          <li>Tabiona</li>
          <li>Altamont</li>
          <li>Neola</li>
          <li>+ surrounding communities</li>
        </ul>
        <p class="dz-area__note">By phone, video, or in person — at no cost to you.</p>
      </div>

      <p class="dz-basics">
        New to Medicare? Start with
        <a href="medicare-supplement-vs-advantage.html">Medigap vs Medicare Advantage</a> ·
        <a href="medicare-part-a-vs-part-b.html">Part A vs Part B</a> ·
        <a href="when-to-enroll-medicare-utah.html">when to enroll in Utah</a>.
      </p>
    </section>

    <!-- ================= FOOTER CARD ROW ================= -->
    <section class="dz-cards">
      <article class="dz-fcard">
        <div class="dz-fcard__head"><span class="dz-fcard__ic dz-fcard__ic--orange" aria-hidden="true">❓</span><h3>Frequently Asked Questions</h3></div>
        <ul class="dz-fcard__list">
          {context.page.faqs?.map((q) => <li>{q.question}</li>)}
        </ul>
        <a href="faq.html" class="dz-fcard__more">View all FAQs →</a>
      </article>

      <article class="dz-fcard">
        <div class="dz-fcard__head"><span class="dz-fcard__ic dz-fcard__ic--blue" aria-hidden="true">🌐</span><h3>Sources</h3></div>
        <ul class="dz-fcard__list dz-fcard__list--links">
          {context.page.sources?.map((s) => <li><a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a> — {s.publisher}</li>)}
        </ul>
      </article>

      <article class="dz-fcard">
        <div class="dz-fcard__head"><span class="dz-fcard__ic dz-fcard__ic--purple" aria-hidden="true">🔗</span><h3>Related</h3></div>
        <ul class="dz-fcard__list dz-fcard__list--links">
          {related.map((r) => <li><a href={r.href}>{r.label}</a></li>)}
        </ul>
      </article>

      <article class="dz-fcard dz-fcard--photo">
        <img src="pictures/help-you-deserve.webp" alt="Local, trusted Medicare help for Duchesne residents" class="dz-fcard__photo" width="480" height="320" loading="lazy" decoding="async" />
        <div class="dz-fcard__photobody">
          <h3>We’re here for Duchesne.</h3>
          <p>Local help. Real answers. No pressure.</p>
        </div>
      </article>
    </section>

    <!-- ================= CTA BAND ================= -->
    <section class="dz-cta">
      <div class="dz-cta__copy">
        <span class="dz-cta__ic" aria-hidden="true">📅</span>
        <div>
          <h2>Ready to Compare Plans or Enroll?</h2>
          <p>Call Rocco DeLuca for a free Medicare consultation.</p>
        </div>
      </div>
      <div class="dz-cta__btns">
        <a href={tel} class="dz-btn dz-btn--primary">📞 Call {BUSINESS.phone} (TTY {BUSINESS.tty})</a>
        <a href={BUSINESS.quoteUrl} class="dz-btn dz-btn--light" target="_blank" rel="noopener noreferrer">Get a Free Quote</a>
      </div>
    </section>

  </div>
</ArticlePage>

<style>
  /* ============ Duchesne landing page (scoped) ============ */
  .dz {
    --navy: #0b2c45;
    --navy-2: #002b49;
    --orange: #e07817;
    --orange-2: #f4922e;
    --ink: #223140;
    --muted: #5a6b7b;
    --line: #e2e8f0;
    color: var(--ink);
    line-height: 1.55;
  }
  .dz * { box-sizing: border-box; }
  .dz section { margin: 3rem 0; }

  .dz .dz-h2 {
    font-size: clamp(1.5rem, 1rem + 1.4vw, 2rem);
    color: var(--navy);
    margin: 0 0 .5rem;
    line-height: 1.2;
  }
  .dz .dz-h2--center { text-align: center; }
  .dz .dz-h2--center::after {
    content: "";
    display: block;
    width: 64px; height: 4px;
    margin: .6rem auto 0;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--orange), var(--orange-2));
  }
  .dz .dz-sub { text-align: center; color: var(--muted); margin: 0 auto 1.8rem; max-width: 640px; }

  /* Links inside the design → brand navy, not the global magenta */
  .dz a:not(.dz-btn):not(.dz-plan__link):not(.dz-fcard__more):not(.dz-chip__link) {
    color: var(--navy); font-weight: 700; text-decoration: underline; text-underline-offset: 2px;
  }
  .dz a:not(.dz-btn):not(.dz-plan__link):not(.dz-fcard__more):not(.dz-chip__link):hover { color: var(--orange); }

  /* ---------- Buttons ---------- */
  .dz .dz-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
    padding: .8rem 1.2rem; border-radius: 12px; font-weight: 800; text-decoration: none;
    font-size: 1rem; line-height: 1.15; border: 2px solid transparent;
    transition: transform .12s ease, box-shadow .12s ease, background .2s ease;
  }
  .dz .dz-btn span { font-weight: 600; opacity: .9; font-size: .85em; }
  .dz .dz-btn:hover { transform: translateY(-1px); }
  .dz .dz-btn--block { display: flex; width: 100%; }
  .dz .dz-btn--primary { background: linear-gradient(180deg, var(--orange-2), var(--orange)); color: #fff; box-shadow: 0 8px 20px rgba(224,120,23,.30); }
  .dz .dz-btn--ghost { background: #fff; color: var(--navy); border-color: #fff; }
  .dz .dz-btn--light { background: #fff; color: var(--navy); }

  /* ---------- HERO ---------- */
  .dz-hero {
    position: relative; overflow: hidden; border-radius: 20px;
    background: #0b2c45;
    box-shadow: 0 20px 50px rgba(11,44,69,.18);
    margin-top: 1rem !important;
  }
  .dz-hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .dz-hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(6,26,43,.60) 0%, rgba(6,26,43,.32) 42%, rgba(6,26,43,0) 70%),
      linear-gradient(180deg, rgba(6,26,43,0) 55%, rgba(6,26,43,.22) 100%);
  }
  .dz-hero__inner {
    position: relative; z-index: 2;
    padding: clamp(1.4rem, 3vw, 3rem);
  }
  .dz-eyebrow {
    display: inline-block; background: rgba(11,44,69,.9); color: #fff; font-weight: 700;
    font-size: .78rem; letter-spacing: .04em; text-transform: uppercase; padding: .3rem .7rem; border-radius: 999px;
  }
  .dz-hero__copy h1 {
    color: #fff; font-size: clamp(2rem, 1.2rem + 3vw, 3.2rem); line-height: 1.08;
    margin: .8rem 0 .6rem; max-width: 16ch; text-shadow: 0 2px 12px rgba(0,0,0,.45);
  }
  .dz .dz-hl { color: #fff; }
  .dz .dz-year { color: var(--orange-2); }
  .dz-hero__lead { color: #eaf1f7; font-size: 1.08rem; max-width: 42ch; margin: 0 0 1.2rem; text-shadow: 0 1px 8px rgba(0,0,0,.4); }
  .dz-hero__btns { display: flex; flex-wrap: wrap; gap: .7rem; }

  .dz-hero__trust {
    list-style: none; margin: 1.8rem 0 0; padding: 1rem 1.2rem;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;
    background: rgba(11,44,69,.72); border: 1px solid rgba(255,255,255,.14);
    border-radius: 16px; backdrop-filter: blur(3px); max-width: 720px;
  }
  .dz-hero__trust li { display: grid; grid-template-columns: auto 1fr; column-gap: .7rem; align-items: center; color: #fff; }
  .dz-trust__ic {
    grid-row: span 2; width: 42px; height: 42px; border-radius: 50%; display: grid; place-items: center;
    font-size: 1.15rem; font-weight: 800; border: 2px solid rgba(255,255,255,.55);
  }
  .dz-hero__trust strong { font-size: 1rem; align-self: end; }
  .dz-hero__trust li > span:last-child { color: #c7d7e5; font-size: .82rem; align-self: start; }

  /* ---------- PLAN OPTION CARDS ---------- */
  .dz-plans__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .dz-plan {
    background: #fff; border: 1px solid var(--line); border-top: 4px solid var(--line);
    border-radius: 16px; padding: 1.6rem 1.4rem; text-align: center;
    box-shadow: 0 8px 24px rgba(11,44,69,.06); transition: transform .15s ease, box-shadow .15s ease;
    display: flex; flex-direction: column;
  }
  .dz-plan:hover { transform: translateY(-4px); box-shadow: 0 16px 36px rgba(11,44,69,.12); }
  .dz-plan--blue { border-top-color: var(--navy); }
  .dz-plan--green { border-top-color: #1f8a4c; }
  .dz-plan--purple { border-top-color: #7c3aed; }
  .dz-plan--orange { border-top-color: var(--orange); }
  .dz-plan__ic {
    width: 60px; height: 60px; border-radius: 50%; display: grid; place-items: center;
    font-size: 1.6rem; margin: 0 auto 1rem; background: #f5f9fc;
  }
  .dz-plan__ic--blue { color: var(--navy); background: #eef4fb; }
  .dz-plan__ic--green { color: #1f8a4c; background: #eef7f1; }
  .dz-plan__ic--purple { color: #7c3aed; background: #f2ecfd; }
  .dz-plan__ic--orange { color: var(--orange); background: #fdf1e4; }
  .dz-plan h3 { color: var(--navy); margin: 0 0 .5rem; font-size: 1.12rem; line-height: 1.2; }
  .dz-plan p { color: var(--muted); margin: 0 0 1.1rem; font-size: .95rem; flex: 1; }
  .dz-plan__link {
    display: block; margin: 0 -1.4rem -1.6rem; padding: .9rem; font-weight: 800; text-decoration: none;
    border-top: 1px solid var(--line); border-radius: 0 0 15px 15px;
  }
  .dz-plan__link--blue { color: var(--navy); background: #eef4fb; }
  .dz-plan__link--green { color: #1f8a4c; background: #eef7f1; }
  .dz-plan__link--purple { color: #7c3aed; background: #f2ecfd; }
  .dz-plan__link--orange { color: var(--orange); background: #fdf1e4; }
  .dz-plan__link:hover { filter: brightness(.97); }

  /* ---------- WHY LOCAL + AGENT CARD ---------- */
  .dz-why { display: grid; grid-template-columns: 1.5fr .9fr; gap: 1.8rem; align-items: start; }
  .dz .dz-h2--rule { margin-bottom: .7rem; }
  .dz .dz-h2--rule::after { content: ""; display: block; width: 56px; height: 4px; margin: .55rem 0 0; border-radius: 4px; background: linear-gradient(90deg, var(--orange), var(--orange-2)); }
  .dz-why__body > p { color: var(--ink); font-size: 1.04rem; }
  .dz-mini { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 1.5rem; }
  .dz-mini__item {
    display: flex; gap: .85rem; align-items: center;
    background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: .95rem 1.05rem;
    box-shadow: 0 6px 18px rgba(11,44,69,.05); transition: transform .15s ease, box-shadow .15s ease;
  }
  .dz-mini__item:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(11,44,69,.11); }
  .dz-mini__ic {
    flex: 0 0 auto; width: 46px; height: 46px; border-radius: 12px; display: grid; place-items: center;
    font-weight: 800; font-size: 1.15rem;
  }
  .dz-mini__ic--blue { background: #eef4fb; color: var(--navy); }
  .dz-mini__ic--green { background: #eef7f1; color: #1f8a4c; }
  .dz-mini__ic--purple { background: #f2ecfd; color: #7c3aed; }
  .dz-mini__ic--orange { background: #fdf1e4; color: var(--orange); }
  .dz-mini__item > div { display: grid; gap: .1rem; min-width: 0; }
  .dz-mini__item strong { color: var(--navy); font-size: .98rem; line-height: 1.2; }
