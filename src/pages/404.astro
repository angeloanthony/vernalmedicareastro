---
// src/pages/404.astro — friendly not-found page (M41). With build.format 'file'
// this emits dist/404.html, which static hosts serve for any unmatched URL.
// It's a wayfinding page, not content: route the lost visitor to the Decision
// Center first, then the main hubs and search. No Article schema — bespoke shell.
import BaseLayout from '../layouts/BaseLayout.astro';
import { BUSINESS } from '../data/business';
---

<BaseLayout
  title="Page Not Found (404) | Vernal Medicare"
  description="That page couldn’t be found. Start with your situation, browse the Medicare Help Center, or search the site."
  canonical="https://vernalmedicare.com/404.html"
>
  <main class="container" style="max-width:820px; padding:2.5rem 1rem;">
    <p style="text-transform:uppercase; letter-spacing:0.05em; font-weight:700; color:#9e0853; margin:0;">Error 404</p>
    <h1 style="margin:0.25rem 0 0.75rem;">We couldn’t find that page</h1>
    <p>The link may be old or mistyped — but you’re close. Here’s the fastest way to what you need.</p>

    <p style="background:#f4f8fb; border:1px solid #dbe6ef; border-radius:12px; padding:1.1rem 1.25rem; font-size:1.05rem;">
      <strong>Not sure where to start?</strong> <a href="/medicare-decision-center.html">Pick your situation</a> and we’ll route you to the right guide.
    </p>

    <h2 style="margin-top:2rem;">Popular starting points</h2>
    <ul style="line-height:1.9;">
      <li><a href="/medicare-help-center.html">Medicare Help Center</a> — the full map of every topic.</li>
      <li><a href="/turning-65.html">Turning 65</a> · <a href="/working-past-65.html">Working past 65</a> — enrollment journeys.</li>
      <li><a href="/medicare-coverage.html">Does Medicare cover it?</a> · <a href="/medicare-drug-coverage.html">Drug coverage</a> — coverage by service or medication.</li>
      <li><a href="/medicare-financial-assistance.html">Help paying for Medicare</a> · <a href="/medicare-calculators.html">Calculators</a> — costs and assistance.</li>
      <li><a href="/medicare-search.html">Search the whole site</a> — if you know what you’re looking for.</li>
    </ul>

    <h2 style="margin-top:2rem;">Or just ask a person — free</h2>
    <p><strong>Call us free at {BUSINESS.phone}</strong> (TTY: {BUSINESS.tty}). Tell us what you were looking for and we’ll get you there — no cost, no pressure.</p>
  </main>
</BaseLayout>
