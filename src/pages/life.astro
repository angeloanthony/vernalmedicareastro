---
// src/pages/life.astro — MIGRATED to the Page Framework.
// Life insurance (NOT Medicare). URL (/life.html), title, description, canonical,
// and the legacy H1 preserved. Now on ArticlePage: automatic Article+FAQ+Breadcrumb
// schema, byline, and related. The inline hand-rolled JSON-LD (InsuranceAgency +
// FAQPage) was removed — the framework generates it; the FAQ Q&A moved into
// page.faqs. No CMS multi-plan marketing block existed (this is not a Medicare
// page), so marketingDisclaimer is unset. The Vimeo <iframe> embed, the flip-comic,
// and the page script are preserved byte-for-byte in the body slot.
import ArticlePage from '../components/layout/ArticlePage.astro';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: 'Life Insurance in Vernal, Utah | Vernal Medicare',
    heading: 'Life Insurance — Simple & Local',
    description:
      'Simple, local help with life insurance—term, whole life, and final expense. Protect income, family, and debts with the right amount and term.',
    taxonomy: {
      silo: 'other-insurance',
      tags: ['other-insurance', 'life-insurance', 'final-expense', 'vernal'],
    },
    summary:
      "Life insurance protects your family's income, your home, and final expenses. Term life covers a set period for income, mortgage, and kids; whole life and final expense cover permanent needs like funeral costs. Simple, local, licensed help picking the right amount and term in Vernal and the Uintah Basin.",
    faqs: [
      {
        question: 'Which is best—term or whole life?',
        answer:
          'Most families start with term life to protect income, mortgage, and kids for a set period. Whole life or final expense can cover permanent needs like funeral costs.',
      },
      {
        question: 'Do I need a medical exam?',
        answer:
          'Some policies are no-exam or simplified issue; others may require labs. It depends on amount, age, and health.',
      },
      {
        question: 'How much coverage should I pick?',
        answer:
          'A common rule is 10–15× annual income, or enough to clear major debts and provide a few years of living expenses.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/life.html',
    ogType: 'article',
    ogDescription:
      'Simple, local help with life insurance—term, whole life, and final expense.',
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Life Insurance', href: '/life.html' },
  ],
};
---

<ArticlePage context={context}>
    <section class="container" id="medigap-intro">
      <h2 style="margin:16px 0;">Life Insurance — Video</h2>

      <div class="mg-two-up">
        <!-- LEFT: video card -->
        <div class="mg-card">
          <div class="mg-ratio">
            <iframe
              src="https://player.vimeo.com/video/1114526437?title=0&byline=0&portrait=0&dnt=1&autoplay=1&muted=1"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
              title="Life Insurance Video"></iframe>
          </div>
        </div>

        <!-- RIGHT: flip-on-click comic (3 images) -->
        <a class="vm-comic" href="pictures/joke12.webp" target="_blank" rel="noopener">
          <img
            src="pictures/joke12.webp"
            data-alt="pictures/joke35.webp"
            data-alt2="pictures/joke16.webp"
            alt="Medicare comic"
            loading="lazy" decoding="async">
        </a>
      </div>
    </section>

    <!-- Hero -->
    <section>
      <p>Protect your family's income, your home, and final expenses with a plan that fits your budget. I'll keep it simple and show clear options.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Life%20Insurance%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Life%20Insurance.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- What we offer -->
    <section>
      <h2>Common options</h2>
      <ul>
        <li><strong>Term Life</strong> — coverage for 10–30 years to protect income, mortgage, and kids.</li>
        <li><strong>Whole Life / Final Expense</strong> — smaller, permanent coverage for funeral costs and debts.</li>
        <li><strong>Living benefit riders</strong> — some policies include access to funds with certain illnesses (varies by carrier).</li>
      </ul>
      <p class="note">Rates depend on age, health, tobacco use, amount, and term. No-exam options may be available.</p>
    </section>

    <!-- How much / how long -->
    <section>
      <h2>How much do I need?</h2>
      <ul>
        <li>Many families choose <strong>10–15× annual income</strong> (or enough to pay off the mortgage + 5 years of expenses).</li>
        <li>Pick a term that matches your big goals (kids at home, years left on mortgage, or time to retirement).</li>
      </ul>
    </section>

    <!-- Simplicity-style program info -->
    <section>
      <h2>Medical bill payment help ("Simplicity" programs)</h2>
      <p><em>Not life insurance</em>, but worth knowing: some employers/health plans offer a "Simplicity" service that makes paying medical bills easier.</p>
      <ul>
        <li><strong>Consolidated billing</strong> — one monthly statement for covered services.</li>
        <li><strong>Interest-free payment plans</strong> — spread high out-of-pocket costs over time.</li>
        <li><strong>Pre-funded payments</strong> — the program can pay providers upfront; you repay the program.</li>
        <li><strong>Rewards & HSA integration</strong> — some add credits for future bills and link to your HSA.</li>
      </ul>
      <p class="note">Details vary by administrator (e.g., Trustmark, Sanford Health Plan, Humana). These are <strong>not</strong> major medical insurance.</p>
    </section>

    <!-- CTA -->
    <section>
      <h2>Get a quick quote</h2>
      <p>Tell me your age, state, and a target amount. I'll show simple options and prices—no pressure.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Life%20Insurance%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Life%20Insurance.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- Disclosures -->
    <section>
      <h2>Disclosures</h2>
      <p>Life insurance is subject to underwriting. Policy features, riders, and availability vary by carrier and state. Read the policy for terms, exclusions, and limitations.</p>
    </section>

<script is:inline>
  (function(){
    document.addEventListener('click', function(e){
      const link = e.target.closest('.vm-comic');
      if (!link) return;

      e.preventDefault();
      const img = link.querySelector('img');
      if (!img) return;

      img.classList.add('is-flipping');

      const onEnd = function(){
        img.removeEventListener('transitionend', onEnd);

        const a = img.getAttribute('src');
        const b = img.getAttribute('data-alt');
        const c = img.getAttribute('data-alt2');

        if (c) {
          // 3-image rotation: a -> b -> c -> a
          img.setAttribute('src', b || a);
          img.setAttribute('data-alt', c || a);
          img.setAttribute('data-alt2', a);
        } else if (b) {
          // 2-image swap: a <-> b
          img.setAttribute('src', b);
          img.setAttribute('data-alt', a);
        }

        link.setAttribute('href', img.getAttribute('src'));

        requestAnimationFrame(() => requestAnimationFrame(() => {
          img.classList.remove('is-flipping');
        }));
      };

      img.addEventListener('transitionend', onEnd);
    });
  })();
  </script>
</ArticlePage>
