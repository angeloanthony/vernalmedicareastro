---
// src/pages/medicare-cost-estimator.astro — Decision Tools (M9).
import CalculatorPage from '../components/layout/CalculatorPage.astro';
import CalculatorSection from '../components/calculator/CalculatorSection.astro';
import CalculatorInput from '../components/calculator/CalculatorInput.astro';
import CalculatorResult from '../components/calculator/CalculatorResult.astro';
import CalculatorPrint from '../components/calculator/CalculatorPrint.astro';
import CalculatorShare from '../components/calculator/CalculatorShare.astro';
import AuthorByline from '../components/content/AuthorByline.astro';
import SummaryBlock from '../components/SummaryBlock.astro';
import NextSteps from '../components/content/NextSteps.astro';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';
import type { PageContext } from '../types/Page';
import type { CalculatorField } from '../types/Calculator';

const f = figuresFor();
const fields: CalculatorField[] = [
  { id: 'path', label: 'Coverage path', type: 'radio', options: [
    { label: 'Original Medicare + Medigap Plan G + Part D', value: 'medigap' },
    { label: 'Medicare Advantage', value: 'advantage' },
  ] },
  { id: 'medigapMonthly', label: 'Medigap Plan G premium (per month)', type: 'currency', help: 'Typical is around $150/mo; leave blank to use that.' },
  { id: 'partDMonthly', label: 'Part D premium (per month)', type: 'currency', help: `Blank uses the ${f.year} base of ${usd(f.partD.basePremium, { cents: true })}.` },
  { id: 'advantageMonthly', label: 'Medicare Advantage premium (per month)', type: 'currency', help: 'Many Advantage plans are $0.' },
  { id: 'usage', label: 'Expected medical use (Advantage only)', type: 'select', options: [
    { label: 'Low', value: 'low' }, { label: 'Typical', value: 'typical' }, { label: 'High', value: 'high' },
  ] },
];

const context: PageContext = {
  page: {
    title: `Medicare Cost Estimator ${f.year} — Original + Medigap vs Advantage | Vernal Medicare`,
    heading: 'Medicare Cost Estimator',
    description: `Estimate your annual Medicare cost for ${f.year}: Original Medicare + Medigap + Part D vs. a Medicare Advantage plan. Premiums, deductibles, and out-of-pocket in one place.`,
    taxonomy: { silo: 'costs-irmaa', tags: ['costs', 'medigap', 'advantage', 'part-b', 'part-d'] },
    summary: `This estimator adds up your yearly Medicare cost by path. Everyone pays the Part B premium (${usd(f.partB.premium, { cents: true })}/mo in ${f.year}); on top of that, Original + Medigap + Part D is predictable, while Medicare Advantage trades a lower premium for variable out-of-pocket costs. Adjust the inputs to fit your situation.`,
    faqs: [
      { question: 'Is this exact?', answer: 'No — it’s an estimate. Medigap premiums vary by insurer and age, and Advantage out-of-pocket depends on your care and network. Use it to compare the two paths, then call us for exact plan quotes.' },
      { question: 'Does it include IRMAA?', answer: 'No. If your income is above the threshold, add your IRMAA surcharge from the IRMAA calculator to the Part B (and Part D) figures here.' },
    ],
    sources: [{ title: 'Medicare costs at a glance', url: 'https://www.medicare.gov/basics/costs/medicare-costs', publisher: 'Medicare.gov' }],
    nextSteps: [
      {
        when: 'Income above the IRMAA threshold?',
        action: 'add your surcharge on top of this estimate using the IRMAA calculator.',
        href: 'medicare-irmaa-calculator.html',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-cost-estimator.html',
    ogType: 'website',
    ogTitle: 'Medicare Cost Estimator',
    ogDescription: 'Estimate your annual Medicare cost: Original + Medigap + Part D vs. Medicare Advantage.',
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  medicalDisclaimer: 'Estimate only, based on published CMS figures and typical premiums. Not a quote.',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Medicare Cost Estimator', href: '/medicare-cost-estimator.html' },
  ],
};
---

<CalculatorPage context={context} bareHeader>
  <div class="ce-hero">
    <div class="ce-hero-text">
      <span class="ce-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>
        Updated for {f.year}
      </span>
      <h1 class="ce-h1">Medicare<br /><span class="ce-h1-accent">Cost Estimator</span></h1>
      <AuthorByline
        authorId={context.author}
        reviewedById={context.reviewedBy}
        updated={context.lastUpdated}
        localAvailability={context.localAvailability}
      />
      <SummaryBlock text={context.page.summary} />
      <NextSteps steps={context.page.nextSteps ?? []} />
      <p class="ce-hero-lede">Wondering what Medicare will <strong>actually cost you</strong>? Adjust the inputs to match your situation and compare the two main paths side by side.</p>
    </div>

    <div class="ce-hero-art" aria-hidden="true">
      <div class="ce-hero-card">
        <div class="ce-hero-card-top">
          <span class="ce-hero-led"></span>
          <span class="ce-hero-dot"></span>
          <span class="ce-hero-dot"></span>
          <span class="ce-hero-solar"></span>
        </div>
        <div class="ce-hero-display">
          <span class="ce-hero-display-label">Annual Cost</span>
          <span class="ce-hero-display-digits">$6,420</span>
        </div>
        <div class="ce-hero-keys">
          <span class="ce-hero-key is-op">C</span>
          <span class="ce-hero-key is-op">%</span>
          <span class="ce-hero-key is-op">÷</span>
          <span class="ce-hero-key is-op">×</span>
          <span class="ce-hero-key">7</span>
          <span class="ce-hero-key">8</span>
          <span class="ce-hero-key">9</span>
          <span class="ce-hero-key is-op">−</span>
          <span class="ce-hero-key">4</span>
          <span class="ce-hero-key">5</span>
          <span class="ce-hero-key">6</span>
          <span class="ce-hero-key is-op">+</span>
          <span class="ce-hero-key">1</span>
          <span class="ce-hero-key">2</span>
          <span class="ce-hero-key">3</span>
          <span class="ce-hero-key is-eq">=</span>
          <span class="ce-hero-key is-zero">0</span>
          <span class="ce-hero-key">.</span>
        </div>
      </div>
      <div class="ce-hero-float">
        <span class="ce-hero-float-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18v-1.5A6.5 6.5 0 0 1 10.5 10h3A6.5 6.5 0 0 1 20 16.5V18"/><rect x="2.5" y="16" width="4" height="5" rx="1.3"/><rect x="17.5" y="16" width="4" height="5" rx="1.3"/><circle cx="12" cy="6" r="3.2"/></svg>
        </span>
        <span>
          <strong>Compares 2 paths</strong>
          <p>Original + Medigap vs. Medicare Advantage.</p>
        </span>
      </div>
    </div>
  </div>

  <div class="ce-feature-grid">
    <div class="ce-feature-card">
      <span class="ce-feature-icon" style="--c:#d97706;--t:#fdf0dc">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M8 7h8M8 11h2M12 11h2M16 11h0M8 15h2M12 15h2M16 15h0"/></svg>
      </span>
      <h3>Monthly &amp; Annual</h3>
      <p>See premiums broken down by month, then rolled up to your total for the year.</p>
    </div>
    <div class="ce-feature-card">
      <span class="ce-feature-icon" style="--c:#16a34a;--t:#e4f5ea">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18v-1.5A6.5 6.5 0 0 1 10.5 10h3A6.5 6.5 0 0 1 20 16.5V18"/><rect x="2.5" y="16" width="4" height="5" rx="1.3"/><rect x="17.5" y="16" width="4" height="5" rx="1.3"/><circle cx="12" cy="6" r="3.2"/></svg>
      </span>
      <h3>Two Paths Compared</h3>
      <p>Original Medicare + Medigap + Part D, side by side with Medicare Advantage.</p>
    </div>
    <div class="ce-feature-card">
      <span class="ce-feature-icon" style="--c:#2563eb;--t:#e5edfe">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l3.5-4.5 3 3L19 7"/></svg>
      </span>
      <h3>Based on the {f.year} Premium</h3>
      <p>Estimated against the {f.year} standard Part B premium of {usd(f.partB.premium, { cents: true })}.</p>
    </div>
    <div class="ce-feature-card">
      <span class="ce-feature-icon" style="--c:#7c3aed;--t:#f0e9fd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M6 6l1.2 12a2 2 0 0 0 2 1.8h5.6a2 2 0 0 0 2-1.8L18 6"/><path d="M9 10.5l2.3 2.5 3.7-4.5"/></svg>
      </span>
      <h3>IRMAA Not Included</h3>
      <p>Higher earners should add their surcharge from the <a href="medicare-irmaa-calculator.html">IRMAA calculator</a>.</p>
    </div>
  </div>

  <form class="calc-form" data-calc-form novalidate>
    <div class="calc-form-head">
      <div class="calc-form-icon" aria-hidden="true">🧮</div>
      <div class="calc-form-titles">
        <h2 class="calc-form-title">Estimate Your Costs</h2>
        <p class="calc-form-sub">Adjust the inputs below to fit your situation.</p>
      </div>
      <span class="calc-form-timer" aria-hidden="true">⏱ About 60 seconds</span>
    </div>

    <CalculatorSection>
      {fields.map((field) => <CalculatorInput field={field} />)}
    </CalculatorSection>

    <div class="calc-actions">
      <button type="button" class="btn btn-primary calc-calculate" data-calc-calculate>Calculate My Costs</button>
      <CalculatorPrint />
      <CalculatorShare />
    </div>
  </form>

  <div class="calc-result-stage">
    <CalculatorResult heading="Estimated annual cost" />
  </div>

  <section class="estimator-preview">
    <h2>What You'll See</h2>
    <p class="estimator-preview-sub">A clear breakdown of your estimated monthly and annual Medicare costs.</p>
    <div class="estimator-features">
      <div class="estimator-feature">
        <div class="fi" aria-hidden="true">📋</div>
        <h3>Monthly Premiums</h3>
        <p>See what you'll pay each month across Part B, Part D, and your plan.</p>
      </div>
      <div class="estimator-feature">
        <div class="fi" aria-hidden="true">🛡️</div>
        <h3>Annual Deductibles</h3>
        <p>View the deductibles built into Part B and Part D for the year.</p>
      </div>
      <div class="estimator-feature">
        <div class="fi" aria-hidden="true">📊</div>
        <h3>Total Annual Cost</h3>
        <p>Get your estimated total yearly cost, path by path.</p>
      </div>
      <div class="estimator-feature">
        <div class="fi" aria-hidden="true">⚖️</div>
        <h3>Side-by-Side Options</h3>
        <p>Compare Original + Medigap against Medicare Advantage to find your fit.</p>
      </div>
    </div>
  </section>

  <aside class="estimator-help">
    <div class="estimator-help-icon" aria-hidden="true">🛡️</div>
    <div class="estimator-help-text">
      <strong>Local, Licensed &amp; Here to Help</strong>
      <span>We're independent, local, and focused on helping Vernal &amp; Uintah Basin residents make confident choices — free, no pressure.</span>
    </div>
    <a class="estimator-help-call" href="tel:+14352195120">📞 Call 435-219-5120 (TTY 711)</a>
  </aside>

  <p>Weighing the two paths? See <a href="medicare-supplement-vs-advantage.html">Medicare Supplement vs Medicare Advantage</a>, or the <a href="medicare-plan-g-high-deductible.html">High-Deductible Plan G</a> option for lower premiums.</p>

  <script>
    import { bindCalculator } from '../lib/calculators';
    import { computeMedicareCost, type CoveragePath, type UsageLevel } from '../lib/calculators/cost';
    import { figuresFor } from '../data/annualMedicareData';
    import { usd } from '../lib/formatters';
    import type { CalculatorResult } from '../types/Calculator';

    const F = figuresFor();
    const num = (v: string, d: number): number => {
      const n = parseFloat((v || '').replace(/[^0-9.]/g, ''));
      return Number.isFinite(n) ? n : d;
    };
    function compute(fields: Record<string, string>): CalculatorResult {
      const path: CoveragePath = fields.path === 'advantage' ? 'advantage' : 'medigap';
      const usage: UsageLevel = fields.usage === 'low' || fields.usage === 'high' ? fields.usage : 'typical';
      const r = computeMedicareCost(path, {
        medigapMonthly: num(fields.medigapMonthly, 150),
        partDMonthly: num(fields.partDMonthly, F.partD.basePremium),
        advantageMonthly: num(fields.advantageMonthly, 0),
        usage,
      }, F);
      return {
        summary: `Estimated ${path === 'medigap' ? 'Original + Medigap + Part D' : 'Medicare Advantage'} cost: about ${usd(r.annualTotal)}/year (${usd(r.annualTotal / 12)}/mo).`,
        rows: [
          ...r.breakdown.map((b) => ({ label: b.label, value: usd(b.amount) })),
          { label: 'Estimated annual total', value: usd(r.annualTotal), emphasis: true },
        ],
      };
    }

    const form = document.querySelector<HTMLElement>('[data-calc-form]');
    const results = document.querySelector<HTMLElement>('[data-calc-results]');
    if (form && results) bindCalculator(form, results, compute);

    // Results update live on every input; the primary button just guides the
    // eye down to the (already computed) estimate for a satisfying action.
    document.querySelector('[data-calc-calculate]')?.addEventListener('click', () => {
      results?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      results?.animate(
        [{ boxShadow: '0 0 0 4px rgba(220,53,69,0.55)' }, { boxShadow: '0 16px 40px rgba(11,44,69,0.28)' }],
        { duration: 900, easing: 'ease-out' },
      );
    });

    // Interactive 3D: the estimate badge tilts toward the cursor and a sheen
    // tracks it, giving the card a floating, tactile feel. Mouse only; honours
    // reduced-motion. bindCalculator re-renders the badge's innards (not the
    // element), so these listeners survive every recompute.
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (results && !reduceMotion) {
      const MAX_TILT = 10; // degrees
      results.addEventListener('pointermove', (e: PointerEvent) => {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        const r = results.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        results.style.setProperty('--ry', `${((px - 0.5) * 2 * MAX_TILT).toFixed(2)}deg`);
        results.style.setProperty('--rx', `${((0.5 - py) * 2 * MAX_TILT).toFixed(2)}deg`);
        results.style.setProperty('--mx', `${(px * 100).toFixed(1)}%`);
        results.style.setProperty('--my', `${(py * 100).toFixed(1)}%`);
        results.classList.add('is-tilting');
      });
      results.addEventListener('pointerleave', () => {
        results.style.setProperty('--rx', '0deg');
        results.style.setProperty('--ry', '0deg');
        results.classList.remove('is-tilting');
      });
    }
  </script>
</CalculatorPage>

<style>
  /* ---- Hero ------------------------------------------------------------ */
  .ce-hero {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 2.4rem;
    align-items: center;
    margin: 0.4rem 0 2rem;
  }

  .ce-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    border-radius: 999px;
    background: #fdf0dc;
    color: #d97706 !important;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .ce-badge svg { width: 17px; height: 17px; }

  .ce-h1 {
    margin: 0.75rem 0 0.6rem;
    font-size: 2.5rem;
    line-height: 1.12;
    color: #0b2c45;
  }
  .ce-h1-accent { color: #d97706; }

  .ce-hero-text :global(.byline) {
    color: #55627a;
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }
  .ce-hero-text :global(.byline a) { color: #2563eb; }

  .ce-hero-text :global(.summary-block) {
    margin: 0 0 1rem;
    color: #333;
  }
  .ce-hero-text :global(.summary-block p) { margin: 0; }

  .ce-hero-text :global(.next-steps) { margin: 0 0 1.1rem; }
  .ce-hero-text :global(.next-step) {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    background: #fdf0dc;
    border-left: 4px solid #d97706;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: #17324d;
    font-size: 0.95rem;
  }
  .ce-hero-text :global(.next-step)::before {
    content: "↓";
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #d97706;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .ce-hero-text :global(.next-step-when) { color: #0b2c45; }
  .ce-hero-text :global(.next-step a) { color: #2563eb; }

  .ce-hero-lede { margin: 0; color: #333; }
  .ce-hero-lede :global(a) { color: #2563eb; }

  .ce-hero-art { position: relative; display: grid; place-items: center; min-height: 300px; }
  .ce-hero-art::before {
    content: "";
    position: absolute;
    width: 200px;
    height: 240px;
    background: #fff;
    border-radius: 16px;
    transform: rotate(-9deg) translate(-46px, 4px);
    box-shadow: 0 14px 34px rgba(11, 44, 69, 0.14);
    z-index: 0;
  }

  .ce-hero-card {
    position: relative;
    width: 100%;
    max-width: 260px;
    background: linear-gradient(160deg, #163e60, #0b2c45 55%, #081d33);
    border-radius: 22px;
    padding: 1.15rem 1.2rem 1.35rem;
    box-shadow: 0 24px 50px rgba(11, 44, 69, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .ce-hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 45%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ce-hero-card { animation: ce-hero-float 6s ease-in-out infinite; }
  }
  @keyframes ce-hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .ce-hero-card-top { display: flex; align-items: center; gap: 0.32rem; margin-bottom: 0.8rem; }
  .ce-hero-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px 1px rgba(74, 222, 128, 0.7);
  }
  .ce-hero-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.25); }
  .ce-hero-solar {
    margin-left: auto;
    width: 28px;
    height: 10px;
    border-radius: 2px;
    background: repeating-linear-gradient(90deg, #2c5478 0 3px, #1c3a56 3px 6px);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .ce-hero-display {
    position: relative;
    background: linear-gradient(165deg, #fbe4bb, #f3c778);
    border-radius: 10px;
    padding: 0.6rem 0.85rem 0.5rem;
    box-shadow: inset 0 2px 6px rgba(60, 36, 4, 0.22);
  }
  .ce-hero-display-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #8a5a10;
    text-transform: uppercase;
  }
  .ce-hero-display-digits {
    display: block;
    text-align: right;
    font-family: 'Courier New', monospace;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #4a2e08;
    font-size: 1.4rem;
    margin-top: 0.05rem;
  }

  .ce-hero-keys {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 32px;
    gap: 0.42rem;
    margin-top: 1rem;
  }
  .ce-hero-key {
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Courier New', monospace;
    font-weight: 700;
    font-size: 0.82rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .ce-hero-key.is-op { background: rgba(96, 165, 250, 0.22); color: #cfe0fb; }
  .ce-hero-key.is-eq {
    grid-row: span 2;
    background: linear-gradient(160deg, #f0a83f, #d97706);
    color: #fff;
    box-shadow: 0 6px 14px rgba(217, 119, 6, 0.35);
  }
  .ce-hero-key.is-zero { grid-column: span 2; }
  .ce-hero-art:hover .ce-hero-key { transform: translateY(-1px); }

  .ce-hero-float {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: -12px;
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    max-width: 230px;
    background: #fff;
    border-radius: 14px;
    padding: 0.9rem 1.05rem;
    box-shadow: 0 14px 32px rgba(11, 44, 69, 0.2);
  }
  .ce-hero-float-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #fdf0dc;
    color: #d97706;
  }
  .ce-hero-float-icon svg { width: 19px; height: 19px; }
  .ce-hero-float strong { display: block; color: #0b2c45; font-size: 0.92rem; }
  .ce-hero-float p { margin: 0.15rem 0 0; color: #55627a; font-size: 0.8rem; }

  @media (max-width: 900px) {
