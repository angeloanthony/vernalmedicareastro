---
// src/pages/medicare-calculators.astro — Calculators hub (M33; redesigned M45).
// The tool cluster had no real index — just a plain link list (a text wall).
// Rebuilt into a polished landing hub (bareHeader + bareFooter) matching the
// help-center / coverage hubs: a hero with feature chips + photo callout, a
// "Choose a Calculator" card grid (one accent-topped card per calculator with
// icon, blurb and CTA), a "turn the estimate into a plan" banner, an
// FAQ · Resources · Related trio, a person CTA, and a trust bar. English-only
// page (no i18n content JSON) — copy lives inline.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

// Per-calculator card data. icon/accent/tint are presentation; the rest is copy.
const CALCS = [
  {
    href: 'medicare-cost-estimator.html',
    name: 'Medicare Cost Estimator',
    desc: 'Compare a Medigap path vs a Medicare Advantage path and see your total yearly cost.',
    cta: 'Estimate Your Costs',
    accent: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>',
  },
  {
    href: 'medicare-part-d-cost-calculator.html',
    name: 'Part D Drug Cost Calculator',
    desc: 'Estimate your yearly drug costs with the new $2,000 out-of-pocket cap.',
    cta: 'Calculate Drug Costs',
    accent: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2.6" y="8.4" width="18.8" height="7.2" rx="3.6" transform="rotate(-45 12 12)"/><path d="M8.7 8.7l6.6 6.6"/></svg>',
  },
  {
    href: 'medicare-irmaa-calculator.html',
    name: 'IRMAA Calculator',
    desc: 'See your income-based Part B and Part D surcharge from your MAGI.',
    cta: 'Check Your IRMAA',
    accent: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9h9a9 9 0 0 0-9-9z"/></svg>',
  },
  {
    href: 'medicare-extra-help-calculator.html',
    name: 'Extra Help & Savings Estimator',
    desc: 'See if you qualify for programs that can help with premiums and drug costs.',
    cta: 'See If You Qualify',
    accent: '#ea580c', tint: '#fdeadd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S4.5 15.2 4.5 9.7A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7.5 2.7C19.5 15.2 12 20.5 12 20.5z"/></svg>',
  },
  {
    href: 'medicare-part-b-penalty-calculator.html',
    name: 'Part B Late Penalty Calculator',
    desc: 'Estimate the permanent penalty for enrolling in Part B late.',
    cta: 'Calculate Penalty',
    accent: '#0d9488', tint: '#d7f0ec',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M11.5 14.5l1.4 1.4 3-3"/></svg>',
  },
  {
    href: 'medicare-enrollment-timeline.html',
    name: 'Enrollment Timeline',
    desc: 'Find your exact Initial Enrollment Period dates from your birthday.',
    cta: 'Find My Dates',
    accent: '#db2777', tint: '#fce7f0',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21h16"/><path d="M5 21v-7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v7"/><path d="M4 15.7c1.2 0 1.2 1 2.4 1s1.2-1 2.4-1 1.2 1 2.4 1 1.2-1 2.4-1 1.2 1 2.4 1 1.2-1 2.4-1"/><path d="M12 8.5V5.5"/><path d="M12 4.2a0.7 0.7 0 1 0 0-.01"/></svg>',
  },
  {
    href: 'medicare-eligibility-calculator.html',
    name: 'Eligibility Calculator',
    desc: 'See if you qualify for Medicare now — before or after 65 — and your key dates.',
    cta: 'Check Eligibility',
    accent: '#0284c7', tint: '#e0f2fe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.5l2.5 2.5 4.5-5"/></svg>',
  },
];

// Hero feature chips.
const FEATURES = [
  { title: '100% Free', sub: 'No signup required',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { title: 'Up-to-Date', sub: '2026 official numbers',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12a8 8 0 1 1-2.3-5.6"/><path d="M20 4v3.5h-3.5"/><path d="M12 8v4l2.5 1.5"/></svg>' },
  { title: 'Made for You', sub: 'Your situation, your results',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/><path d="M15 20c0-2 .8-3.6 2.5-4.6"/></svg>' },
];

// FAQ · Resources · Related.
const FAQS = [
  { q: 'Are these calculators free?', a: 'Yes — completely free, and they run right in your browser. Nothing is stored or shared.' },
  { q: 'How accurate are they?', a: 'They use the current year’s official CMS and Social Security figures for solid estimates. Your exact numbers depend on your specific plan and situation — which is what we help with.' },
  { q: 'Where do the numbers come from?', a: 'Official published sources: CMS Medicare premiums and deductibles, the Social Security IRMAA brackets, and the current Part D coverage rules.' },
];
const RESOURCES = [
  { label: 'How Much Does Medicare Cost?', href: 'medicare-costs.html' },
  { label: 'Medicare IRMAA Explained', href: 'medicare-irmaa.html' },
  { label: '2026 Medicare IRMAA Brackets', href: 'medicare-irmaa-brackets-2026.html' },
  { label: '2026 Medicare IRMAA Calculator', href: 'medicare-irmaa-calculator.html' },
];
const RELATED = [
  { label: 'Medicare Costs Overview', href: 'medicare-costs.html' },
  { label: 'Medicare Glossary', href: 'medicare-glossary.html' },
  { label: 'Medicare News & Updates', href: 'medicare-news.html' },
  { label: 'Where Do I Start With Medicare?', href: 'medicare-help-center.html' },
];

// Trust bar.
const TRUST = [
  { title: 'Local & Trusted', sub: 'Licensed in Utah', color: '#16a34a',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { title: 'No Cost, No Pressure', sub: 'We’re here to help', color: '#7c3aed',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { title: 'We Work for You', sub: 'Your best interests first', color: '#ea580c',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S4.5 15.2 4.5 9.7A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7.5 2.7C19.5 15.2 12 20.5 12 20.5z"/></svg>' },
  { title: 'Here When You Need Us', sub: 'Call, email, or meet locally', color: '#2563eb',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];

const phoneTel = `tel:${BUSINESS.phoneTel}`;

const context: PageContext = {
  page: {
    title: 'Free Medicare Calculators — Costs, IRMAA, Penalties & More | Vernal Medicare',
    heading: 'Free Medicare Calculators',
    description:
      'Free Medicare calculators: cost estimator, Part D drug costs, IRMAA, Extra Help eligibility, late-enrollment penalty, your enrollment timeline, and Medicare eligibility. Fed by current CMS figures.',
    taxonomy: { silo: 'tools', tags: ['tools', 'calculators', 'costs', 'irmaa', 'part-d'] },
    summary:
      `Put real numbers to your Medicare decisions. These ${CALCS.length} free calculators run right in your browser, using the current year’s official figures — estimate your costs, your income surcharge, your penalty, your enrollment dates, and whether you qualify for help. Then call us to turn the estimate into a plan.`,
    faqs: FAQS.map((f) => ({ question: f.q, answer: f.a })),
    nextSteps: [
      { when: 'Want the numbers for your exact situation?', action: `call us free at ${BUSINESS.phone} — we’ll run them with you.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-calculators.html',
    ogType: 'website',
    ogTitle: 'Free Medicare Calculators',
    ogDescription: 'Cost, Part D, IRMAA, Extra Help, penalty, and enrollment-timeline calculators.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Calculators', href: '/medicare-calculators.html' },
  ],
};
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="cx-hero">
    <div class="cx-hero__copy">
      <h1 class="cx-hero__title">Free Medicare<br />Calculators</h1>
      <p class="cx-hero__tag">Accurate. Current. Easy to Use.</p>
      <p class="cx-hero__lede">Get personalized estimates for your costs, surcharges, penalties, and important Medicare dates — all using this year’s official figures.</p>

      <ul class="cx-hero__features">
        {FEATURES.map((f) => (
          <li>
            <span class="cx-hero__feat-icon" aria-hidden="true" set:html={f.icon} />
            <span><strong>{f.title}</strong><em>{f.sub}</em></span>
          </li>
        ))}
      </ul>
    </div>

    <div class="cx-hero__art">
      <img
        class="cx-hero__img"
        src="/pictures/calc-hero.webp"
        alt="An older man using a Medicare cost calculator on his laptop at home"
        width="792"
        height="900"
        loading="eager"
        decoding="async"
      />
      <div class="cx-hero__callout">
        <span class="cx-hero__callout-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><rect x="8" y="6" width="8" height="3" rx="0.6"/><path d="M8.5 13h.01M12 13h.01M15.5 13h.01M8.5 16.5h.01M12 16.5h.01M15.5 16.5v2"/></svg></span>
        <p><strong>Get your numbers in minutes!</strong>Call us free at <a href={phoneTel}>{BUSINESS.phone}</a> (TTY: {BUSINESS.tty}) and we’ll help you understand them.</p>
      </div>
    </div>
  </section>

  {/* ─── Choose a Calculator ──────────────────────────────────────────── */}
  <section class="cx-cats" aria-labelledby="cx-cats-h">
    <h2 id="cx-cats-h" class="cx-h2 cx-h2--center cx-h2--ruled"><span>Choose a Calculator</span></h2>
    <div class="cx-cats__grid">
      {CALCS.map((c) => (
        <a class="cx-card" href={c.href} style={`--accent:${c.accent};--tint:${c.tint}`}>
          <span class="cx-card__icon" aria-hidden="true" set:html={c.icon} />
          <h3 class="cx-card__title">{c.name}</h3>
          <p class="cx-card__blurb">{c.desc}</p>
          <span class="cx-card__cta">
            {c.cta}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  {/* ─── Turn the estimate into a plan ────────────────────────────────── */}
  <section class="cx-plan">
    <span class="cx-plan__art" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="12" height="16" rx="2"/><path d="M8 3.2V2.6a1.4 1.4 0 0 1 1.4-1.4h1.2A1.4 1.4 0 0 1 12 2.6v.6"/><path d="M7.5 9l1.4 1.4 3-3M7.5 14l1.4 1.4 3-3"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><path d="M16 15h3M16 17.5h3M16 20h1.5"/></svg></span>
    <div class="cx-plan__msg">
      <h2 class="cx-plan__title">Turn Your Estimate Into a Plan — Free</h2>
      <p>Calculators give you a number; we give you the plan behind it. <strong>Call us free at {BUSINESS.phone}</strong> (TTY: {BUSINESS.tty}) and we’ll run the numbers for your exact doctors, drugs, and budget.</p>
    </div>
    <div class="cx-plan__actions">
      <a class="cx-plan__phone" href={phoneTel}>
        <span class="cx-plan__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="cx-plan__quote" href={BUSINESS.quoteUrl} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg>
        Request a Free Quote
      </a>
    </div>
  </section>

  {/* ─── FAQ · Resources · Related trio ───────────────────────────────── */}
  <div class="cx-trio">
    <section class="cx-panel">
      <h2 class="cx-panel__h"><span class="cx-panel__hicon cx-panel__hicon--blue" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.4c0 1.7-2.1 2.1-2.1 3.6"/><circle cx="12" cy="17.1" r="0.6" fill="currentColor" stroke="none"/></svg></span>Frequently Asked Questions</h2>
      {FAQS.map((f) => (
        <details class="cx-faq">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
      <a class="cx-panel__more" href="faq.html">View all FAQs →</a>
    </section>

    <section class="cx-panel">
      <h2 class="cx-panel__h"><span class="cx-panel__hicon cx-panel__hicon--green" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l4 4v14H6z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 16.5h4"/></svg></span>Helpful Resources</h2>
      <ul class="cx-links">
        {RESOURCES.map((r) => <li><a href={r.href}>{r.label}</a></li>)}
      </ul>
    </section>

    <section class="cx-panel">
      <h2 class="cx-panel__h"><span class="cx-panel__hicon cx-panel__hicon--purple" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.5 5 5.5.8-4 3.9 1 5.5-5-2.7-5 2.7 1-5.5-4-3.9 5.5-.8z"/></svg></span>Related</h2>
      <ul class="cx-links cx-links--related">
        {RELATED.map((r) => <li><a href={r.href}>{r.label}</a></li>)}
      </ul>
    </section>
  </div>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="cx-cta">
    <img class="cx-cta__photo" src="/pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent in Vernal, Utah" width="88" height="88" loading="lazy" decoding="async" />
    <div class="cx-cta__msg">
      <h2 class="cx-cta__title">Talk to a local, licensed agent</h2>
      <p>Rocco DeLuca can walk you through your options — free, no pressure.</p>
    </div>
    <div class="cx-cta__actions">
      <a class="cx-cta__phone" href={phoneTel}>
        <span class="cx-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="cx-cta__quote" href={BUSINESS.quoteUrl} target="_blank" rel="noopener noreferrer">
        <span class="cx-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        Get a Free Quote
      </a>
    </div>
  </section>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="cx-trust">
    {TRUST.map((t) => (
      <div class="cx-trust__item">
        <span class="cx-trust__icon" style={`--c:${t.color}`} aria-hidden="true" set:html={t.icon} />
        <span class="cx-trust__text"><strong>{t.title}</strong><em>{t.sub}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the help-center / coverage hubs: navy #0b2c45, blue #2563eb,
     per-tool accents (blue/green/purple/orange/teal/pink). */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .cx-hero {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.25rem 0 1.5rem;
  }
  .cx-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.05;
    font-weight: 800;
    color: #0b2c45;
    margin: 0 0 0.5rem;
  }
  .cx-hero__tag { margin: 0 0 0.9rem; font-size: clamp(1.05rem, 2.2vw, 1.35rem); font-weight: 800; color: #2563eb; }
  .cx-hero__lede { font-size: 1.02rem; color: #475569; line-height: 1.55; margin: 0 0 1.6rem; max-width: 46ch; }

  .cx-hero__features { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .cx-hero__features li { display: flex; align-items: center; gap: 0.7rem; }
  .cx-hero__features strong { display: block; color: #0b2c45; font-size: 0.95rem; line-height: 1.2; }
  .cx-hero__features em { color: #5b6b7d; font-size: 0.82rem; font-style: normal; line-height: 1.3; display: block; margin-top: 0.1rem; }
  .cx-hero__feat-icon {
    flex: none; width: 42px; height: 42px; border-radius: 12px;
    display: grid; place-items: center; background: #e2edfb; color: #1f4e8c;
  }
  .cx-hero__feat-icon svg { width: 22px; height: 22px; }

  .cx-hero__art { position: relative; display: flex; justify-content: center; }
  .cx-hero__img {
    width: 100%; height: auto; display: block;
    aspect-ratio: 5 / 4; object-fit: cover; object-position: 60% 22%;
    border-radius: 18px; box-shadow: 0 18px 44px rgba(11, 44, 69, 0.18);
  }
  .cx-hero__callout {
    position: absolute; left: 1.25rem; right: 1.25rem; bottom: -1rem;
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: #fff; border: 1px solid #e1e9f2; border-radius: 14px;
    padding: 0.9rem 1.1rem; box-shadow: 0 14px 34px rgba(11, 44, 69, 0.16);
  }
  .cx-hero__callout-icon { flex: none; display: grid; place-items: center; width: 40px; height: 40px; border-radius: 50%; background: #e6effe; color: #2563eb; }
  .cx-hero__callout-icon svg { width: 22px; height: 22px; }
  .cx-hero__callout p { margin: 0; color: #475569; font-size: 0.85rem; line-height: 1.45; }
  .cx-hero__callout strong { display: block; color: #0b2c45; font-size: 0.92rem; margin-bottom: 0.1rem; }
  .cx-hero__callout :global(a) { color: #2563eb; font-weight: 700; text-decoration: none; }
  .cx-hero__callout :global(a:hover) { text-decoration: underline; }

  /* ── Section heading ──────────────────────────────────────────────────── */
