---
// src/pages/medicare-glossary.astro — Medicare Glossary (M29, redesigned M45).
// A categorized knowledge system rendered from data/glossary.ts, now presented
// as a polished landing hub (bareHeader + bareFooter) that matches the Help
// Center / Costs / IRMAA hubs: an illustrated hero with feature chips + a
// new-here router, an A–Z letter index, a "Browse Terms by Topic" card grid,
// then the full term definitions restyled from a <dl> wall into per-category
// term cards, a person CTA banner, an FAQ / resources / related trio, and a
// trust bar. Each term still leads with a plain-language answer, then the
// detail, then a link to the Vernal page that OWNS the topic.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { GLOSSARY } from '../data/glossary';
import { CATEGORY_META, type GlossaryCategory } from '../types/Glossary';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const CATEGORY_ORDER: GlossaryCategory[] = ['enrollment', 'costs', 'plans', 'assistance', 'coverage'];
const bySlug = new Map(GLOSSARY.map((t) => [t.slug, t]));

// Language-neutral presentation metadata per category (accent, tint, icon),
// zipped with the translated CATEGORY_META by key.
const CAT_STYLE: Record<GlossaryCategory, { accent: string; tint: string; icon: string }> = {
  enrollment: { accent: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M7.5 13h2M11 13h2M14.5 13h2M7.5 16.5h2M11 16.5h2"/></svg>' },
  costs: { accent: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>' },
  plans: { accent: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H12v16H6.5A2.5 2.5 0 0 0 4 21.5z"/><path d="M20 5.5A2.5 2.5 0 0 0 17.5 3H12v16h5.5a2.5 2.5 0 0 1 2.5 2.5z"/></svg>' },
  assistance: { accent: '#0d9488', tint: '#d7f0ec',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.4 5.6a4 4 0 0 0-6-.3l-.4.5-.5-.5a4 4 0 1 0-5.7 5.6l.5.5L14 17l5.7-5.9.7-.7a4 4 0 0 0 0-4.8z"/><path d="M4 13h3l1.5 2.2L11 11l1.5 2h3"/></svg>' },
  coverage: { accent: '#ea580c', tint: '#fdeadd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.6 3.4 3.4 10.6a5 5 0 0 0 7.1 7.1l7.1-7.1a5 5 0 1 0-7-7.1z"/><path d="M7 7l7 7"/></svg>' },
};

const groups = CATEGORY_ORDER.map((cat) => ({
  cat,
  meta: CATEGORY_META[cat],
  st: CAT_STYLE[cat],
  terms: GLOSSARY.filter((t) => t.category === cat).sort((a, b) => a.term.localeCompare(b.term)),
}));

// A–Z index → each active letter jumps to the first term that starts with it.
const ALPHABET = '#ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const sortedAll = [...GLOSSARY].sort((a, b) => a.term.localeCompare(b.term));
const letterTarget = new Map<string, string>();
for (const t of sortedAll) {
  const first = t.term[0].toUpperCase();
  const key = /[A-Z]/.test(first) ? first : '#';
  if (!letterTarget.has(key)) letterTarget.set(key, t.slug);
}

// Hero feature chips — icons parallel to FEATURES.
const FEATURES = [
  { title: 'Plain English', sub: 'No jargon',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H12v16H6.5A2.5 2.5 0 0 0 4 21.5z"/><path d="M20 5.5A2.5 2.5 0 0 0 17.5 3H12v16h5.5a2.5 2.5 0 0 1 2.5 2.5z"/></svg>' },
  { title: 'Trusted & Local', sub: 'Vernal & Uintah Basin',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6.5-5.3-6.5-10.5a6.5 6.5 0 0 1 13 0C18.5 15.7 12 21 12 21z"/><circle cx="12" cy="10.3" r="2.4"/></svg>' },
  { title: 'Always Current', sub: '2026 rules & figures',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>' },
  { title: '100% Free', sub: 'No signup required',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
];

// Trust bar.
const TRUST = [
  { title: 'Local & Trusted', sub: 'Licensed in Utah', color: '#16a34a',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { title: 'No Cost, No Pressure', sub: 'We’re here to help', color: '#7c3aed',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { title: 'We Work for You', sub: 'Your best interests first', color: '#ea580c',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.4 5.6a4 4 0 0 0-6-.3l-.4.5-.5-.5a4 4 0 1 0-5.7 5.6L12 17l6-6.1.4-.5a4 4 0 0 0 0-4.8z"/></svg>' },
  { title: 'Here When You Need Us', sub: 'Call, email, or meet locally', color: '#2563eb',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];

const arrowSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>';
const phoneTel = `tel:${BUSINESS.phoneTel}`;

const context: PageContext = {
  page: {
    title: 'Medicare Glossary — Plain-English Terms | Vernal Medicare',
    heading: 'Medicare Glossary',
    description:
      'Medicare terms explained in plain English, by category — enrollment, costs, plans, financial assistance, and coverage. Each term links to a deeper guide.',
    taxonomy: { silo: 'medicare-101', tags: ['medicare-101', 'glossary', 'reference', 'overview'] },
    summary:
      `Medicare has its own vocabulary. This glossary explains ${GLOSSARY.length} key terms in plain English, grouped by topic, with a link from each to the guide that covers it in depth. Not sure what something on your paperwork means? Look it up here, or call us free.`,
    faqs: [
      { question: 'What is IRMAA?', answer: 'IRMAA (the Income-Related Monthly Adjustment Amount) is an income-based surcharge added to your Medicare Part B and Part D premiums if your income is above the year’s threshold.' },
      { question: 'What is the difference between a copay and coinsurance?', answer: 'A copayment is a flat dollar amount (e.g. $20 per visit); coinsurance is a percentage of the cost (e.g. 20% under Part B). Copays are predictable; coinsurance scales with the price of care.' },
      { question: 'What does "creditable coverage" mean?', answer: 'Creditable coverage is other drug or health coverage at least as good as Medicare’s. Keeping it lets you delay Medicare without a late-enrollment penalty.' },
    ],
    sources: [
      { title: 'Medicare.gov glossary', url: 'https://www.medicare.gov/glossary', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'Confused by a term on your Medicare paperwork?', action: `call us free at ${BUSINESS.phone} — we’ll explain it in plain English.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-glossary.html',
    ogType: 'article',
    ogTitle: 'Medicare Glossary — Plain-English Terms',
    ogDescription: 'Medicare terms explained simply, by category, each linked to a deeper guide.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Medicare Glossary', href: '/medicare-glossary.html' },
  ],
};

const FAQS = context.page.faqs ?? [];
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="gl-hero">
    <div class="gl-hero__copy">
      <h1 class="gl-hero__title">Medicare Glossary</h1>
      <p class="gl-hero__tag">Understand Medicare with confidence.</p>
      <p class="gl-hero__lede">
        Plain-English definitions of the terms that matter most — from A to Z.
        Learn the basics, compare your options, and make the best decisions for
        your health and your wallet. {GLOSSARY.length} terms, grouped by topic.
      </p>

      <ul class="gl-hero__features">
        {FEATURES.map((f) => (
          <li>
            <span class="gl-hero__feat-icon" aria-hidden="true" set:html={f.icon} />
            <span><strong>{f.title}</strong><em>{f.sub}</em></span>
          </li>
        ))}
      </ul>
    </div>

    <div class="gl-hero__art">
      <img
        class="gl-hero__img"
        src="/pictures/medicareglossary.webp"
        alt="An open Medicare Glossary book — your guide to Medicare made simple."
        width="1536"
        height="1024"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  {/* ─── New-here router ──────────────────────────────────────────────── */}
  <div class="gl-newhere">
    <p class="gl-newhere__msg">
      <span class="gl-newhere__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15"/><path d="M13 6l6 6-6 6"/></svg></span>
      <span><strong>New here?</strong> Start with <a href="medicare-help-center.html">Where do I start with Medicare?</a> and we’ll guide you step by step.</span>
    </p>
    <a class="gl-newhere__call" href={phoneTel}>
      <span class="gl-newhere__call-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
      <span>Call {BUSINESS.phone}<em>We’ll point you the right direction</em></span>
    </a>
  </div>

  {/* ─── A–Z letter index ─────────────────────────────────────────────── */}
  <section class="gl-az" aria-label="Find a term by letter">
    <h2 class="gl-az__h">Find a Term by Letter</h2>
    <div class="gl-az__row">
      {ALPHABET.map((L) => (
        letterTarget.has(L)
          ? <a class="gl-az__key" href={`#${letterTarget.get(L)}`}>{L}</a>
          : <span class="gl-az__key gl-az__key--off">{L}</span>
      ))}
    </div>
  </section>

  {/* ─── Browse Terms by Topic ────────────────────────────────────────── */}
  <section class="gl-cats" aria-labelledby="gl-cats-h">
    <h2 id="gl-cats-h" class="gl-h2 gl-h2--center">Browse Terms <span>by Topic</span></h2>
    <div class="gl-cats__grid">
      {groups.map((g) => (
        <article class="gl-card" style={`--accent:${g.st.accent};--tint:${g.st.tint}`}>
          <div class="gl-card__head">
            <span class="gl-card__icon" aria-hidden="true" set:html={g.st.icon} />
            <div>
              <h3 class="gl-card__title">{g.meta.label}</h3>
              <p class="gl-card__blurb">{g.meta.blurb}</p>
            </div>
          </div>
          <ul class="gl-card__list">
            {g.terms.slice(0, 3).map((t) => (
              <li><a href={`#${t.slug}`}>{t.term.replace(/\s*\(.*\)$/, '')}</a></li>
            ))}
          </ul>
          <a class="gl-card__cta" href={`#${g.cat}`}>
            <span>View all {g.terms.length} terms</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </a>
        </article>
      ))}

      {/* Calculators cross-link card — mirrors the hub design, links to the tools. */}
      <article class="gl-card" style="--accent:#dc2626;--tint:#fdeaea">
        <div class="gl-card__head">
          <span class="gl-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><rect x="8" y="6" width="8" height="3" rx="0.6"/><path d="M8.5 13h.01M12 13h.01M15.5 13h.01M8.5 16.5h.01M12 16.5h.01M15.5 16.5v2"/></svg></span>
          <div>
            <h3 class="gl-card__title">Calculators &amp; Tools</h3>
            <p class="gl-card__blurb">Put the terms to work — estimate your real costs.</p>
          </div>
        </div>
        <ul class="gl-card__list">
          <li><a href="medicare-cost-estimator.html">Medicare Cost Estimator</a></li>
          <li><a href="medicare-part-d-cost-calculator.html">Part D Drug Cost Calculator</a></li>
          <li><a href="medicare-irmaa-calculator.html">IRMAA Calculator</a></li>
        </ul>
        <a class="gl-card__cta" href="medicare-calculators.html">
          <span>Explore all calculators</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
        </a>
      </article>
    </div>
  </section>

  {/* ─── Full definitions, by category ────────────────────────────────── */}
  {groups.map((g) => (
    <section id={g.cat} class="gl-sec" style={`--accent:${g.st.accent};--tint:${g.st.tint}`}>
      <header class="gl-sec__head">
        <span class="gl-sec__icon" aria-hidden="true" set:html={g.st.icon} />
        <div class="gl-sec__heading">
          <h2>{g.meta.label}</h2>
          <p>{g.meta.blurb}</p>
        </div>
        <span class="gl-sec__count">{g.terms.length} terms</span>
      </header>

      <div class="gl-terms">
        {g.terms.map((t) => (
          <article id={t.slug} class="gl-term">
            <h3 class="gl-term__name">{t.term}</h3>
            <p class="gl-term__short">{t.short}</p>
            <p class="gl-term__full">{t.full}</p>
            <p class="gl-term__links">
              {t.authorityHref && (
                <a class="gl-term__learn" href={t.authorityHref}>{t.authorityLabel} <span aria-hidden="true">→</span></a>
              )}
              {t.calculatorHref && t.calculatorHref !== t.authorityHref && (
                <a class="gl-term__learn" href={t.calculatorHref}>Calculator <span aria-hidden="true">→</span></a>
              )}
              {t.related && t.related.length > 0 && (
                <span class="gl-term__related">
                  {'Related: '}
                  {t.related
                    .map((slug) => bySlug.get(slug))
                    .filter(Boolean)
                    .map((r, i) => (
                      <Fragment>{i > 0 ? ', ' : ''}<a href={`#${r!.slug}`}>{r!.term.replace(/\s*\(.*\)$/, '')}</a></Fragment>
                    ))}
                </span>
              )}
            </p>
          </article>
        ))}
      </div>
    </section>
  ))}

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="gl-cta">
    <img class="gl-cta__photo" src="/pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent in Vernal, Utah" width="88" height="88" loading="lazy" decoding="async" />
    <div class="gl-cta__msg">
      <h2 class="gl-cta__title">A term still not clicking?</h2>
      <p>A glossary can only go so far. If something on your Medicare mail or a plan document has you stuck, we’ll walk through it in plain English — local, licensed, no pressure.</p>
    </div>
    <div class="gl-cta__actions">
      <a class="gl-cta__phone" href={phoneTel}>
        <span class="gl-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="gl-cta__quote" href="medicare-quote-vernal.html">
        <span class="gl-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        Request a Free Quote
      </a>
    </div>
  </section>

  {/* ─── FAQ · Resources · Related trio ───────────────────────────────── */}
  <div class="gl-trio">
    <section class="gl-panel">
      <h2 class="gl-panel__h"><span class="gl-panel__hicon gl-panel__hicon--blue" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.4c0 1.7-2.1 2.1-2.1 3.6"/><circle cx="12" cy="17.1" r="0.6" fill="currentColor" stroke="none"/></svg></span>Common Questions</h2>
      {FAQS.map((q) => (
        <details class="gl-faq">
          <summary set:html={q.question} />
          <p set:html={q.answer} />
        </details>
      ))}
      <a class="gl-panel__more" href="faq.html">View all FAQs →</a>
    </section>

    <section class="gl-panel">
      <h2 class="gl-panel__h"><span class="gl-panel__hicon gl-panel__hicon--green" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l4 4v14H6z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 16.5h4"/></svg></span>Helpful Resources</h2>
      <ul class="gl-links">
        <li><a href="https://www.medicare.gov/glossary" target="_blank" rel="noopener noreferrer">Medicare.gov — official glossary</a></li>
        <li><a href="medicare-costs.html">Medicare coverage &amp; costs</a></li>
        <li><a href="medicare-irmaa.html">Medicare premiums &amp; IRMAA rules</a></li>
        <li><a href="medicare-irmaa-brackets-2026.html">2026 Medicare IRMAA brackets</a></li>
      </ul>
    </section>

    <section class="gl-panel">
      <h2 class="gl-panel__h"><span class="gl-panel__hicon gl-panel__hicon--purple" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H13v15H6.5A2.5 2.5 0 0 0 4 20z"/><path d="M20 6.5A2.5 2.5 0 0 0 17.5 4H13v14h4.5a2.5 2.5 0 0 1 2.5 2.5z"/></svg></span>Related Reads</h2>
      <ul class="gl-links gl-links--related">
        <li><a href="medicare-help-center.html">Where Do I Start With Medicare?</a></li>
        <li><a href="medicare-part-a-vs-part-b.html">The 4 Parts of Medicare</a></li>
        <li><a href="medicare-supplement-vs-advantage.html">Medigap vs Medicare Advantage</a></li>
        <li><a href="medicare-news.html">Medicare News &amp; Updates</a></li>
      </ul>
    </section>
  </div>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="gl-trust">
    {TRUST.map((t) => (
      <div class="gl-trust__item">
        <span class="gl-trust__icon" style={`--c:${t.color}`} aria-hidden="true" set:html={t.icon} />
        <span class="gl-trust__text"><strong>{t.title}</strong><em>{t.sub}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the Help Center / Costs / IRMAA hubs: navy #0b2c45,
     blue #2563eb, with per-topic accents. */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .gl-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.25rem 0 1.5rem;
  }
  .gl-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
