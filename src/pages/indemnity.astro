---
// src/pages/indemnity.astro — MIGRATED to the Page Framework.
// The COPAY COVERAGE (FIXED INDEMNITY) page — under-65 / supplemental, NOT Medicare.
// URL (/indemnity.html), title, description, canonical, and the legacy hero H1
// preserved. Now on ArticlePage: automatic Article+FAQ+Breadcrumb schema, byline,
// related, and the required marketing disclaimer. The inline hand-rolled JSON-LD
// (InsuranceAgency + FAQPage) and the inline CMS marketing-disclaimer block were
// removed — the framework generates both; the FAQ Q&A moved into page.faqs and
// marketingDisclaimer:true set. The Vimeo <iframe> embed, the flip-comic, all
// custom markup/prose/CTAs, and the flip-comic page script are preserved
// byte-for-byte in the body slot. No Medicare-figures data layer is needed, so no
// figuresFor()/usd import.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: 'Copay Coverage (Fixed Indemnity) in Vernal, Utah | Vernal Medicare',
    heading: 'Copay Coverage (Fixed Indemnity) — Simple Safety Net',
    description:
      "Simple cash benefits that help with hospital and doctor costs your main insurance doesn't fully cover. Fixed indemnity is a supplemental plan—less is more.",
    taxonomy: {
      silo: 'other-insurance',
      tags: ['other-insurance', 'indemnity', 'copay', 'vernal', 'uintah-county'],
    },
    summary:
      "Fixed indemnity (copay coverage) is supplemental insurance that pays fixed cash benefits for covered services — helping with hospital copays, deductibles, ER visits, and other out-of-pocket costs your main plan doesn't fully cover. It is not major medical or minimum essential coverage; it works alongside your primary plan, and benefits can be paid to you or assigned to your provider.",
    faqs: [
      {
        question: 'Is fixed indemnity major medical insurance?',
        answer:
          'No. It is supplemental coverage. It pays fixed amounts for covered services and is not minimum essential coverage.',
      },
      {
        question: 'Can it pay me or my provider?',
        answer:
          'Yes. Benefits can be paid to you or assigned to your hospital or provider, depending on the policy.',
      },
      {
        question: 'Why consider it?',
        answer:
          "To help with out-of-pocket costs such as hospital copays, deductibles, ER visits, or scheduled procedures that your main plan doesn't fully cover.",
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/indemnity.html',
    ogType: 'article',
    ogDescription:
      "Cash benefits paid for covered services to help with copays and deductibles. Supplemental—works with your main plan.",
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-07-01',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Copay Coverage (Fixed Indemnity)', href: '/indemnity.html' },
  ],
};
---

<ArticlePage context={context}>
  <section class="container" id="medigap-intro">
      <div class="mg-two-up">
        <!-- LEFT: video card -->
        <div class="mg-card">
          <div class="mg-ratio">
            <iframe
              src="https://player.vimeo.com/video/1145693994?badge=0&amp;autopause=0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
              title="Copay Coverage Video"></iframe>
          </div>
        </div>

        <!-- RIGHT: flip-on-click comic (3 images) -->
        <a class="vm-comic" href="pictures/joke15.webp" target="_blank" rel="noopener">
          <img
            src="pictures/joke15.webp"
            data-alt="pictures/joke21.webp"
            data-alt2="pictures/joke11.webp"
            alt="Medicare comic"
            loading="lazy" decoding="async">
        </a>
      </div>
      </section>

    <!-- Hero -->
    <section>
      <p><strong>Cash benefits paid for covered services</strong> to help with hospital copays, deductibles, and other out-of-pocket costs your main plan doesn't fully cover.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Copay%20Coverage%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Copay%20Coverage.%20My%20current%20plan%20is%3A%20____.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- What it is -->
    <section>
      <h2>What it is</h2>
      <ul>
        <li><strong>Fixed benefits:</strong> pays set amounts per covered service or day (example: an office visit might pay a set dollar amount—varies by plan).</li>
        <li><strong>Supplemental:</strong> <em>not</em> a substitute for major medical. It works <em>with</em> your primary insurance.</li>
        <li><strong>Flexible use:</strong> use the cash for copays, deductibles, prescriptions—or other expenses from a hospital stay.</li>
        <li><strong>Payment options:</strong> benefits can be paid to you or assigned to the provider.</li>
      </ul>
    </section>

    <!-- When it helps -->
    <section>
      <h2>When it helps</h2>
      <ul>
        <li>High hospital or ER copays on a Medicare Advantage or individual plan.</li>
        <li>Big deductibles on under-65 coverage.</li>
        <li>Scheduled procedures or unexpected accidents.</li>
      </ul>
    </section>

    <!-- Carrier note -->
    <section>
      <h2>Plans we can discuss</h2>
      <p>Options include <strong>Golden Rule Insurance Company</strong> (UnitedHealthcare) fixed indemnity plans such as Health ProtectorGuard®, and other carriers. Product names, amounts, and availability vary by state.</p>
    </section>

    <!-- CTA -->
    <section>
      <h2>Quick chat?</h2>
      <p>Tell me your current plan and goals. I'll show simple supplemental options—no pressure.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Copay%20Coverage%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Copay%20Coverage.%20My%20current%20plan%20is%3A%20____.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- Disclosures -->
    <section>
      <h2>Disclosures</h2>
      <p>Fixed indemnity insurance is supplemental and <strong>not</strong> minimum essential coverage. Benefits are paid in fixed amounts as defined by the policy and may have limitations, exclusions, and waiting periods. Availability and policy forms vary by state and carrier. Read the policy for details.</p>
      <p>Not connected with or endorsed by the U.S. government or the federal Medicare program.</p>
    </section>

<script>
  (function(){
    document.addEventListener('click', function(e){
      const link = e.target.closest('.vm-comic');
      if (!link) return;

      e.preventDefault();
      const img = link.querySelector('img');
      if (!img) return;

      img.classList.add('is-flipping');

      const onEnd = function(){
        img.removeEventListener('transitionend', onEnd);

        const a = img.getAttribute('src');
        const b = img.getAttribute('data-alt');
        const c = img.getAttribute('data-alt2');

        if (c) {
          // 3-image rotation: a -> b -> c -> a
          img.setAttribute('src', b || a);
          img.setAttribute('data-alt', c || a);
          img.setAttribute('data-alt2', a);
        } else if (b) {
          // 2-image swap: a <-> b
          img.setAttribute('src', b);
          img.setAttribute('data-alt', a);
        }

        link.setAttribute('href', img.getAttribute('src'));

        requestAnimationFrame(() => requestAnimationFrame(() => {
          img.classList.remove('is-flipping');
        }));
      };

      img.addEventListener('transitionend', onEnd);
    });
  })();
  </script>
</ArticlePage>
