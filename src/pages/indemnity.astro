---
// src/pages/indemnity.astro  —  converted from indemnity.html
// URL preserved: /indemnity.html. Body + page scripts VERBATIM. Metadata, header,
// footer, LocalBusiness schema, GA, nav/3CX scripts come from BaseLayout.
import BaseLayout from '../layouts/BaseLayout.astro';

// Page-specific JSON-LD carried over verbatim (LocalBusiness is in the layout).
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "InsuranceAgency",
    "name": "Vernal Medicare",
    "url": "https://vernalmedicare.com/",
    "logo": "https://vernalmedicare.com/pictures/Rocco.webp",
    "description": "Licensed help with Medicare and under-65 health insurance, plus supplemental options like fixed indemnity.",
    "telephone": "+1-435-219-5120",
    "email": "rocco@vernalmedicare.com",
    "areaServed": "Uintah County, Utah",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vernal",
      "addressRegion": "UT",
      "postalCode": "84078",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is fixed indemnity major medical insurance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. It is supplemental coverage. It pays fixed amounts for covered services and is not minimum essential coverage."
        }
      },
      {
        "@type": "Question",
        "name": "Can it pay me or my provider?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Benefits can be paid to you or assigned to your hospital or provider, depending on the policy."
        }
      },
      {
        "@type": "Question",
        "name": "Why consider it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To help with out-of-pocket costs such as hospital copays, deductibles, ER visits, or scheduled procedures that your main plan doesn't fully cover."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Copay Coverage (Fixed Indemnity) in Vernal, Utah | Vernal Medicare"
  description="Simple cash benefits that help with hospital and doctor costs your main insurance doesn't fully cover. Fixed indemnity is a supplemental plan—less is more."
  canonical="https://vernalmedicare.com/indemnity.html"
  ogDescription="Cash benefits paid for covered services to help with copays and deductibles. Supplemental—works with your main plan."
  twitterDescription="Cash benefits for covered services to help with out-of-pocket costs. Supplemental coverage."
  schema={schema}
>
<main id="content">

<div class="cms-disclaimer-compact" style="background: #f9fafb; border-left: 4px solid #d97706; padding: 1rem 1.25rem; margin: 1.5rem auto; max-width: 1100px; font-size: 0.9rem; color: #333; line-height: 1.5;">
  <p style="margin: 0.5rem 0; text-align: left;"><strong>We do not offer every plan available in your area.</strong> Please contact <a href="https://www.medicare.gov" target="_blank" rel="nofollow">Medicare.gov</a> or 1-800-MEDICARE (TTY: 711) to get information on all of your options. Not connected with or endorsed by the U.S. government or the federal Medicare program.</p>
</div>

  <section class="container" id="medigap-intro">
      <h1 style="margin:16px 0;">Copay Coverage — Video</h1>

      <div class="mg-two-up">
        <!-- LEFT: video card -->
        <div class="mg-card">
          <div class="mg-ratio">
            <iframe
              src="https://player.vimeo.com/video/1145693994?badge=0&amp;autopause=0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
              title="Copay Coverage Video"></iframe>
          </div>
        </div>

        <!-- RIGHT: flip-on-click comic (3 images) -->
        <a class="vm-comic" href="pictures/joke15.webp" target="_blank" rel="noopener">
          <img
            src="pictures/joke15.webp"
            data-alt="pictures/joke21.webp"
            data-alt2="pictures/joke11.webp"
            alt="Medicare comic"
            loading="lazy" decoding="async">
        </a>
      </div>
      </section>
    
    <!-- Hero -->
    <section>
      <h1>Copay Coverage (Fixed Indemnity) — Simple Safety Net</h1>
      <p><strong>Cash benefits paid for covered services</strong> to help with hospital copays, deductibles, and other out-of-pocket costs your main plan doesn't fully cover.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Copay%20Coverage%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Copay%20Coverage.%20My%20current%20plan%20is%3A%20____.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- What it is -->
    <section>
      <h2>What it is</h2>
      <ul>
        <li><strong>Fixed benefits:</strong> pays set amounts per covered service or day (example: an office visit might pay a set dollar amount—varies by plan).</li>
        <li><strong>Supplemental:</strong> <em>not</em> a substitute for major medical. It works <em>with</em> your primary insurance.</li>
        <li><strong>Flexible use:</strong> use the cash for copays, deductibles, prescriptions—or other expenses from a hospital stay.</li>
        <li><strong>Payment options:</strong> benefits can be paid to you or assigned to the provider.</li>
      </ul>
    </section>

    <!-- When it helps -->
    <section>
      <h2>When it helps</h2>
      <ul>
        <li>High hospital or ER copays on a Medicare Advantage or individual plan.</li>
        <li>Big deductibles on under-65 coverage.</li>
        <li>Scheduled procedures or unexpected accidents.</li>
      </ul>
    </section>

    <!-- Carrier note -->
    <section>
      <h2>Plans we can discuss</h2>
      <p>Options include <strong>Golden Rule Insurance Company</strong> (UnitedHealthcare) fixed indemnity plans such as Health ProtectorGuard®, and other carriers. Product names, amounts, and availability vary by state.</p>
    </section>

    <!-- CTA -->
    <section>
      <h2>Quick chat?</h2>
      <p>Tell me your current plan and goals. I'll show simple supplemental options—no pressure.</p>
      <p style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
        <a class="button primary" href="tel:+14352195120" aria-label="Call Vernal Medicare at 435-219-5120">
          Call (435) 219-5120 (TTY: 711)
        </a>
        <a
          class="button"
          href="mailto:rocco@vernalmedicare.com?subject=Copay%20Coverage%20question&body=Hi%20Rocco%2C%0D%0A%0D%0AI%27d%20like%20help%20with%20Copay%20Coverage.%20My%20current%20plan%20is%3A%20____.%0D%0A%0D%0AThanks!"
          aria-label="Email Vernal Medicare"
        >
          Email us
        </a>
      </p>
    </section>

    <!-- Disclosures -->
    <section>
      <h2>Disclosures</h2>
      <p>Fixed indemnity insurance is supplemental and <strong>not</strong> minimum essential coverage. Benefits are paid in fixed amounts as defined by the policy and may have limitations, exclusions, and waiting periods. Availability and policy forms vary by state and carrier. Read the policy for details.</p>
      <p>Not connected with or endorsed by the U.S. government or the federal Medicare program.</p>
    </section>
    </main>
  
  

<script>
  (function(){
    document.addEventListener('click', function(e){
      const link = e.target.closest('.vm-comic');
      if (!link) return;

      e.preventDefault();
      const img = link.querySelector('img');
      if (!img) return;

      img.classList.add('is-flipping');

      const onEnd = function(){
        img.removeEventListener('transitionend', onEnd);

        const a = img.getAttribute('src');
        const b = img.getAttribute('data-alt');
        const c = img.getAttribute('data-alt2');

        if (c) {
          // 3-image rotation: a -> b -> c -> a
          img.setAttribute('src', b || a);
          img.setAttribute('data-alt', c || a);
          img.setAttribute('data-alt2', a);
        } else if (b) {
          // 2-image swap: a <-> b
          img.setAttribute('src', b);
          img.setAttribute('data-alt', a);
        }

        link.setAttribute('href', img.getAttribute('src'));

        requestAnimationFrame(() => requestAnimationFrame(() => {
          img.classList.remove('is-flipping');
        }));
      };

      img.addEventListener('transitionend', onEnd);
    });
  })();
  </script>
</BaseLayout>
