    "logo": "https://vernalmedicare.com/pictures/Rocco.webp",
    "description": "Licensed help with Medicare Advantage, Medigap, Part D, and under-65 health insurance in Vernal and the Uintah Basin.",
    "telephone": "+1-435-219-5120",
    "email": "rocco@vernalmedicare.com",
    "areaServed": "Uintah County, Utah",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vernal",
      "addressRegion": "UT",
      "postalCode": "84078",
      "addressCountry": "US"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Medigap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Medigap (Medicare Supplement) helps pay the costs Original Medicare doesn't, like deductibles, copays, and coinsurance. You keep Original Medicare and can see any provider who accepts Medicare."
        }
      },
      {
        "@type": "Question",
        "name": "Does Medigap include drug coverage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Most people add a separate Part D plan for prescriptions."
        }
      },
      {
        "@type": "Question",
        "name": "When can I enroll?",
