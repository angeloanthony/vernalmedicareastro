<script>
  (function(){
    document.addEventListener('click', function(e){
      const link = e.target.closest('.vm-comic');
      if (!link) return;

      e.preventDefault();
      const img = link.querySelector('img');
      if (!img) return;

      img.classList.add('is-flipping');

      const onEnd = function(){
        img.removeEventListener('transitionend', onEnd);

        const a = img.getAttribute('src');
        const b = img.getAttribute('data-alt');
        const c = img.getAttribute('data-alt2');

        if (c) {
          // 3-image rotation: a -> b -> c -> a
          img.setAttribute('src', b || a);
          img.setAttribute('data-alt', c || a);
          img.setAttribute('data-alt2', a);
        } else if (b) {
          // 2-image swap: a <-> b
          img.setAttribute('src', b);
          img.setAttribute('data-alt', a);
        }

        link.setAttribute('href', img.getAttribute('src'));

        requestAnimationFrame(() => requestAnimationFrame(() => {
          img.classList.remove('is-flipping');
        }));
      };

      img.addEventListener('transitionend', onEnd);
    });
  })();
  </script>

<script>
  (function(){
    const wrap = document.querySelector('.smile-wrap');
    if (!wrap) return;
    const track = wrap.querySelector('.smile-track');
    const prev  = wrap.querySelector('.smile-arrow.prev');
    const next  = wrap.querySelector('.smile-arrow.next');

    function slideBy(dir){
      const firstSlide = track.querySelector('.smile-slide');
      if (!firstSlide) return;
      const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap) || 16;
      const w = firstSlide.getBoundingClientRect().width + gap;
      track.scrollBy({ left: dir * w, behavior: 'smooth' });
    }

    prev && prev.addEventListener('click', () => slideBy(-1));
    next && next.addEventListener('click', () => slideBy(1));

    track.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); slideBy(-1); }
      if (e.key === 'ArrowRight'){ e.preventDefault(); slideBy(1); }
    });
  })();
  </script>
