<script is:inline>
// Replace your existing vm-comic script with this enhanced version

(function(){
  document.addEventListener('click', function(e){
    const link = e.target.closest('.vm-comic');
    if (!link) return;

    e.preventDefault();
    const img = link.querySelector('img');
    if (!img) return;

    // Array of all 5 images to cycle through
    const images = [
      'pictures/joke2.webp',
      'pictures/joke4.webp',
      'pictures/joke49.webp',
      'pictures/joke13.webp',  // Add your 4th image path here
      'pictures/joke5.webp'     // Add your 5th image path here
    ];

    // Get current image
    const currentSrc = img.getAttribute('src');
    
    // Find current index
    let currentIndex = images.indexOf(currentSrc);
    
    // If not found, start from beginning
    if (currentIndex === -1) currentIndex = 0;
    
    // Get next image (cycle back to start after last image)
    const nextIndex = (currentIndex + 1) % images.length;
    const nextSrc = images[nextIndex];

    // Apply flip animation
    img.classList.add('is-flipping');
    
    const onEnd = function(){
      img.removeEventListener('transitionend', onEnd);
      img.setAttribute('src', nextSrc);
      
      requestAnimationFrame(() => requestAnimationFrame(() => {
        img.classList.remove('is-flipping');
      }));
    };
    
    img.addEventListener('transitionend', onEnd);
  });
})();
</script>

<script is:inline>
(function(){
  const wrap = document.querySelector('.smile-wrap');
  if (!wrap) return;
  const track = wrap.querySelector('.smile-track');
  const prev  = wrap.querySelector('.smile-arrow.prev');
  const next  = wrap.querySelector('.smile-arrow.next');

  function slideBy(dir){
    const firstSlide = track.querySelector('.smile-slide');
    if (!firstSlide) return;
    const gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap) || 16;
    const w = firstSlide.getBoundingClientRect().width + gap;
    track.scrollBy({ left: dir * w, behavior: 'smooth' });
  }

  prev && prev.addEventListener('click', () => slideBy(-1));
  next && next.addEventListener('click', () => slideBy(1));

  track.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') { e.preventDefault(); slideBy(-1); }
    if (e.key === 'ArrowRight'){ e.preventDefault(); slideBy(1); }
  });
})();
</script>


<script is:inline>
(() => {
  const root = document.getElementById('vm-reviews');
  if (!root) return;

  const track  = root.querySelector('.vm-reviews__track');
  const slides = Array.from(root.querySelectorAll('.vm-reviews__slide'));
  const prev   = root.querySelector('.vm-reviews__prev');
  const next   = root.querySelector('.vm-reviews__next');
  const dotsWrap = root.querySelector('.vm-reviews__dots');

  const starSVG = (filled) =>
    `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="${filled ? 'currentColor' : 'none'}" stroke="currentColor" d="M12 3.6l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5-5.8-3-5.8 3 1.1-6.5-4.7-4.6 6.5-.9L12 3.6z"/></svg>`;

  slides.forEach(slide => {
    const rating = Number(slide.dataset.rating || 5);
    const starsEl = slide.querySelector('.vm-reviews__stars');
    if (starsEl) starsEl.innerHTML = Array.from({length:5}, (_,i)=>starSVG(i < rating)).join('');
  });

  const dots = slides.map((_, i) => {
    const b = document.createElement('button');
    b.className = 'vm-reviews__dot';
    b.setAttribute('aria-label', `Go to review ${i + 1}`);
    b.addEventListener('click', () => go(i));
    dotsWrap.appendChild(b);
    return b;
  });

  let index = 0;
  const go = (i) => {
    index = (i + slides.length) % slides.length;
    track.style.transform = `translateX(-${index * 100}%)`;
    dots.forEach((d, di) => d.classList.toggle('is-active', di === index));
  };

  prev.addEventListener('click', () => go(index - 1));
  next.addEventListener('click', () => go(index + 1));

  let timer = setInterval(() => { if (!root.matches(':hover')) go(index + 1); }, 6000);
  document.addEventListener('visibilitychange', () => {
    clearInterval(timer);
    if (!document.hidden) timer = setInterval(() => { if (!root.matches(':hover')) go(index + 1); }, 6000);
  });

  go(0);
})();
</script>

