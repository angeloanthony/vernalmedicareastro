  .topics-badge { margin: 2rem 0; }

  .topics-hub {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: #33475b;
  }

  .topics-hub a {
    font-weight: 700;
    color: #0b6ea3;
  }

  .rel-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .rel-pill {
    display: inline-flex;
    align-items: center;
    background: linear-gradient(160deg, #0b2c45, #0b6ea3);
    color: #fff;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    box-shadow: 0 3px 10px rgba(11, 44, 69, 0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .rel-pill:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(11, 44, 69, 0.28);
    filter: brightness(1.08);
  }

  /* ── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 720px) {
    .vs-grid {
      grid-template-columns: 1fr;
    }
    .vs-or {
      margin: -0.25rem 0;
    }
    .vs-or span {
      width: 44px;
      height: 44px;
      font-size: 0.9rem;
    }
    .verdict-split {
      grid-template-columns: 1fr;
    }
  }
</style>
