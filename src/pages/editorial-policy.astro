---
// src/pages/editorial-policy.astro — E-E-A-T (M26). How we research, source,
// review, and update. Describes the site's ACTUAL process (single-source annual
// figures, official sources, agent review) — all true, no invention. Linked
// from every article byline ("How we keep this accurate").
//
// Redesigned (M45) from a plain ArticlePage text wall into a polished trust
// landing page (bareHeader + bareFooter) matching the help-center hub design
// language: an accuracy hero with an ACCURATE·TRUSTED·TRANSPARENT checklist
// card, two "who/where" cards, a "numbers current" feature strip, a review
// panel, an independence note, a FAQ/sources/related trio, and a person CTA.
// Schema (Article + FAQPage + Breadcrumb) still assembles from `context`.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: 'Editorial Policy & How We Keep Medicare Info Accurate | Vernal Medicare',
    heading: 'Editorial Policy — How We Keep This Accurate',
    description:
      'How Vernal Medicare researches, sources, reviews, and updates its Medicare content — official sources, single-source annual figures, and review by a licensed agent.',
    taxonomy: { silo: 'trust', tags: ['trust', 'editorial-policy', 'accuracy', 'e-e-a-t'] },
    summary:
      'Medicare decisions are high-stakes, so accuracy matters. Every page here is written and reviewed by a licensed Medicare agent, sourced from official government references (Medicare.gov, CMS, Social Security, IRS), and built so the year’s official figures live in one place and update everywhere at once. Here’s exactly how that works.',
    faqs: [
      { question: 'Who writes and reviews this content?', answer: `Rocco DeLuca, a licensed Medicare insurance agent serving Vernal and the Uintah Basin, writes and reviews the Medicare content on this site.` },
      { question: 'How often are the numbers updated?', answer: 'The year’s official figures (premiums, deductibles, IRMAA brackets, drug caps) are updated each year when CMS and Social Security publish them, and any time an official change is announced mid-year.' },
      { question: 'What sources do you use?', answer: 'Primary, official sources only for facts and figures: Medicare.gov, the Centers for Medicare & Medicaid Services (CMS), the Social Security Administration (SSA), and the IRS. We cite them on the relevant pages.' },
      { question: 'How do I report an error?', answer: `If you spot something that looks wrong or out of date, please tell us — email ${BUSINESS.email} or call ${BUSINESS.phone}. We take corrections seriously and fix them quickly.` },
    ],
    sources: [
      { title: 'Medicare.gov — official U.S. government Medicare site', url: 'https://www.medicare.gov', publisher: 'Medicare.gov' },
      { title: 'Centers for Medicare & Medicaid Services (CMS)', url: 'https://www.cms.gov', publisher: 'CMS.gov' },
      { title: 'Social Security Administration', url: 'https://www.ssa.gov', publisher: 'SSA.gov' },
    ],
    nextSteps: [
      { when: 'Have a question about a number on this site?', action: `call us at ${BUSINESS.phone} — we’ll show you exactly where it comes from.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/editorial-policy.html',
    ogType: 'article',
    ogTitle: 'Editorial Policy — How We Keep This Accurate',
    ogDescription: 'Official sources, single-source annual figures, and review by a licensed agent.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Editorial Policy', href: '/editorial-policy.html' },
  ],
};

const phoneTel = `tel:${BUSINESS.phoneTel}`;

// ── Official sources (checkmarked list in the "Where the Facts Come From" card)
const SOURCE_ITEMS = [
  { name: 'Medicare.gov', note: 'The official U.S. government Medicare site', href: 'https://www.medicare.gov' },
  { name: 'Centers for Medicare & Medicaid Services (CMS)', note: 'Sets the annual figures', href: 'https://www.cms.gov' },
  { name: 'Social Security Administration (SSA)', note: 'Part B premiums, IRMAA & enrollment', href: 'https://www.ssa.gov' },
  { name: 'The IRS', note: 'Income (MAGI) rules that drive IRMAA', href: 'https://www.irs.gov' },
];

// ── "How We Keep the Numbers Current" — four-up feature strip
const CURRENT = [
  { accent: '#16a34a', tint: '#e4f5ea', title: 'Annual Reviews',
    body: 'We review the figures every year as soon as CMS and SSA release the updates.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M8 14l2.5 2.5L16 12"/></svg>' },
  { accent: '#2563eb', tint: '#e5edfe', title: 'Verified & Updated',
    body: 'When an official mid-year change is announced, we update quickly.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>' },
  { accent: '#ea580c', tint: '#fdeadd', title: 'Corrections Welcome',
    body: 'Spot an error or outdated figure? Tell us and we’ll fix it fast.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l4 4v14H6z"/><path d="M14 3v5h5"/><path d="M9.5 14l1.8 1.8L15 12"/></svg>' },
  { accent: '#7c3aed', tint: '#f0e9fd', title: 'One Source of Truth',
    body: 'Every official figure lives in one file and updates across the whole site at once.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
];

// ── "How Pages Are Reviewed & Updated" — three sub-items in the blue panel
const REVIEW = [
  { title: 'Reviewed Before Publishing', body: 'Each page is reviewed by Rocco before it goes live.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.6 3-6.5 7-6.5s7 2.9 7 6.5"/></svg>' },
  { title: 'Refreshed Regularly', body: 'We review and refresh the content every year.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12a8 8 0 1 1-2.3-5.6"/><path d="M20 4v4h-4"/></svg>' },
  { title: 'Last Updated', body: 'Every page shows a “Last updated” date in its byline.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/></svg>' },
];

const RELATED = [
  { label: 'Credentials & Certifications — Rocco DeLuca', href: '/medicare-agent-credentials.html' },
  { label: 'About Vernal Medicare', href: '/about.html' },
  { label: 'Medicare & Health Insurance FAQ', href: '/faq.html' },
  { label: 'Client Reviews — Vernal Medicare', href: '/reviews.html' },
];

const FAQS = context.page.faqs ?? [];
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="ep-hero">
    <div class="ep-hero__copy">
      <p class="ep-eyebrow">
        <span class="ep-eyebrow__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>
        Our Commitment to Accuracy
      </p>
      <h1 class="ep-hero__title">Editorial Policy</h1>
      <p class="ep-hero__sub">How We Keep This Accurate</p>
      <p class="ep-hero__lede">Medicare information can be complex — that’s why accuracy is our top priority. We write, review, and update every page with care, so you can make confident, informed decisions about your healthcare.</p>

      <div class="ep-promise">
        <span class="ep-promise__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>
        <p><strong>Our promise:</strong> Trusted information. Always up to date. Always working for you.</p>
      </div>
    </div>

    <aside class="ep-card-check" aria-label="Our standard">
      <span class="ep-card-check__tab" aria-hidden="true"></span>
      <p class="ep-card-check__kicker">Every page is</p>
      <ul>
        <li><span class="ep-tick" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg></span>Accurate</li>
        <li><span class="ep-tick" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg></span>Trusted</li>
        <li><span class="ep-tick" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg></span>Transparent</li>
      </ul>
      <p class="ep-card-check__note">Written &amp; reviewed by a licensed local agent.</p>
    </aside>
  </section>

  {/* ─── Who / Where cards ────────────────────────────────────────────── */}
  <div class="ep-duo">
    <article class="ep-card" style="--accent:#2563eb;--tint:#e5edfe">
      <div class="ep-card__head">
        <span class="ep-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.6 3-6.5 7-6.5s7 2.9 7 6.5"/></svg></span>
        <h2 class="ep-card__title">Who Writes This</h2>
      </div>
      <p>Our content is written and reviewed by <a href="/about.html"><strong>Rocco DeLuca</strong></a>, a licensed Medicare insurance agent who lives and works in Vernal and serves the Uintah Basin. It reflects real, hands-on experience helping local beneficiaries — not a national content mill.</p>
      <p class="ep-quotebox">Real experience. Local knowledge. A commitment to helping our community.</p>
      <a class="ep-inline-cta" href="/medicare-agent-credentials.html">See Rocco’s credentials
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
      </a>
    </article>

    <article class="ep-card" style="--accent:#0d9488;--tint:#d7f0ec">
      <div class="ep-card__head">
        <span class="ep-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V10M19 21V10M9 21V10M15 21V10"/><path d="M12 3 3.5 8.5h17z"/></svg></span>
        <h2 class="ep-card__title">Where the Facts Come From</h2>
      </div>
      <p>For anything factual — premiums, deductibles, IRMAA brackets, drug caps, enrollment windows, penalties — we use <strong>primary, official sources only</strong>:</p>
      <ul class="ep-sources">
        {SOURCE_ITEMS.map((s) => (
          <li>
            <span class="ep-tick ep-tick--sm" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5 9-11"/></svg></span>
            <span><a href={s.href} target="_blank" rel="nofollow"><strong>{s.name}</strong></a> — {s.note}</span>
          </li>
        ))}
      </ul>
    </article>
  </div>

  {/* ─── How We Keep the Numbers Current ──────────────────────────────── */}
  <section class="ep-section" aria-labelledby="ep-current-h">
    <h2 id="ep-current-h" class="ep-h2">How We Keep the Numbers Current</h2>
    <p class="ep-h2sub">Medicare’s numbers change every year. We make sure every official figure on our site is current, accurate, and verifiable.</p>
    <div class="ep-strip">
      {CURRENT.map((f) => (
        <div class="ep-feat" style={`--accent:${f.accent};--tint:${f.tint}`}>
          <span class="ep-feat__icon" aria-hidden="true" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─── How Pages Are Reviewed & Updated ─────────────────────────────── */}
  <section class="ep-review">
    <div class="ep-review__badge" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 3h6v3H9z"/><path d="M8.5 12l1.6 1.6L14 10"/><path d="M8.5 17h7"/></svg></div>
    <div class="ep-review__body">
      <h2 class="ep-h2 ep-h2--light">How Pages Are Reviewed &amp; Updated</h2>
      <div class="ep-review__grid">
        {REVIEW.map((r) => (
          <div class="ep-review__item">
            <span class="ep-review__icon" aria-hidden="true" set:html={r.icon} />
            <div>
              <strong>{r.title}</strong>
              <p>{r.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── Independence & Compliance note ───────────────────────────────── */}
  <aside class="ep-note" aria-label="Our independence and compliance">
    <span class="ep-note__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01M11 12h1v4h1"/></svg></span>
    <p><strong>Our independence &amp; compliance.</strong> We’re a local, independent agency — not the government. <em>We do not offer every plan available in your area.</em> Our guidance is educational and general; your best choice depends on your specific situation, which is why we offer free one-on-one help. There’s no cost to you — licensed agents are paid by the insurance carriers, and your premium doesn’t change whether you enroll through us or on your own. For all of your options, contact <a href="https://www.medicare.gov" target="_blank" rel="nofollow">Medicare.gov</a> or 1-800-MEDICARE (TTY: 711).</p>
  </aside>

  {/* ─── FAQ · Sources · Related trio ─────────────────────────────────── */}
  <div class="ep-trio">
    <section class="ep-panel">
      <h2 class="ep-panel__h"><span class="ep-panel__hicon ep-panel__hicon--orange" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.4c0 1.7-2.1 2.1-2.1 3.6"/><circle cx="12" cy="17.1" r="0.6" fill="currentColor" stroke="none"/></svg></span>Frequently Asked Questions</h2>
      {FAQS.map((q) => (
        <details class="ep-faq">
          <summary set:html={q.question} />
          <p set:html={q.answer} />
        </details>
      ))}
      <a class="ep-panel__more" href="/faq.html">View all FAQs →</a>
    </section>

    <section class="ep-panel">
      <h2 class="ep-panel__h"><span class="ep-panel__hicon ep-panel__hicon--blue" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg></span>Sources</h2>
      <ul class="ep-links">
        {SOURCE_ITEMS.slice(0, 3).map((s) => (
          <li><a href={s.href} target="_blank" rel="noopener noreferrer">{s.name}</a></li>
        ))}
      </ul>
    </section>

    <section class="ep-panel">
      <h2 class="ep-panel__h"><span class="ep-panel__hicon ep-panel__hicon--purple" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 15l6-6"/><path d="M8 8.5 6.5 10a3.5 3.5 0 0 0 5 5l1.5-1.5"/><path d="M16 15.5 17.5 14a3.5 3.5 0 0 0-5-5L11 10.5"/></svg></span>Related</h2>
      <ul class="ep-links ep-links--arrow">
        {RELATED.map((r) => (
          <li><a href={r.href}>{r.label}</a></li>
        ))}
      </ul>
    </section>
  </div>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="ep-cta">
    <img class="ep-cta__photo" src="/pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent in Vernal, Utah" width="88" height="88" loading="lazy" decoding="async" />
    <div class="ep-cta__msg">
      <h2 class="ep-cta__title">Talk to a Local, Licensed Agent</h2>
      <p>Rocco DeLuca can walk you through your options — free, no pressure.</p>
    </div>
    <div class="ep-cta__actions">
      <a class="ep-cta__phone" href={phoneTel}>
        <span class="ep-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="ep-cta__quote" href={BUSINESS.quoteUrl} target="_blank" rel="noopener noreferrer">
        <span class="ep-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        Get a Free Quote
      </a>
    </div>
  </section>
</ArticlePage>

<style>
  /* Palette echoes the help-center / coverage hubs: navy #0b2c45, blue #2563eb,
     with per-section accents (blue/green/teal/orange/purple). */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .ep-hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.75rem 2.75rem;
    margin: 0.25rem 0 1.75rem;
  }
  .ep-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin: 0 0 0.75rem; padding: 0;
    color: #1f4e8c; font-weight: 800; font-size: 0.82rem;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .ep-eyebrow__icon { display: grid; place-items: center; width: 26px; height: 26px; border-radius: 8px; background: #dceafe; color: #2563eb; }
  .ep-eyebrow__icon svg { width: 16px; height: 16px; }
  .ep-hero__title { font-size: clamp(2.4rem, 6vw, 3.8rem); line-height: 1; font-weight: 800; color: #0b2c45; margin: 0; }
  .ep-hero__sub { font-size: clamp(1.2rem, 2.6vw, 1.6rem); font-weight: 700; color: #2563eb; margin: 0.35rem 0 1rem; }
  .ep-hero__lede { font-size: 1.05rem; color: #475569; line-height: 1.6; margin: 0 0 1.5rem; max-width: 48ch; }

  .ep-promise {
    display: flex; align-items: flex-start; gap: 0.85rem;
    background: #e8f7ee; border: 1px solid #bfe8cd; border-radius: 14px;
    padding: 1rem 1.25rem;
  }
  .ep-promise__icon { flex: none; display: grid; place-items: center; width: 40px; height: 40px; border-radius: 50%; background: #16a34a; color: #fff; }
  .ep-promise__icon svg { width: 22px; height: 22px; }
  .ep-promise p { margin: 0; color: #14532d; font-size: 0.98rem; line-height: 1.5; }
  .ep-promise strong { color: #0f3d22; }

  .ep-card-check {
    position: relative;
    background: #fff;
    border: 1px solid #e4ecf5;
    border-radius: 18px;
    padding: 2rem 1.75rem 1.6rem;
    box-shadow: 0 20px 50px rgba(11, 44, 69, 0.16);
  }
  .ep-card-check__tab {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    width: 74px; height: 12px; border-radius: 0 0 10px 10px;
    background: linear-gradient(90deg, #2563eb, #0d9488);
  }
  .ep-card-check__kicker { margin: 0 0 1rem; color: #64748b; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .ep-card-check ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.7rem; }
  .ep-card-check li {
    display: flex; align-items: center; gap: 0.8rem;
    font-size: 1.4rem; font-weight: 800; color: #0b2c45; line-height: 1;
    padding-bottom: 0.7rem; border-bottom: 1px dashed #e2e8f0;
  }
  .ep-card-check li:last-child { border-bottom: none; padding-bottom: 0; }
  .ep-tick { flex: none; display: grid; place-items: center; width: 34px; height: 34px; border-radius: 50%; background: #16a34a; color: #fff; }
  .ep-tick svg { width: 20px; height: 20px; }
  .ep-tick--sm { width: 22px; height: 22px; }
  .ep-tick--sm svg { width: 13px; height: 13px; }
  .ep-card-check__note { margin: 1.1rem 0 0; color: #64748b; font-size: 0.85rem; line-height: 1.4; }

  /* ── Who / Where cards ────────────────────────────────────────────────── */
  .ep-duo {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    margin: 0 0 2.5rem;
  }
  .ep-card {
    background: #fff; border: 1px solid #e8edf3; border-top: 4px solid var(--accent);
    border-radius: 16px; padding: 1.75rem 1.75rem 1.6rem;
    box-shadow: 0 10px 30px rgba(11, 44, 69, 0.06);
  }
  .ep-card__head { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1rem; }
  .ep-card__icon { flex: none; width: 50px; height: 50px; border-radius: 14px; display: grid; place-items: center; background: var(--tint); color: var(--accent); }
  .ep-card__icon svg { width: 27px; height: 27px; }
  .ep-card__title { margin: 0; font-size: 1.25rem; color: #0b2c45; line-height: 1.2; }
  .ep-card p { color: #475569; font-size: 0.98rem; line-height: 1.6; margin: 0 0 0.9rem; }
