---
// src/pages/medicare-vernal-ut.astro — MIGRATED to the Page Framework.
// The OFFICE / "Visit Us" LOCAL page. URL (/medicare-vernal-ut.html), title,
// description, canonical, and the legacy H1 preserved. Now on ArticlePage:
// automatic Article+FAQ+Breadcrumb schema, byline, related, and the required
// marketing disclaimer. The inline hand-rolled JSON-LD (BreadcrumbList,
// LocalBusiness/InsuranceAgency, FAQPage) and the inline "Disclosures" CMS
// marketing block were removed — the framework generates breadcrumb + FAQ +
// disclaimer, and the LocalBusiness block only duplicated the sitewide
// LocalBusiness from business.ts, so it was dropped. FAQ Q&A moved into
// page.faqs; marketingDisclaimer:true set. The Google Maps <iframe> embed,
// the hero, NAP grid, hours/directions, and all custom markup are preserved
// byte-for-byte in the body slot. No stale $185/$257/$1,676 figures appeared,
// so no figuresFor()/usd data layer is needed.
import ArticlePage from '../components/layout/ArticlePage.astro';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: "Vernal Medicare Office at Smith's Pharmacy | Visit Our Local Agent",
    heading: "Visit Vernal Medicare at Smith's Pharmacy",
    description:
      "Visit Vernal Medicare inside Smith's Pharmacy at 1080 W Hwy 40 in Vernal, UT. Stop in, call, or schedule a home visit. Free plan reviews. Mon–Fri 1pm–5pm. Call 435-219-5120.",
    taxonomy: { silo: 'local', tags: ['local', 'vernal', 'office', 'uintah-county'] },
    summary:
      "Vernal Medicare's local office is inside Smith's Pharmacy at 1080 W Hwy 40 in Vernal, Utah — open Monday through Friday, 1pm to 5pm, with Saturday appointments and no-charge home visits across the Uintah Basin. Stop in, call, or schedule a visit for a free, no-pressure Medicare plan review.",
    faqs: [
      {
        question: 'Where is Vernal Medicare located?',
        answer:
          "Inside Smith's Pharmacy at 1080 W Hwy 40, Vernal, UT 84078. Look for our office area near the back of the pharmacy.",
      },
      {
        question: 'What are your office hours?',
        answer:
          'Monday through Friday, 1pm to 5pm. Saturday appointments and home visits are available throughout the Uintah Basin.',
      },
      {
        question: 'Do I need an appointment to stop in?',
        answer:
          'Walk-ins are welcome during office hours. For dedicated time and a full side-by-side plan comparison, scheduling ahead is recommended — call 435-219-5120.',
      },
      {
        question: 'Do you charge for Medicare help?',
        answer:
          "No. Plan reviews and enrollments are free. Licensed agents are paid by the insurance carriers, so there's no cost to you.",
      },
      {
        question: 'Can you come to me?',
        answer:
          'Yes. Home visits are available at no extra charge throughout Vernal, Naples, Maeser, Jensen, Roosevelt, Duchesne, and the surrounding Uintah Basin communities.',
      },
      {
        question: 'What should I bring to an appointment?',
        answer:
          "Your Medicare card (or Social Security card if you're approaching 65), a list of your current medications, and a list of doctors and specialists you want to keep seeing.",
      },
      {
        question: 'Where can I learn about Medicare options before I come in?',
        answer:
          'See our complete 2026 Medicare guide for Vernal. It covers Medicare Advantage, Medigap, Part D, costs, enrollment periods, and local hospitals and pharmacies.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-vernal-ut.html',
    ogType: 'article',
    ogTitle: "Vernal Medicare Office at Smith's Pharmacy | Visit Us",
    ogDescription:
      "Visit our Vernal Medicare office inside Smith's Pharmacy on Hwy 40. Free plan reviews, phone consultations, and home visits across the Uintah Basin.",
    gaIds: ['G-FTDW9B2G6Q'],
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-07-01',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Visit Us in Vernal', href: '/medicare-vernal-ut.html' },
  ],
};
---

<ArticlePage context={context}>
  <!-- Hero -->
  <section class="hero-row">
    <div class="hero-image-wrapper">
      <img src="/pictures/vernalmedicare.webp" alt="Vernal Medicare office at Smith's Pharmacy in Vernal, Utah" width="1600" height="600" class="hero-banner" loading="eager" decoding="async" fetchpriority="high">
      <div class="hero-text">
        <p>Stop in, call, or schedule a home visit — we serve Vernal, Naples, Maeser, Jensen, and the Uintah Basin.</p>
        <p>
          <a href="tel:+14352195120" class="enroll-btn" aria-label="Call Vernal Medicare">(435) 219-5120</a>
          <a href="https://www.google.com/maps?q=Smith%27s%20Pharmacy,+1080+W+Highway+40,+Vernal,+UT+84078" class="enroll-btn" target="_blank" rel="noopener" aria-label="Get directions">Get Directions</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Pillar reference -->
  <section class="container" style="padding:1rem 1rem; max-width:980px;">
    <p style="background:#f0f9ff; border-left:5px solid #0b6ea3; border-radius:6px; padding:1rem 1.25rem; margin:1rem 0;">
      <strong>Looking for the full Medicare picture?</strong> See our <a href="/medicare-plans-vernal-utah.html">complete 2026 Medicare guide for Vernal and the Uintah Basin</a> — covering Medicare Advantage, Medigap, Part D, costs, enrollment, and local providers. This page is just for finding our office.
    </p>
  </section>

  <!-- NAP + Map -->
  <section class="local-nap" aria-label="Vernal Medicare office location">
    <div class="container nap-grid">
      <div class="nap-info">
        <h2>Find Us Inside Smith's Pharmacy</h2>
        <p><strong>Vernal Medicare</strong><br>
          1080 W Hwy 40 (inside Smith's Pharmacy)<br>
          Vernal, UT 84078</p>
        <p>
          <strong>Phone:</strong> <a href="tel:+14352195120">(435) 219-5120</a> (TTY: 711)<br>
          <strong>Email:</strong> <a href="mailto:rocco@vernalmedicare.com">rocco@vernalmedicare.com</a><br>
          <strong>Hours:</strong> Mon–Fri 1pm–5pm, Sat by appointment
        </p>
        <ul class="nap-points">
          <li>Walk-ins welcome during office hours.</li>
          <li>Phone consultations and home visits available — no extra charge.</li>
          <li>Serving Vernal, Naples, Maeser, Ballard, Jensen, Roosevelt, Duchesne, and the entire Uintah Basin.</li>
        </ul>
        <p class="nap-ctas">
          <a class="button" href="tel:+14352195120" aria-label="Call Vernal Medicare now">Call Now</a>
          <a class="button" href="https://www.google.com/maps?q=Smith%27s%20Pharmacy,+1080+W+Highway+40,+Vernal,+UT+84078" target="_blank" rel="noopener" aria-label="Open directions in Google Maps">Directions</a>
          <a class="button" href="#faq" aria-label="See FAQs about visiting our office">FAQs</a>
        </p>
      </div>

      <figure class="map-wrap">
        <iframe
          src="https://www.google.com/maps?q=Smith%27s%20Pharmacy,+1080+W+Highway+40,+Vernal,+UT+84078&output=embed"
          width="100%" height="320" style="border:0;" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade" allowfullscreen
          title="Smith's Pharmacy in Vernal, Utah"></iframe>
        <figcaption>
          Located inside <strong>Smith's Pharmacy</strong> —
          <a href="https://www.google.com/maps?cid=5192524098518186165" target="_blank" rel="noopener">open in Google Maps</a>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- What to expect -->
  <section class="help">
    <div class="container">
      <h2>What to Expect When You Visit</h2>
      <div class="help-grid">
        <div class="help-left">
          <h3>Three Ways to Meet</h3>
          <ol>
            <li><strong>In-person at our office.</strong> Drop in to Smith's Pharmacy at 1080 W Hwy 40 during office hours, or schedule ahead for dedicated time and a side-by-side plan comparison.</li>
            <li><strong>By phone.</strong> Call <a href="tel:+14352195120">(435) 219-5120</a> for a phone consultation — we can do everything remotely from initial review to final enrollment.</li>
            <li><strong>At your home.</strong> Home visits are available at no extra charge throughout the Uintah Basin. Helpful if mobility is a challenge or you want to review documents in your own space.</li>
          </ol>

          <h3>What to Bring</h3>
          <ul>
            <li>Your red, white, and blue Medicare card (or Social Security card if you're approaching 65)</li>
            <li>A list of your current medications, with dosages</li>
            <li>A list of doctors and specialists you want to keep seeing</li>
            <li>Your preferred pharmacy</li>
          </ul>

          <p>If you don't have all of this ready, no problem — bring what you have and we'll work with it. <a href="/medicare-checklist-2026.html">Our 2026 Medicare checklist</a> covers everything in detail.</p>
        </div>

        <figure class="help-right">
          <img src="/pictures/carriers.webp" width="680" height="420" alt="Major Medicare carriers we work with" loading="lazy" decoding="async">
        </figure>
      </div>
    </div>
  </section>


  <!-- Areas served + cluster links -->
  <section class="areas">
    <div class="container">
      <h2>Areas We Serve</h2>
      <p>Vernal • Naples • Maeser • Ballard • Jensen • Roosevelt • Duchesne • Myton • Tabiona • Altamont • Neola • Uintah Basin</p>
      <p>Also see:
        <a href="/medicare-plans-vernal-utah.html">Complete Medicare Guide</a> •
        <a href="/medicare-roosevelt-utah.html">Medicare in Roosevelt</a> •
        <a href="/medicare-duchesne-utah.html">Medicare in Duchesne</a> •
        <a href="/medicare-cost-uintah-county.html">Medicare costs in Uintah County</a> •
        <a href="/reviews.html">Client Reviews</a>
      </p>
    </div>
  </section>
</ArticlePage>
