// legacy page. Now on ArticlePage: automatic Article+FAQ+Breadcrumb schema,
// byline, related, and the required marketing disclaimer. The inline hand-rolled
// JSON-LD (Breadcrumb/Article/FAQ) and the inline CMS marketing-disclaimer block
// were removed — the framework generates both. The single FAQ Q&A moved into
// page.faqs. The figuresFor()/usd data layer is kept intact so the "Key 2026
// Numbers" line renders live CMS figures ($202.90 / $283 / $1,736).
import ArticlePage from '../components/layout/ArticlePage.astro';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';

const f = figuresFor();

const context: PageContext = {
  page: {
    title: 'Your 2026 Medicare Checklist — Free Vernal, Utah Guide',
    heading: 'Your 2026 Medicare Checklist — Vernal & Uintah Basin',
    description:
      'Download your free 2026 Medicare checklist. Everything Vernal and Uintah Basin residents need to review before enrollment. Call 435-219-5120.',
    taxonomy: {
      silo: 'enrollment',
      tags: ['checklist', 'enrollment', 'deadlines', 'turning-65'],
    },
    summary:
      'A free 2026 Medicare checklist for Vernal and Uintah Basin residents: gather your doctors, prescriptions, and pharmacy, review the questions that matter, check the key 2026 cost numbers, and work through the action steps before the December 7 deadline.',
    faqs: [
      {
        question: 'What should I check before Medicare enrollment in 2026?',
        answer:
          'Review your doctors, prescriptions, pharmacy, and current plan changes. Check the 2026 cost numbers. Call 435-219-5120 for a free personalized plan review.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-checklist-2026.html',
    ogType: 'article',
    gaIds: ['G-NW6ENB89NF', 'G-FTDW9B2G6Q'],
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-07-01',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: '2026 Medicare Checklist', href: '/medicare-checklist-2026.html' },
  ],
};
---

<ArticlePage context={context}>
  <p>Whether you are new to Medicare or reviewing your current plan, this checklist covers everything Uintah Basin residents should evaluate before making a decision for 2026.</p>

  <h2>Before You Compare Plans</h2>
  <p><strong>Gather your information:</strong> List of current doctors and specialists with addresses. List of all prescription medications with dosages and frequency. Preferred pharmacy name and location. Current Medicare card (Original Medicare, Advantage, or both). Any upcoming scheduled procedures or specialist referrals. Income information if you may qualify for Extra Help or Medicaid.</p>

  <h2>Questions to Answer</h2>
  <p><strong>Coverage needs:</strong> Are your current doctors accepting your plan next year? Has your plan's formulary changed for any of your medications? Has your plan's premium, copay, or deductible changed? Do you need dental, vision, or hearing coverage? Do you travel or spend time outside Utah? Have you had any major health changes this year?</p>

  <h2>Key 2026 Numbers to Know</h2>
  <p>Part B premium: {usd(f.partB.premium, { cents: true })}/month. Part B deductible: {usd(f.partB.deductible)}/year. Part A hospital deductible: {usd(f.partA.deductible)}. Part D annual out-of-pocket cap: $2,000. Insulin cap: $35/month. Annual Enrollment Period: October 15 – December 7.</p>

  <h2>Action Steps</h2>
  <p>Review your Annual Notice of Change (ANOC) letter from your current plan. Compare plans using our <a href="free-medicare-comparison-vernal.html">free comparison tool</a>. Call <a href="tel:+14352195120">435-219-5120</a> for a personalized review. Enroll in the best plan before December 7. Set a calendar reminder to review again next year.</p>

  <h2>Get Help With Your Checklist</h2>
  <p>Bring this checklist to your appointment with Rocco at Smith's Pharmacy, or go through it over the phone. We will work through every item and ensure you have the best coverage for 2026.</p>

  <p>Related: <a href="medicare-open-enrollment-2026.html">Open Enrollment 2026</a> | <a href="when-to-enroll-medicare-utah.html">Enrollment deadlines</a> | <a href="medicare-cost-uintah-county.html">Cost breakdown</a></p>
  <p><em>Source: <a href="https://www.medicare.gov" target="_blank" rel="nofollow">Medicare.gov</a>.</em></p>

  <p style="text-align:center;margin-top:2rem;">
    <a href="https://www.sunfirematrix.com/app/consumer/medicareadvocates/10569110/" class="enroll-btn" target="_blank" rel="noopener noreferrer">Compare Plans &amp; Enroll</a>
  </p>
  <p style="text-align:center;margin-top:1rem;">
    <strong>Call Rocco:</strong> <a href="tel:+14352195120">435-219-5120</a> (TTY: 711) &bull; <a href="mailto:rocco@vernalmedicare.com">rocco@vernalmedicare.com</a>
  </p>
</ArticlePage>
