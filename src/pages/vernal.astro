---
// src/pages/vernal.astro — the Vernal, Utah local hub.
// Redesigned from a plain-prose ArticlePage into a custom landing page
// (bareHeader + bareFooter) themed around the Uintah Basin's red-rock desert:
// an illustrated hero, a "what we do" card grid, a how-it-works timeline paired
// with a local-focus stat card, colored enrollment-window pills, and a person
// CTA banner. URL, title, description, canonical, H1 and schema are unchanged;
// the ArticlePage framework still auto-generates Article+Breadcrumb schema and
// the byline is preserved inline for E-E-A-T.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';
import { BUSINESS } from '../data/business';
import { authorById } from '../data/authors';
import type { PageContext } from '../types/Page';

const f = figuresFor();
const partB = usd(f.partB.premium, { cents: true });
const agent = authorById('rocco');

const context: PageContext = {
  page: {
    title: 'Vernal Medicare — Local, Licensed Medicare Help in Uintah County',
    heading: 'Medicare Help in Vernal, Utah',
    description:
      'Compare Medicare Advantage, Medigap, and Part D with a local, licensed agent in Vernal and the Uintah Basin. Free, no-pressure guidance.',
    taxonomy: { silo: 'local', tags: ['local', 'vernal', 'uintah-county', 'overview'] },
    summary:
      'Local, licensed help comparing Medicare Advantage (Part C), Medigap, and Part D — right here in Vernal. We check your doctors, prescriptions, and budget so you can choose with confidence.',
  },
  meta: {
    canonical: 'https://vernalmedicare.com/vernal.html',
    ogType: 'article',
    ogTitle: 'Medicare in Vernal, Utah | Vernal Medicare',
    ogDescription:
      'Local, licensed Medicare help in Vernal, Utah. Compare Medicare Advantage, Medigap, and Part D with a local agent.',
  },
  author: 'rocco',
  datePublished: '2026-04-04',
  lastUpdated: '2026-06-30',
  marketingDisclaimer: true,
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Vernal, Utah', href: '/vernal.html' },
  ],
};

const updated = new Date(context.lastUpdated + 'T00:00:00').toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

// ── "What we do in Vernal" — each card links to the relevant local page. ──────
const SERVICES = [
  {
    accent: '#2563eb', tint: '#e6effe',
    title: 'Compare plans',
    blurb: 'Advantage, Medigap & Part D checked against your doctors, clinics, and pharmacies.',
    href: 'medicare-plans-vernal-utah.html',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M9 3v18"/><path d="M12.5 8h4M12.5 12h4M12.5 16h4"/></svg>',
  },
  {
    accent: '#0d9488', tint: '#d8f2ee',
    title: 'Medigap + Part D',
    blurb: 'Plan G, Plan N, and drug plans built for predictable, steady monthly costs.',
    href: 'medigap.html',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 11.5l2 2 4-4"/></svg>',
  },
  {
    accent: '#ea580c', tint: '#fdece0',
    title: 'Drug review',
    blurb: 'Formularies, prior authorization, and preferred pharmacies matched to your meds.',
    href: 'medicare-drug-coverage.html',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 13.5l-4 4a3.5 3.5 0 0 1-5-5l4-4"/><path d="M13.5 10.5l4-4a3.5 3.5 0 0 0-5-5l-4 4"/><path d="M8.5 15.5l7-7"/></svg>',
  },
  {
    accent: '#7c3aed', tint: '#f1e9fd',
    title: 'Savings programs',
    blurb: 'Extra Help & Medicare Savings Programs — we check every dollar you qualify for.',
    href: 'medicare-savings-programs-utah.html',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 8.6A5 5 0 0 0 12 5.6a5 5 0 0 0-8.8 3c0 4 4.8 7.4 8.8 9.8 4-2.4 8.8-5.8 8.8-9.8z"/></svg>',
  },
  {
    accent: '#c2571f', tint: '#fbe6d6',
    title: 'Annual checkups',
    blurb: 'We recheck your plan each year so it still fits when your life or meds change.',
    href: 'medicare-quote-vernal.html',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2"/><path d="M3.5 9.5h17M8 3v4M16 3v4"/><path d="M8.5 14l2 2 3.5-3.5"/></svg>',
  },
];

// ── How it works — a connected 4-step timeline. ───────────────────────────────
const STEPS = [
  { title: 'Quick chat', blurb: 'Tell us your doctors, meds, and must-haves.' },
  { title: 'Side-by-side options', blurb: 'We narrow the choices to what actually fits you.' },
  { title: 'Enroll when ready', blurb: 'By phone or online, with a licensed agent.' },
  { title: 'We stay with you', blurb: 'Year-round help for questions and changes.' },
];

// ── Enrollment windows — colored quick-reference pills. ───────────────────────
const WINDOWS = [
  { c: '#0d9488', bg: '#d8f2ee', label: 'AEP', dates: 'Oct 15 – Dec 7', note: 'Change plans; starts Jan 1' },
  { c: '#7c3aed', bg: '#f1e9fd', label: 'OEP (MA)', dates: 'Jan 1 – Mar 31', note: 'One switch if you’re on MA' },
  { c: '#2563eb', bg: '#e6effe', label: 'IEP / ICEP', dates: 'Around 65', note: 'Your first eligibility' },
  { c: '#d6455f', bg: '#fbe0e6', label: 'SEPs', dates: 'Life events', note: 'Moving, losing coverage, Extra Help' },
];
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="vh-hero">
    <img class="vh-hero__bg" src="/pictures/medicarevernal.webp" alt="" width="1600" height="720" loading="eager" decoding="async" fetchpriority="high" />
    <span class="vh-hero__scrim" aria-hidden="true"></span>
    <div class="vh-hero__copy">
      <h1 class="vh-hero__title">Medicare Help in <span>Vernal, Utah</span></h1>

      <div class="vh-byline">
        <img class="vh-byline__photo" src="/pictures/rocco.webp" alt={`${agent?.name ?? 'Rocco DeLuca'}, licensed Medicare agent in Vernal, Utah`} width="52" height="52" loading="eager" decoding="async" />
        <span class="vh-byline__text">
          By <strong>{agent?.name ?? 'Rocco DeLuca'}</strong>, {agent?.jobTitle ?? 'Licensed Medicare Insurance Agent'}
          <em>Updated {updated}</em>
        </span>
      </div>

      <p class="vh-hero__lede"><strong>Local, licensed help</strong> comparing Medicare Advantage (Part C), Medigap, and Part D — right here in Vernal. We check your doctors, prescriptions, and budget so you can choose with confidence.</p>

      <div class="vh-hero__actions">
        <a class="vh-btn vh-btn--call" href={`tel:${BUSINESS.phoneTel}`}>
          <span class="vh-btn__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
          <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
        </a>
        <a class="vh-btn vh-btn--ghost" href="about.html">
          <span class="vh-btn__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M4 7l8 6 8-6"/></svg></span>
          Email us
        </a>
      </div>
    </div>

  </section>

  {/* ─── What we do ───────────────────────────────────────────────────── */}
  <section class="vh-sec" aria-labelledby="vh-do-h">
    <h2 id="vh-do-h" class="vh-h2">What we do <span>in Vernal</span></h2>
    <div class="vh-cards">
      {SERVICES.map((s) => (
        <a class="vh-card" href={s.href} style={`--accent:${s.accent};--tint:${s.tint}`}>
          <span class="vh-card__icon" aria-hidden="true" set:html={s.icon} />
          <h3 class="vh-card__title">{s.title}</h3>
          <p class="vh-card__blurb">{s.blurb}</p>
          <span class="vh-card__more" aria-hidden="true">Learn more ›</span>
        </a>
      ))}
    </div>
  </section>

  {/* ─── How it works + Local focus ───────────────────────────────────── */}
  <section class="vh-sec vh-work">
    <div class="vh-work__steps">
      <h2 class="vh-h2">How it <span>works</span></h2>
      <ol class="vh-timeline">
        {STEPS.map((s, i) => (
          <li class="vh-step">
            <span class="vh-step__dot">{i + 1}</span>
            <div class="vh-step__body">
              <strong>{s.title}</strong>
              <span>{s.blurb}</span>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <aside class="vh-local">
      <svg class="vh-local__map" viewBox="0 0 140 120" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <rect x="0" y="0" width="140" height="120" rx="12" fill="#eef6fb"/>
        <path d="M14 20 h112 v80 h-112 z" fill="#dbeef7"/>
        <path d="M0 64 C 40 54, 90 82, 140 66" stroke="#9cc9e0" stroke-width="4" fill="none"/>
        <path d="M52 0 V120 M96 0 V120 M0 42 H140 M0 86 H140" stroke="#c3ddec" stroke-width="2"/>
        <g fill="#d6455f"><path d="M44 40 c0 8 -8 12 -8 12 s-8 -4 -8 -12 a8 8 0 0 1 16 0z"/></g>
        <circle cx="36" cy="40" r="3" fill="#fff"/>
        <g fill="#2563eb"><path d="M92 58 c0 8 -8 12 -8 12 s-8 -4 -8 -12 a8 8 0 0 1 16 0z"/></g>
        <circle cx="84" cy="58" r="3" fill="#fff"/>
        <g fill="#0d9488"><path d="M114 34 c0 7 -7 11 -7 11 s-7 -4 -7 -11 a7 7 0 0 1 14 0z"/></g>
        <circle cx="107" cy="34" r="2.6" fill="#fff"/>
      </svg>
      <div class="vh-local__body">
        <p class="vh-local__eyebrow">Local focus: Vernal &amp; the Basin</p>
        <p class="vh-local__stat">{partB}<em>/mo</em></p>
        <p class="vh-local__cap">What most beneficiaries pay for Original Medicare Part&nbsp;B in {f.year}.</p>
        <p class="vh-local__note">We coordinate around the clinics and pharmacies you already use across Vernal, Naples, Maeser, and Jensen — and we’re easy to reach when you need us.</p>
      </div>
    </aside>
  </section>

  {/* ─── Enrollment windows ───────────────────────────────────────────── */}
  <section class="vh-sec">
    <h2 class="vh-h2">Enrollment windows <span>(quick guide)</span></h2>
    <div class="vh-windows">
      {WINDOWS.map((w) => (
        <div class="vh-win" style={`--c:${w.c};--bg:${w.bg}`}>
          <span class="vh-win__label">{w.label}</span>
          <span class="vh-win__dates">{w.dates}</span>
          <span class="vh-win__note">{w.note}</span>
        </div>
      ))}
    </div>
    <p class="vh-windows__foot">Not sure which window is yours? <a href="medicare-enrollment-periods.html">See how the enrollment periods work</a> — or just call and we’ll tell you in a minute.</p>
  </section>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="vh-cta">
    <img class="vh-cta__photo" src="/pictures/rocco.webp" alt={`${agent?.name ?? 'Rocco DeLuca'}, licensed Medicare agent in Vernal, Utah`} width="92" height="92" loading="lazy" decoding="async" />
    <div class="vh-cta__msg">
      <h2 class="vh-cta__title">Talk with a local, licensed agent</h2>
      <p>Free, no-pressure guidance from someone who lives and works in the Basin. Call, email, or request a quote — we’ll do the rest.</p>
    </div>
    <div class="vh-cta__actions">
      <a class="vh-btn vh-btn--call" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="vh-btn__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="vh-btn vh-btn--quote" href="medicare-quote-vernal.html">Get a Free Quote</a>
    </div>
  </section>
</ArticlePage>

<style>
  /* Palette: site navy #0b2c45 + blue #2563eb, warmed with Uintah Basin
     red-rock tones (#c2571f / #ea580c) and desert sky blues. */

  .vh-sec { margin: 0 0 2.75rem; }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .vh-hero {
    position: relative;
    overflow: hidden;
    border-radius: 26px;
    background: #0b2c45;
    padding: clamp(2rem, 4vw, 3.75rem) clamp(1.5rem, 3.5vw, 3rem);
    margin: 0.25rem 0 2.75rem;
    box-shadow: 0 20px 50px rgba(11, 44, 69, 0.20);
  }
  .vh-hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .vh-hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(6,26,43,.6) 0%, rgba(6,26,43,.3) 45%, rgba(6,26,43,0) 74%),
      linear-gradient(180deg, rgba(6,26,43,0) 60%, rgba(6,26,43,.2) 100%);
  }
  .vh-hero__copy { position: relative; z-index: 2; max-width: 46rem; }

  .vh-hero__title {
    font-size: clamp(2.1rem, 4.8vw, 3.3rem);
    line-height: 1.06;
    font-weight: 800;
    color: #fff;
    margin: 0 0 1rem;
    text-shadow: 0 2px 14px rgba(0,0,0,.45);
  }
  .vh-hero__title span { color: #f4922e; }

  .vh-byline { display: flex; align-items: center; gap: 0.7rem; margin: 0 0 1.15rem; }
  .vh-byline__photo { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; object-position: top center; border: 2px solid #fff; box-shadow: 0 5px 14px rgba(0,0,0,0.35); flex: none; }
  .vh-byline__text { color: #e6eef6; font-size: 0.92rem; line-height: 1.35; text-shadow: 0 1px 8px rgba(0,0,0,.4); }
  .vh-byline__text strong { color: #fff; }
  .vh-byline__text em { display: block; font-style: normal; font-size: 0.82rem; color: #c3d3e2; }

  .vh-hero__lede { font-size: 1.06rem; color: #eaf1f7; line-height: 1.6; margin: 0 0 1.6rem; max-width: 46ch; text-shadow: 0 1px 10px rgba(0,0,0,.4); }
  .vh-hero__lede strong { color: #fff; }
  .vh-hero__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  /* ── Buttons (shared) ─────────────────────────────────────────────────── */
  .vh-btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    text-decoration: none; font-weight: 800; border-radius: 14px;
    padding: 0.8rem 1.25rem; font-size: 1rem;
    transition: transform 0.12s ease, filter 0.12s ease, box-shadow 0.12s ease;
  }
  .vh-btn:hover { transform: translateY(-2px); }
  .vh-btn__icon { flex: none; display: grid; place-items: center; width: 30px; height: 30px; border-radius: 50%; background: rgba(255,255,255,0.22); }
  .vh-btn__icon svg { width: 18px; height: 18px; }
  .vh-btn--call {
    background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
    color: #fff; box-shadow: 0 12px 26px rgba(37, 99, 235, 0.34);
  }
  .vh-btn--call span:last-child { display: flex; flex-direction: column; line-height: 1.15; text-align: left; }
  .vh-btn--call em { font-style: normal; font-weight: 600; font-size: 0.76rem; opacity: 0.9; }
  .vh-btn--ghost { background: #fff; color: #0b2c45; border: 1.5px solid #cdd9e6; }
  .vh-btn--ghost .vh-btn__icon { background: #eef4fb; color: #2563eb; }
  .vh-btn--quote { background: #fff; color: #0b2c45; }
  .vh-btn--call, .vh-btn--quote { will-change: transform; }

  /* ── Section headings ─────────────────────────────────────────────────── */
  .vh-h2 { color: #0b2c45; font-size: clamp(1.45rem, 3vw, 2rem); font-weight: 800; margin: 0 0 1.5rem; }
  .vh-h2 span { color: #c2571f; }

  /* ── What we do — cards ───────────────────────────────────────────────── */
  .vh-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.25rem;
  }
  .vh-card {
    display: flex; flex-direction: column;
    background: #fff; text-decoration: none;
    border: 1px solid #e8edf3;
    border-top: 4px solid var(--accent);
    border-radius: 16px;
    padding: 1.5rem 1.35rem;
    box-shadow: 0 10px 28px rgba(11, 44, 69, 0.06);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .vh-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(11, 44, 69, 0.13); }
  .vh-card__icon {
    width: 54px; height: 54px; border-radius: 14px;
    display: grid; place-items: center;
    background: var(--tint); color: var(--accent);
    margin-bottom: 1rem;
  }
  .vh-card__icon svg { width: 28px; height: 28px; }
  .vh-card__title { margin: 0 0 0.45rem; font-size: 1.14rem; color: #0b2c45; }
  .vh-card__blurb { margin: 0 0 1rem; color: #5b6b7d; font-size: 0.93rem; line-height: 1.5; }
  .vh-card__more { margin-top: auto; color: var(--accent); font-weight: 800; font-size: 0.9rem; }

  /* ── How it works + Local focus ───────────────────────────────────────── */
  .vh-work {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  .vh-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
  .vh-timeline::before {
    content: ""; position: absolute; left: 18px; top: 12px; bottom: 12px;
    width: 3px; background: linear-gradient(180deg, #2563eb, #c2571f); border-radius: 2px;
  }
  .vh-step { display: flex; align-items: flex-start; gap: 1rem; padding: 0.55rem 0; position: relative; }
  .vh-step__dot {
    flex: none; width: 38px; height: 38px; border-radius: 50%;
    display: grid; place-items: center; z-index: 1;
    background: #2563eb; color: #fff; font-weight: 800;
    box-shadow: 0 6px 16px rgba(37, 99, 235, 0.3); border: 3px solid #f5fafd;
  }
  .vh-step:nth-child(2) .vh-step__dot { background: #0d9488; box-shadow: 0 6px 16px rgba(13,148,136,0.3); }
  .vh-step:nth-child(3) .vh-step__dot { background: #ea580c; box-shadow: 0 6px 16px rgba(234,88,12,0.3); }
  .vh-step:nth-child(4) .vh-step__dot { background: #c2571f; box-shadow: 0 6px 16px rgba(194,87,31,0.3); }
  .vh-step__body { padding-top: 0.15rem; }
  .vh-step__body strong { display: block; color: #0b2c45; font-size: 1.05rem; }
  .vh-step__body span { color: #5b6b7d; font-size: 0.93rem; line-height: 1.45; }

  .vh-local {
    display: flex; gap: 1.1rem; align-items: flex-start;
    background: linear-gradient(180deg, #fff6ef 0%, #fdfbf8 100%);
    border: 1px solid #f0dcc9;
    border-radius: 18px;
    padding: 1.5rem 1.6rem;
    box-shadow: 0 12px 30px rgba(11, 44, 69, 0.06);
  }
  .vh-local__map { flex: none; width: 120px; height: auto; border-radius: 12px; }
  .vh-local__eyebrow { margin: 0 0 0.35rem; color: #c2571f; font-weight: 800; font-size: 0.9rem; }
  .vh-local__stat { margin: 0; color: #0b2c45; font-size: 2.1rem; font-weight: 800; line-height: 1; }
  .vh-local__stat em { font-style: normal; font-size: 1rem; font-weight: 700; color: #7c8a99; }
  .vh-local__cap { margin: 0.35rem 0 0.75rem; color: #5b6b7d; font-size: 0.88rem; line-height: 1.4; }
  .vh-local__note { margin: 0; color: #5b6b7d; font-size: 0.9rem; line-height: 1.5; }

  /* ── Enrollment windows ───────────────────────────────────────────────── */
  .vh-windows {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .vh-win {
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--c) 22%, #fff);
    border-left: 5px solid var(--c);
    border-radius: 14px;
    padding: 1.05rem 1.2rem;
    display: flex; flex-direction: column; gap: 0.15rem;
  }
  .vh-win__label { color: var(--c); font-weight: 800; font-size: 1.05rem; }
  .vh-win__dates { color: #0b2c45; font-weight: 700; font-size: 0.95rem; }
  .vh-win__note { color: #5b6b7d; font-size: 0.85rem; line-height: 1.35; }
  .vh-windows__foot { margin: 1.1rem 0 0; color: #5b6b7d; font-size: 0.95rem; }
  .vh-windows__foot a { color: #2563eb; font-weight: 700; text-decoration: none; }
  .vh-windows__foot a:hover { text-decoration: underline; }

  /* ── Person CTA banner ────────────────────────────────────────────────── */
  .vh-cta {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.75rem;
    background: linear-gradient(120deg, #0b2c45 0%, #123a5c 100%);
    border-radius: 22px;
    padding: 1.9rem 2.25rem;
    margin: 0 0 1.5rem;
    box-shadow: 0 22px 50px rgba(11, 44, 69, 0.28);
  }
