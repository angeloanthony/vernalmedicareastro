---
// src/pages/medicare-decision-center.astro — the Decision Center (M39, Wave 2).
// A situation-based FRONT DOOR: the visitor self-selects "where do I start?"
// and is routed into one of the hubs we've already built. Pure navigation
// layer over data/decisionPaths.ts — no new content, just a better on-ramp.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { DECISION_PATHS } from '../data/decisionPaths';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: 'Where Do I Start With Medicare? — Medicare Decision Center | Vernal Medicare',
    heading: 'Where Do I Start With Medicare?',
    description:
      'Not sure where to begin with Medicare? Pick your situation — turning 65, still working, already enrolled, needing drug or financial help, comparing plans, or estimating costs — and we’ll point you to the right guide. Free local help in the Uintah Basin.',
    taxonomy: { silo: 'medicare-101', tags: ['medicare-101', 'hub', 'decision-center', 'start-here', 'overview'], pillar: true },
    summary:
      'Medicare has a lot of doors. This is the one that asks a single question — where are you right now? Pick the situation that sounds like you, and we’ll route you straight into the right guide, calculator, or checklist. If none fit, one call sorts it out.',
    faqs: [
      { question: 'I’m brand new to Medicare — where do I start?', answer: 'If you’re turning 65, start with the turning-65 walkthrough — it lays out every step in order. If you’re still working past 65, start with the Working Past 65 Center instead, because your employer coverage changes the timing.' },
      { question: 'I already have Medicare — is this for me too?', answer: 'Yes. Choose "I already have Medicare" to review or switch your plan during Open Enrollment, check whether a service is covered, or add dental, vision, and hearing.' },
      { question: 'What if none of the situations fit me?', answer: `Call us free at ${BUSINESS.phone} (TTY: ${BUSINESS.tty}). Tell us your situation in a sentence and we’ll point you to the exact right answer — no cost, no pressure.` },
    ],
    sources: [
      { title: 'Medicare.gov — get started with Medicare', url: 'https://www.medicare.gov/basics/get-started-with-medicare', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'Still not sure which path is yours?', action: `call us free at ${BUSINESS.phone} — we’ll find it with you in a few minutes.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-decision-center.html',
    ogType: 'website',
    ogTitle: 'Where Do I Start With Medicare?',
    ogDescription: 'Pick your situation — turning 65, still working, already enrolled, drug help, financial help, comparing plans, or costs — and we’ll route you to the right guide.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Where Do I Start?', href: '/medicare-decision-center.html' },
  ],
};
---

<ArticlePage context={context}>
  <p>Medicare is easier when you start from where you actually are. Pick the situation that sounds like you below — each one opens the right guide, calculator, or checklist. Prefer to just ask a person? <strong>Call {BUSINESS.phone}</strong> and we’ll point you there in a couple of minutes, free.</p>

  <div class="dec-grid">
    {DECISION_PATHS.map((p) => (
      <section class="dec-card" id={p.id}>
        <h2><a href={p.primary.href}>{p.situation}</a></h2>
        <p class="dec-blurb">{p.blurb}</p>
        <p class="dec-primary"><a href={p.primary.href}>{p.primary.label} →</a></p>
        <ul class="dec-links">
          {p.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </section>
    ))}
  </div>

  <h2>Want the Whole Map Instead?</h2>
  <p>If you’d rather browse everything by topic, the <a href="medicare-help-center.html">Medicare Help Center</a> lists every guide, calculator, and local resource in one place. Or read the <a href="medicare-plans-vernal-utah.html">complete 2026 Vernal guide</a> start to finish.</p>

  <h2>Or Just Start With a Person — Free</h2>
  <p>You don’t have to pick the perfect path. <strong>Call us free at {BUSINESS.phone}</strong> (TTY: {BUSINESS.tty}) or <a href="medicare-quote-vernal.html">request a free quote</a>, tell us your situation in a sentence, and we’ll take it from there — comparing your options against the doctors and pharmacy you already use. No cost, no pressure.</p>
</ArticlePage>

<style>
  .dec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }
  .dec-card {
    border: 1px solid var(--color-border, #e5e9ee);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    background: var(--color-surface, #fbfcfd);
  }
  .dec-card h2 { margin: 0 0 0.35rem; font-size: 1.15rem; }
  .dec-card h2 a { text-decoration: none; }
  .dec-blurb { color: var(--color-text-muted, #667085); font-size: 0.92rem; margin: 0 0 0.6rem; }
  .dec-primary { font-weight: 700; margin: 0 0 0.6rem; }
  .dec-links { list-style: none; padding: 0; margin: 0; }
  .dec-links li { padding: 0.2rem 0; font-size: 0.92rem; border-top: 1px solid var(--color-border, #eef1f4); }
</style>
