---
// src/pages/medicare-irmaa-calculator.astro — NET-NEW page (fills Vernal's IRMAA
// gap). URL: /medicare-irmaa-calculator.html. Built on CalculatorPage → the
// framework generates header/byline/summary/FAQ/related/CTA/disclaimer + HowTo
// schema; the interactive estimate runs client-side from annualMedicareData.
import CalculatorPage from '../components/layout/CalculatorPage.astro';
import CalculatorSection from '../components/calculator/CalculatorSection.astro';
import CalculatorInput from '../components/calculator/CalculatorInput.astro';
import CalculatorResult from '../components/calculator/CalculatorResult.astro';
import CalculatorComparison from '../components/calculator/CalculatorComparison.astro';
import CalculatorPrint from '../components/calculator/CalculatorPrint.astro';
import CalculatorShare from '../components/calculator/CalculatorShare.astro';
import AuthorByline from '../components/content/AuthorByline.astro';
import SummaryBlock from '../components/SummaryBlock.astro';
import NextSteps from '../components/content/NextSteps.astro';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';
import type { PageContext } from '../types/Page';
import type { CalculatorField } from '../types/Calculator';

const f = figuresFor();
const year = f.year;

const statusField: CalculatorField = {
  id: 'status',
  label: 'Tax filing status',
  type: 'radio',
  options: [
    { label: 'Single', value: 'single' },
    { label: 'Married filing jointly', value: 'married' },
  ],
};
const magiField: CalculatorField = {
  id: 'magi',
  label: 'Modified adjusted gross income (MAGI)',
  type: 'currency',
  help: `IRMAA for ${year} is based on your MAGI from ${year - 2}.`,
};

// 2026 IRMAA brackets table (single filers) built from the figures data.
const bounds = f.irmaa.single;
const bracketRows = f.irmaa.partBByTier.map((partB, i) => {
  const range =
    i === 0
      ? `≤ ${usd(bounds[0])}`
      : i < bounds.length
        ? `${usd(bounds[i - 1] + 1)} – ${usd(bounds[i])}`
        : `> ${usd(bounds[bounds.length - 1])}`;
  return {
    label: range,
    values: [usd(partB, { cents: true }), usd(f.irmaa.partDByTier[i], { cents: true })],
    emphasis: i === 0,
  };
});

const howItWorks = [
  {
    title: 'Social Security Looks Back Two Years',
    text: `Social Security looks back at your tax return from two years ago to decide whether you owe IRMAA today.`,
    color: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><path d="M15.3 15.3L21 21"/></svg>',
  },
  {
    title: 'Higher Income Means Higher Premiums',
    text: `If your income is above the first threshold, a surcharge is added to both your Part B premium and your Part D premium.`,
    color: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>',
  },
  {
    title: 'Life-Changing Event?',
    text: `Retirement, marriage, divorce, or the death of a spouse may reduce your IRMAA if your income has dropped.`,
    color: '#ea580c', tint: '#fdeadd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S4.5 15.2 4.5 9.7A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7.5 2.7C19.5 15.2 12 20.5 12 20.5z"/></svg>',
    href: 'medicare-irmaa-life-changing-events.html',
  },
  {
    title: 'You Can Appeal',
    text: `You can appeal with Form SSA-44 if a qualifying life event caused your income to decrease.`,
    color: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M11.5 14.5l1.4 1.4 3-3"/></svg>',
    href: 'medicare-irmaa-appeal-ssa-44.html',
  },
];

const context: PageContext = {
  page: {
    title: `${year} IRMAA Calculator | Medicare Part B & Part D Surcharge by Income | Vernal Medicare`,
    heading: `${year} Medicare IRMAA Calculator`,
    description: `Estimate your ${year} Medicare IRMAA surcharge from your income. See your Part B premium and Part D surcharge by MAGI and filing status. Free help from a local Vernal agent.`,
    taxonomy: { silo: 'costs-irmaa', tags: ['irmaa', 'costs', 'part-b', 'part-d'] },
    summary: `IRMAA is an income-related surcharge added to Medicare Part B and Part D premiums. In ${year} it starts above ${usd(f.irmaa.single[0])} MAGI (single) or ${usd(f.irmaa.married[0])} (married), based on your income from ${year - 2}. Enter your income below to estimate it.`,
    faqs: [
      {
        question: 'What is IRMAA?',
        answer:
          'IRMAA (Income-Related Monthly Adjustment Amount) is an extra charge added to your Medicare Part B and Part D premiums when your income is above a set threshold. It is not a separate bill — it is added to your premiums.',
      },
      {
        question: `What income does ${year} IRMAA use?`,
        answer: `Your ${year} IRMAA is based on the Modified Adjusted Gross Income (MAGI) from your ${year - 2} tax return — a two-year lookback. If your income has dropped since then, you may be able to appeal.`,
      },
      {
        question: 'How do I appeal or lower my IRMAA?',
        answer:
          'If a life-changing event (retirement, marriage, divorce, or the death of a spouse) lowered your income, file Form SSA-44 with Social Security to request a reduction. Call us and we can walk you through it.',
      },
    ],
    sources: [
      { title: 'Medicare costs at a glance', url: 'https://www.medicare.gov/basics/costs/medicare-costs', publisher: 'Medicare.gov' },
      { title: 'Medicare premiums & income brackets (IRMAA)', url: 'https://www.ssa.gov/benefits/medicare/medicare-premiums.html', publisher: 'Social Security Administration' },
    ],
    nextSteps: [
      {
        when: 'If your income dropped after retirement,',
        action: 'you may be paying IRMAA you no longer owe — ask us about filing Form SSA-44 to appeal.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-irmaa-calculator.html',
    ogType: 'website',
    ogTitle: `${year} Medicare IRMAA Calculator`,
    ogDescription: `Estimate your ${year} Medicare IRMAA surcharge on Part B and Part D by income.`,
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: `${year} IRMAA Calculator`, href: '/medicare-irmaa-calculator.html' },
  ],
  medicalDisclaimer:
    'Estimates only, based on published CMS figures. Your actual premium is set by Social Security.',
};
---

<CalculatorPage context={context} bareHeader>
  <div class="irmaa-hero">
    <div class="irmaa-hero-text">
      <span class="irmaa-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2.5" width="16" height="19" rx="2.5"/><path d="M8 7h8M8 11h2M12 11h2M16 11h0M8 15h2M12 15h2M16 15h0M8 19h2M12 19h2"/></svg>
        Updated for {year}
      </span>
      <h1 class="irmaa-h1">{year} Medicare<br /><span class="irmaa-h1-accent">IRMAA Calculator</span></h1>
      <AuthorByline
        authorId={context.author}
        reviewedById={context.reviewedBy}
        updated={context.lastUpdated}
        localAvailability={context.localAvailability}
      />
      <SummaryBlock text={context.page.summary} />
      <NextSteps steps={context.page.nextSteps ?? []} />
      <p class="irmaa-hero-lede">Higher-income Medicare beneficiaries pay more for Part B and Part D through IRMAA — an income-related surcharge. Enter your income and filing status below to estimate your {year} surcharge.</p>
    </div>

    <div class="irmaa-hero-art" aria-hidden="true">
      <div class="irmaa-hero-card">
        <div class="irmaa-hero-card-top">
          <span class="irmaa-hero-led"></span>
          <span class="irmaa-hero-dot"></span>
          <span class="irmaa-hero-dot"></span>
          <span class="irmaa-hero-solar"></span>
        </div>
        <div class="irmaa-hero-display">
          <span class="irmaa-hero-display-label">MAGI</span>
          <span class="irmaa-hero-display-digits">IRMAA</span>
        </div>
        <div class="irmaa-hero-keys">
          <span class="irmaa-hero-key is-op">C</span>
          <span class="irmaa-hero-key is-op">%</span>
          <span class="irmaa-hero-key is-op">÷</span>
          <span class="irmaa-hero-key is-op">×</span>
          <span class="irmaa-hero-key">7</span>
          <span class="irmaa-hero-key">8</span>
          <span class="irmaa-hero-key">9</span>
          <span class="irmaa-hero-key is-op">−</span>
          <span class="irmaa-hero-key">4</span>
          <span class="irmaa-hero-key">5</span>
          <span class="irmaa-hero-key">6</span>
          <span class="irmaa-hero-key is-op">+</span>
          <span class="irmaa-hero-key">1</span>
          <span class="irmaa-hero-key">2</span>
          <span class="irmaa-hero-key">3</span>
          <span class="irmaa-hero-key is-eq">=</span>
          <span class="irmaa-hero-key is-zero">0</span>
          <span class="irmaa-hero-key">.</span>
        </div>
      </div>
      <div class="irmaa-hero-float">
        <span class="irmaa-hero-float-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="4.5" width="17" height="16" rx="2.5"/><path d="M3.5 9.5h17M8 2.5v4M16 2.5v4"/></svg>
        </span>
        <span>
          <strong>Uses your {year - 2} income</strong>
          <p>Estimate your potential {year} IRMAA surcharge.</p>
        </span>
      </div>
    </div>
  </div>

  <div class="irmaa-feature-grid">
    <div class="irmaa-feature-card">
      <span class="irmaa-feature-icon" style="--c:#2563eb;--t:#e5edfe">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.6-3 8.4-7 10-4-1.6-7-5.4-7-10V6l7-3z"/></svg>
      </span>
      <h3>Income-Based Surcharges</h3>
      <p>IRMAA adds to your Medicare Part B and Part D premiums based on your income.</p>
    </div>
    <div class="irmaa-feature-card">
      <span class="irmaa-feature-icon" style="--c:#16a34a;--t:#e4f5ea">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M2.8 19c0-3.3 2.7-5.5 6.2-5.5s6.2 2.2 6.2 5.5"/><circle cx="17.5" cy="8.5" r="2.4"/><path d="M15.8 13.7c2.7.3 4.9 2.3 4.9 5.3"/></svg>
      </span>
      <h3>Based on {year - 2} Tax Return</h3>
      <p>Medicare looks at your {year - 2} income to determine your {year} IRMAA.</p>
    </div>
    <div class="irmaa-feature-card">
      <span class="irmaa-feature-icon" style="--c:#ea580c;--t:#fdeadd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M6 6l1.2 12a2 2 0 0 0 2 1.8h5.6a2 2 0 0 0 2-1.8L18 6"/><path d="M9 10.5l2.3 2.5 3.7-4.5"/></svg>
      </span>
      <h3>Income Dropped?</h3>
      <p>You may qualify for a lower IRMAA. Ask us about appealing with <a href="medicare-irmaa-appeal-ssa-44.html">Form SSA-44</a>.</p>
    </div>
    <div class="irmaa-feature-card">
      <span class="irmaa-feature-icon" style="--c:#7c3aed;--t:#f0e9fd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18v-1.5A6.5 6.5 0 0 1 10.5 10h3A6.5 6.5 0 0 1 20 16.5V18"/><rect x="2.5" y="16" width="4" height="5" rx="1.3"/><rect x="17.5" y="16" width="4" height="5" rx="1.3"/><circle cx="12" cy="6" r="3.2"/></svg>
      </span>
      <h3>We're Here to Help</h3>
      <p>Get local, personalized help to understand your options and potential savings.</p>
    </div>
  </div>

  <form class="calc-form" data-calc-form novalidate>
    <div class="calc-form-head">
      <div class="calc-form-icon" aria-hidden="true">🧮</div>
      <div class="calc-form-titles">
        <h2 class="calc-form-title">Estimate Your IRMAA</h2>
        <p class="calc-form-sub">Adjust the inputs below — your estimate updates as you type.</p>
      </div>
      <span class="calc-form-timer" aria-hidden="true">⏱ About 20 seconds</span>
    </div>

    <CalculatorSection title="Your details">
      <CalculatorInput field={statusField} />
      <CalculatorInput field={magiField} />
    </CalculatorSection>

    <div class="irmaa-gauge" data-irmaa-gauge aria-hidden="true">
      <p class="irmaa-gauge-caption">Where your income lands</p>
      <div class="irmaa-gauge-track">
        <div class="irmaa-gauge-seg" data-tier="0"></div>
        <div class="irmaa-gauge-seg" data-tier="1"></div>
        <div class="irmaa-gauge-seg" data-tier="2"></div>
        <div class="irmaa-gauge-seg" data-tier="3"></div>
        <div class="irmaa-gauge-seg" data-tier="4"></div>
        <div class="irmaa-gauge-seg" data-tier="5"></div>
      </div>
      <div class="irmaa-gauge-labels">
        <span data-tier="0">Standard</span>
        <span data-tier="1">Tier 1</span>
        <span data-tier="2">Tier 2</span>
        <span data-tier="3">Tier 3</span>
        <span data-tier="4">Tier 4</span>
        <span data-tier="5">Tier 5</span>
      </div>
    </div>

    <div class="calc-actions">
      <button type="button" class="btn btn-primary" data-calc-calculate>See My IRMAA Estimate</button>
      <CalculatorPrint />
      <CalculatorShare />
    </div>
  </form>

  <div class="calc-result-stage">
    <CalculatorResult heading={`Your ${year} IRMAA estimate`} />
  </div>

  <h2>{year} IRMAA brackets — single filers</h2>
  <CalculatorComparison
    rowHeader={`${year - 2} MAGI (single)`}
    columns={['Monthly Part B', 'Monthly Part D surcharge']}
    rows={bracketRows}
    caption={`${year} Medicare IRMAA, single filers. Married-filing-jointly thresholds are roughly double.`}
  />

  <h2 class="irmaa-how-h">How IRMAA Works</h2>
  <p>IRMAA is based on your <strong>modified adjusted gross income</strong> — your adjusted gross income plus any tax-exempt interest. Because of the two-year lookback, a big one-time income event (selling a home, a Roth conversion, capital gains) can push you into IRMAA even if your current income is lower.</p>

  <div class="irmaa-how-grid">
    {howItWorks.map((h) => (
      <div class="irmaa-how-card" style={`--c:${h.color};--t:${h.tint}`}>
        <span class="irmaa-how-icon" aria-hidden="true" set:html={h.icon} />
        <h3>{h.title}</h3>
        <p>{h.text}</p>
        {h.href && <a class="irmaa-how-link" href={h.href}>Learn more →</a>}
      </div>
    ))}
  </div>

  <script>
    import { bindCalculator, readFields } from '../lib/calculators';
    import { computeIrmaa, type FilingStatus } from '../lib/calculators/irmaa';
    import { figuresFor } from '../data/annualMedicareData';
    import { usd } from '../lib/formatters';
    import type { CalculatorResult } from '../types/Calculator';

    const F = figuresFor();
    const toStatus = (v: string): FilingStatus => (v === 'married' ? 'married' : 'single');
    const toNum = (v: string): number => {
      const n = parseFloat((v || '').replace(/[^0-9.]/g, ''));
      return Number.isFinite(n) ? n : 0;
    };

    function compute(fields: Record<string, string>): CalculatorResult {
      const magi = toNum(fields.magi);
      const r = computeIrmaa(toStatus(fields.status), magi, F);
      return {
        summary: r.hasIrmaa
          ? `At a MAGI of ${usd(magi)}, you'd pay about ${usd(r.monthlyExtra, { cents: true })}/month extra from IRMAA (${usd(r.annualExtra)}/year).`
          : `At a MAGI of ${usd(magi)}, you're in the standard tier — no IRMAA surcharge.`,
        rows: [
          { label: 'IRMAA tier', value: r.tier === 0 ? 'Standard (no IRMAA)' : `Tier ${r.tier} of 5` },
          { label: 'Monthly Part B premium', value: usd(r.partBPremium, { cents: true }) },
          { label: 'Monthly Part D surcharge', value: usd(r.partDSurcharge, { cents: true }) },
          { label: 'Extra per month from IRMAA', value: usd(r.monthlyExtra, { cents: true }), emphasis: true },
          { label: 'Extra per year from IRMAA', value: usd(r.annualExtra) },
        ],
      };
    }

    const form = document.querySelector<HTMLElement>('[data-calc-form]');
    const results = document.querySelector<HTMLElement>('[data-calc-results]');
    if (form && results) bindCalculator(form, results, compute);

    // Results update live on every input; the primary button just guides the
    // eye down to the (already computed) estimate for a satisfying action.
    const resultCard = document.querySelector<HTMLElement>('.calc-result');
    document.querySelector('[data-calc-calculate]')?.addEventListener('click', () => {
      resultCard?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      resultCard?.animate(
        [{ boxShadow: '0 0 0 4px rgba(37,99,235,0.45)' }, { boxShadow: '0 16px 40px rgba(11,44,69,0.28)' }],
        { duration: 900, easing: 'ease-out' },
      );
    });

    // Interactive 3D: the estimate card tilts toward the cursor and a sheen
    // tracks it. Properties are set on .calc-result itself (not a descendant)
    // so the transform the CSS reads actually picks them up. Mouse only;
    // honours reduced-motion.
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (resultCard && !reduceMotion) {
      const MAX_TILT = 8; // degrees
      resultCard.addEventListener('pointermove', (e: PointerEvent) => {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        const r = resultCard.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        resultCard.style.setProperty('--ry', `${((px - 0.5) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--rx', `${((0.5 - py) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--mx', `${(px * 100).toFixed(1)}%`);
        resultCard.style.setProperty('--my', `${(py * 100).toFixed(1)}%`);
        resultCard.classList.add('is-tilting');
      });
      resultCard.addEventListener('pointerleave', () => {
        resultCard.style.setProperty('--rx', '0deg');
        resultCard.style.setProperty('--ry', '0deg');
        resultCard.classList.remove('is-tilting');
      });
    }

    // Live tier gauge: highlights where the entered MAGI falls among the 5
    // IRMAA brackets, with a small pulse the moment the tier changes.
    const gauge = document.querySelector<HTMLElement>('[data-irmaa-gauge]');
    let lastTier: number | null = null;
    function updateGauge(fields: Record<string, string>) {
      if (!gauge) return;
      const magi = toNum(fields.magi);
      const r = computeIrmaa(toStatus(fields.status), magi, F);
      gauge.querySelectorAll<HTMLElement>('.irmaa-gauge-seg').forEach((el) => {
        const t = Number(el.dataset.tier);
        el.classList.toggle('is-filled', t <= r.tier);
        el.classList.toggle('is-active', t === r.tier);
      });
      gauge.querySelectorAll<HTMLElement>('.irmaa-gauge-labels span').forEach((el) => {
        el.classList.toggle('is-active', Number(el.dataset.tier) === r.tier);
      });
      if (lastTier !== null && lastTier !== r.tier) {
        const active = gauge.querySelector<HTMLElement>('.irmaa-gauge-seg.is-active');
        active?.animate(
          [{ transform: 'scaleY(2.4)' }, { transform: 'scaleY(1.6)' }],
          { duration: 380, easing: 'ease-out' },
        );
      }
      lastTier = r.tier;
    }
    if (form) {
      const onChange = () => updateGauge(readFields(form));
      form.addEventListener('input', onChange);
      form.addEventListener('change', onChange);
      onChange();
    }
  </script>
</CalculatorPage>

<style>
  /* ---- Hero ------------------------------------------------------------ */
  .irmaa-hero {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 2.4rem;
    align-items: center;
    margin: 0.4rem 0 2rem;
  }

  .irmaa-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    border-radius: 999px;
    background: #e5edfe;
    color: #2563eb !important;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .irmaa-badge svg { width: 17px; height: 17px; }

  .irmaa-h1 {
    margin: 0.75rem 0 0.6rem;
    font-size: 2.5rem;
    line-height: 1.12;
    color: #0b2c45;
  }
  .irmaa-h1-accent { color: #2563eb; }

  .irmaa-hero-text :global(.byline) {
    color: #55627a;
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }
  .irmaa-hero-text :global(.byline a) { color: #2563eb; }

  .irmaa-hero-text :global(.summary-block) {
    margin: 0 0 1rem;
    color: #333;
  }
  .irmaa-hero-text :global(.summary-block p) { margin: 0; }

  .irmaa-hero-text :global(.next-steps) { margin: 0 0 1.1rem; }
  .irmaa-hero-text :global(.next-step) {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    background: #eaf1fd;
    border-left: 4px solid #2563eb;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: #17324d;
    font-size: 0.95rem;
  }
  .irmaa-hero-text :global(.next-step)::before {
    content: "↓";
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #2563eb;
