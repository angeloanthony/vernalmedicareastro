---
// src/pages/medicare-news.astro — Medicare Intelligence Center index (M31).
// Redesigned (M45) from a plain nav + link list into a polished landing hub
// (bareHeader + bareFooter) matching the help-center / coverage hubs: a hero
// with feature chips + the "Medicare News" photo, a colored category-card grid
// (one card per category, each surfacing its latest update), a wide Consumer
// Alerts banner, a Questions / FAQ / Related trio, a person CTA banner, and a
// trust bar. Still fully data-driven: every card renders from data/news.ts, so
// adding an article to that file lights it up here with no layout change.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { NEWS_ARTICLES } from '../data/news';
import { NEWS_CATEGORY_META, type NewsCategory } from '../types/News';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const CATEGORY_ORDER: NewsCategory[] = ['costs', 'part-d', 'coverage', 'assistance', 'alerts'];
const fmt = (iso: string) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(iso));

// Only current + historical show on the index; sort newest first.
const live = NEWS_ARTICLES.filter((a) => a.lifecycle !== 'archived').sort((a, b) => b.published.localeCompare(a.published));
const groups = CATEGORY_ORDER
  .map((cat) => ({ cat, meta: NEWS_CATEGORY_META[cat], items: live.filter((a) => a.category === cat) }))
  .filter((g) => g.items.length > 0);

// Presentation metadata per category — icon, accent colour, tint. Keyed by
// NewsCategory so the palette stays stable as articles come and go.
const CAT_STYLE: Record<NewsCategory, { accent: string; tint: string; icon: string }> = {
  costs: {
    accent: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>',
  },
  'part-d': {
    accent: '#dc2626', tint: '#fdeaea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.6 3.4 3.4 10.6a5 5 0 0 0 7.1 7.1l7.1-7.1a5 5 0 1 0-7-7.1z"/><path d="M7 7l7 7"/></svg>',
  },
  coverage: {
    accent: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 0 0-9 9h18a9 9 0 0 0-9-9z"/><path d="M12 12v6.5a2 2 0 0 1-4 0"/></svg>',
  },
  assistance: {
    accent: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.4 5.6a4 4 0 0 0-6-.3l-.4.5-.5-.5a4 4 0 1 0-5.7 5.6l.5.5L14 17l5.7-5.9.7-.7a4 4 0 0 0 0-4.8z"/><path d="M4 13h3l1.5 2.2L11 11l1.5 2h3"/></svg>',
  },
  alerts: {
    accent: '#ea580c', tint: '#fdeadd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>',
  },
};

// Split off Consumer Alerts — it renders as a full-width banner, not a card.
const cardGroups = groups.filter((g) => g.cat !== 'alerts');
const alertGroup = groups.find((g) => g.cat === 'alerts');

// Related-updates rail: the newest handful of live articles.
const related = live.slice(0, 4);

const FEATURES = [
  { title: 'Plain English', sub: 'No jargon',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h9l4 4v14H6z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 16.5h4"/></svg>' },
  { title: 'Trusted Local', sub: 'Vernal & Uintah Basin',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { title: 'Always Up to Date', sub: 'Reviewed each release',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><path d="M12 13l2 2 4-4"/></svg>' },
  { title: 'Here to Help', sub: 'No cost, no pressure',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
];

const TRUST = [
  { color: '#16a34a', title: 'Local & Trusted', sub: 'Licensed in Utah',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { color: '#7c3aed', title: 'No Cost, No Pressure', sub: 'We’re here to help',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { color: '#ea580c', title: 'We Work for You', sub: 'Your best interests first',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20.4 5.6a4 4 0 0 0-6-.3l-2.4 2.4-2.4-2.4a4 4 0 1 0-5.7 5.6L12 19l8.1-8.1a4 4 0 0 0 .3-5.3z"/></svg>' },
  { color: '#2563eb', title: 'Here When You Need Us', sub: 'Call, email, or meet locally',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];

const context: PageContext = {
  page: {
    title: 'Medicare News & Updates — Uintah Basin | Vernal Medicare',
    heading: 'Medicare News & Updates',
    description:
      'Plain-English Medicare news for 2026: the $2,000 drug cap, insulin cap, Medicare Advantage changes, Extra Help, GLP-1 coverage, and scam alerts — what changed and what to do.',
    taxonomy: { silo: 'medicare-101', tags: ['news', 'updates', 'medicare-101', '2026'] },
    summary:
      'Medicare rules change every year. This is what’s new — explained simply, with what changed, who it affects, and what to do about it. Reviewed by a licensed local agent and tied to the guides that go deeper.',
    faqs: [
      { question: 'What’s the biggest Medicare change for 2026?', answer: 'For most people it’s the $2,000 annual cap on out-of-pocket Part D drug costs — the old “donut hole” is gone. Insulin is also capped at $35 a month.' },
      { question: 'How often do you update this news?', answer: 'We review the figures and updates as CMS and Social Security release them, and sooner if a mid-year change is announced. Each article shows when it was published.' },
      { question: 'Will these changes affect my plan?', answer: 'It depends on your plan and situation. Call us free and we’ll tell you exactly what a change means for you — no cost, no pressure.' },
    ],
    sources: [
      { title: 'Medicare.gov — official U.S. government Medicare site', url: 'https://www.medicare.gov', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'Not sure how a change affects you?', action: `call us free at ${BUSINESS.phone} — we’ll explain it for your situation.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-news.html',
    ogType: 'website',
    ogTitle: 'Medicare News & Updates',
    ogDescription: 'What changed in Medicare, who it affects, and what to do — in plain English.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Medicare News', href: '/medicare-news.html' },
  ],
};

const FAQS = context.page.faqs ?? [];
const phoneTel = `tel:${BUSINESS.phoneTel}`;
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="nw-hero">
    <div class="nw-hero__copy">
      <h1 class="nw-hero__title">Medicare<br />News &amp; Updates</h1>
      <p class="nw-hero__tagline">Stay informed. Make confident decisions.</p>
      <p class="nw-hero__lede">
        Medicare rules change every year. We break it down in plain English —
        what’s new, what changed, who it affects, and what to do about it.
        Reviewed by a licensed local agent and tied to the guides that go deeper.
      </p>

      <ul class="nw-hero__features">
        {FEATURES.map((f) => (
          <li>
            <span class="nw-hero__feat-icon" aria-hidden="true" set:html={f.icon} />
            <span><strong>{f.title}</strong><em>{f.sub}</em></span>
          </li>
        ))}
      </ul>
    </div>

    <div class="nw-hero__art">
      <img
        class="nw-hero__img"
        src="/pictures/medicarenews.webp"
        alt="Tablet showing Medicare News — what’s new, what changed, what to do"
        width="1536"
        height="1024"
        loading="eager"
        decoding="async"
      />
      <div class="nw-hero__callout">
        <span class="nw-hero__callout-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>
        <p><strong>Reviewed by a local, licensed agent</strong><span>Every update is checked and tied to a deeper guide.</span></p>
      </div>
    </div>
  </section>

  {/* ─── Category quick-nav ───────────────────────────────────────────── */}
  <nav class="nw-nav" aria-label="News categories">
    {groups.map((g) => {
      const st = CAT_STYLE[g.cat];
      return <a href={`#${g.cat}`} style={`--accent:${st.accent};--tint:${st.tint}`}>{g.meta.label}</a>;
    })}
  </nav>

  {/* ─── Category card grid ───────────────────────────────────────────── */}
  <section class="nw-cats" aria-label="Latest updates by topic">
    <div class="nw-cats__grid">
      {cardGroups.map((g) => {
        const st = CAT_STYLE[g.cat];
        const [lead, ...rest] = g.items;
        return (
          <article id={g.cat} class="nw-card" style={`--accent:${st.accent};--tint:${st.tint}`}>
            <div class="nw-card__head">
              <span class="nw-card__icon" aria-hidden="true" set:html={st.icon} />
              <div>
                <h2 class="nw-card__title">{g.meta.label}</h2>
                <p class="nw-card__blurb">{g.meta.blurb}</p>
              </div>
            </div>

            <a class="nw-feat" href={`medicare-news/${lead.slug}.html`}>
              <span class="nw-feat__date">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/></svg>
                {fmt(lead.published)}{lead.lifecycle === 'historical' ? ' · past update' : ''}
              </span>
              <span class="nw-feat__title">{lead.title}</span>
              <span class="nw-feat__dek">{lead.dek}</span>
            </a>

            {rest.length > 0 && (
              <ul class="nw-more">
                {rest.map((a) => (
                  <li><a href={`medicare-news/${a.slug}.html`}>{a.title}</a></li>
                ))}
              </ul>
            )}

            <a class="nw-card__cta" href={`medicare-news/${lead.slug}.html`}>
              <span>Read the update</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
            </a>
          </article>
        );
      })}
    </div>
  </section>

  {/* ─── Consumer Alerts banner ───────────────────────────────────────── */}
  {alertGroup && (() => {
    const st = CAT_STYLE.alerts;
    const lead = alertGroup.items[0];
    return (
      <section id="alerts" class="nw-alert" style={`--accent:${st.accent};--tint:${st.tint}`}>
        <div class="nw-alert__badge">
          <span class="nw-alert__icon" aria-hidden="true" set:html={st.icon} />
          <div>
            <h2 class="nw-alert__label">{alertGroup.meta.label}</h2>
            <p>{alertGroup.meta.blurb}</p>
          </div>
        </div>
        <a class="nw-alert__item" href={`medicare-news/${lead.slug}.html`}>
          <span class="nw-alert__title">{lead.title}</span>
          <span class="nw-alert__date">{fmt(lead.published)}</span>
          <span class="nw-alert__dek">{lead.dek}</span>
          <span class="nw-alert__more">Read the alert
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </section>
    );
  })()}

  {/* ─── Questions · FAQ · Related trio ───────────────────────────────── */}
  <div class="nw-trio">
    <section class="nw-panel nw-panel--ask">
      <h2 class="nw-panel__h"><span class="nw-panel__hicon nw-panel__hicon--blue" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.4c0 1.7-2.1 2.1-2.1 3.6"/><circle cx="12" cy="17.1" r="0.6" fill="currentColor" stroke="none"/></svg></span>Questions About a Change?</h2>
      <p class="nw-panel__body">News is only useful if you know what it means for <em>you</em>. Call us free at <strong>{BUSINESS.phone}</strong> (TTY: {BUSINESS.tty}) and we’ll translate any Medicare change into a plan for your situation.</p>
      <a class="nw-panel__btn" href="medicare-help-center.html">Go to Medicare Help Center →</a>
    </section>

    <section class="nw-panel">
      <h2 class="nw-panel__h"><span class="nw-panel__hicon nw-panel__hicon--green" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.4c0 1.7-2.1 2.1-2.1 3.6"/><circle cx="12" cy="17.1" r="0.6" fill="currentColor" stroke="none"/></svg></span>Frequently Asked Questions</h2>
      {FAQS.map((q) => (
        <details class="nw-faq">
          <summary set:html={q.question} />
          <p set:html={q.answer} />
        </details>
      ))}
    </section>

    <section class="nw-panel">
      <h2 class="nw-panel__h"><span class="nw-panel__hicon nw-panel__hicon--purple" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H13v15H6.5A2.5 2.5 0 0 0 4 20z"/><path d="M20 6.5A2.5 2.5 0 0 0 17.5 4H13v14h4.5a2.5 2.5 0 0 1 2.5 2.5z"/></svg></span>Related Updates</h2>
      <ul class="nw-links">
        {related.map((a) => (
          <li><a href={`medicare-news/${a.slug}.html`}>{a.title}</a></li>
        ))}
      </ul>
    </section>
  </div>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="nw-cta">
    <img class="nw-cta__photo" src="/pictures/rocco.webp" alt="Rocco DeLuca, licensed Medicare agent in Vernal, Utah" width="88" height="88" loading="lazy" decoding="async" />
    <div class="nw-cta__msg">
      <h2 class="nw-cta__title">Talk to a local, licensed agent</h2>
      <p>Rocco DeLuca can walk you through your options — free, no pressure.</p>
    </div>
    <div class="nw-cta__actions">
      <a class="nw-cta__phone" href={phoneTel}>
        <span class="nw-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="nw-cta__quote" href="medicare-quote-vernal.html">
        <span class="nw-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        Get a Free Quote
      </a>
    </div>
  </section>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="nw-trust">
    {TRUST.map((t) => (
      <div class="nw-trust__item">
        <span class="nw-trust__icon" style={`--c:${t.color}`} aria-hidden="true" set:html={t.icon} />
        <span class="nw-trust__text"><strong>{t.title}</strong><em>{t.sub}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the help-center / coverage hubs: navy #0b2c45, blue #2563eb,
     with per-category accents (blue/red/green/purple/orange). */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .nw-hero {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.25rem 0 1.75rem;
  }
  .nw-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.03;
    font-weight: 800;
    color: #0b2c45;
    margin: 0 0 0.6rem;
  }
  .nw-hero__tagline { font-size: 1.15rem; font-weight: 700; color: #0b2c45; margin: 0 0 0.75rem; }
  .nw-hero__lede { font-size: 1.02rem; color: #475569; line-height: 1.55; margin: 0 0 1.6rem; max-width: 48ch; }

  .nw-hero__features {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.25rem;
  }
  .nw-hero__features li { display: flex; align-items: center; gap: 0.7rem; }
  .nw-hero__features strong { display: block; color: #0b2c45; font-size: 0.95rem; line-height: 1.2; }
  .nw-hero__features em { color: #5b6b7d; font-size: 0.82rem; font-style: normal; line-height: 1.3; display: block; margin-top: 0.1rem; }
  .nw-hero__feat-icon {
    flex: none; width: 42px; height: 42px; border-radius: 12px;
    display: grid; place-items: center;
    background: #e2edfb; color: #1f4e8c;
  }
  .nw-hero__feat-icon svg { width: 22px; height: 22px; }

  .nw-hero__art { position: relative; display: flex; justify-content: center; }
  .nw-hero__img {
    width: 100%; height: auto; display: block;
    border-radius: 18px;
    box-shadow: 0 18px 44px rgba(11, 44, 69, 0.18);
  }
  .nw-hero__callout {
    position: absolute; left: 1.25rem; right: 1.25rem; bottom: -1rem;
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: #fff; border: 1px solid #e1e9f2; border-radius: 14px;
    padding: 0.9rem 1.1rem;
    box-shadow: 0 14px 34px rgba(11, 44, 69, 0.16);
  }
  .nw-hero__callout-icon { flex: none; display: grid; place-items: center; width: 40px; height: 40px; border-radius: 50%; background: #e4f5ea; color: #16a34a; }
  .nw-hero__callout-icon svg { width: 22px; height: 22px; }
  .nw-hero__callout p { margin: 0; color: #475569; font-size: 0.85rem; line-height: 1.45; }
  .nw-hero__callout strong { display: block; color: #0b2c45; font-size: 0.92rem; margin-bottom: 0.1rem; }

  /* ── Category quick-nav ───────────────────────────────────────────────── */
  .nw-nav { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: 0 0 1.75rem; }
  .nw-nav a {
    padding: 0.4rem 0.95rem;
    background: var(--tint); color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, #fff);
    border-radius: 999px; font-size: 0.9rem; font-weight: 700; text-decoration: none;
    transition: filter 0.12s ease, transform 0.12s ease;
  }
  .nw-nav a:hover { filter: brightness(0.97); transform: translateY(-1px); }

  /* ── Category card grid ───────────────────────────────────────────────── */
  .nw-cats { margin: 0 0 1.5rem; }
  .nw-cats__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .nw-card {
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid #e8edf3;
    border-top: 4px solid var(--accent);
    border-radius: 16px;
    padding: 1.6rem 1.5rem 1.4rem;
