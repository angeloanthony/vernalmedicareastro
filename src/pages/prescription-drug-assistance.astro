---
// src/pages/prescription-drug-assistance.astro — Part D / Drug Assistance HUB (M8).
// Pillar for the drug-assistance silo: explains how to pay for expensive drugs on
// Medicare and links every featured drug page (grouped by condition, from data).
// Redesigned (M46) from plain prose into the site's hub visual language (hero
// photo + callout, numbered icon cards, condition-grouped card grid, FAQ ·
// Sources · Related trio, dark person CTA) matching medicare-calculators.astro.
import ArticlePage from '../components/layout/ArticlePage.astro';
import AuthorByline from '../components/content/AuthorByline.astro';
import SummaryBlock from '../components/SummaryBlock.astro';
import NextSteps from '../components/content/NextSteps.astro';
import { FEATURED_DRUGS, PROGRAMS, FUND_STATUS_META } from '../data/drugs';
import { CONDITIONS, CONDITION_STYLE, FALLBACK_CONDITION_STYLE } from '../data/conditions';
import { BUSINESS } from '../data/business';
import { figuresFor } from '../data/annualMedicareData';
import type { FundStatus } from '../types/Drug';
import type { PageContext } from '../types/Page';

const capAmount = figuresFor().partD.annualCap;

// Group featured drugs by condition (data-driven), skipping empty conditions.
const byCondition = CONDITIONS.map((c) => ({
  ...c,
  drugs: FEATURED_DRUGS.filter((d) => d.conditions.includes(c.key)),
})).filter((g) => g.drugs.length > 0);

const COND_STYLE = CONDITION_STYLE;
const FALLBACK_STYLE = FALLBACK_CONDITION_STYLE;

// Foundation fund-open/closed status, for the "Foundation Fund Status" section
// (label/dot text from the shared FUND_STATUS_META; pill color maps to this
// page's own .pda-pill classes).
const FUND_PILL_CLS: Record<FundStatus, string> = { open: 'is-green', verify: 'is-amber', closed: 'is-red' };
const foundations = PROGRAMS.filter((p) => p.type === 'foundation');

// Compact "Related Medicare Tools" cards — real, existing tool pages only.
const TOOLS = [
  {
    href: 'medicare-formulary-lookup.html', name: 'Formulary Lookup', desc: 'See typical Part D coverage & rules.',
    color: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2.5h9l4 4v14.5H6z"/><path d="M15 2.5v5h4"/><path d="M9.3 14.5a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4z"/><path d="M11 16l2.2 2.2"/></svg>',
  },
  {
    href: 'medicare-drug-cost-calculator.html', name: 'Drug Cost Calculator', desc: 'Estimate costs & generic savings.',
    color: '#ca8a04', tint: '#fef3c7',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2.6" y="8.4" width="18.8" height="7.2" rx="3.6" transform="rotate(-45 12 12)"/><path d="M8.7 8.7l6.6 6.6"/></svg>',
  },
  {
    href: 'medicare-extra-help-calculator.html', name: 'Extra Help & Savings Estimator', desc: 'See if you qualify for MSPs & Extra Help.',
    color: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5S4.5 15.2 4.5 9.7A4.2 4.2 0 0 1 12 7a4.2 4.2 0 0 1 7.5 2.7C19.5 15.2 12 20.5 12 20.5z"/></svg>',
  },
  {
    href: 'medicare-cost-estimator.html', name: 'Cost Estimator', desc: 'Estimate total annual Medicare costs.',
    color: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>',
  },
  {
    href: 'medicare-irmaa-calculator.html', name: 'IRMAA Calculator', desc: 'Income-based premium surcharges.',
    color: '#0d9488', tint: '#d7f0ec',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9h9a9 9 0 0 0-9-9z"/></svg>',
  },
];

// "Four Kinds of Help" cards.
const KINDS = [
  {
    n: 1, title: 'Manufacturer Patient Assistance Programs',
    text: 'The drug company provides the medication free or at a low cost based on income.',
    color: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V9l8-5 8 5v12"/><path d="M9 21v-6h6v6"/><path d="M9 12h.01M15 12h.01M9 9h.01M15 9h.01"/></svg>',
  },
  {
    n: 2, title: 'Nonprofit / Patient Foundations',
    text: 'Disease-based charities help with copays and out-of-pocket costs.',
    color: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M2.8 19c0-3.3 2.7-5.5 6.2-5.5s6.2 2.2 6.2 5.5"/><circle cx="17.5" cy="8.5" r="2.4"/><path d="M15.8 13.7c2.7.3 4.9 2.3 4.9 5.3"/></svg>',
  },
  {
    n: 3, title: 'Government Programs',
    text: 'Extra Help and Medicare Savings Programs can lower drug and Medicare costs.',
    color: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5L12 5l8 5.5"/><path d="M5 10.5V19h14v-8.5"/><path d="M9.5 19v-5h5v5"/></svg>',
  },
  {
    n: 4, title: 'Search & Discount Tools',
    text: 'Free databases and tools that find additional ways to save on medications.',
    color: '#ea580c', tint: '#fdeadd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><path d="M15.3 15.3L21 21"/></svg>',
  },
];

const FAQS = [
  {
    q: 'What is Medicare Extra Help?',
    a: 'Extra Help (also called the Part D Low-Income Subsidy or LIS) is a federal program that lowers or eliminates Part D premiums, deductibles, and copays for people with limited income and resources. You apply free through Social Security.',
  },
  {
    q: 'Can I use a manufacturer copay card if I have Medicare?',
    a: 'Usually no. Federal anti-kickback rules generally prohibit people with Medicare or other government drug coverage from using manufacturer copay coupons or savings cards. However, you may still qualify for that manufacturer’s Patient Assistance Program, which provides the drug free or at low cost to eligible people based on income.',
  },
  {
    q: 'What are copay assistance foundations?',
    a: 'Nonprofit foundations such as the PAN Foundation, HealthWell Foundation, Good Days, and the Patient Advocate Foundation Co-Pay Relief Program provide grants that cover out-of-pocket costs for specific diseases. Unlike manufacturer copay cards, these grants can be used by people on Medicare.',
  },
  {
    q: 'How do I qualify for prescription assistance?',
    a: 'Most programs use income limits, often a multiple of the federal poverty level, and many are tied to a specific diagnosis. Manufacturer programs typically require you to be uninsured or underinsured. Each program lists its own rules, and we can help you check yours and apply.',
  },
  {
    q: 'Is this assistance free to apply for?',
    a: 'Yes. Every program listed here is free to apply for. Be cautious of anyone who charges a fee to enroll you in Extra Help, a foundation grant, or a manufacturer assistance program.',
  },
  {
    q: `Does Medicare's $${capAmount.toLocaleString()} cap help with drug costs?`,
    a: `Yes. Since 2025, Medicare Part D limits what you pay out of pocket for covered drugs to $${capAmount.toLocaleString()} per year, and the Medicare Prescription Payment Plan lets you spread that amount across monthly installments. Assistance programs can help with costs before and around that cap.`,
  },
];
const RESOURCES = [
  { label: 'Get help with drug costs', sub: 'Medicare.gov', href: 'https://www.medicare.gov/basics/costs/help/drug-costs' },
  { label: 'Extra Help (Part D Low-Income Subsidy)', sub: 'Social Security Administration', href: 'https://www.ssa.gov/medicare/part-d-extra-help' },
];
const RELATED = [
  { label: 'Part D Drug Cost Calculator', href: 'medicare-part-d-cost-calculator.html' },
  { label: 'Cheapest Prescription Drug Plans in Vernal', href: 'cheapest-prescription-drug-plans.html' },
  { label: 'Tier 3 vs Tier 4 Drugs on Medicare Part D', href: 'tier-3-vs-tier-4-medicare-part-d.html' },
  { label: 'Eliquis Assistance Programs', href: 'eliquis-assistance-program.html' },
];

const context: PageContext = {
  page: {
    title: 'Prescription Drug Assistance on Medicare — Help Paying for Expensive Drugs | Vernal Medicare',
    heading: 'Prescription Drug Assistance on Medicare',
    description:
      "Can't afford your medication on Medicare? Manufacturer patient assistance programs, nonprofit copay grants, and Extra Help can lower or eliminate the cost. See programs by drug — free local help in Utah.",
    taxonomy: { silo: 'part-d', tags: ['drug-assistance', 'part-d', 'extra-help', 'costs'], pillar: true },
    summary:
      "If a prescription is unaffordable, you have more options than you think. On Medicare you usually can't use manufacturer copay coupons — but you can often use the manufacturer's Patient Assistance Program (free drug by income), nonprofit foundation grants, and Extra Help. Pick your drug below to see the programs that fit.",
    faqs: FAQS.map((f) => ({ question: f.q, answer: f.a })),
    sources: [
      { title: 'Get help with drug costs', url: 'https://www.medicare.gov/basics/costs/help/drug-costs', publisher: 'Medicare.gov' },
      { title: 'Extra Help (Part D Low-Income Subsidy)', url: 'https://www.ssa.gov/medicare/part-d-extra-help', publisher: 'Social Security Administration' },
    ],
    nextSteps: [
      {
        when: 'If a medication is straining your budget,',
        action: 'send us your drug list — we\'ll check assistance programs, Extra Help, and the lowest-cost Part D plan for you, free.',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/prescription-drug-assistance.html',
    ogType: 'article',
    ogTitle: 'Prescription Drug Assistance on Medicare',
    ogDescription: 'Manufacturer PAPs, nonprofit grants, and Extra Help — how to pay for expensive drugs on Medicare.',
  },
  author: 'rocco',
  datePublished: '2026-06-30',
  lastUpdated: '2026-06-30',
  medicalDisclaimer:
    'Not medical advice. Program availability, eligibility, and funding change — verify current details with each program directly.',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Prescription Drug Assistance', href: '/prescription-drug-assistance.html' },
  ],
};

const phoneTel = `tel:${BUSINESS.phoneTel}`;
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="pda-hero">
    <div class="pda-hero__copy">
      <h1 class="pda-hero__title">{context.page.heading}</h1>
      <AuthorByline
        authorId={context.author}
        reviewedById={context.reviewedBy}
        updated={context.lastUpdated}
        localAvailability={context.localAvailability}
      />
      <SummaryBlock text={context.page.summary} />
      <NextSteps steps={context.page.nextSteps ?? []} />
    </div>

    <div class="pda-hero__art">
      <img
        class="pda-hero__img"
        src="/pictures/smithpharmacy.webp"
        alt="Rocco DeLuca helping a Medicare beneficiary with a prescription at Smith's Pharmacy in Vernal"
        width="792"
        height="600"
        loading="eager"
        decoding="async"
      />
      <div class="pda-hero__callout">
        <span class="pda-hero__callout-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="2.5" width="10" height="19" rx="3"/><path d="M9.5 7h5M9.5 10.5h5M9.5 14h3"/></svg></span>
        <div>
          <strong>Local Help with Your Medication Costs</strong>
          <p>We'll search programs so you can save.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ─── Copay-card vs. PAP notice ────────────────────────────────────── */}
  <div class="pda-notice">
    <span class="pda-notice__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M12 8v5"/><circle cx="12" cy="16.3" r="0.6" fill="currentColor" stroke="none"/></svg></span>
    <p><strong>On Medicare?</strong> You generally <strong>cannot use manufacturer copay coupons or savings cards</strong> — federal anti-kickback rules block them. But manufacturer <strong>Patient Assistance Programs</strong> (free drug by income) and nonprofit <strong>foundation grants</strong> still can help. The search below focuses on the programs that work <em>with</em> Medicare.</p>
  </div>

  {/* ─── Program Finder ───────────────────────────────────────────────── */}
  <section class="pda-finder">
    <h2 class="pda-h2">Search Assistance Programs</h2>
    <p class="pda-h2-sub">Search a medication, or filter by condition and program type, to see every program that may help.</p>
    <div class="pda-finder__panel">
      <div class="pda-finder__search">
        <span class="pda-finder__search-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><path d="M15.3 15.3L21 21"/></svg></span>
        <label for="pf-search" class="pda-sr-only">Search a medication</label>
        <input type="text" id="pf-search" class="pda-finder__input" list="pf-drug-names" autocomplete="off" placeholder="Medication name — e.g. Eliquis, Ozempic, Humira" />
        <datalist id="pf-drug-names"></datalist>
      </div>
      <div class="pda-finder__filters">
        <div>
          <label class="pda-finder__label" for="pf-cond">Condition (optional)</label>
          <select id="pf-cond" class="pda-finder__select"><option value="all">Any condition</option></select>
        </div>
        <div>
          <label class="pda-finder__label" for="pf-type">Type of help</label>
          <select id="pf-type" class="pda-finder__select">
            <option value="all">All program types</option>
            <option value="government">Government programs</option>
            <option value="foundation">Nonprofit copay grants</option>
            <option value="manufacturer">Manufacturer programs</option>
            <option value="database">Discount &amp; search tools</option>
          </select>
        </div>
      </div>
      <div class="pda-finder__examples">
        <span class="pda-finder__examples-lbl">Try:</span>
        <button type="button" class="pda-chip">Eliquis</button>
        <button type="button" class="pda-chip">Ozempic</button>
        <button type="button" class="pda-chip">Jardiance</button>
        <button type="button" class="pda-chip">Humira</button>
        <button type="button" class="pda-chip">Farxiga</button>
        <button type="button" class="pda-chip">Repatha</button>
      </div>
      <p class="pda-finder__count" id="pf-count"></p>
      <div class="pda-finder__grid" id="pf-grid" aria-live="polite"></div>
    </div>
  </section>

  {/* Program details modal (Program Finder) */}
  <div class="pda-modal" id="pf-modal" role="dialog" aria-modal="true" aria-label="Program details">
    <div class="pda-modal__bg" data-pf-close></div>
    <div class="pda-modal__panel" id="pf-modal-panel"></div>
  </div>

  {/* ─── Four Kinds of Help ───────────────────────────────────────────── */}
  <section class="pda-kinds">
    <h2 class="pda-h2">The Four Kinds of Help</h2>
    <p class="pda-h2-sub">These programs can lower what you pay for medications.</p>
    <div class="pda-kinds__grid">
      {KINDS.map((k) => (
        <div class="pda-kind" style={`--c:${k.color};--t:${k.tint}`}>
          <span class="pda-kind__icon" aria-hidden="true" set:html={k.icon} />
          <h3>{k.n}. {k.title}</h3>
          <p>{k.text}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─── Find Assistance by Medication ───────────────────────────────── */}
  <section class="pda-find">
    <h2 class="pda-h2">Find Assistance by Medication</h2>
    <p class="pda-h2-sub">Select your condition to see programs that may help.</p>
    <div class="pda-find__panel">
      <div class="pda-find__grid">
        {byCondition.map((g) => {
          const style = COND_STYLE[g.key] ?? FALLBACK_STYLE;
          return (
            <div class="pda-cond">
              <h3 class="pda-cond__h" style={`--c:${style.color};--t:${style.tint}`}>
                <span class="pda-cond__icon" aria-hidden="true" set:html={style.icon} />
                {g.label}
              </h3>
              <ul>
                {g.drugs.map((d) => (
                  <li><a href={`/${d.slug}-assistance-program.html`}>{d.drug}</a> <span class="pda-cond__generic">({d.generic})</span></li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* ─── Eligibility Estimator ─────────────────────────────────────────── */}
  <section class="pda-estimator">
    <h2 class="pda-h2">Do I Qualify? Quick Eligibility Estimator</h2>
    <p class="pda-h2-sub">Answer a few quick questions for a rough idea of which kinds of help you may qualify for. Nothing is saved or submitted.</p>
    <div class="pda-estimator__panel">
      <div class="pda-estimator__grid">
        <div>
          <label class="pda-finder__label" for="est-status">Marital status</label>
          <select id="est-status" class="pda-finder__select">
            <option value="single">Single</option>
            <option value="married">Married</option>
          </select>
        </div>
        <div>
          <label class="pda-finder__label" for="est-house">People in household</label>
          <select id="est-house" class="pda-finder__select">
            <option>1</option><option>2</option><option>3</option><option>4</option>
            <option>5</option><option>6</option><option>7</option><option>8</option>
          </select>
        </div>
        <div>
          <label class="pda-finder__label" for="est-income">Annual household income</label>
          <input type="text" inputmode="numeric" id="est-income" class="pda-finder__input pda-finder__input--plain" placeholder="e.g. 28,000" />
        </div>
        <div>
          <label class="pda-finder__label" for="est-cost">Your monthly drug cost</label>
          <select id="est-cost" class="pda-finder__select">
            <option value="0">Not sure</option>
            <option value="100">Under $100</option>
            <option value="300">$100–300</option>
            <option value="600">$300–600</option>
            <option value="1000">$600–1,000</option>
            <option value="1500">Over $1,000</option>
          </select>
        </div>
      </div>
      <button type="button" id="est-go" class="pda-estimator__btn">See what I may qualify for</button>
      <div id="est-result" class="pda-estimator__result" aria-live="polite"></div>
    </div>
  </section>

  {/* ─── Foundation Fund Status ────────────────────────────────────────── */}
  <section class="pda-fundstatus">
    <h2 class="pda-h2">Foundation Fund Status</h2>
    <p class="pda-h2-sub">Fund availability changes often and varies by diagnosis — always verify directly with the foundation before applying.</p>
    <div class="pda-fundstatus__panel">
      {foundations.map((p) => (
        <div class="pda-fund-row">
          <span class="pda-fund-row__name"><a href={p.url} target="_blank" rel="noopener noreferrer">{p.name}</a></span>
          {p.status && <span class={`pda-pill ${FUND_PILL_CLS[p.status]}`}>{FUND_STATUS_META[p.status].dot} {FUND_STATUS_META[p.status].label}</span>}
        </div>
      ))}
    </div>
  </section>

  {/* ─── Document Checklist ────────────────────────────────────────────── */}
  <section class="pda-checklist-section">
    <h2 class="pda-h2">Documents You'll Need to Apply</h2>
    <div class="pda-checklist-panel" id="pda-print-area">
      <div class="pda-print-head">
        <h3>Prescription Drug Assistance — Document Checklist</h3>
        <p>Vernal Medicare &middot; Rocco DeLuca, licensed Utah Medicare agent &middot; {BUSINESS.phone}</p>
      </div>
      <ul class="pda-checklist">
        <li>Medicare card (red, white &amp; blue)</li>
        <li>Prescription drug plan (Part D) card</li>
        <li>Social Security award or benefit letter</li>
        <li>Proof of income (Social Security, pension, wages)</li>
        <li>Most recent tax return, if you file one</li>
        <li>Complete medication list with dosages</li>
        <li>Preferred pharmacy name &amp; address</li>
        <li>Bank &amp; resource information (for Extra Help and Medicaid)</li>
        <li>Prescribing doctor's name &amp; contact info (for diagnosis verification)</li>
      </ul>
      <button type="button" class="pda-estimator__btn pda-no-print" id="pda-print-btn">Print / Save as PDF</button>
    </div>
  </section>

  {/* ─── Note + Help-panel duo ────────────────────────────────────────── */}
  <div class="pda-duo">
    <div class="pda-note">
      <span class="pda-note__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M2.8 19c0-3.3 2.7-5.5 6.2-5.5s6.2 2.2 6.2 5.5"/><circle cx="17.5" cy="8.5" r="2.4"/><path d="M15.8 13.7c2.7.3 4.9 2.3 4.9 5.3"/></svg></span>
      <p><strong>Don't see your medication, or not sure where to start?</strong> Call us — we'll screen every program you might qualify for and help you apply, free, anywhere in the Uintah Basin or by phone across Utah.</p>
    </div>
    <div class="pda-help">
      <span class="pda-help__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11.5l2 2 4-4.5"/><path d="M4 6.5l8-3.5 8 3.5v5c0 5-3.4 8.2-8 9.5-4.6-1.3-8-4.5-8-9.5z"/></svg></span>
      <h3>We're Here to Help</h3>
      <p class="pda-help__sub">Our job is to save you time and money.</p>
      <ul class="pda-help__list">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> We check every option</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Help with applications</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Local & personal support</li>
      </ul>
      <a class="pda-help__cta" href={phoneTel}>Call {BUSINESS.phone}</a>
    </div>
  </div>

  {/* ─── Related Medicare Tools ────────────────────────────────────────── */}
  <section class="pda-tools">
    <h2 class="pda-h2">Related Medicare Tools</h2>
    <div class="pda-tools__grid">
      {TOOLS.map((t) => (
