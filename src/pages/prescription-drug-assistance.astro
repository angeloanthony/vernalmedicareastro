  <script>
    // Program Finder — search a medication or filter by condition/type across
    // the shared PROGRAMS database (data/drugs.ts) — same data every per-drug
    // assistance page uses, so results here always match those pages.
    import { PROGRAMS, TYPE_META } from '../data/drugs';
    import { CONDITIONS, condLabel } from '../data/conditions';
    import { BUSINESS } from '../data/business';

    const smsBase = `sms:${BUSINESS.phoneTel}?body=`;

    const searchEl = document.getElementById('pf-search') as HTMLInputElement | null;
    const condEl = document.getElementById('pf-cond') as HTMLSelectElement | null;
    const typeEl = document.getElementById('pf-type') as HTMLSelectElement | null;
    const gridEl = document.getElementById('pf-grid');
    const countEl = document.getElementById('pf-count');
    const datalist = document.getElementById('pf-drug-names');
    const modal = document.getElementById('pf-modal');
    const panel = document.getElementById('pf-modal-panel');

    if (searchEl && condEl && typeEl && gridEl && countEl && datalist && modal && panel) {
      condEl.innerHTML =
        '<option value="all">Any condition</option>' +
        CONDITIONS.map((c) => `<option value="${c.key}">${c.label}</option>`).join('');

      // drug name -> { conditions[], mfr program ids[] }, built from the
      // manufacturer programs' own `drugs` lists.
      const DRUG_INDEX: Record<string, { name: string; conditions: string[]; mfr: string[] }> = {};
      function indexDrug(name: string, conds: string[], mfrId?: string) {
        const k = name.toLowerCase();
        if (!DRUG_INDEX[k]) DRUG_INDEX[k] = { name, conditions: [], mfr: [] };
        conds.forEach((c) => { if (!DRUG_INDEX[k].conditions.includes(c)) DRUG_INDEX[k].conditions.push(c); });
        if (mfrId && !DRUG_INDEX[k].mfr.includes(mfrId)) DRUG_INDEX[k].mfr.push(mfrId);
      }
      PROGRAMS.forEach((p) => {
        if (p.type === 'manufacturer' && p.drugs) {
          const conds = p.conditions.filter((c) => c !== 'any');
          p.drugs.forEach((d) => indexDrug(d, conds, p.id));
        }
      });
      datalist.innerHTML = Object.values(DRUG_INDEX).map((e) => `<option value="${e.name}"></option>`).join('');

      const TYPE_ORDER: Record<string, number> = { government: 0, foundation: 1, manufacturer: 2, database: 3 };

      function condsForQuery(q: string) {
        if (!q) return null;
        if (DRUG_INDEX[q]) return DRUG_INDEX[q];
        const key = Object.keys(DRUG_INDEX).find((k) => k.includes(q));
        return key ? DRUG_INDEX[key] : { name: null as string | null, conditions: [] as string[], mfr: [] as string[] };
      }

      function programMatches(p: (typeof PROGRAMS)[number], q: string, info: { conditions: string[]; mfr: string[] }, cond: string, typeFilter: string) {
        if (typeFilter !== 'all' && p.type !== typeFilter) return false;
        if (cond !== 'all' && !p.conditions.includes('any') && !p.conditions.includes(cond)) return false;
        if (!q) return true;
        if (p.conditions.includes('any')) return true;
        if (info.mfr.includes(p.id)) return true;
        if (p.type === 'manufacturer') return !!p.drugs?.some((d) => d.toLowerCase().includes(q));
        return info.conditions.some((c) => p.conditions.includes(c));
      }

      function typicalLine(p: (typeof PROGRAMS)[number], drugName: string) {
        if (p.typical) return p.typical;
        if (p.type === 'government') return 'May lower or eliminate your Part D premium, deductible, and copays.';
        if (p.type === 'foundation') return 'May cover copays and coinsurance for a qualifying diagnosis.';
        if (p.type === 'database') return 'Free search to find programs for your specific medications.';
        let drug: string | null = null;
        if (drugName && p.drugs) {
          const q = drugName.toLowerCase();
          drug = p.drugs.find((d) => d.toLowerCase().includes(q)) ?? null;
        }
        return `May provide ${drug || 'your medication'} at no cost if you qualify.`;
      }

      function render() {
        const q = searchEl!.value.trim().toLowerCase();
        const cond = condEl!.value;
        const typeFilter = typeEl!.value;
        const info = condsForQuery(q) ?? { name: null, conditions: [], mfr: [] };

        const list = PROGRAMS.filter((p) => programMatches(p, q, info, cond, typeFilter))
          .sort((a, b) => (TYPE_ORDER[a.type] - TYPE_ORDER[b.type]) || a.name.localeCompare(b.name));

        const label = q ? (info.name || searchEl!.value.trim()) : '';
        countEl!.textContent = q && label
          ? `Showing ${list.length} program${list.length === 1 ? '' : 's'} that may help with ${label}.`
          : `Showing ${list.length} of ${PROGRAMS.length} assistance programs.`;

        if (!list.length) {
          gridEl!.innerHTML = `<div class="pda-finder__empty">No programs match that search. Try the medication's brand name, broaden the filters, or <a href="${smsBase}${encodeURIComponent('Hi, can you help me find assistance for a medication?')}">text us the drug name &rarr;</a></div>`;
          return;
        }

        gridEl!.innerHTML = list.map((p) => {
          const t = TYPE_META[p.type];
          const statusChip = p.status ? `<span class="pda-pill is-${p.status === 'open' ? 'green' : p.status === 'verify' ? 'amber' : 'red'}">${p.status === 'open' ? '🟢 Fund open' : p.status === 'verify' ? '🟡 Verify availability' : '🔴 Currently closed'}</span>` : '';
          return `<div class="pda-prog">
            <div class="pda-prog__top"><h3>${p.name}</h3><span class="pda-pill" style="background:${t.tint};color:${t.color}">${t.label}</span></div>
            <div class="pda-prog__tagline">${p.tagline}</div>
            ${statusChip ? `<div class="pda-prog__status">${statusChip}</div>` : ''}
            <button type="button" class="pda-prog__view" data-id="${p.id}">View details &amp; apply
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
            </button>
          </div>`;
        }).join('');
      }

      function openModal(p: (typeof PROGRAMS)[number]) {
        const t = TYPE_META[p.type];
        const typical = typicalLine(p, searchEl!.value.trim());
        const condText = p.conditions.includes('any') ? 'Any condition' : p.conditions.map((c) => condLabel(c)).join(', ');
        const drugLine = p.drugs?.length ? `<div class="pda-modal__sec"><h4>Medications it may cover</h4><p>${p.drugs.join(', ')}</p></div>` : '';
        const phoneBtn = p.phone ? `<a class="pda-modal__ghost" href="tel:${p.phone.replace(/[^0-9]/g, '')}">${p.phone}</a>` : '';

        panel!.innerHTML = `
          <button type="button" class="pda-modal__close" data-pf-close aria-label="Close">&times;</button>
          <h2>${p.name}</h2>
          <p class="pda-modal__sub"><span class="pda-pill" style="background:${t.tint};color:${t.color}">${t.label}</span></p>
          <div class="pda-modal__typical"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.5l2.5 2.5 4.5-5"/></svg><span>Typical assistance: ${typical}</span></div>
          <div class="pda-modal__sec"><h4>What it helps with</h4><p>${p.helps}</p></div>
          <div class="pda-modal__sec"><h4>Who may qualify</h4><p>${p.eligibility}</p></div>
          <div class="pda-modal__sec"><h4>Conditions covered</h4><p>${condText}</p></div>
          ${drugLine}
          <div class="pda-modal__actions">
            <a class="pda-modal__primary" href="${p.url}" target="_blank" rel="noopener noreferrer">${p.urlLabel || 'Visit program'}</a>
            ${phoneBtn}
          </div>
          <div class="pda-modal__sec" style="margin-top:1.2rem">
            <a class="pda-pill is-blue pda-modal__sms" href="${smsBase}${encodeURIComponent(`Hi, can you help me apply for ${p.name}?`)}">Ask us to help me apply</a>
          </div>`;
        modal!.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function closeModal() { modal!.classList.remove('is-open'); document.body.style.overflow = ''; }

      gridEl.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.pda-prog__view');
        if (!btn) return;
        const p = PROGRAMS.find((x) => x.id === btn.getAttribute('data-id'));
        if (p) openModal(p);
      });
      modal.addEventListener('click', (e) => { if ((e.target as HTMLElement).closest('[data-pf-close]')) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal!.classList.contains('is-open')) closeModal(); });

      document.querySelectorAll<HTMLElement>('.pda-chip').forEach((c) => {
        c.addEventListener('click', () => { searchEl.value = c.textContent || ''; render(); searchEl.focus(); });
      });

      searchEl.addEventListener('input', render);
      condEl.addEventListener('change', render);
      typeEl.addEventListener('change', render);
      render();
    }
  </script>

  <script>
    // Eligibility Estimator — MSP/Extra Help uses the real published dollar
    // limits (computeAssistanceEligibility); manufacturer PAP / foundation
    // grants are estimated as a rough % of the federal poverty level, since
    // those programs are typically priced that way.
    import { computeAssistanceEligibility } from '../lib/calculators/assistance';
    import { figuresFor } from '../data/annualMedicareData';
    import { pctOfFpl } from '../data/federalPovertyLevel';

    const F = figuresFor();
    const estGo = document.getElementById('est-go');
    if (estGo) {
      const estStatus = document.getElementById('est-status') as HTMLSelectElement;
      const estHouse = document.getElementById('est-house') as HTMLSelectElement;
      const estIncome = document.getElementById('est-income') as HTMLInputElement;
      const estCost = document.getElementById('est-cost') as HTMLSelectElement;
      const estResult = document.getElementById('est-result')!;

      type Tier = 'yes' | 'maybe' | 'no';
      const iconFor = (s: Tier) =>
        s === 'yes'
          ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>'
          : s === 'maybe'
            ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v5"/><circle cx="12" cy="16.3" r="0.6" fill="currentColor" stroke="none"/></svg>'
            : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>';
      const estRow = (state: Tier, title: string, text: string) =>
        `<div class="pda-est-row"><div class="pda-est-row__ico is-${state}">${iconFor(state)}</div><div><h4>${title}</h4><p>${text}</p></div></div>`;
      const tierFor = (pct: number, strong: number, maybe: number): Tier => (pct <= strong ? 'yes' : pct <= maybe ? 'maybe' : 'no');
      const tierText = (s: Tier) =>
        s === 'yes' ? 'You likely qualify based on income.' : s === 'maybe' ? 'You may qualify — worth applying.' : 'Your income is likely above the typical limit, but rules vary.';

      estGo.addEventListener('click', () => {
        const size = parseInt(estHouse.value, 10) || 1;
        const income = parseFloat((estIncome.value || '').replace(/[^0-9.]/g, ''));
        if (!income || income < 0) {
          estResult.innerHTML = '<div class="pda-est-note">Enter your annual household income to see an estimate.</div>';
          estResult.classList.add('is-shown');
          return;
        }
        const married = estStatus.value === 'married';
        const monthlyIncome = income / 12;
        const pct = pctOfFpl(income, size);

        const assist = computeAssistanceEligibility(monthlyIncome, 0, married, F);
        const mspState: Tier = assist.program !== 'none' ? 'yes' : assist.extraHelp === 'possible' ? 'maybe' : 'no';
        const mspText = assist.program !== 'none'
          ? `Based on income alone, you may qualify for ${assist.program.toUpperCase()} — which also unlocks Extra Help automatically. (Resource/asset limits also apply — check yours when you apply.)`
          : assist.extraHelp === 'possible'
            ? 'Your income is close to the Medicare Savings Program limit — worth applying; resource limits also matter.'
            : 'Your income is likely above the Medicare Savings Program limit, but resource rules vary — worth checking directly.';

        const ehState: Tier = assist.extraHelp === 'automatic' ? 'yes' : assist.extraHelp === 'possible' ? 'maybe' : 'no';
        const ehText = assist.extraHelp === 'automatic'
          ? 'Qualifying for a Medicare Savings Program grants Extra Help automatically.'
          : assist.extraHelp === 'possible'
            ? 'You may qualify for Extra Help on income alone — apply free through Social Security.'
            : 'Income is likely above the typical Extra Help limit, but it is still free to check.';

        const pap = tierFor(pct, 300, 400);
        const fnd = tierFor(pct, 400, 500);

        const costVal = parseInt(estCost.value, 10) || 0;
        const costNote = costVal >= 600
          ? ` With high monthly drug costs, the $${F.partD.annualCap.toLocaleString()} yearly Part D cap matters a lot — ask about the Medicare Prescription Payment Plan to spread payments over the year.`
          : '';

        estResult.innerHTML =
          `<div class="pda-est-headline">Your income is about ${Math.round(pct)}% of the federal poverty level (household of ${size}).</div>` +
          estRow(mspState, 'Medicare Savings Programs', mspText) +
          estRow(ehState, 'Medicare Extra Help (Part D)', ehText) +
          estRow(pap, 'Manufacturer Patient Assistance', `${tierText(pap)} These provide brand-name drugs free or at low cost.`) +
          estRow(fnd, 'Foundation Grants', `${tierText(fnd)} Available when a fund is open for your diagnosis.`) +
          `<div class="pda-est-note">This is a rough, income-only screening. Real eligibility also depends on your assets/resources, your specific diagnosis, and whether a fund is currently open.${costNote}</div>`;
        estResult.classList.add('is-shown');
      });
    }

    const printBtn = document.getElementById('pda-print-btn');
    printBtn?.addEventListener('click', () => window.print());
  </script>
</ArticlePage>

