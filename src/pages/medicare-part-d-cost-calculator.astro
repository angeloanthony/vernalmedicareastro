---
// src/pages/medicare-part-d-cost-calculator.astro — Calculator Platform (M33).
// Estimates annual Part D drug costs with the 2026 $2,000 out-of-pocket cap.
import CalculatorPage from '../components/layout/CalculatorPage.astro';
import CalculatorSection from '../components/calculator/CalculatorSection.astro';
import CalculatorInput from '../components/calculator/CalculatorInput.astro';
import CalculatorResult from '../components/calculator/CalculatorResult.astro';
import CalculatorPrint from '../components/calculator/CalculatorPrint.astro';
import CalculatorShare from '../components/calculator/CalculatorShare.astro';
import AuthorByline from '../components/content/AuthorByline.astro';
import SummaryBlock from '../components/SummaryBlock.astro';
import NextSteps from '../components/content/NextSteps.astro';
import { figuresFor } from '../data/annualMedicareData';
import { usd } from '../lib/formatters';
import type { PageContext } from '../types/Page';
import type { CalculatorField } from '../types/Calculator';

const f = figuresFor();
const year = f.year;
const premiumField: CalculatorField = {
  id: 'premium', label: 'Your Part D plan’s monthly premium', type: 'currency',
  help: `The ${year} base premium is about ${usd(f.partD.basePremium, { cents: true })}, but plans vary.`,
};
const drugField: CalculatorField = {
  id: 'drugoop', label: 'Estimated yearly out-of-pocket drug spend (without the cap)', type: 'currency',
  help: 'A rough guess is fine — the calculator applies the annual cap for you.',
};

const context: PageContext = {
  page: {
    title: `Medicare Part D Drug Cost Calculator ${year} — With the $2,000 Cap | Vernal Medicare`,
    heading: 'Part D Drug Cost Calculator',
    description: `Estimate your yearly Medicare Part D costs — premium plus out-of-pocket drug spending, now capped at ${usd(f.partD.annualCap)} for ${year}.`,
    taxonomy: { silo: 'part-d', tags: ['part-d', 'costs', 'tools', 'drug-cap'] },
    summary: `In ${year}, your out-of-pocket spending on covered Part D drugs is capped at ${usd(f.partD.annualCap)} — the old “donut hole” is gone. Enter your plan premium and rough drug spending to estimate your yearly total and see how much the cap saves you.`,
    faqs: [
      { question: `What is the ${year} Part D out-of-pocket cap?`, answer: `${usd(f.partD.annualCap)}. Once your out-of-pocket spending on covered drugs reaches it, you pay nothing more for covered prescriptions the rest of the year.` },
      { question: 'Does the cap include my premium?', answer: 'No — the cap is on your out-of-pocket drug costs (deductible, copays, coinsurance). Your monthly plan premium is separate.' },
    ],
    sources: [{ title: 'Medicare.gov — drug coverage (Part D)', url: 'https://www.medicare.gov/drug-coverage-part-d', publisher: 'Medicare.gov' }],
    nextSteps: [
      {
        when: 'Drug costs still adding up fast?',
        action: 'check whether you qualify for Extra Help — it can cut your premium and copays further.',
        href: 'medicare-extra-help-calculator.html',
      },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-part-d-cost-calculator.html',
    ogType: 'website',
    ogTitle: 'Part D Drug Cost Calculator',
    ogDescription: 'Estimate your yearly Part D costs with the new $2,000 out-of-pocket cap.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  medicalDisclaimer: 'Simplified estimate. Your actual costs depend on your plan’s formulary, tiers, and pharmacy.',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Part D Plans', href: '/best-part-d-plans-vernal.html' },
    { name: 'Drug Cost Calculator', href: '/medicare-part-d-cost-calculator.html' },
  ],
};
---

<CalculatorPage context={context} bareHeader>
  <div class="pd-hero">
    <div class="pd-hero-text">
      <span class="pd-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2.6" y="8.4" width="18.8" height="7.2" rx="3.6" transform="rotate(-45 12 12)"/><path d="M8.7 8.7l6.6 6.6"/></svg>
        Updated for {year}
      </span>
      <h1 class="pd-h1">Part D Drug Cost<br /><span class="pd-h1-accent">Calculator</span></h1>
      <AuthorByline
        authorId={context.author}
        reviewedById={context.reviewedBy}
        updated={context.lastUpdated}
        localAvailability={context.localAvailability}
      />
      <SummaryBlock text={context.page.summary} />
      <NextSteps steps={context.page.nextSteps ?? []} />
      <p class="pd-hero-lede">Part D costs come in two pieces: your monthly premium, and what you pay out of pocket for your drugs — which is now capped at <strong>{usd(f.partD.annualCap)}</strong> a year. Estimate your total below, then <a href="best-part-d-plans-vernal.html">compare Part D plans</a>.</p>
    </div>

    <div class="pd-hero-art" aria-hidden="true">
      <div class="pd-hero-card">
        <div class="pd-hero-card-top">
          <span class="pd-hero-led"></span>
          <span class="pd-hero-dot"></span>
          <span class="pd-hero-dot"></span>
          <span class="pd-hero-solar"></span>
        </div>
        <div class="pd-hero-display">
          <span class="pd-hero-display-label">Annual Cap</span>
          <span class="pd-hero-display-digits">{usd(f.partD.annualCap)}</span>
        </div>
        <div class="pd-hero-keys">
          <span class="pd-hero-key is-op">C</span>
          <span class="pd-hero-key is-op">%</span>
          <span class="pd-hero-key is-op">÷</span>
          <span class="pd-hero-key is-op">×</span>
          <span class="pd-hero-key">7</span>
          <span class="pd-hero-key">8</span>
          <span class="pd-hero-key">9</span>
          <span class="pd-hero-key is-op">−</span>
          <span class="pd-hero-key">4</span>
          <span class="pd-hero-key">5</span>
          <span class="pd-hero-key">6</span>
          <span class="pd-hero-key is-op">+</span>
          <span class="pd-hero-key">1</span>
          <span class="pd-hero-key">2</span>
          <span class="pd-hero-key">3</span>
          <span class="pd-hero-key is-eq">=</span>
          <span class="pd-hero-key is-zero">0</span>
          <span class="pd-hero-key">.</span>
        </div>
      </div>
      <div class="pd-hero-float">
        <span class="pd-hero-float-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 18v-1.5A6.5 6.5 0 0 1 10.5 10h3A6.5 6.5 0 0 1 20 16.5V18"/><rect x="2.5" y="16" width="4" height="5" rx="1.3"/><rect x="17.5" y="16" width="4" height="5" rx="1.3"/><circle cx="12" cy="6" r="3.2"/></svg>
        </span>
        <span>
          <strong>The donut hole is gone</strong>
          <p>Once you hit the cap, covered drugs cost you nothing more this year.</p>
        </span>
      </div>
    </div>
  </div>

  <div class="pd-feature-grid">
    <div class="pd-feature-card">
      <span class="pd-feature-icon" style="--c:#7c3aed;--t:#f0e9fd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16.5" rx="2"/><path d="M8 7h8M8 11h2M12 11h2M16 11h0M8 15h2M12 15h2M16 15h0"/></svg>
      </span>
      <h3>{usd(f.partD.annualCap)} Annual Cap</h3>
      <p>Once your covered drug out-of-pocket spending hits the cap, you pay nothing more for the rest of {year}.</p>
    </div>
    <div class="pd-feature-card">
      <span class="pd-feature-icon" style="--c:#2563eb;--t:#e5edfe">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M14.6 9a2.7 2.7 0 0 0-2.6-1.6c-1.5 0-2.5.8-2.5 1.9 0 2.5 5 1.4 5 4 0 1.1-1 2-2.6 2A2.8 2.8 0 0 1 9.2 15"/></svg>
      </span>
      <h3>Premium + Out-of-Pocket</h3>
      <p>Your yearly total is your plan premium plus what you actually spend on drugs, capped by the {year} limit.</p>
    </div>
    <div class="pd-feature-card">
      <span class="pd-feature-icon" style="--c:#16a34a;--t:#e4f5ea">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 15l3.5-4.5 3 3L19 7"/></svg>
      </span>
      <h3>Based on the {year} Base Premium</h3>
      <p>Estimated against the {year} base Part D premium of {usd(f.partD.basePremium, { cents: true })}.</p>
    </div>
    <div class="pd-feature-card">
      <span class="pd-feature-icon" style="--c:#ea580c;--t:#fdeadd">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M6 6l1.2 12a2 2 0 0 0 2 1.8h5.6a2 2 0 0 0 2-1.8L18 6"/><path d="M9 10.5l2.3 2.5 3.7-4.5"/></svg>
      </span>
      <h3>Still Too High?</h3>
      <p>You may qualify for lower costs — check the <a href="medicare-extra-help-calculator.html">Extra Help calculator</a>.</p>
    </div>
  </div>

  <form class="calc-form" data-calc-form novalidate>
    <div class="calc-form-head">
      <div class="calc-form-icon" aria-hidden="true">🧮</div>
      <div class="calc-form-titles">
        <h2 class="calc-form-title">Estimate Your Part D Cost</h2>
        <p class="calc-form-sub">Adjust the inputs below — your estimate updates as you type.</p>
      </div>
      <span class="calc-form-timer" aria-hidden="true">⏱ About 20 seconds</span>
    </div>

    <CalculatorSection title="Your plan & drugs">
      <CalculatorInput field={premiumField} />
      <CalculatorInput field={drugField} />
    </CalculatorSection>
    <div class="calc-actions">
      <button type="button" class="btn btn-primary" data-calc-calculate>See My Part D Estimate</button>
      <CalculatorPrint />
      <CalculatorShare />
    </div>
  </form>

  <div class="calc-result-stage">
    <CalculatorResult heading="Your estimated yearly Part D cost" />
  </div>

  <p>Struggling with drug costs? See <a href="medicare-extra-help-calculator.html">whether you qualify for Extra Help</a> or <a href="prescription-drug-assistance.html">prescription assistance</a> — both can cut this further.</p>

  <script>
    import { bindCalculator } from '../lib/calculators';
    import { computePartDCost } from '../lib/calculators/partDCost';
    import { figuresFor } from '../data/annualMedicareData';
    import { usd } from '../lib/formatters';
    import type { CalculatorResult } from '../types/Calculator';

    const F = figuresFor();
    const num = (s: string) => Number(String(s || '').replace(/[^0-9.]/g, '')) || 0;

    function compute(fields: Record<string, string>): CalculatorResult {
      const r = computePartDCost(num(fields.premium), num(fields.drugoop), F);
      return {
        summary:
          r.capSavings > 0
            ? `The ${usd(r.cap)} cap saves you about ${usd(r.capSavings)} this year — your estimated yearly total is ${usd(r.annualTotal)}.`
            : `Your estimated yearly Part D total is ${usd(r.annualTotal)} (you’re under the ${usd(r.cap)} drug cap).`,
        rows: [
          { label: 'Annual premium', value: usd(r.annualPremium) },
          { label: 'Out-of-pocket drug cost (after cap)', value: usd(r.cappedDrugOutOfPocket) },
          { label: 'Saved by the $2,000 cap', value: usd(r.capSavings) },
          { label: 'Estimated yearly total', value: usd(r.annualTotal), emphasis: true },
        ],
      };
    }

    const form = document.querySelector<HTMLElement>('[data-calc-form]');
    const results = document.querySelector<HTMLElement>('[data-calc-results]');
    if (form && results) bindCalculator(form, results, compute);

    // Results update live on every input; the primary button just guides the
    // eye down to the (already computed) estimate for a satisfying action.
    const resultCard = document.querySelector<HTMLElement>('.calc-result');
    document.querySelector('[data-calc-calculate]')?.addEventListener('click', () => {
      resultCard?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      resultCard?.animate(
        [{ boxShadow: '0 0 0 4px rgba(124,58,237,0.45)' }, { boxShadow: '0 16px 40px rgba(11,44,69,0.28)' }],
        { duration: 900, easing: 'ease-out' },
      );
    });

    // Interactive 3D: the estimate card tilts toward the cursor and a sheen
    // tracks it. Mouse only; honours reduced-motion.
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (resultCard && !reduceMotion) {
      const MAX_TILT = 8; // degrees
      resultCard.addEventListener('pointermove', (e: PointerEvent) => {
        if (e.pointerType && e.pointerType !== 'mouse') return;
        const r = resultCard.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width;
        const py = (e.clientY - r.top) / r.height;
        resultCard.style.setProperty('--ry', `${((px - 0.5) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--rx', `${((0.5 - py) * 2 * MAX_TILT).toFixed(2)}deg`);
        resultCard.style.setProperty('--mx', `${(px * 100).toFixed(1)}%`);
        resultCard.style.setProperty('--my', `${(py * 100).toFixed(1)}%`);
        resultCard.classList.add('is-tilting');
      });
      resultCard.addEventListener('pointerleave', () => {
        resultCard.style.setProperty('--rx', '0deg');
        resultCard.style.setProperty('--ry', '0deg');
        resultCard.classList.remove('is-tilting');
      });
    }
  </script>
</CalculatorPage>

<style>
  /* ---- Hero ------------------------------------------------------------ */
  .pd-hero {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 2.4rem;
    align-items: center;
    margin: 0.4rem 0 2rem;
  }

  .pd-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.8rem 0.35rem 0.6rem;
    border-radius: 999px;
    background: #f0e9fd;
    color: #7c3aed !important;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .pd-badge svg { width: 17px; height: 17px; }

  .pd-h1 {
    margin: 0.75rem 0 0.6rem;
    font-size: 2.5rem;
    line-height: 1.12;
    color: #0b2c45;
  }
  .pd-h1-accent { color: #7c3aed; }

  .pd-hero-text :global(.byline) {
    color: #55627a;
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }
  .pd-hero-text :global(.byline a) { color: #2563eb; }

  .pd-hero-text :global(.summary-block) {
    margin: 0 0 1rem;
    color: #333;
  }
  .pd-hero-text :global(.summary-block p) { margin: 0; }

  .pd-hero-text :global(.next-steps) { margin: 0 0 1.1rem; }
  .pd-hero-text :global(.next-step) {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    background: #f0e9fd;
    border-left: 4px solid #7c3aed;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: #17324d;
    font-size: 0.95rem;
  }
  .pd-hero-text :global(.next-step)::before {
    content: "↓";
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #7c3aed;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .pd-hero-text :global(.next-step-when) { color: #0b2c45; }
  .pd-hero-text :global(.next-step a) { color: #2563eb; }

  .pd-hero-lede { margin: 0; color: #333; }
  .pd-hero-lede :global(a) { color: #2563eb; }

  .pd-hero-art { position: relative; display: grid; place-items: center; min-height: 300px; }
  .pd-hero-art::before {
    content: "";
    position: absolute;
    width: 200px;
    height: 240px;
    background: #fff;
    border-radius: 16px;
    transform: rotate(-9deg) translate(-46px, 4px);
    box-shadow: 0 14px 34px rgba(11, 44, 69, 0.14);
    z-index: 0;
  }

  .pd-hero-card {
    position: relative;
    width: 100%;
    max-width: 260px;
    background: linear-gradient(160deg, #163e60, #0b2c45 55%, #081d33);
    border-radius: 22px;
    padding: 1.15rem 1.2rem 1.35rem;
    box-shadow: 0 24px 50px rgba(11, 44, 69, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .pd-hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), transparent 45%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .pd-hero-card { animation: pd-hero-float 6s ease-in-out infinite; }
  }
  @keyframes pd-hero-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .pd-hero-card-top { display: flex; align-items: center; gap: 0.32rem; margin-bottom: 0.8rem; }
  .pd-hero-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px 1px rgba(74, 222, 128, 0.7);
  }
  .pd-hero-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.25); }
  .pd-hero-solar {
    margin-left: auto;
    width: 28px;
    height: 10px;
    border-radius: 2px;
    background: repeating-linear-gradient(90deg, #2c5478 0 3px, #1c3a56 3px 6px);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .pd-hero-display {
    position: relative;
    background: linear-gradient(165deg, #e6d9fb, #cbb2f5);
    border-radius: 10px;
    padding: 0.6rem 0.85rem 0.5rem;
    box-shadow: inset 0 2px 6px rgba(40, 15, 60, 0.22);
  }
  .pd-hero-display-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #5b2fa0;
    text-transform: uppercase;
  }
  .pd-hero-display-digits {
    display: block;
    text-align: right;
    font-family: 'Courier New', monospace;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #341764;
    font-size: 1.4rem;
    margin-top: 0.05rem;
  }

  .pd-hero-keys {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 32px;
    gap: 0.42rem;
    margin-top: 1rem;
  }
  .pd-hero-key {
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Courier New', monospace;
    font-weight: 700;
    font-size: 0.82rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .pd-hero-key.is-op { background: rgba(96, 165, 250, 0.22); color: #cfe0fb; }
  .pd-hero-key.is-eq {
    grid-row: span 2;
    background: linear-gradient(160deg, #a78bfa, #7c3aed);
    color: #fff;
    box-shadow: 0 6px 14px rgba(124, 58, 237, 0.35);
  }
  .pd-hero-key.is-zero { grid-column: span 2; }
  .pd-hero-art:hover .pd-hero-key { transform: translateY(-1px); }

  .pd-hero-float {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: -12px;
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    max-width: 230px;
    background: #fff;
    border-radius: 14px;
    padding: 0.9rem 1.05rem;
    box-shadow: 0 14px 32px rgba(11, 44, 69, 0.2);
  }
  .pd-hero-float-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: #f0e9fd;
    color: #7c3aed;
  }
  .pd-hero-float-icon svg { width: 19px; height: 19px; }
  .pd-hero-float strong { display: block; color: #0b2c45; font-size: 0.92rem; }
  .pd-hero-float p { margin: 0.15rem 0 0; color: #55627a; font-size: 0.8rem; }

  @media (max-width: 900px) {
    .pd-hero { grid-template-columns: 1fr; }
    .pd-hero-art { margin-top: 0.5rem; }
    .pd-h1 { font-size: 2.1rem; }
  }

  /* ---- Feature cards ----------------------------------------------------- */
  .pd-feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
    margin: 0 0 2rem;
  }
  .pd-feature-card {
    background: #fff;
    border: 1px solid #e8edf3;
    border-radius: 14px;
    padding: 1.2rem 1.15rem 1.3rem;
    box-shadow: 0 10px 26px rgba(11, 44, 69, 0.06);
  }
  .pd-feature-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    margin-bottom: 0.75rem;
    background: var(--t);
    color: var(--c);
  }
  .pd-feature-icon svg { width: 22px; height: 22px; }
  .pd-feature-card h3 { margin: 0 0 0.35rem; font-size: 0.98rem; line-height: 1.25; color: #0b2c45; }
  .pd-feature-card p { margin: 0; color: #55627a; font-size: 0.86rem; line-height: 1.5; }
  .pd-feature-card p :global(a) { color: #2563eb; }

  @media (max-width: 900px) {
    .pd-feature-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .pd-feature-grid { grid-template-columns: 1fr; }
  }
</style>
