---
// src/pages/[locale]/[...path].astro — the dynamic localized route (Phase A.5).
// One route generates EVERY localized page: a path is emitted only for
// (locale, page) pairs whose translated JSON is committed (existence-aware —
// getLocalizedContent), so this route cannot produce a 404.
// With build.format:'file' this emits /es/turning-65.html, matching the
// site's .html URL policy.
import { getLocalizedContent } from '../../i18n/content';
import Turning65Page from '../../components/content/Turning65Page.astro';

// One shared component per extracted page (content key === slug).
const COMPONENTS: Record<string, (props: Record<string, never>) => unknown> = {
  'turning-65': Turning65Page,
};

export function getStaticPaths() {
  // DATA ONLY — getStaticPaths is extracted into an isolated prerender chunk
  // that cannot see the component imports above. Filtering on COMPONENTS here
  // throws "COMPONENTS is not defined" (playbook §4.4 gotcha). The data-side
  // filter is CONTENT_PAGES, applied inside getLocalizedContent().
  return getLocalizedContent().map(({ locale, page }) => ({
    params: { locale, path: page },
    props: { contentKey: page },
  }));
}

const Page = COMPONENTS[Astro.props.contentKey];
---

<Page />
