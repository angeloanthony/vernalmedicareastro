---
// src/pages/[locale]/[...path].astro — the dynamic localized route (Phase A.5).
// One route generates EVERY localized page: a path is emitted only for
// (locale, page) pairs whose translated JSON is committed (existence-aware —
// getLocalizedContent), so this route cannot produce a 404.
// With build.format:'file' this emits /es/turning-65.html, matching the
// site's .html URL policy.
import { getLocalizedContent } from '../../i18n/content';
import Turning65Page from '../../components/content/Turning65Page.astro';
import MedigapPage from '../../components/content/MedigapPage.astro';
import WorkingPast65Page from '../../components/content/WorkingPast65Page.astro';
import BestMedicareAdvantagePage from '../../components/content/BestMedicareAdvantagePage.astro';
import SupplementVsAdvantagePage from '../../components/content/SupplementVsAdvantagePage.astro';
import BestPartDPlansPage from '../../components/content/BestPartDPlansPage.astro';
import EnrollmentPeriodsPage from '../../components/content/EnrollmentPeriodsPage.astro';
import MedicareCostsPage from '../../components/content/MedicareCostsPage.astro';
import DecisionCenterPage from '../../components/content/DecisionCenterPage.astro';
import HelpCenterPage from '../../components/content/HelpCenterPage.astro';
import QuotePage from '../../components/content/QuotePage.astro';
import IrmaaPage from '../../components/content/IrmaaPage.astro';
import ExtraHelpPage from '../../components/content/ExtraHelpPage.astro';
import SavingsProgramsPage from '../../components/content/SavingsProgramsPage.astro';
import AboutPage from '../../components/content/AboutPage.astro';
import HomePage from '../../components/content/HomePage.astro';

// One shared component per extracted page (content key === slug).
const COMPONENTS: Record<string, (props: Record<string, never>) => unknown> = {
  'turning-65': Turning65Page,
  'medigap': MedigapPage,
  'working-past-65': WorkingPast65Page,
  'best-medicare-advantage-vernal': BestMedicareAdvantagePage,
  'medicare-supplement-vs-advantage': SupplementVsAdvantagePage,
  'best-part-d-plans-vernal': BestPartDPlansPage,
  'medicare-enrollment-periods': EnrollmentPeriodsPage,
  'medicare-costs': MedicareCostsPage,
  'medicare-decision-center': DecisionCenterPage,
  'medicare-help-center': HelpCenterPage,
  'medicare-quote-vernal': QuotePage,
  'medicare-irmaa': IrmaaPage,
  'medicare-extra-help-utah': ExtraHelpPage,
  'medicare-savings-programs-utah': SavingsProgramsPage,
  'about': AboutPage,
  'index': HomePage,
};

export function getStaticPaths() {
  // DATA ONLY — getStaticPaths is extracted into an isolated prerender chunk
  // that cannot see the component imports above. Filtering on COMPONENTS here
  // throws "COMPONENTS is not defined" (playbook §4.4 gotcha). The data-side
  // filter is CONTENT_PAGES, applied inside getLocalizedContent().
  // The homepage's path is undefined so /es emits dist/es.html (URL /es.html),
  // matching localePageHref('index', locale) and the site's .html policy.
  return getLocalizedContent().map(({ locale, page }) => ({
    params: { locale, path: page === 'index' ? undefined : page },
    props: { contentKey: page },
  }));
}

const Page = COMPONENTS[Astro.props.contentKey];
---

<Page />
