---
// src/pages/privacy.astro  —  converted from privacy.html
// URL preserved: /privacy.html. Body + page scripts VERBATIM. Metadata, header,
// footer, LocalBusiness schema, GA, nav/3CX scripts come from BaseLayout.
import BaseLayout from '../layouts/BaseLayout.astro';

// Page-specific JSON-LD carried over verbatim (LocalBusiness is in the layout).
const schema = [];
---

<BaseLayout
  title="Terms & Conditions | Vernal Medicare"
  description="Terms for using VernalMedicare.com and Medicare marketing disclosures."
  canonical="https://vernalmedicare.com/terms.html"
  gaIds={[]}
>
  <main class="container" style="max-width:900px;line-height:1.7">
    <h1>Terms &amp; Conditions</h1>
    <p><strong>No government affiliation.</strong> We are not connected with or endorsed by the U.S. government or the federal Medicare program.</p>
    <p><strong>Compensation.</strong> Our help is free to you. We may be paid by plan sponsors/insurers. This does not change the plans we show you.</p>
    <p><strong>TPMO disclosure.</strong> We do not offer every plan available in your area. Information we provide is limited to the plans we do offer. Contact <a href="https://www.medicare.gov" rel="nofollow">Medicare.gov</a> or 1-800-MEDICARE (TTY: 1-877-486-2048), 24/7, to get information on all your options.</p>
    <p><strong>Availability.</strong> Plan availability varies by ZIP/county. Enrollment depends on contract renewal.</p>
    <p><strong>Use of site.</strong> Information is general and may change. Using this site does not create a client/broker relationship.</p>
    <p>See our <a href="privacy.html">Privacy Policy</a>.</p>
  </main>

  

<script>document.getElementById('y').textContent=new Date().getFullYear()</script>
</BaseLayout>
