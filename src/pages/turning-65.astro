---
// src/pages/turning-65.astro — Turning-65 Center (M30, Wave 1). The definitive
// "I'm turning 65 — what do I do?" funnel. An ORCHESTRATOR: the journey steps
// come from data/turning65.ts and each links to an existing Vernal pillar or
// calculator. The same data can power a future checklist/wizard/reminder tool.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { TURNING_65_STEPS } from '../data/turning65';
import { BUSINESS } from '../data/business';
import type { PageContext } from '../types/Page';

const context: PageContext = {
  page: {
    title: 'Turning 65 & Medicare — Your Step-by-Step Guide | Vernal Medicare',
    heading: 'Turning 65: Your Medicare Step-by-Step',
    description:
      'Turning 65? Here’s exactly what to do, in order — when to enroll, whether to delay for employer coverage, Medigap vs Advantage, Part D, costs, and IRMAA. Free local help in the Uintah Basin.',
    taxonomy: { silo: 'enrollment', tags: ['turning-65', 'enrollment', 'iep', 'journey', 'deadlines'], pillar: true },
    summary:
      `Turning 65 is when Medicare starts — and the choices you make now are some of the hardest to undo. This is the whole journey in ${TURNING_65_STEPS.length} steps: when your window opens, whether to delay for employer coverage, how to sign up, the big Medigap-vs-Advantage decision, drug coverage, and what it all costs. Work through it here, or let us walk you through it free.`,
    faqs: [
      { question: 'When should I sign up for Medicare if I’m turning 65?', answer: 'Your Initial Enrollment Period is the 7 months around your 65th birthday — 3 months before your birthday month, that month, and 3 months after. Sign up in the first 3 months for the earliest coverage start.' },
      { question: 'Do I have to enroll at 65 if I’m still working?', answer: 'Not always. If you have active, creditable employer coverage, you may delay Part B without penalty and get a Special Enrollment Period later. Retiree and COBRA coverage usually don’t count — check before you delay.' },
      { question: 'Medigap or Medicare Advantage — which should I pick at 65?', answer: 'There’s no single right answer. Medigap offers go-anywhere coverage and predictable costs with a separate Part D plan; Medicare Advantage bundles everything with a network and an out-of-pocket cap. It’s the most consequential (and hardest to reverse) choice — we compare both with you free.' },
    ],
    sources: [
      { title: 'Medicare.gov — Get started with Medicare', url: 'https://www.medicare.gov/basics/get-started-with-medicare', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'Turning 65 in the next year?', action: `call us free at ${BUSINESS.phone} — we’ll build your personal plan and timeline, no pressure.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/turning-65.html',
    ogType: 'article',
    ogTitle: 'Turning 65: Your Medicare Step-by-Step',
    ogDescription: 'Exactly what to do, in order, when you’re turning 65 — from a local Uintah Basin agent.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Turning 65', href: '/turning-65.html' },
  ],
};
---

<ArticlePage context={context}>
  <p>"I'm turning 65 — what do I actually do?" Here's the whole thing, in order. Each step links to a deeper guide or a calculator, and you can hand any of it to us to do together, free.</p>

  <div style="background:#0b2c45;color:#fff;padding:1.25rem 1.5rem;border-radius:12px;margin:1.5rem 0 2rem;">
    <strong>The 60-second version:</strong> your enrollment window opens 3 months before your birthday month. Enroll in Part A &amp; B (unless you have creditable employer coverage). Then make the big choice — <a href="medicare-supplement-vs-advantage.html" style="color:#9fd0ff;">Medigap or Medicare Advantage</a> — add <a href="best-part-d-plans-vernal.html" style="color:#9fd0ff;">Part D drug coverage</a>, and check your <a href="medicare-costs.html" style="color:#9fd0ff;">costs and IRMAA</a>. Not sure? <strong>Call {BUSINESS.phone}.</strong>
  </div>

  <h2>Your Step-by-Step Timeline</h2>
  <ol class="t65-steps">
    {TURNING_65_STEPS.map((s, i) => (
      <li id={s.id} class="t65-step">
        <p class="t65-when">{s.when}</p>
        <h3>{s.title}</h3>
        <p>{s.task}</p>
        <p class="t65-links">
          {s.relatedHref && <a href={s.relatedHref}>{s.relatedLabel} →</a>}
          {s.calculatorHref && <Fragment> · <a href={s.calculatorHref}>{s.calculatorLabel}</a></Fragment>}
        </p>
        {s.nextStep && <p class="t65-next"><strong>What’s next:</strong> {s.nextStep}</p>}
      </li>
    ))}
  </ol>

  <h2>Everything You Might Need</h2>
  <ul>
    <li><strong>Understand it:</strong> <a href="medicare-help-center.html">Medicare Help Center</a> · <a href="medicare-glossary.html">Glossary</a> · <a href="medicare-part-a-vs-part-b.html">Part A vs Part B</a>.</li>
    <li><strong>Run the numbers:</strong> <a href="medicare-cost-estimator.html">Cost estimator</a> · <a href="medicare-irmaa-calculator.html">IRMAA calculator</a> · <a href="medicare-enrollment-timeline.html">enrollment timeline</a> · <a href="medicare-part-b-penalty-calculator.html">late-penalty calculator</a>.</li>
    <li><strong>Compare coverage:</strong> <a href="medigap.html">Medigap</a> · <a href="best-medicare-advantage-vernal.html">Medicare Advantage</a> · <a href="best-part-d-plans-vernal.html">Part D</a>.</li>
    <li><strong>Get help paying:</strong> <a href="medicare-extra-help-utah.html">Extra Help</a> · <a href="medicare-savings-programs-utah.html">Medicare Savings Programs</a>.</li>
  </ul>

  <h2>Do This With a Local Person — Free</h2>
  <p>Turning 65 is a lot at once, and the Medigap-vs-Advantage decision is hard to reverse. You don't have to guess. <strong>Call us free at {BUSINESS.phone}</strong> (TTY: {BUSINESS.tty}) or <a href="medicare-quote-vernal.html">request a free quote</a>, and we'll build your personal timeline and compare every option against the doctors and pharmacy you already use — no cost, no pressure.</p>
</ArticlePage>

<style>
  .t65-steps { list-style: none; counter-reset: t65; padding: 0; margin: 1.5rem 0; }
  .t65-step {
    counter-increment: t65;
    position: relative;
    padding: 1rem 0 1rem 3rem;
    border-top: 1px solid var(--color-border, #e5e9ee);
  }
  .t65-step::before {
    content: counter(t65);
    position: absolute;
    left: 0; top: 1rem;
    width: 2rem; height: 2rem;
    display: flex; align-items: center; justify-content: center;
    background: #0b2c45; color: #fff;
    border-radius: 999px; font-weight: 700;
  }
  .t65-step h3 { margin: 0.25rem 0 0.5rem; }
  .t65-when {
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent, #9e0853);
    margin: 0;
  }
  .t65-links { font-size: 0.95rem; margin: 0.5rem 0; }
  .t65-next {
    font-size: 0.9rem;
    color: var(--color-text-muted, #667085);
    margin: 0.5rem 0 0;
  }
</style>
