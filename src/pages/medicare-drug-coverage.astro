---
// src/pages/medicare-drug-coverage.astro — Drug-Coverage Center hub (M32).
// A knowledge graph organized by condition: each drug is a node with the same
// standardized "does Medicare cover it?" structure. Distinct intent from the
// drug-ASSISTANCE pages ("help paying for X") — they interlink, not duplicate.
//
// Design: custom landing-page layout (bareHeader + bareFooter) matching the
// services-coverage hub (medicare-coverage.astro) — a hero, a condition quick-
// nav, a color-coded "explore by condition" card grid (each drug a link with a
// covered/conditional/limited badge), a person CTA banner, an FAQ/centers/agent
// trio, and a trust bar. Every internal link the old text hub exposed still
// ships, inside the cards.
import ArticlePage from '../components/layout/ArticlePage.astro';
import { DRUG_COVERAGE } from '../data/drugCoverage';
import { DRUG_CONDITION_META, type DrugCondition, type CoverageStatus } from '../types/DrugCoverage';
import { BUSINESS } from '../data/business';
import { authorById } from '../data/authors';
import type { PageContext } from '../types/Page';

const agent = authorById('rocco');

const ORDER: DrugCondition[] = ['diabetes', 'heart', 'autoimmune', 'respiratory', 'weight'];
const STATUS_LABEL: Record<CoverageStatus, string> = { covered: 'Covered', conditional: 'Covered with criteria', limited: 'Usually not covered' };
const groups = ORDER
  .map((c) => ({ c, meta: DRUG_CONDITION_META[c], drugs: DRUG_COVERAGE.filter((d) => d.condition === c).sort((a, b) => a.brand.localeCompare(b.brand)) }))
  .filter((g) => g.drugs.length > 0);

// Per-condition accent + tint + icon for the card grid, quick-nav, and centers.
const CAT_STYLE: Record<DrugCondition, { accent: string; tint: string; icon: string }> = {
  diabetes: {
    accent: '#2563eb', tint: '#e5edfe',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3s6.5 6.7 6.5 11a6.5 6.5 0 0 1-13 0C5.5 9.7 12 3 12 3z"/></svg>',
  },
  heart: {
    accent: '#dc2626', tint: '#fde8e8',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5s-7-4.7-7-10.2A3.8 3.8 0 0 1 12 7.4a3.8 3.8 0 0 1 7 2.9c0 5.5-7 10.2-7 10.2z"/><path d="M4.5 12h3l1.3-2.5L11 15l1.4-3h2"/></svg>',
  },
  autoimmune: {
    accent: '#7c3aed', tint: '#f0e9fd',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
  respiratory: {
    accent: '#0d9488', tint: '#d7f0ec',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v8"/><path d="M12 8c-1-2.2-3.1-2.7-4.2-1.6C6.4 7.7 6 12 6 15.2A2.8 2.8 0 0 0 11 17c.6-.7 1-1.7 1-2.8"/><path d="M12 8c1-2.2 3.1-2.7 4.2-1.6C17.6 7.7 18 12 18 15.2A2.8 2.8 0 0 1 13 17c-.6-.7-1-1.7-1-2.8"/></svg>',
  },
  weight: {
    accent: '#16a34a', tint: '#e4f5ea',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6" width="16" height="15" rx="2"/><circle cx="12" cy="4" r="1.4"/><path d="M8 13l2.3 3 3-6L15.5 15H17"/></svg>',
  },
};

const context: PageContext = {
  page: {
    title: 'Does Medicare Cover My Drug? — Coverage by Medication | Vernal Medicare',
    heading: 'Does Medicare Cover My Drug?',
    description:
      'Does Medicare cover Eliquis, Jardiance, Humira, and more? Coverage by medication — which part covers it, when, prior authorization, and what to do if it doesn’t. Free local help.',
    taxonomy: { silo: 'part-d', tags: ['drug-coverage', 'part-d', 'coverage', 'formulary'] },
    summary:
      `Wondering if Medicare covers a specific medication? This center answers "does Medicare cover it?" for ${DRUG_COVERAGE.length} common brand-name drugs, organized by the condition they treat — with the same details every time: which part covers it, under what circumstances, whether prior authorization applies, and what to do if it isn’t covered.`,
    faqs: [
      { question: 'Which part of Medicare covers prescription drugs?', answer: 'Most self-administered prescriptions are covered by Part D — a standalone drug plan or the drug coverage built into a Medicare Advantage plan. A few drugs given in a clinic fall under Part B.' },
      { question: 'Why does my plan require prior authorization?', answer: 'For expensive brand drugs and biologics, plans often require prior authorization (approval before covering) or step therapy (trying a lower-cost option first). Your doctor submits the request, and you can appeal a denial.' },
      { question: 'What if Medicare won’t cover my drug?', answer: 'Options include comparing plans that cover it on a better tier, requesting an exception with your doctor’s support, using a biosimilar or covered alternative, and applying for manufacturer or foundation assistance. We can help you sort through them free.' },
    ],
    sources: [
      { title: 'Medicare.gov — drug coverage (Part D)', url: 'https://www.medicare.gov/drug-coverage-part-d', publisher: 'Medicare.gov' },
    ],
    nextSteps: [
      { when: 'Not sure if your plan covers your medication?', action: `call us free at ${BUSINESS.phone} — bring your drug list and we’ll check it.` },
    ],
  },
  meta: {
    canonical: 'https://vernalmedicare.com/medicare-drug-coverage.html',
    ogType: 'website',
    ogTitle: 'Does Medicare Cover My Drug?',
    ogDescription: 'Coverage by medication — which part, when, prior auth, and what to do if it isn’t covered.',
  },
  author: 'rocco',
  datePublished: '2026-07-01',
  lastUpdated: '2026-07-01',
  breadcrumb: [
    { name: 'Home', href: '/' },
    { name: 'Drug Coverage', href: '/medicare-drug-coverage.html' },
  ],
};

const FAQS = context.page.faqs ?? [];

// A "where to next" router card that rounds out the grid.
const NEXT_CARD = {
  accent: '#ea580c', tint: '#fdeadd',
  title: 'Where to Next?',
  blurb: 'Not sure your plan covers your list? Start with one of these.',
  icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.4 9.3a2.6 2.6 0 0 1 4.7 1.5c0 1.8-2.1 2.1-2.1 3.7"/><circle cx="12" cy="17.2" r="0.7" fill="currentColor" stroke="none"/></svg>',
  links: [
    { label: 'Compare Part D plans', href: 'best-part-d-plans-vernal.html' },
    { label: 'Help paying for Medicare', href: 'medicare-financial-assistance.html' },
    { label: 'Does Medicare cover a service?', href: 'medicare-coverage.html' },
    { label: 'Start with your situation', href: 'medicare-decision-center.html' },
  ],
};

// Trust bar.
const TRUST = [
  { color: '#16a34a', title: 'Local & Trusted', sub: 'Licensed in Utah', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg>' },
  { color: '#7c3aed', title: 'No Cost, No Obligation', sub: 'We’re here to help', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17.5" cy="9" r="2.2"/></svg>' },
  { color: '#ea580c', title: 'We Work for You', sub: 'Your best interests first', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M8 13l3 3 5-5 4 4"/><path d="M2 9l4-4 4 3 4-3 4 4"/></svg>' },
  { color: '#2563eb', title: 'Here When You Need Us', sub: 'Call, email, or meet locally', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><rect x="3" y="12" width="4" height="6" rx="1.5"/><rect x="17" y="12" width="4" height="6" rx="1.5"/><path d="M20 18v1a3 3 0 0 1-3 3h-3"/></svg>' },
];
---

<ArticlePage context={context} bareHeader bareFooter>
  {/* ─── Hero ─────────────────────────────────────────────────────────── */}
  <section class="cov-hero">
    <div class="cov-hero__copy">
      <h1 class="cov-hero__title">Does Medicare <span>Cover My Drug?</span></h1>
      <p class="cov-hero__lede">Wondering if Medicare covers a specific medication? This center gives you clear, simple answers for the common conditions — and the brand-name drugs used to treat them.</p>

      <ul class="cov-hero__points">
        <li>
          <span class="cov-hero__pt-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span>
          <span><strong>Clear Answers</strong><em>Every drug reviewed the same way</em></span>
        </li>
        <li>
          <span class="cov-hero__pt-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1"/><path d="M9 10h6M9 14h6M9 18h4"/></svg></span>
          <span><strong>{DRUG_COVERAGE.length} Common Drugs</strong><em>From diabetes to weight loss</em></span>
        </li>
        <li>
          <span class="cov-hero__pt-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.5s-7-4.9-7-10.4A4 4 0 0 1 12 7a4 4 0 0 1 7 3.1c0 5.5-7 10.4-7 10.4z"/></svg></span>
          <span><strong>Know Before You Go</strong><em>Check coverage and save money</em></span>
        </li>
      </ul>
    </div>

    <div class="cov-hero__art">
      <img
        class="cov-hero__img"
        src="/pictures/smithpharmacy.webp"
        alt="The prescription counter at a local pharmacy."
        width="1600"
        height="1200"
        loading="eager"
        decoding="async"
      />
      <div class="cov-hero__callout">
        <span class="cov-hero__callout-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="3" width="10" height="7" rx="2"/><path d="M9 10v3a3 3 0 0 0 6 0v-3"/><path d="M12 16v2a3 3 0 0 1-3 3H7"/></svg></span>
        <p>Not sure about your drug? Call us free at <a href={`tel:${BUSINESS.phoneTel}`}>{BUSINESS.phone}</a> (TTY: {BUSINESS.tty}) and we’ll check it for you.</p>
      </div>
    </div>
  </section>

  {/* ─── Condition quick-nav ──────────────────────────────────────────── */}
  <nav class="cov-quicknav" aria-label="Jump to a condition">
    {groups.map((g) => (
      <a href={`#${g.c}`} style={`--accent:${CAT_STYLE[g.c].accent};--tint:${CAT_STYLE[g.c].tint}`}>
        <span class="cov-quicknav__icon" aria-hidden="true" set:html={CAT_STYLE[g.c].icon} />
        {g.meta.label}
      </a>
    ))}
  </nav>

  {/* ─── Explore-by-condition card grid ───────────────────────────────── */}
  <section class="cov-cats" aria-labelledby="cov-cats-h">
    <h2 id="cov-cats-h" class="cov-h2 cov-h2--center">Explore by <span>Condition</span></h2>
    <div class="cov-cats__grid">
      {groups.map((g) => (
        <article class="cov-card" id={g.c} style={`--accent:${CAT_STYLE[g.c].accent};--tint:${CAT_STYLE[g.c].tint}`}>
          <div class="cov-card__head">
            <span class="cov-card__icon" aria-hidden="true" set:html={CAT_STYLE[g.c].icon} />
            <div>
              <h3 class="cov-card__title">{g.meta.label}</h3>
              <p class="cov-card__blurb">{g.meta.blurb}</p>
            </div>
          </div>
          <ul class="cov-card__list">
            {g.drugs.map((d) => (
              <li>
                <a href={`does-medicare-cover-${d.slug}.html`}>Does Medicare cover {d.brand}?</a>
                <span class={`cov-badge cov-badge--${d.status}`}>{STATUS_LABEL[d.status]}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}

      <article class="cov-card cov-card--links" style={`--accent:${NEXT_CARD.accent};--tint:${NEXT_CARD.tint}`}>
        <div class="cov-card__head">
          <span class="cov-card__icon" aria-hidden="true" set:html={NEXT_CARD.icon} />
          <div>
            <h3 class="cov-card__title">{NEXT_CARD.title}</h3>
            <p class="cov-card__blurb">{NEXT_CARD.blurb}</p>
          </div>
        </div>
        <ul class="cov-card__list cov-card__list--plain">
          {NEXT_CARD.links.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  {/* ─── Person CTA banner ────────────────────────────────────────────── */}
  <section class="cov-cta">
    <img class="cov-cta__photo" src="/pictures/rocco.webp" alt={`${agent?.name ?? 'Rocco DeLuca'}, licensed Medicare agent in Vernal, Utah`} width="88" height="88" loading="lazy" decoding="async" />
    <div class="cov-cta__msg">
      <h2 class="cov-cta__title">Bring Us Your Drug List — <em>Free</em></h2>
      <p>The fastest way to know what your plan covers (and for how much) is to check your exact medication list against the formularies. We’ll match a plan to your drugs and pharmacy and find ways to save you money.</p>
    </div>
    <div class="cov-cta__actions">
      <a class="cov-cta__phone" href={`tel:${BUSINESS.phoneTel}`}>
        <span class="cov-cta__phone-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.7 21 3 13.3 3 3c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1z"/></svg></span>
        <span>Call {BUSINESS.phone}<em>(TTY: {BUSINESS.tty})</em></span>
      </a>
      <a class="cov-cta__quote" href="medicare-quote-vernal.html">
        <span class="cov-cta__quote-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H9l-4 3v-3H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/></svg></span>
        Get a Free Quote
      </a>
    </div>
  </section>

  {/* ─── FAQ · Drug centers · Agent trio ──────────────────────────────── */}
  <div class="cov-trio">
    <section class="cov-panel">
      <h2 class="cov-panel__h">Frequently Asked Questions</h2>
      {FAQS.map((q) => (
        <details class="cov-faq">
          <summary>{q.question}</summary>
          <p set:html={q.answer} />
        </details>
      ))}
      <p class="cov-panel__src"><strong>Sources:</strong> <a href="https://www.medicare.gov/drug-coverage-part-d" target="_blank" rel="noopener noreferrer">Medicare.gov — drug coverage (Part D)</a></p>
    </section>

    <section class="cov-panel">
      <h2 class="cov-panel__h">Browse by Condition</h2>
      <ul class="cov-centers">
        {groups.map((g) => (
          <li style={`--accent:${CAT_STYLE[g.c].accent};--tint:${CAT_STYLE[g.c].tint}`}>
            <span class="cov-centers__icon" aria-hidden="true" set:html={CAT_STYLE[g.c].icon} />
            <a href={`#${g.c}`}>{g.meta.label}</a>
          </li>
        ))}
        <li style={`--accent:${NEXT_CARD.accent};--tint:${NEXT_CARD.tint}`}>
          <span class="cov-centers__icon" aria-hidden="true" set:html={NEXT_CARD.icon} />
          <a href="prescription-drug-assistance.html">Help paying for a drug</a>
        </li>
      </ul>
    </section>

    <section class="cov-panel cov-panel--agent">
      <img class="cov-agent__photo" src="/pictures/rocco.webp" alt={`${agent?.name ?? 'Rocco DeLuca'}, licensed Medicare agent`} width="96" height="96" loading="lazy" decoding="async" />
      <h2 class="cov-panel__h">Talk to a Local, Licensed Agent</h2>
      <p class="cov-agent__blurb">{agent?.name ?? 'Rocco DeLuca'} can walk you through your options — free, no pressure.</p>
      <a class="cov-agent__cta" href={`tel:${BUSINESS.phoneTel}`}>Call {BUSINESS.phone} →</a>
      <span class="cov-agent__sig">— {agent?.name ?? 'Rocco DeLuca'}</span>
    </section>
  </div>

  {/* ─── Trust bar ────────────────────────────────────────────────────── */}
  <section class="cov-trust">
    {TRUST.map((item) => (
      <div class="cov-trust__item">
        <span class="cov-trust__icon" style={`--c:${item.color}`} aria-hidden="true" set:html={item.icon} />
        <span class="cov-trust__text"><strong>{item.title}</strong><em>{item.sub}</em></span>
      </div>
    ))}
  </section>
</ArticlePage>

<style>
  /* Palette echoes the services-coverage hub: navy #0b2c45, blue #2563eb, with
     per-condition accents (blue/red/purple/teal/green/orange). */

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .cov-hero {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    align-items: center;
    gap: 2.5rem;
    background: linear-gradient(180deg, #eaf3fb 0%, #f4f9fd 100%);
    border: 1px solid #dbe6f2;
    border-radius: 24px;
    padding: 2.5rem 2.75rem;
    margin: 0.25rem 0 2rem;
  }
  .cov-hero__title {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.05;
    font-weight: 800;
    color: #0b2c45;
    margin: 0 0 0.75rem;
  }
  .cov-hero__title span { color: #2563eb; }
  .cov-hero__lede { font-size: 1.08rem; color: #475569; line-height: 1.55; margin: 0 0 1.75rem; max-width: 46ch; }
  .cov-hero__points { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .cov-hero__points li { display: flex; align-items: center; gap: 0.85rem; }
  .cov-hero__points strong { display: block; color: #0b2c45; font-size: 1rem; }
  .cov-hero__points em { color: #5b6b7d; font-size: 0.88rem; font-style: normal; }
  .cov-hero__pt-icon {
    flex: none; width: 46px; height: 46px; border-radius: 50%;
    display: grid; place-items: center;
    background: #e2edfb; color: #1f4e8c;
  }
  .cov-hero__pt-icon svg { width: 24px; height: 24px; }

  .cov-hero__art { position: relative; display: flex; justify-content: center; }
  .cov-hero__img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 18px;
    box-shadow: 0 18px 44px rgba(11, 44, 69, 0.18);
  }
  .cov-hero__callout {
    position: absolute; left: 1.25rem; right: 1.25rem; bottom: -0.75rem;
    display: flex; align-items: flex-start; gap: 0.75rem;
    background: #fff; border: 1px solid #e1e9f2; border-radius: 14px;
    padding: 0.9rem 1.1rem;
    box-shadow: 0 14px 34px rgba(11, 44, 69, 0.16);
  }
  .cov-hero__callout-icon { flex: none; display: grid; place-items: center; width: 34px; height: 34px; border-radius: 50%; background: #e6effe; color: #2563eb; }
  .cov-hero__callout-icon svg { width: 20px; height: 20px; }
  .cov-hero__callout p { margin: 0; color: #475569; font-size: 0.86rem; line-height: 1.45; }
  .cov-hero__callout a { color: #2563eb; font-weight: 700; text-decoration: none; white-space: nowrap; }
  .cov-hero__callout a:hover { text-decoration: underline; }

  /* ── Condition quick-nav ──────────────────────────────────────────────── */
  .cov-quicknav {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem;
    margin: 0 0 2.5rem;
  }
  .cov-quicknav a {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem 0.5rem 0.55rem;
    background: #fff; border: 1px solid #e5e9ee; border-radius: 999px;
    color: #1f2d3d; text-decoration: none; font-weight: 700; font-size: 0.92rem;
    box-shadow: 0 4px 14px rgba(11, 44, 69, 0.05);
    transition: transform 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .cov-quicknav a:hover { transform: translateY(-2px); border-color: var(--accent); box-shadow: 0 8px 20px rgba(11, 44, 69, 0.1); }
  .cov-quicknav__icon {
    flex: none; width: 30px; height: 30px; border-radius: 50%;
    display: grid; place-items: center; background: var(--tint); color: var(--accent);
  }
  .cov-quicknav__icon svg { width: 18px; height: 18px; }

  /* ── Section headings ─────────────────────────────────────────────────── */
  .cov-h2 { color: #0b2c45; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin: 0 0 1.75rem; }
  .cov-h2--center { text-align: center; }
  .cov-h2 span { color: #2563eb; }

  /* ── Coverage card grid ───────────────────────────────────────────────── */
  .cov-cats { margin: 0 0 3rem; }
  .cov-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .cov-card {
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid #e8edf3;
    border-top: 4px solid var(--accent);
    border-radius: 16px;
    padding: 1.6rem 1.5rem;
    box-shadow: 0 10px 30px rgba(11, 44, 69, 0.06);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .cov-card:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(11, 44, 69, 0.12); }
  .cov-card__head { display: flex; align-items: flex-start; gap: 0.9rem; margin-bottom: 1.1rem; }
  .cov-card__icon {
    flex: none; width: 52px; height: 52px; border-radius: 14px;
